            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":3},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-05-05 18:13:42.814000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-20 14:17:51\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":27,\"id\":\"d39f16930e8e41a55ce773b46d282eae\",\"menuId\":\"4d86341cee2d5560a2bc61b25f43eb9f\",\"metaData\":{\"params\":{\"connectionId\":\"\",\"queryId\":\"\",\"chart\":\"devtools\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":7,\"y\":69,\"w\":4,\"h\":27}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"devtools\",\"updatedAt\":\"2026-07-15 11:57:36.508000\",\"updatedBy\":\"b5e923912240161c067592321042f60a\",\"w\":4,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport { Form } from 'react-bootstrap';\\n\\nimport styled from 'styled-components';\\n\\nexport default function InfosusStep1({\\n  registerEdit,\\n  watchEdit,\\n  setValueEdit,\\n}) {\\n  return (\\n    <>\\n      <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n        {/* Perihal */}\\n        <Form.Group className=\\\"w-100\\\">\\n          <TitleInput className=\\\"mb-3\\\">Perihal</TitleInput>\\n          <StyledTextarea\\n            type=\\\"text\\\"\\n            as={'textarea'}\\n            rows={3}\\n            placeholder=\\\"Isi perihal secara detail\\\"\\n            {...registerEdit?.('about')}\\n          />\\n        </Form.Group>\\n\\n        <Divinder />\\n        <Form.Group className=\\\"w-100\\\">\\n          <div\\n            className=\\\"d-flex justify-content-between align-items-center\\\"\\n            style={{ marginBottom: '1.43rem' }}\\n          >\\n            <div\\n              style={{\\n                color: 'var(--black-400)',\\n                fontSize: '1.14286rem',\\n                fontWeight: '600',\\n                textAlign: 'center',\\n              }}\\n            >\\n              Fakta-Fakta\\n            </div>\\n            <button\\n              type=\\\"button\\\"\\n              onClick={() => {\\n                const current = watchEdit?.('facts') || [];\\n                setValueEdit?.('facts', [...current, { facts: '' }]);\\n              }}\\n              style={{\\n                background: 'none',\\n                border: 'none',\\n                color: 'var(--primary)',\\n                fontWeight: '600',\\n                cursor: 'pointer',\\n                padding: 0,\\n                fontSize: '1rem',\\n              }}\\n            >\\n              + Tambah Fakta\\n            </button>\\n          </div>\\n\\n          {(watchEdit?.('facts') || []).length > 0 ? (\\n            <div\\n              style={{\\n                display: 'flex',\\n                flexDirection: 'column',\\n                gap: '0.75rem',\\n              }}\\n            >\\n              {(watchEdit?.('facts') || []).map((item, index) => (\\n                <div\\n                  key={index}\\n                  style={{\\n                    width: '100%',\\n                    paddingTop: 11,\\n                    paddingBottom: 11,\\n                    paddingLeft: 16,\\n                    paddingRight: 11,\\n                    background: 'var(--Background-Primary, white)',\\n                    overflow: 'hidden',\\n                    borderRadius: 10,\\n                    outline: '1px var(--Border-Primary, #E6E9F0) solid',\\n                    outlineOffset: '-1px',\\n                    justifyContent: 'flex-start',\\n                    alignItems: 'flex-start',\\n                    gap: 8,\\n                    display: 'inline-flex',\\n                  }}\\n                >\\n                  <CustomStyledTextarea\\n                    as=\\\"textarea\\\"\\n                    rows={2}\\n                    placeholder=\\\"Masukkan Fakta-Fakta\\\"\\n                    value={item.facts || ''}\\n                    onChange={(e) => {\\n                      const currentFacts = watchEdit?.('facts') || [];\\n\\n                      const updated = currentFacts.map((item, i) =>\\n                        i === index ? { ...item, facts: e.target.value } : item,\\n                      );\\n\\n                      setValueEdit?.('facts', updated, {\\n                        shouldValidate: true,\\n                        shouldDirty: true,\\n                      });\\n                    }}\\n                    style={{\\n                      flex: '1 1 0',\\n                    }}\\n                  />\\n                  <button\\n                    type=\\\"button\\\"\\n                    onClick={() => {\\n                      const updated = (watchEdit?.('facts') || []).filter(\\n                        (_, i) => i !== index,\\n                      );\\n                      setValueEdit?.('facts', updated);\\n                    }}\\n                    style={{\\n                      width: 16,\\n                      justifyContent: 'flex-start',\\n                      alignItems: 'center',\\n                      gap: 10,\\n                      display: 'flex',\\n                      background: 'none',\\n                      border: 'none',\\n                      cursor: 'pointer',\\n                      padding: 0,\\n                      minWidth: 16,\\n                      flexShrink: 0,\\n                    }}\\n                  >\\n                    <i className=\\\"ph ph-x\\\" style={{ fontSize: 16 }}></i>\\n                  </button>\\n                </div>\\n              ))}\\n            </div>\\n          ) : (\\n            <div\\n              style={{\\n                padding: '1rem',\\n                textAlign: 'center',\\n                color: 'var(--black-400)',\\n                backgroundColor: 'var(--black-25)',\\n                borderRadius: '0.5rem',\\n                border: '1px dashed var(--black-100)',\\n                fontSize: '1rem',\\n              }}\\n            >\\n              Belum ada Fakta-Fakta. Klik \\\"Tambah Fakta\\\" untuk menambahkan.\\n            </div>\\n          )}\\n        </Form.Group>\\n      </div>\\n    </>\\n  );\\n}\\n\\nconst StepIndicator = styled.span`\\n  margin-left: 1rem;\\n  font-size: 0.875rem;\\n  color: var(--black-400);\\n  font-weight: 500;\\n`;\\n\\nconst TitleHead = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-weight: 500;\\nline-height: 140%; \\n`;\\n\\nconst Divider = styled.div`\\n  width: 100%;\\n  height: 0;\\n  margin-top:1.25rem;\\n  margin-bottom:1.25rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst Divinder = styled.div`\\n  width: 100%;\\n  border-top: 1px solid var(--black-100);\\n  margin-top:1.42857rem;\\n  margin-bottom:1.42857rem;\\n\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\\nconst TitleInput = styled.div`\\ncolor: var(--black);\\nfont-size: 1rem;\\nfont-weight: 500;\\nline-height: 140%; \\n\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  font-family:Inter;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\nconst CustomStyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  font-family: Inter;\\n\\n  border: none;\\n  outline: none;\\n  box-shadow: none;\\n  background: transparent;\\n\\n  resize: none;\\n\\n  &:focus {\\n    outline: none;\\n    box-shadow: none;\\n  }\\n`;\\n\\nconst FormStyle = styled(Form.Group)`\\n    margin-bottom: 1.14rem;\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"d39f16930e8e41a55ce773b46d282eae\":false},\"customColors\":false,\"limitData\":0,\"backgroundColor\":\"\",\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigFields\":{\"tableCategoryCustom\":[]},\"container\":{\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"containLabel\":false},\"title\":{\"show\":false,\"text\":\"\",\"fontSize\":\"\",\"width\":\"\",\"fontFamily\":\"\",\"fontColor\":\"\"},\"dataLabel\":{\"fontWeight\":\"\",\"fontCase\":\"\",\"show\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"numberOnly\":false,\"percentOnly\":false,\"isDate\":false,\"labelWidth\":\"\",\"fontSize\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"color\":\"\",\"position\":\"\",\"dateFormatter\":\"\"},\"legend\":{\"show\":false,\"showValue\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"isPercentage\":false,\"valuePrefix\":\"\",\"fontSize\":\"\",\"width\":\"\",\"customPosition\":{\"left\":\"\",\"right\":\"\",\"top\":\"\",\"bottom\":\"\"},\"icon\":\"\",\"type\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"fontColor\":\"\",\"fontCase\":\"\"},\"series\":{\"seriesName\":false,\"percentage\":false,\"inverse\":false,\"smooth\":false,\"labelLine\":false,\"borderWidth\":\"\",\"opacity\":1,\"suggestionColor\":false,\"caseSensitive\":false,\"customPosition\":{\"left\":\"\",\"right\":\"\",\"top\":\"\",\"bottom\":\"\"},\"startAngle\":\"\",\"endAngle\":\"\",\"symbol\":\"\"},\"xAxis\":{\"show\":false,\"inverse\":false,\"width\":\"\",\"min\":\"\",\"max\":\"\",\"interval\":0,\"numberFormatter\":false,\"showLabel\":false,\"labelRotate\":\"50\",\"labelSize\":\"\",\"title\":{\"show\":false,\"text\":\"\",\"titleDistance\":null,\"fontSize\":\"\",\"fontFamily\":\"\"},\"grid\":{\"show\":false,\"showAxisline\":false,\"showSplitLine\":false,\"width\":\"\",\"color\":\"\",\"splitLineColor\":\"\"},\"tick\":{\"show\":false,\"type\":\"\",\"color\":\"\"},\"overflow\":\"\",\"labelColor\":\"\",\"labelCase\":\"\",\"labelFormat\":\"\"},\"yAxis\":{\"show\":false,\"inverse\":false,\"width\":\"\",\"min\":\"\",\"max\":\"\",\"interval\":0,\"numberFormatter\":false,\"showLabel\":false,\"labelRotate\":\"50\",\"labelSize\":\"\",\"title\":{\"show\":false,\"text\":\"\",\"titleDistance\":null,\"fontSize\":\"\",\"fontFamily\":\"\"},\"grid\":{\"show\":false,\"showAxisline\":false,\"showSplitLine\":false,\"width\":\"\",\"color\":\"\",\"splitLineColor\":\"\"},\"tick\":{\"show\":false,\"type\":\"\",\"color\":\"\"},\"overflow\":\"\",\"labelColor\":\"\",\"labelCase\":\"\",\"labelFormat\":\"\"},\"enable\":false,\"animation\":{\"enable\":false,\"duration\":\"\"},\"watermark\":{\"enable\":false,\"link\":\"\",\"styleText\":{\"text\":\"\",\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"fontSize\":\"\",\"opacity\":\"1\",\"fontColor\":\"\"},\"styleImage\":{\"imageUrl\":\"\",\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"width\":\"\",\"height\":\"\",\"opacity\":\"1\"}},\"customColorKey\":[],\"axis\":{\"radius\":\"\",\"center\":[]}},\"useAsFilterConfig\":{\"enable\":false},\"childrenConfig\":{\"enable\":false,\"pageBykey\":[]},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":true,\"actionCopy\":false,\"pageState\":false,\"orderColumn\":false,\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false,\"splitTime\":false,\"shareAPI\":\"\"},\"x\":7,\"y\":69},\"additionalInfo\":null,\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
