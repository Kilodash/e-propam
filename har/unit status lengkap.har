            "mimeType": "application/json",
            "compression": 7944,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":3},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-05-05 18:15:18.814000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-20 14:17:51\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":16,\"id\":\"57aa9b76c958acd3817c669a52c57e3a\",\"menuId\":\"4d86341cee2d5560a2bc61b25f43eb9f\",\"metaData\":{\"params\":{\"connectionId\":\"\",\"queryId\":\"\",\"chart\":\"devtools\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":1,\"y\":63,\"w\":3,\"h\":16}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"devtools\",\"updatedAt\":\"2026-07-15 11:57:36.508000\",\"updatedBy\":\"b5e923912240161c067592321042f60a\",\"w\":3,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport { Form } from 'react-bootstrap';\\n\\nimport styled from 'styled-components';\\n\\nexport default function InfosusStep3({\\n  registerEdit,\\n  watchEdit,\\n  setValueEdit,\\n}) {\\n  return (\\n    <>\\n      <Form.Group className=\\\"w-100\\\">\\n        <div\\n          className=\\\"d-flex justify-content-between align-items-center\\\"\\n          style={{ marginBottom: '1.43rem' }}\\n        >\\n          <div\\n            style={{\\n              color: 'var(--black-400)',\\n              fontSize: '1.14286rem',\\n              fontWeight: '600',\\n              textAlign: 'center',\\n            }}\\n          >\\n            Paraf\\n          </div>\\n          <button\\n            type=\\\"button\\\"\\n            onClick={() => {\\n              const current = watchEdit?.('signature') || [];\\n              setValueEdit?.('signature', [...current, { signature: '' }]);\\n            }}\\n            style={{\\n              background: 'none',\\n              border: 'none',\\n              color: 'var(--primary)',\\n              fontWeight: '600',\\n              cursor: 'pointer',\\n              padding: 0,\\n              fontSize: '0.875rem',\\n            }}\\n          >\\n            + Tambah Paraf\\n          </button>\\n        </div>\\n        {(watchEdit?.('signature') || []).length > 0 ? (\\n          <div\\n            style={{\\n              display: 'flex',\\n              flexDirection: 'column',\\n              gap: '0.75rem',\\n            }}\\n          >\\n            {(watchEdit?.('signature') || []).map((item, index) => (\\n              <div\\n                key={index}\\n                style={{\\n                  width: '100%',\\n                  paddingLeft: 16,\\n                  paddingRight: 16,\\n                  paddingTop: 11,\\n                  paddingBottom: 11,\\n                  background: 'white',\\n                  overflow: 'hidden',\\n                  borderRadius: 10,\\n                  outline: '1px #E6E9F0 solid',\\n                  outlineOffset: '-1px',\\n                  justifyContent: 'space-between',\\n                  alignItems: 'center',\\n                  gap: 8,\\n                  display: 'flex',\\n                }}\\n              >\\n                <input\\n                  type=\\\"text\\\"\\n                  placeholder=\\\"Masukkan Paraf\\\"\\n                  value={item.signature || ''}\\n                  onChange={(e) => {\\n                    const currentFacts = watchEdit?.('signature') || [];\\n\\n                    const updated = currentFacts.map((item, i) =>\\n                      i === index ? { ...item, signature: e.target.value } : item,\\n                    );\\n\\n                    setValueEdit?.('signature', updated, {\\n                      shouldValidate: true,\\n                      shouldDirty: true,\\n                    });\\n                  }}\\n                  style={{\\n                    flex: '1 1 0',\\n                    color: item.signature ? '#050505' : '#A0A3AA',\\n                    fontSize: 14,\\n                    fontFamily: 'Inter',\\n                    fontWeight: '400',\\n                    lineHeight: '19.60px',\\n                    wordWrap: 'break-word',\\n                    border: 'none',\\n                    outline: 'none',\\n                    background: 'transparent',\\n                  }}\\n                />\\n                <button\\n                  type=\\\"button\\\"\\n                  onClick={() => {\\n                    const updated = (watchEdit?.('signature') || []).filter(\\n                      (_, i) => i !== index,\\n                    );\\n                    setValueEdit?.('signature', updated);\\n                  }}\\n                  style={{\\n                    width: 16,\\n                    height: 16,\\n                    position: 'relative',\\n                    background: 'none',\\n                    border: 'none',\\n                    cursor: 'pointer',\\n                    padding: 0,\\n                    display: 'flex',\\n                    alignItems: 'center',\\n                    justifyContent: 'center',\\n                  }}\\n                >\\n                  <i className=\\\"ph ph-x\\\" style={{ fontSize: 16 }} />\\n                </button>\\n              </div>\\n            ))}\\n          </div>\\n        ) : (\\n          <div\\n            style={{\\n              padding: '1rem',\\n              textAlign: 'center',\\n              color: 'var(--black-400)',\\n              backgroundColor: 'var(--black-25)',\\n              borderRadius: '0.5rem',\\n              border: '1px dashed var(--black-100)',\\n              fontSize: '0.875rem',\\n            }}\\n          >\\n            Belum ada Paraf. Klik \\\"Tambah Paraf\\\" untuk menambahkan.\\n          </div>\\n        )}\\n      </Form.Group>\\n    </>\\n  );\\n}\\n\\nconst StepIndicator = styled.span`\\n  margin-left: 1rem;\\n  font-size: 0.875rem;\\n  color: var(--black-400);\\n  font-weight: 500;\\n`;\\n\\nconst TitleHead = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-weight: 500;\\nline-height: 140%; \\n`;\\n\\nconst Divider = styled.div`\\n  width: 100%;\\n  height: 0;\\n  margin-top:1.25rem;\\n  margin-bottom:1.25rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst Divinder = styled.div`\\n  width: 100%;\\n  border-top: 1px solid var(--black-100);\\n  margin-top:1.42857rem;\\n  margin-bottom:1.42857rem;\\n\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\\nconst TitleInput = styled.div`\\ncolor: var(--black);\\nfont-size: 1rem;\\nfont-weight: 500;\\nline-height: 140%; \\n\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  font-family:Inter;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\nconst CustomStyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  font-family: Inter;\\n\\n  border: none;\\n  outline: none;\\n  box-shadow: none;\\n  background: transparent;\\n\\n  resize: none;\\n\\n  &:focus {\\n    outline: none;\\n    box-shadow: none;\\n  }\\n`;\\n\\nconst FormStyle = styled(Form.Group)`\\n    margin-bottom: 1.14rem;\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"57aa9b76c958acd3817c669a52c57e3a\":false},\"customColors\":false,\"limitData\":0,\"backgroundColor\":\"\",\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigFields\":{\"tableCategoryCustom\":[]},\"container\":{\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"containLabel\":false},\"title\":{\"show\":false,\"text\":\"\",\"fontSize\":\"\",\"width\":\"\",\"fontFamily\":\"\",\"fontColor\":\"\"},\"dataLabel\":{\"fontWeight\":\"\",\"fontCase\":\"\",\"show\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"numberOnly\":false,\"percentOnly\":false,\"isDate\":false,\"labelWidth\":\"\",\"fontSize\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"color\":\"\",\"position\":\"\",\"dateFormatter\":\"\"},\"legend\":{\"show\":false,\"showValue\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"isPercentage\":false,\"valuePrefix\":\"\",\"fontSize\":\"\",\"width\":\"\",\"customPosition\":{\"left\":\"\",\"right\":\"\",\"top\":\"\",\"bottom\":\"\"},\"icon\":\"\",\"type\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"fontColor\":\"\",\"fontCase\":\"\"},\"series\":{\"seriesName\":false,\"percentage\":false,\"inverse\":false,\"smooth\":false,\"labelLine\":false,\"borderWidth\":\"\",\"opacity\":1,\"suggestionCo