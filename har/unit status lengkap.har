onParentName === 'Polda';\\n\\n  // const isPaminal = permissionParentName === 'Paminal';\\n\\n  const { dispatchNotification } = useNotification();\\n  // const isAllowed = useMemo(() => {\\n  //   return (\\n  //     userGroupName === 'Paminal' ||\\n  //     userGroupName === 'Polda' ||\\n  //     allowedGroupNames.includes(userGroupName)\\n  //   );\\n  // }, [userGroupName]);\\n\\n  const isPaminal = useMemo(() => {\\n    return allowedGroupNames.includes(userGroupName);\\n  }, [userGroupName]);\\n\\n  const isYanduan = useMemo(() => {\\n    return suratDumasGroups.includes(userGroupName);\\n  }, [userGroupName]);\\n\\n  // const isAllowed = useMemo(() => {\\n  //   return (\\n  //     allowedGroupNames.includes(userGroupName) ||\\n  //     suratDumasGroups.includes(userGroupName)\\n  //   );\\n  // }, [userGroupName]);\\n\\n  // const canAccessSuratDumas = useMemo(() => {\\n  //   return suratDumasGroups.includes(userGroupName);\\n  // }, [userGroupName]);\\n\\n  const canAccessBuatLaporan = isPaminal || isYanduan || isTaudDivPropam;\\n\\n  if (!canAccessBuatLaporan) {\\n    return (\\n      <div className=\\\"d-flex justify-content-end\\\">\\n        <CetakLaporan className=\\\"w-100\\\" />\\n      </div>\\n    );\\n  }\\n\\n  return (\\n    <>\\n      <div className=\\\"d-flex align-items-center justify-content-end gap-5\\\">\\n        <CetakLaporan />\\n        <BuatLaporan\\n          user={user}\\n          dispatchNotification={dispatchNotification}\\n          showLaporanInformasi={isPaminal}\\n          showInfosus={isPaminal}\\n          showSuratDumas={isYanduan}\\n          showSuratKadiv={isTaudDivPropam}\\n        />\\n        {/* <div>\\n          <h3>Data Grup:</h3>\\n           <pre>{JSON.stringify(grupData, null, 2)}</pre> \\n        </div> */}\\n      </div>\\n    </>\\n  );\\n}\\n\\nconst allowedGroupNames = [\\n  'KANIT PAMINAL POLRES ACEH BARAT DAYA POLDA ACEH',\\n  'KANIT PAMINAL POLRES ACEH BARAT POLDA ACEH',\\n  'KANIT PAMINAL POLRES ACE