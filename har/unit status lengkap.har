          "content": {
            "size": 12085,
            "mimeType": "application/json",
            "compression": 8473,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":3},\"data\":{\"createdAt\":\"2026-06-18 16:50:20.829000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-06-18 16:50:20\",\"h\":62,\"id\":\"07031b282ea9e361c12a75c1790ae60f\",\"menuId\":\"2734f2a65be5c978f8555bf1658b587f\",\"name\":\"Devtools\",\"responsive\":{\"1024\":{\"x\":0,\"y\":66,\"w\":12,\"h\":62}},\"type\":\"devtools\",\"updatedAt\":\"2026-07-15 11:57:36.508000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":12,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState } from 'react';\\nimport { Form } from 'react-bootstrap';\\nimport styled from 'styled-components';\\n\\nexport default function LaporanUpload({\\n  registerEdit,\\n  watchEdit,\\n  setValueEdit,\\n  uploadedFiles,\\n  setUploadedFiles,\\n  dispatchNotification,\\n  user,\\n  dashboard,\\n}) {\\n  const [isDragging, setIsDragging] = useState(false);\\n  const [loading, setLoading] = useState(false);\\n\\n  const filterValidFiles = (files) => {\\n    const allowedExtensions = [\\n      '.pdf',\\n      '.jpg',\\n      '.jpeg',\\n      '.png',\\n      '.doc',\\n      '.docx',\\n      '.mp4',\\n    ];\\n    const MAX_FILE_SIZE = 10 * 1024 * 1024;\\n    const validFiles = [];\\n    const invalidFiles = [];\\n\\n    files.forEach((file) => {\\n      const fileName = file.name.toLowerCase();\\n      const isValidExt = allowedExtensions.some((ext) =>\\n        fileName.endsWith(ext),\\n      );\\n      const isValidSize = file.size <= MAX_FILE_SIZE;\\n\\n      if (isValidExt && isValidSize) {\\n        validFiles.push(file);\\n      } else {\\n        if (!isValidExt) {\\n          invalidFiles.push(`${file.name} (format tidak diizinkan)`);\\n        } else if (!isValidSize) {\\n          invalidFiles.push(`${file.name} (melebihi 10MB)`);\\n        }\\n      }\\n    });\\n\\n    if (invalidFiles.length > 0 && dispatchNotification) {\\n      dispatchNotification(\\n        `File ditolak: ${invalidFiles.join(', ')}`,\\n        'danger',\\n      );\\n    }\\n\\n    return validFiles;\\n  };\\n\\n  const handleDragOver = (e) => {\\n    e.preventDefault();\\n    setIsDragging(true);\\n  };\\n\\n  const handleDragLeave = (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n  };\\n\\n  const handleDrop = async (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n\\n    const droppedFiles = Array.from(e.dataTransfer.files);\\n    const validFiles = filterValidFiles(droppedFiles);\\n    if (validFiles.length === 0) return;\\n\\n    for (const file of validFiles) {\\n      await handleFileUpload(file);\\n    }\\n  };\\n\\n  const handleFileChange = async (e) => {\\n    const selectedFiles = Array.from(e.target.files);\\n    const validFiles = filterValidFiles(selectedFiles);\\n    if (validFiles.length === 0) {\\n      e.target.value = '';\\n      return;\\n    }\\n\\n    for (const file of validFiles) {\\n      await handleFileUpload(file);\\n    }\\n    e.target.value = '';\\n  };\\n\\n  const handleFileUpload = async (file) => {\\n    console.log('Uploading file:', file.name, file.size);\\n\\n    const allowedExtensions = [\\n      '.pdf',\\n      '.jpg',\\n      '.jpeg',\\n      '.png',\\n      '.doc',\\n      '.docx',\\n      '.mp4',\\n    ];\\n    const fileName = file.name.toLowerCase();\\n    const isValidExt = allowedExtensions.some((ext) => fileName.endsWith(ext));\\n\\n    if (!isValidExt) {\\n      if (dispatchNotification) {\\n        dispatchNotification(`File \\\"${file.name}\\\" tidak diizinkan.`, 'danger');\\n      }\\n      return null;\\n    }\\n\\n    if (file.size > 10 * 1024 * 1024) {\\n      if (dispatchNotification) {\\n        dispatchNotification(`File ${file.name} melebihi batas 10MB`, 'danger');\\n      }\\n      return null;\\n    }\\n\\n    const blockedExtensions = [\\n      '.exe',\\n      '.bat',\\n      '.sh',\\n      '.cmd',\\n      '.js',\\n      '.html',\\n      '.htm',\\n      '.php',\\n      '.asp',\\n      '.jar',\\n    ];\\n    const isBlockedExt = blockedExtensions.some((ext) =>\\n      fileName.endsWith(ext),\\n    );\\n\\n    if (isBlockedExt) {\\n      if (dispatchNotification) {\\n        dispatchNotification(\\n          `File \\\"${file.name}\\\" adalah file berbahaya.`,\\n          'danger',\\n        );\\n      }\\n      return null;\\n    }\\n\\n    const queryParams = new URLSearchParams({\\n      folder: 'agent',\\n      workspaceId: user?.workspaceId || '',\\n      dashboardId: dashboard?.id || '',\\n      createdBy: user?.id || '',\\n      extractFile: 'false',\\n    }).toString();\\n\\n    const formData = new FormData();\\n    formData.append('file', file);\\n    formData.append('tags', 'assets');\\n\\n    try {\\n      const res = await fetch(\\n        `/api/v1/apps/upload/upload-file?${queryParams}`,\\n        {\\n          method: 'POST',\\n          body: formData,\\n        },\\n      );\\n\\n      if (!res.ok) {\\n        const errorText = await res.text();\\n        throw new Error(`Upload gagal: ${res.status} - ${errorText}`);\\n      }\\n\\n      const result = await res.json();\\n      const uploadedFileInfo = result?.data?.path || '';\\n\\n      if (setUploadedFiles) {\\n        setUploadedFiles((prev) => [\\n          ...prev,\\n          {\\n            name: file.name,\\n            path: uploadedFileInfo,\\n            size: file.size,\\n          },\\n        ]);\\n      }\\n\\n      if (dispatchNotification) {\\n        dispatchNotification(`File ${file.name} berhasil diupload`, 'success');\\n      }\\n      return uploadedFileInfo;\\n    } catch (err) {\\n      console.error('Error upload file:', err);\\n      if (dispatchNotification) {\\n        dispatchNotification(\\n          `Error uploading ${file.name}: ${err.message}`,\\n          'danger',\\n        );\\n      }\\n      return null;\\n    }\\n  };\\n\\n  const removeFile = (file) => {\\n    if (setUploadedFiles && uploadedFiles) {\\n      setUploadedFiles((prev) => prev.filter((f) => f.name !== file.name));\\n    }\\n  };\\n\\n  const getFileIcon = (file) => {\\n    const name = file?.name?.toLowerCase() || '';\\n    const ext = name.split('.').pop();\\n\\n    switch (ext) {\\n      case 'jpg':\\n      case 'jpeg':\\n      case 'png':\\n      case 'gif':\\n        return <i className=\\\"ph-fill ph-image\\\"></i>;\\n      case 'pdf':\\n        return <i className=\\\"ph-fill ph-file-pdf\\\"></i>;\\n      case 'doc':\\n      case 'docx':\\n        return <i className=\\\"ph-fill ph-file-doc\\\"></i>;\\n      case 'txt':\\n        return <i className=\\\"ph-fill ph-file-text\\\"></i>;\\n      case 'xls':\\n      case 'xlsx':\\n        return <i className=\\\"ph-fill ph-file-xls\\\"></i>;\\n      case 'mp4':\\n      case 'mov':\\n      case 'avi':\\n      case 'mkv':\\n        return <i className=\\\"ph ph-video\\\"></i>;\\n      case 'mp3':\\n      case 'wav':\\n        return <i className=\\\"ph-fill ph-microphone\\\"></i>;\\n      default:\\n        return <i className=\\\"ph-fill ph-file\\\"></i>;\\n    }\\n  };\\n\\n  const triggerFileInput = () => {\\n    const fileInput = document.getElementById('fileInputLanjutLidik');\\n    if (fileInput) fileInput.click();\\n  };\\n\\n  return (\\n    <>\\n      <Form.Group className=\\\"mb-3 w-100\\\">\\n        <TitleInput className=\\\"pb-2\\\">Dokumen</TitleInput>\\n\\n        <StyledInput\\n          id=\\\"fileInputLanjutLidik\\\"\\n          type=\\\"file\\\"\\n          multiple\\n          style={{ display: 'none' }}\\n          onChange={handleFileChange}\\n          accept=\\\".doc,.docx,.png,.jpg,.jpeg,.pdf,.mp4\\\"\\n        />\\n\\n        <UploadBox\\n          onDrop={handleDrop}\\n          onDragOver={handleDragOver}\\n          onDragLeave={handleDragLeave}\\n          onClick={triggerFileInput}\\n          isDragging={isDragging}\\n        >\\n          <i className=\\\"ph-fill ph-upload-simple pb-2\\\"></i>\\n          <p style={{ fontWeight: '400', fontSize: '0.875rem' }}>\\n            <span style={{ fontWeight: '600', color: 'var(--primary-500)' }}>\\n              Choose file\\n            </span>{' '}\\n            or drag and drop\\n          </p>\\n          <small>\\n            doc, docx, png, jpg, jpeg, pdf, mp4 only. 10MB max size.\\n          </small>\\n        </UploadBox>\\n\\n        {uploadedFiles && uploadedFiles.length > 0 && (\\n          <FileList className=\\\"py-4\\\">\\n            {uploadedFiles.map((file, idx) => (\\n              <FileItem key={`file-${idx}`}>\\n                <StyledFile>\\n                  <FileIcon>{getFileIcon(file)}</FileIcon>\\n                </StyledFile>\\n                <div>\\n                  {file.name} - {(file.size / (1024 * 1024)).toFixed(1)} MB\\n                </div>\\n                <button\\n                  type=\\\"button\\\"\\n                  onClick={() => removeFile(file)}\\n                  style={{ color: '#dc3545' }}\\n                >\\n                  ✕\\n                </button>\\n              </FileItem>\\n            ))}\\n          </FileList>\\n        )}\\n      </Form.Group>\\n    </>\\n  );\\n}\\n\\n// Styled Components (sama seperti sebelumnya)\\nconst TitleInput = styled.div`\\n  color: var(--black);\\n  font-size: 1rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;\\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst FileIcon = styled.div`\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  font-size: 1.25rem;\\n`;\\n\\nconst FileList = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.75rem;\\n  margin-top: 1rem;\\n`;\\n\\nconst StyledFile = styled.div`\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  width: 2rem;\\n  height: 2rem;\\n  border-radius: 0.5rem;\\n  background: var(--primary-50);\\n  color: var(--primary-600);\\n  \\n  i {\\n    font-size: 1.25rem;\\n  }\\n`;\\n\\nconst FileItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  justify-content: space-between;\\n  padding: 0.75rem;\\n  background: var(--white);\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  font-size: 0.875rem;\\n  transition: all 0.2s ease;\\n  \\n  &:hover {\\n    background: var(--black-25);\\n    border-color: var(--black-200);\\n  }\\n  \\n  > div:first-child {\\n    display: flex;\\n    align-items: center;\\n    gap: 0.75rem;\\n  }\\n  \\n  button {\\n    background: none;\\n    border: none;\\n    padding: 0.25rem 0.5rem;\\n    color: var(--danger-500);\\n    font-size: 1.125rem;\\n    cursor: pointer;\\n    border-radius: 0.375rem;\\n    display: flex;\\n    align-items: center;\\n    justify-content: center;\\n    \\n    &:hover {\\n      background: var(--danger-50);\\n      color: var(--danger-600);\\n    }\\n  }\\n`;\\n\\nconst UploadBox = styled.div`\\n  border: 1px dashed var(--black-100);\\n  background: var(--black-25);\\n  border-radius: 0.5rem;\\n  text-align: center;\\n  cursor: pointer;\\n  padding: 2rem 0.75rem;\\n  transition: all 0.2s ease;\\n  \\n  ${({ isDragging }) =>\\n    isDragging &&\\n    `\\n    border-color: var(--primary);\\n    background: var(--primary-25);\\n  `}\\n  \\n  &:hover {\\n    border-color: var(--primary-400);\\n    background: var(--primary-25);\\n  }\\n  \\n  i {\\n    font-size: 1.6rem;\\n    color: var(--black);\\n    margin-bottom: 0.5rem;\\n  }\\n  \\n  p {\\n    font-weight: 400;\\n    font-size: 0.875rem;\\n    margin-bottom: 0.25rem;\\n    pointer-events: none;\\n    \\n    span {\\n      font-weight: 600;\\n      color: var(--primary-500);\\n    }\\n  }\\n  \\n  small {\\n    font-size: 0.75rem;\\n    color: var(--black-400);\\n    pointer-events: none;\\n  }\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"07031b282ea9e361c12a75c1790ae60f\":false}}},\"x\":0,\"y\":66},\"additionalInfo\":null,\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
