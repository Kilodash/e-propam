l\":\"Summary\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"summary\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Category\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"category\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Title\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"title\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Information\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"information\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Polda\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"polda\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Polres\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"polres\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Polsek\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"polsek\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Sender Name\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"sender_name\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Sender Address\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"sender_address\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Id Address\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"id_address\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Score\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_score\",\"dataType\":\"double precision\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Analysis\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_analysis\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Economic Stability Impact\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_economic_stability_impact\",\"dataType\":\"double precision\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Economic Stability Analysis\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_economic_stability_analysis\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Real Societal Impact\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_real_societal_impact\",\"dataType\":\"double precision\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Real Societal Impact Analysis\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_real_societal_impact_analysis\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Scale Escalation\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_scale_escalation\",\"dataType\":\"double precision\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Scale Escalation Analysis\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_scale_escalation_analysis\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Casualties Impact\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"casualties_impact\",\"dataType\":\"double precision\",\"styles\":{\"col\":12}},{\"label\":\"Casualties Analysis\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"casualties_analysis\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Disaster Type\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"disaster_type\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Disaster Normalized\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"disaster_normalized\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Number Of Casualities\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"number_of_casualities\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Impact Level\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"impact_level\",\"dataType\":\"double precision\",\"styles\":{\"col\":12}},{\"label\":\"Contingency Analysis\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"contingency_analysis\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Past Fact Check\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"past_fact_check\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Past Fact Check Confidence\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"past_fact_check_confidence\",\"dataType\":\"integer\",\"styles\":{\"col\":12}},{\"label\":\"Past Fact Check Decision\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"past_fact_check_decision\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Polda Code\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"polda_code\",\"dataType\":\"integer\",\"styles\":{\"col\":12}},{\"label\":\"Polres Code\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"polres_code\",\"dataType\":\"bigint\",\"styles\":{\"col\":12}},{\"label\":\"Polsek Code\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"polsek_code\",\"dataType\":\"bigint\",\"styles\":{\"col\":12}},{\"label\":\"Recommendation\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"recommendation\",\"dataType\":\"text\",\"styles\":{\"col\":12}},{\"label\":\"Status\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"status\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Tag\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"tag\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}},{\"label\":\"Urgency Score Category\",\"placeholder\":\"\",\"type\":\"text\",\"fieldName\":\"urgency_score_category\",\"dataType\":\"character varying\",\"styles\":{\"col\":12}}],\"editId\":null,\"dataChildren\":{\"isChildren\":false},\"multiForm\":false,\"tableOrigin\":\"\"},\"key\":\"prepetrator_id\",\"name\":\"Propam Aduan (Test)\",\"status\":\"active\",\"table\":\"gold.report\",\"tableConfig\":{\"size\":\"10\",\"order\":\"desc\",\"orderBy\":\"created_date\",\"search_by\":[\"id\",\"pengirim\",\"prepetrator_id\"],\"pagination\":\"full\",\"addAction\":false,\"refreshPage\":true,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import { useForm } from 'react-hook-form';\\nimport React, { useState, useEffect } from 'react';\\nimport { dashboard } from '@store/app';\\nimport { Link, useSearchParams } from 'react-router-dom';\\nimport { usePermission } from '@app/hooks/permission.hook';\\nimport { useLocation, useNavigate } from 'react-router-dom';\\n\\nimport {\\n  Table,\\n  Dropdown,\\n  Button,\\n  Modal,\\n  Form,\\n  Row,\\n  Col,\\n  Card,\\n  Spinner,\\n  ProgressBar,\\n} from 'react-bootstrap';\\nimport styled from 'styled-components';\\n\\nconst dummyStatuses = [\\n  { statuss: 'Diterima', status1: 'BAGYANDUAN DIVPROPAM', status2: null },\\n  { statuss: 'Diterima', status1: 'BAGYANDUAN DIVPROPAM', status2: null },\\n  {\\n    statuss: 'Diterima',\\n    status1: 'BAGYANDUAN DIVPROPAM',\\n    status2: 'Ditangani Tim 2',\\n  },\\n  { statuss: 'Diterima', status1: 'BAGYANDUAN DIVPROPAM', status2: null },\\n  { statuss: 'Diterima', status1: 'BAGYANDUAN DIVPROPAM', status2: null },\\n];\\n\\nexport default function TableListView({ widget, data, G }) {\\n  const [searchParams] = useSearchParams();\\n  const currentPage = parseInt(searchParams.get('page') || '1', 10);\\n  const navigate = useNavigate();\\n  const location = useLocation();\\n\\n  const formatDateID = (dateString) => {\\n    if (!dateString) return '-';\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return '-';\\n    const hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n    const tahun = date.getFullYear().toString().slice(-2);\\n    const jam = date.getHours().toString().padStart(2, '0');\\n    const menit = date.getMinutes().toString().padStart(2, '0');\\n    return `${hari}, ${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n  };\\n\\n  const formatDate = (dateString) => {\\n    if (!dateString) return '-';\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return '-';\\n    const hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n    const tahun = date.getFullYear().toString().slice(-2);\\n    return `${hari}, ${tanggal} ${bulan} ${tahun}`;\\n  };\\n\\n  // const goToDetail = (item) => {\\n  //   const segments = location.pathname.split('/').filter(Boolean);\\n\\n  //   const source = segments[segments.length - 1];\\n\\n  //   const viewIndex = segments.indexOf('view');\\n\\n  //   let basePath;\\n  //   if (viewIndex !== -1 && segments[viewIndex + 1]) {\\n  //     basePath = '/' + segments.slice(0, viewIndex + 2).join('/');\\n  //   } else {\\n  //     basePath = '/' + segments.slice(0, -2).join('/');\\n  //   }\\n\\n  //   navigate(\\n  //     `${basePath}/report/detail-laporan?detail-laporan=${item.id}&source=${source}`,\\n  //   );\\n  // };\\n\\n  const goToDetail = (item) => {\\n    const segments = location.pathname.split('/').filter(Boolean);\\n    const source = segments[segments.length - 1];\\n    const viewIndex = segments.indexOf('view');\\n\\n    let basePath;\\n\\n    if (viewIndex !== -1 && segments[viewIndex + 1]) {\\n      basePath = '/' + segments.slice(0, viewIndex + 2).join('/');\\n    } else if (segments.includes('builder')) {\\n      basePath = '/' + segments.slice(0, -2).join('/');\\n    } else {\\n      basePath = '';\\n    }\\n\\n    navigate(\\n      `${basePath}/report/detail-laporan?detail-laporan=${item.prepetrator_id}&source=${source}`,\\n    );\\n  };\\n\\n  console.log('duh', data[0]);\\n\\n  return (\\n    <>\\n      <StyledTableContainer>\\n        <StyledTable bordered>\\n          <thead>\\n            <tr>\\n              <th style={{ width: '0%' }}>No</th>\\n              <th style={{ width: '16%' }}>Informasi Laporan</th>\\n              <th style={{ width: '12%' }}>Terlapor</th>\\n              <th style={{ width: '12%' }}>Pelapor</th>\\n              <th style={{ width: '12%' }}>Peristiwa</th>\\n              {/* <th style={{ width: '12%' }}>Satuan Wilayah</th> */}\\n              <th style={{ width: '2%' }}>Kategori</th>\\n              <th style={{ width: '30%' }}>Rangkuman</th>\\n              <th style={{ width: '30%' }}>Last Updated</th>\\n              <th style={{ width: '20%', textAlign: 'center' }}>Status</th>\\n              <th style={{ width: '5%' }}>Aksi</th>\\n            </tr>\\n          </thead>\\n          <tbody>\\n            {data?.map((item, index) => {\\n              return (\\n                <tr key={item.id || index}>\\n                  <td>{(currentPage - 1) * 10 + (index + 1)}</td>\\n                  <td>\\n                    <div className=\\\"flex flex-col gap-2\\\">\\n                      {item.id}\\n                      <div className=\\\"fw-500\\\"></div>\\n                      <div className=\\\"text-muted\\\">\\n                        {formatDateID(item.created_date)}\\n                      </div>\\n                      {/* <div>{item.created_date_utc}</div> */}\\n                      <div className=\\\"flex items-center gap-2\\\">\\n                        <InformasiBadge\\n                          value={item.source_alias || 'landing page'}\\n                        >\\n                          {item.source_alias || 'landing page'}\\n                        </InformasiBadge>\\n                      </div>\\n                    </div>\\n                  </td>\\n                  <td>\\n                    <div>{item.prepetrator_name || '-'}</div>\\n                    <div className=\\\"text-muted\\\">\\n                      {item.prepetrator_id || '-'}\\n                    </div>\\n                  </td>\\n                  <td>\\n                    <div>{item.pengirim}</div>\\n                    <div className=\\\"text-muted\\\">{item.reporter_nik || '-'}</div>\\n                    {item.total_report > 1 && (\\n                      <BadgeCell\\n                        style={{\\n                          marginTop: '5px',\\n                          backgroundColor: 'var(--warning-25)',\\n                          color: 'var(--warning)',\\n                        }}\\n                      >\\n                        Laporan ke {item.total_report}\\n                      </BadgeCell>\\n                    )}\\n                  </td>\\n                  <td>\\n                    <TextEllipsis>{item['5w1h_where'] || '-'}</TextEllipsis>\\n                    <div className=\\\"text-muted\\\">\\n                      {formatDate(item['5w1h_when'])}\\n                    </div>\\n                  </td>\\n                  {/* <td>\\n                    <TextEllipsis>{item.polda || '-'}</TextEllipsis>\\n                    <TextEllipsis>{item.polres || '-'}</TextEllipsis>\\n                    <TextEllipsis>{item.polsek || '-'}</TextEllipsis>\\n                  </td> */}\\n                  <td>\\n                    <div>{item.category || '-'}</div>\\n                    {/* <div className=\\\"text-muted\\\">{item.category}</div> */}\\n                  </td>\\n                  <td>\\n                    <div\\n                      style={{\\n                        overflowY: 'auto',\\n                        height: '7lh',\\n                        lineHeight: '1.5',\\n                      }}\\n                    >\\n                      {item.content}\\n                    </div>\\n                  </td>\\n\\n                  <td>\\n                    <div>{formatDateID(item.updated_at)}</div>\\n                  </td>\\n\\n                  <td>\\n                    <div className=\\\"flex flex-col gap-4\\\">\\n                      {item.status_label && (\\n                        <BadgeCell\\n                          style={{\\n                            backgroundColor: 'var(--primary-25)',\\n                            color: 'var(--primary)',\\n                          }}\\n                          value={item.status_label}\\n                        >\\n                          {item.status_label}\\n                        </BadgeCell>\\n                      )}\\n\\n                      {item.disposisi_case_position && (\\n                        <BadgeCell value={item.disposisi_case_position}>\\n                          {item.disposisi_case_position}\\n                        </BadgeCell>\\n                      )}\\n                    </div>\\n                  </td>\\n\\n                  <td>\\n                    {/* to={`detail-laporan?id-laporan=${item.id}`} */}\\n\\n                    {/* <StyledLink\\n                      to={`report/detail-laporan?id-laporan=${item.ticket || 251016000008}`}\\n                      target=\\\"_blank\\\"\\n                    >\\n                      Detail\\n                    </StyledLink> */}\\n                    <Button onClick={() => goToDetail(item)}>Detail</Button>\\n                  </td>\\n                </tr>\\n              );\\n            })}\\n          </tbody>\\n        </StyledTable>\\n      </StyledTableContainer>\\n    </>\\n  );\\n}\\nconst StyledLink = styled(Link)`\\ndisplay: flex;\\npadding: 6px 12px;\\njustify-content: center;\\nalign-items: center;\\ngap: 8px;\\nborder-radius: 8px;\\nbackground: var(--primary-500);\\ncolor:var(--white);\\n\\n&:hover {\\ncolor:var(--white);\\n\\n}\\n`;\\n\\nconst Title = styled.div`\\ncolor: var(--black);\\nfont-size: 1rem;\\nfont-weight: 600;\\nline-height: 150%; \\n`;\\n\\nconst Small = styled.div`\\ncolor: var(--black-700);\\nfont-size: 0.875rem;\\nfont-weight: 400;\\nline-height: 150%; `;\\n\\nconst TitleInput = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-weight: 500;\\nline-height: 140%; \\n\\n`;\\nconst StyledCard = styled(Card)`\\nborder-radius: 0.625rem;\\n`;\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;  \\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid #e1e2e5;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;  \\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid #e1e2e5;\\n  font-family:Inter;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\nconst StyledTableContainer = styled.div`\\n  border-radius: 0.5rem;\\n  border: 1px solid var(--Border-Primary, #E1E2E5);\\n  overflow-x: auto;  /* <-- Ubah dari 'hidden' menjadi 'auto' */\\n  overflow-y: hidden; /* Opsional: sembunyikan scroll vertikal jika tidak perlu */\\n  \\n  /* Opsional: agar border-radius tetap terlihat saat discroll */\\n  -webkit-overflow-scrolling: touch;\\n`;\\nconst StyledTable = styled.table`\\n  width: 100%;\\n  border-collapse: collapse;\\n  margin-bottom: 0;\\n \\n  thead th {\\n\\n    padding: 1rem 0.9rem;\\n    color: var(--black-500);\\n    white-space: nowrap;\\n    font-size: 12px;\\n    font-style: normal;\\n    font-weight: 600;\\n    line-height: 140%; \\n    letter-spacing: -0.24px;\\n  }\\n \\n  tbody td {\\n    padding: 1rem 0.9rem;\\n    color: var(--black);\\n    text-overflow: ellipsis;\\n    font-size: 12px;\\n    font-style: normal;\\n    font-weight: 400;\\n    line-height: 140%; \\n    text-transform: capitalize;\\n    border-top: 1px solid var(--black-100);\\n    vertical-align: top; \\n    \\n   \\n    word-wrap: break-word;\\n    overflow-wrap: break-word;\\n  }\\n  \\n  tbody tr:last-child td {\\n    border-bottom: none;\\n  }\\n`;\\n\\nconst StyledDropdownMenu = styled(Dropdown.Menu)`\\n  border-radius: 0.5rem;\\n  border: 1px solid #e1e2e5;\\n  box-shadow: 0px 4px 12px rgba(0,0,0,0.15);\\n  padding: 0.5rem 0;\\n\\n   .dropdown-item {\\n    padding: 0.5rem 1rem;\\n    font-size: 0.875rem;\\n    color: var(--black);\\n\\n    &:hover {\\n      background-color: var(--black-50); \\n  \\n    }\\n`;\\nconst getBadgeColor = (value) => {\\n  if (!value) return { background: 'var(--black-500)', color: 'var(--black)' };\\n  const val = value.toLowerCase();\\n\\n  if (val === 'masuk')\\n    return {\\n      background: 'var(--Background-Secondary, #F5F7FA);',\\n      color: 'var(--black)',\\n    };\\n\\n  if (val === 'diterima')\\n    return {\\n      background: 'var(--black-25);',\\n      color: 'var(--black)',\\n    };\\n  if (val === 'selesai')\\n    return {\\n      background: 'var(--success-50);',\\n      color: 'var(--success)',\\n    };\\n\\n  if (val === 'bagyanduan divpropam')\\n    return {\\n      background: 'var(--success-50);',\\n      color: 'var(--success)',\\n    };\\n\\n  if (val === 'ditangani tim 2')\\n    return {\\n      background: 'var(--primary-50);',\\n      color: 'var(--primary)',\\n    };\\n\\n  // prioritas\\n\\n  return { background: 'var(--black-25)', color: 'var(--black)' };\\n};\\n\\nconst BadgeCell = styled.span`\\n  display: flex;\\n  padding: 4px 8px;\\n  // width: min-content; \\n  margin: 0 auto; \\n  \\n  text-align: center;\\n  justify-content: center;\\n  align-items: center;\\n  \\n  border-radius: 6px;\\n  font-size: 0.75rem;\\n  font-weight: 600;\\n\\n  \\n  background-color: ${({ value }) => getBadgeColor(value).background};\\n  color: ${({ value }) => getBadgeColor(value).color};\\n`;\\n\\nconst InformasiBadge = styled.span`\\n  display: inline-block;\\n  padding: 4px 8px;\\n  border-radius: 0.375rem;\\n  font-size: 10px;\\n  font-weight: 600;\\n  text-transform: capitalize;\\n  background-color: ${({ value }) => getInfoBadge(value).background};\\n  color: ${({ value }) => getInfoBadge(value).color};\\n  border: ${({ value }) => getInfoBadge(value).border};\\n`;\\n\\nconst getInfoBadge = (value) => {\\n  if (!value) return { background: '#9ca3af', color: '#fff' };\\n  // if (!value) return { background: '#9ca3af', color: 'red' };\\n  const val = value.toLowerCase();\\n\\n  if (val === 'landing page')\\n    return {\\n      background: 'var(--white)',\\n      color: 'var(--black)',\\n      border: '1px solid var(--black-100)',\\n    };\\n\\n  if (val === 'masyarakat')\\n    return {\\n      background: 'var(--white)',\\n      color: 'var(--primary)',\\n      border: '1px solid var(--black-100)',\\n    };\\n\\n  if (val === 'sumber qr code')\\n    return {\\n      background: 'var(--white)',\\n      color: 'var(--black)',\\n      border: '1px solid var(--black-100)',\\n    };\\n  // return { background: '#9ca3af', color: '#fff' };\\n  return { background: '#9ca3af', color: '#fff' };\\n};\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst UploadBox = styled.div`\\nborder: 1px dashed var(--Border-Primary, #E6E9F0);\\nbackground: var(--Background-Secondary, #F5F7FA);\\n  border-radius: 0.5rem;\\n\\n  text-align: center;\\n  cursor: pointer;\\n  padding: 3rem 0.75rem;\\n\\n\\n`;\\n\\nconst FileList = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n  padding-top:1.2rem;\\n`;\\n\\nconst FileItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  border-radius: 0.75rem;\\n  border: 1px solid var(--Border-Primary, #E6E8EB);\\n  background: var(--Background-Secondary, #F7F8FA);\\n  padding: 0.5rem;\\n  font-size: 0.875rem;\\n  \\n`;\\n\\nconst FileIcon = styled.div`\\n  font-size: 1.25rem;\\n  margin-right: 0.5rem;\\n`;\\n\\nconst ProgressWrapper = styled.div`\\n  display: flex;\\n  align-items: center;\\n  gap: 8px;\\n  width: 105px; \\n`;\\n\\nconst StyledProgressBar = styled(ProgressBar)`\\n  flex: 1;\\n  height: 6px;\\n  border-radius: 4px;\\n  background-color: #e9ecef;\\n  width: 100px;\\n\\n  .progress-bar {\\n    background-color: ${({ value }) => {\\n      if (value >= 80) return 'var(--success)';\\n      if (value >= 50) return 'var(--primary)';\\n      return 'var(--warning)';\\n    }};\\n    transition: width 0.5s ease;\\n  }\\n`;\\n\\nconst PercentLabel = styled.span`\\n  font-size: 12px;\\n  font-weight: 500;\\n  min-width: 35px;\\n  text-align: right;\\n  color: var(--text-color, #333);\\n`;\\n\\nconst TextEllipsis = styled.span`\\n  display: -webkit-box;\\n  -webkit-line-clamp: 2;\\n  -webkit-box-orient: vertical;\\n  overflow: hidden;\\n  text-overflow: ellipsis;\\n`;\\n\",\"html\":\"\"},\"columns\":[{\"header\":\"Id\",\"accessor\":\"id\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"id\"},{\"header\":\"Phone No\",\"accessor\":\"phone_no\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"phone_no\"},{\"header\":\"Created Date\",\"accessor\":\"created_date\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"created_date\"},{\"header\":\"Detail\",\"accessor\":\"detail\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail\"},{\"header\":\"Detail What\",\"accessor\":\"detail_what\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail_what\"},{\"header\":\"Detail Where\",\"accessor\":\"detail_where\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail_where\"},{\"header\":\"Detail When\",\"accessor\":\"detail_when\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail_when\"},{\"header\":\"Detail Why\",\"accessor\":\"detail_why\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail_why\"},{\"header\":\"Detail Who\",\"accessor\":\"detail_who\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail_who\"},{\"header\":\"Detail How\",\"accessor\":\"detail_how\",\"minWidth\":\"150px\",\"disableFilters\":false,\"field\":\"detail_how\"},{\"header\":\"Summary\",\"accessor\":\"summary\",\"minWidth\":\"150px\",\"disableFil