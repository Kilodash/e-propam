          "postData": {
            "mimeType": "application/json",
            "text": "{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"96d2527795a0b17ff4e890d36ad660fe\",\"sourceId\":[\"e3dd3c5e53fa4350bb2d65e687708e7c\"],\"name\":\"Detail laporan\",\"chart\":\"table\",\"database_type\":\"postgresql\",\"dateMapping\":{\"timeZone\":\"Asia/Jakarta\",\"fields\":[\"comment_date\"]},\"filters\":[{\"table\":\"aduan_masyarakat_v3.\\\"prepetrator\\\"\",\"field\":\"id\",\"fieldType\":\"character varying\",\"field_type_origin\":\"character varying\",\"operatorField\":\"AND\",\"operator\":\"is\",\"value\":{\"gte\":0,\"is\":\"260608000047-00001\",\"isOneOf\":[],\"lte\":0}}],\"enableCache\":false,\"expiredTime\":0,\"exludeGrok\":false,\"metaData\":{\"widgetId\":\"36584f99010d42c82e9382364e9d32fe\",\"widgetName\":\"Detail laporan\",\"menuId\":\"ce64015a07578d9195a0e589de1108c8\",\"dashboardId\":\"1769155096865\",\"dashboardName\":\"Propam Aduan\"},\"globalVariable\":{}}"
          }
