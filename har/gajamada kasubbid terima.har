 semua field yang wajib diisi',\\n  },\\n\\n  {\\n    label: 'Verifikasi Unit Korbrimob',\\n    value: 'VERIFIKASI_UNIT_KORBRIMOB',\\n    compatiblePermission: ['KORBRIMOB'],\\n    compatibleStatus: ['Laporan Diterima'],\\n    compatibleSubStatus: [],\\n    customName: {\\n      Bagyanduan: '',\\n      Provos: '',\\n      Paminal: '',\\n      Wabprof: '',\\n    },\\n    actionNavigate: false,\\n    icon: 'ph ph-clipboard-text',\\n    description: 'Harap lengkapi semua field yang wajib diisi',\\n  },\\n\\n  {\\n    label: 'Kirim Hasil Gelar Lidik Korbrimob',\\n    value: 'KIRIM_HASIL_GELAR_LIDIK_KORBRIMOB',\\n    compatiblePermission: ['KORBRIMOB'],\\n    compatibleStatus: ['Lidik'],\\n    compatibleSubStatus: [],\\n    customName: {\\n      Bagyanduan: '',\\n      Provos: '',\\n      Paminal: '',\\n      Wabprof: '',\\n    },\\n    actionNavigate: false,\\n    icon: 'ph ph-clipboard-text',\\n    description: 'Harap lengkapi semua field yang wajib diisi',\\n  },\\n];\\nconst UNIT_OPTIONS_BY_GROUP = {\\n  Paminal: [\\n    { label: 'DEN A BIRO PAMINAL', value: 'DEN A BIRO PAMINAL' },\\n    { label: 'DEN B BIRO PAMINAL', value: 'DEN B BIRO PAMINAL' },\\n    { label: 'DEN C BIRO PAMINAL', value: 'DEN C BIRO PAMINAL' },\\n    { label: 'BAG BINPAM BIRO PAMINAL', value: 'BAG BINPAM BIRO PAMINAL' },\\n    { label: 'BAG PRODOK BIRO PAMINAL', value: 'BAG PRODOK BIRO PAMINAL' },\\n    { label: 'BAG LITPERS BIRO PAMINAL', value: 'BAG LITPERS BIRO PAMINAL' },\\n  ],\\n  Provos: [\\n    { label: 'UNIT RIKSA 1 BIRO PROVOS', value: 'UNIT RIKSA 1 BIRO PROVOS' },\\n    { label: 'UNIT RIKSA 2 BIRO PROVOS', value: 'UNIT RIKSA 2 BIRO PROVOS' },\\n    { label: 'UNIT RIKSA 3 BIRO PROVOS', value: 'UNIT RIKSA 3 BIRO PROVOS' },\\n    { label: 'UNIT RIKSA 4 BIRO PROVOS', value: 'UNIT RIKSA 4 BIRO PROVOS' },\\n    { label: 'UNIT RIKSA 5 BIRO PROVOS', value: 'UNIT RIKSA 5 BIRO PROVOS' },\\n    { label: 'UNIT RIKSA 6 BIRO PROVOS', value: 'UNIT RIKSA 6 BIRO PROVOS' },\\n    { label: 'SUBBAG RIKUM BIRO PROVOS', value: 'SUBBAG RIKUM BIRO PROVOS' },\\n    { label: 'SUBBAG RIKSUS BIRO PROVOS', value: 'SUBBAG RIKSUS BIRO PROVOS' },\\n  ],\\n  Wabprof: [\\n    { label: 'TIM A BIRO WABPROF', value: 'TIM A BIRO WABPROF' },\\n    { label: 'TIM B BIRO WABPROF', value: 'TIM B BIRO WABPROF' },\\n    { label: 'TIM C BIRO WABPROF', value: 'TIM C BIRO WABPROF' },\\n    { label: 'TIM D BIRO WABPROF', value: 'TIM D BIRO WABPROF' },\\n    { label: 'TIM E BIRO WABPROF', value: 'TIM E BIRO WABPROF' },\\n    { label: 'TIM F BIRO WABPROF', value: 'TIM F BIRO WABPROF' },\\n    { label: 'TIM G BIRO WABPROF', value: 'TIM G BIRO WABPROF' },\\n    { label: 'TIM H BIRO WABPROF', value: 'TIM H BIRO WABPROF' },\\n  ],\\n  Wassidik: [{ label: 'BIRO WASSIDIK', value: 'BIRO WASSIDIK' }],\\n  Itwasum: [{ label: 'BIRO ITWASUM', value: 'BIRO ITWASUM' }],\\n};\\n\\nconst UNIT_OPTIONS = [\\n  {\\n    label: 'UNIT 1 SUBBID PAMINAL',\\n    value: 'UNIT 1 SUBBID PAMINAL',\\n  },\\n  {\\n    label: 'UNIT 2 SUBBID PAMINAL',\\n    value: 'UNIT 2 SUBBID PAMINAL',\\n  },\\n  {\\n    label: 'UNIT 3 SUBBID PAMINAL',\\n    value: 'UNIT 3 SUBBID PAMINAL',\\n  },\\n  {\\n    label: 'UR BINPAM',\\n    value: 'UR BINPAM',\\n  },\\n  {\\n    label: 'UR PRODOK',\\n    value: 'UR PRODOK',\\n  },\\n  {\\n    label: 'UR LITPERS',\\n    value: 'UR LITPERS',\\n  },\\n  {\\n    label: 'UNIT 1 SUBBID PROVOS',\\n    value: 'UNIT 1 SUBBID PROVOS',\\n  },\\n  {\\n    label: 'UNIT 2 SUBBID PROVOS',\\n    value: 'UNIT 2 SUBBID PROVOS',\\n  },\\n  {\\n    label: 'UNIT 3 SUBBID PROVOS',\\n    value: 'UNIT 3 SUBBID PROVOS',\\n  },\\n  {\\n    label: 'UNIT 4 SUBBID PROVOS',\\n    value: 'UNIT 4 SUBBID PROVOS',\\n  },\\n];\\n\\nconst UNITOPTIONS = [\\n  {\\n    label: 'PAMINAL',\\n    value: 'paminal',\\n  },\\n  {\\n    label: 'PROVOS',\\n    value: 'provos',\\n  },\\n  {\\n    label: 'WABPROF',\\n    value: 'wabprof',\\n  },\\n  {\\n    label: 'WASIDIK',\\n    value: 'wasidik',\\n  },\\n  {\\n    label: 'ITWASUM',\\n    value: 'itwasum',\\n  },\\n  {\\n    label: 'UR BINPAM',\\n    value: 'UR BINPAM',\\n  },\\n  {\\n    label: 'UR PRODOK',\\n    value: 'UR PRODOK',\\n  },\\n  {\\n    label: 'UR LITPERS',\\n    value: 'UR LITPERS',\\n  },\\n  {\\n    label: 'UNIT 1',\\n    value: 'UNIT 1',\\n  },\\n  {\\n    label: 'UNIT 2',\\n    value: 'UNIT 2',\\n  },\\n  {\\n    label: 'UNIT 3',\\n    value: 'UNIT 3',\\n  },\\n];\\n\\nconst FormComponents: any = {\\n  TAMBAH_TERLAPOR: TambahLaporForm,\\n  LIMPAH_PERKARA: LimpahPerkara,\\n  TERIMA_LAPORAN: TerimaLaporan,\\n  TOLAK_LAPORAN: TolakLaporan,\\n  LIMPAH: Limpah,\\n  LIMPAH_KABID: LimpahKabid,\\n  LIMPAH_POLDA: LimpahPolda,\\n  LANJUTKAN_LAPORAN: LanjutkanLaporan,\\n  REVISI: Revisi,\\n  TOLAK: Tolak,\\n  VERIFIKASI_UNIT: VerifikasiUnit,\\n  VERIFIKASI_UNIT_POLDA: VerifikasiUnitPolda,\\n  VERIFIKASI_SUB_UNIT: VerifikasiSubUnit,\\n  EDIT_LAPORAN: ModalEditLaporan,\\n  KIRIM_SUBBID_PROVOS: KirimSubbidProvos,\\n  LIMPAH_BIRO: LimpahBiro,\\n  VERIFIKASI_SURAT: VerifikasiSurat,\\n  VERIFIKASI_UNIT_KORBRIMOB: VerifikasiUnitKorbri,\\n  KIRIM_HASIL_GELAR_LIDIK_KORBRIMOB: KirimHasilGelarKorbrimob,\\n  // LIDIK\\n  LIDIK: ModalLidik,\\n  LANJUT_LIDIK: ModalLanjutLidik,\\n  GELAR_LIDIK: ModalGelarLidik,\\n  GELAR_PERKARA: ModalGelarPerkara,\\n  GELAR_PERKARA_RJ: ModalGelarPerkaraRj,\\n  HASIL_GELAR_RJ: ModalHasilGelarRj,\\n\\n  // KIRIM HASIL\\n  KIRIM_HASIL_GELAR_LIDIK_POLDA: KirimHasilGelarPolda,\\n  KIRIM_HASIL_GELAR_LIDIK_MABES: KirimHasilGelarMabes,\\n  KIRIM_HASIL_GELAR_LIDIK_POLRES: KirimHasilGelarPolres,\\n\\n  // FORM PROSES\\n  RIKSA_CEPAT: RiksaCepat,\\n  PEMBERKASAN: PemberkasanForm,\\n  PROSES_SIDANG_DISIPLIN: ProsesSidangDisiplinForm,\\n  HASIL_SIDANG_DISIPLIN: HasilSidangDisiplinForm,\\n  PROSES_SIDANG_KKEP: ProsesSidangKKEPForm,\\n  HASIL_SIDANG_KKEP: HasilSidangKKEPForm,\\n\\n  // BANDING\\n  BANDING: BandingForm,\\n  TOLAK_BANDING: TolakBandingForm,\\n  KEBERATAN: KeberataForm,\\n  TIDAK_KEBERATAN: TidakKeberatanForm,\\n\\n  // LIMPAH\\n  LIMPAH_BAG_REHABPERS: LimpahBagRehabpersForm,\\n  LIMPAH_WASSIDIK: LimpahBiroWassidik,\\n  LIMPAH_BIRO_PROVOS: LimpahBiroProvos,\\n  LIMPAH_SUBBID_PROVOS: LimpahSubbidProvos,\\n  LIMPAH_YANDUAN: LimpahYanduan,\\n\\n  // PENCABUTAN\\n  PENCABUTAN: Pencabutan,\\n  PENCABUTAN_SEBELUM_SPRIN_LIDIK: PencabutanSebelumSprinLidik,\\n  PENCABUTAN_SETELAH_SPRIN_LIDIK: PencabutanSetelahSprinLidik,\\n  GELAR_PENCABUTAN: GelarPencabutan,\\n\\n  // RESTORATIVE\\n  RESTORATIVE_JUSTICE: RestorativeJustice,\\n  LIMPAH_POLRES: LimpahPolres,\\n  KEMBALI_KE_KABID: KembaliKabid,\\n\\n  // TAMBAHAN\\n  // TERIMA_DAN_TERUSKAN: TerimaDanTeruskan,\\n  // REVISI_LIMPAH: RevisiLimpah,\\n};\\n\\nconst DynamicForm = ({ type, ...props }: any) => {\\n  const Component = FormComponents[type];\\n  if (!Component) return <></>;\\n\\n  return <Component {...props} />;\\n};\\n\\nconst isUnitAlreadySelected = (casePosition) => {\\n  if (!casePosition || casePosition === '') return false;\\n\\n  const allUnitValues = Object.values(UNIT_OPTIONS_BY_GROUP).flatMap(\\n    (options) => options.map((opt) => opt.value),\\n  );\\n\\n  return allUnitValues.includes(casePosition);\\n};\\n\\nconst DEFAULT_UNIT_CONFIG = {\\n  type: 'single',\\n  unitOptions: UNIT_OPTIONS,\\n  unitLabel: 'Unit',\\n  required: true,\\n  getSubUnitOptions: () => [],\\n};\\nexport default function ActionAduanFeatures({\\n  widget,\\n  data,\\n  G,\\n  pageState,\\n  tabState,\\n  user,\\n  // loadingWidgetCalling,\\n}) {\\n  const { dispatchNotification } = useNotification();\\n  const { checkingPermissionAccess } = usePermission();\\n  // const [shouldHideActions, setShouldHideActions] = useState(false);\\n  const [modalAction, setModalAction] = useState({\\n    show: false,\\n    data: null,\\n  });\\n  const [tabData, setTabData] = useState('');\\n  const [loading, setLoading] = useState(false);\\n  const [unitOptions, setUnitOptions] = useState([]);\\n\\n  const tabSet = tabState?.features?.[0] || [];\\n\\n  const allTab = tabState?.features || [];\\n\\n  useEffect(() => {\\n    if (tabSet.length === 0) return;\\n\\n    setTabData(tabSet);\\n  }, [tabSet]);\\n\\n  // useEffect(() => {\\n  //   const urlParams = new URLSearchParams(window.location.search);\\n  //   const source = urlParams.get('source');\\n\\n  //   if (source === 'cari-laporan') {\\n  //     setShouldHideActions(true);\\n  //   }\\n  // }, []);\\n\\n  const shouldHideActions = (() => {\\n    const urlParams = new URLSearchParams(window.location.search);\\n    const source = urlParams.get('source');\\n    return source === 'cari-laporan';\\n  })();\\n\\n  const pages = {\\n    informasiDasar: pageState?.['dad5b834f5a7a46b8a119d6e54211dbd'],\\n    informasiPelapor: pageState?.['295a451dd09f9f90b84e651c4c65e98f'],\\n    informasiTerlapor: pageState?.['b7b630239fb7ad396f2a432f47e876b2'],\\n    // informasi detail untuk edit laporan\\n    informasiDetail: pageState?.['36584f99010d42c82e9382364e9d32fe'],\\n    // ini tabset data terlapor (harusnya ga kepake karna pake tabData)\\n    dataTerlapor: pageState?.['1b4585af9dd59ba73d7b220c4b1a0a5a'],\\n    dataTimeline: pageState?.['1d05ba6d572d5d65307ffd83ca1399d4'],\\n  };\\n\\n  // console.log(pages?.dataTimeline?.data?.[0], 'informasi dasar');\\n\\n  // const informasiDasar = pages?.informasiTerlapor?.data?.[0] || [];\\n  const informasiDasar = pages?.informasiDasar?.data?.[0] || [];\\n  const terlaporArray =\\n    pages?.informasiTerlapor?.data?.[0]?.prepetrator_data || [];\\n  const policeReport =\\n    pages?.informasiTerlapor?.data?.[0]?.police_reports || [];\\n  const documentReport =\\n    pages?.informasiTerlapor?.data?.[0]?.officer_details || [];\\n\\n  const timelineData = pages?.dataTimeline?.data?.[0] || [];\\n\\n  // console.log(timelineData, 'ini timeliine');\\n\\n  // console.log(documentReport, 'ini document');\\n\\n  const getCurrentReportData = () => {\\n    const dasarData = pages.informasiDasar?.data?.[0] || {};\\n    const pelaporData = pages.informasiPelapor?.data?.[0] || {};\\n\\n    const terlaporArray =\\n      pages.informasiTerlapor?.data?.[0]?.prepetrator_data || [];\\n    const terlaporPertama = terlaporArray[0] || {};\\n\\n    const detailData = pages.informasiDetail?.data?.[0] || {};\\n\\n    return {\\n      ...dasarData,\\n      ...pelaporData,\\n      ...detailData,\\n\\n      // Data terlapor - langsung pakai field dari API\\n      name: terlaporPertama.name,\\n      rank: terlaporPertama.rank,\\n      position: terlaporPertama.position,\\n      functional_assignment: terlaporPertama.functional_assignment,\\n      identity_number: terlaporPertama.identity_number,\\n\\n      prepetrator_id:\\n        dasarData.prepetrator_id || terlaporPertama.prepetrator_id,\\n      id: dasarData.id || dasarData.report_id,\\n    };\\n  };\\n\\n  const informasiDasarData = pages?.informasiDasar?.data?.[0];\\n  const forWujudData = pages?.informasiDasar?.data?.[0];\\n  const currentCasePosition = pages?.informasiDasar?.data?.[0]?.case_position;\\n  const STATUS = informasiDasarData?.status || 'Laporan Masuk';\\n  const SUB_STATUS = informasiDasarData?.sub_status || '';\\n\\n  const permissionParentName = user?.permissionDetail?.parentDetail?.name;\\n\\n  const groupName = user?.groupDetail?.parentDetail?.name;\\n\\n  const permissionMap = Object.fromEntries(\\n    (user?.permissionDetail?.privileges || []).flatMap((p: any) =>\\n      (p.privileges || []).map((x: any) => [x.value, p.id]),\\n    ),\\n  );\\n  // const permissionMap = Object.fromEntries(\\n  //   (user?.permissionDetail?.privileges || [])\\n  //     .filter((p: any) => p.id === user?.permissionDetail?.id)\\n  //     .flatMap((p: any) =>\\n  //       (p.privileges || []).map((x: any) => [x.value, p.id]),\\n  //     ),\\n  // );\\n\\n  const DROPDOWN_CONFIG = DROPDOWN_OPTIONS.filter((item: any) =>\\n    item.compatiblePermission.includes(permissionParentName),\\n  ).filter((item: any) => {\\n    const permissionId = permissionMap[item.value];\\n    if (!permissionId) return false;\\n\\n    const isAllowed = checkingPermissionAccess({\\n      id: permissionId,\\n      access: item.value,\\n      level: 'fusion-app',\\n    });\\n    if (!isAllowed) return false;\\n\\n    // console.log(`Permission ${item.value}:`, isAllowed);\\n\\n    let statusMatch;\\n    if (item.compatibleStatus.includes('all status')) {\\n      statusMatch = true; // Selalu true untuk all status\\n    } else {\\n      statusMatch = item.compatibleStatus.includes(STATUS);\\n    }\\n    if (!statusMatch) return false;\\n\\n    // === CHECK SUB STATUS ===\\n    let subMatch;\\n    if (item.compatibleSubStatus.length === 0) {\\n      subMatch = true;\\n    } else if (item.compatibleSubStatus.includes('all status')) {\\n      subMatch = true; // Selalu true untuk all status\\n    } else {\\n      subMatch = item.compatibleSubStatus.includes(SUB_STATUS);\\n    }\\n    if (!subMatch) return false;\\n    // == check posisi laporan ==\\n    const casePos = currentCasePosition?.toUpperCase() || '';\\n\\n    if (item.compatibleCasePosition && item.compatibleCasePosition.length > 0) {\\n      const positionMatch = item.compatibleCasePosition.includes(casePos);\\n      if (!positionMatch) return false;\\n    }\\n\\n    // === CHECK WUJUD PERBUATAN ===\\n    const wujudPerbuatan = forWujudData?.form_of_action?.toUpperCase() || '';\\n    if (\\n      item.compatibleWujudPerbuatan &&\\n      item.compatibleWujudPerbuatan.length > 0\\n    ) {\\n      const wujudMatch = item.compatibleWujudPerbuatan.includes(wujudPerbuatan);\\n      if (!wujudMatch) return false;\\n    }\\n\\n    // ========== KONDISI UNTUK VERIFIKASI_UNIT ==========\\n    if (item.value === 'VERIFIKASI_UNIT') {\\n      // Cek case_position apakah sudah termasuk dalam daftar unit options\\n      if (isUnitAlreadySelected(informasiDasarData?.case_position)) {\\n        return false;\\n      }\\n    }\\n\\n    // ========== KONDISI UNTUK VERIFIKASI_UNIT_POLDA ==========\\n    if (item.value === 'VERIFIKASI_UNIT_POLDA') {\\n      const selectedUnit = informasiDasarData?.unit_label;\\n\\n      const dynamicUnits = unitOptions.map((opt) => opt.value);\\n\\n      if (selectedUnit && dynamicUnits.includes(selectedUnit)) {\\n        return false;\\n      }\\n    }\\n\\n    // ========== KONDISI UNTUK VERIFIKASI_SUB_UNIT ==========\\n\\n    if (item.value === 'VERIFIKASI_SUB_UNIT') {\\n      // Jika sub_unit sudah ada, sembunyikan aksi\\n      if (informasiDasarData?.sub_unit) {\\n        return false;\\n      }\\n      // Jika case_position belum terisi dengan unit yang valid, sembunyikan aksi\\n      if (!isUnitAlreadySelected(informasiDasarData?.case_position)) {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'TERIMA_LAPORAN') {\\n      const casePosition = informasiDasarData?.case_position || '';\\n      const poldaDisposisi = informasiDasarData?.polda_disposisi || '';\\n      const userPermissionName = user?.permissionDetail?.name || '';\\n      const restrictedPositions = [\\n        'KABAG BAGYANDUAN',\\n        'KABAG BINPAM BIRO PAMINAL',\\n      ];\\n\\n      const allowedMapping = {\\n        'Kasubbag Yanduan Polda': `KASUBBAG YANDUAN ${poldaDisposisi}`,\\n        'Kabid Propam': `KABID PROPAM ${poldaDisposisi}`,\\n        'Kasubbid Paminal': `KASUBBID PAMINAL ${poldaDisposisi}`,\\n      };\\n\\n      if (allowedMapping[userPermissionName]) {\\n        const expectedCasePosition = allowedMapping[userPermissionName];\\n        if (casePosition !== expectedCasePosition) {\\n          return false;\\n        }\\n      }\\n      if (\\n        STATUS === 'Laporan Diterima' &&\\n        casePosition === 'KASUBBID PAMINAL KORBRIMOB POLRI'\\n      ) {\\n        return false;\\n      }\\n\\n      if (\\n        STATUS === 'Laporan Diterima' &&\\n        restrictedPositions.includes(casePosition)\\n      ) {\\n        return false;\\n      }\\n\\n      if (\\n        user?.permissionDetail?.name === 'Kabag Yanduan' &&\\n        STATUS === 'Laporan Dikirim ke Polda' &&\\n        casePosition === `OPERATOR YANDUAN ${poldaDisposisi}`\\n      ) {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'LIMPAH_POLRES') {\\n      const casePosition = informasiDasarData?.case_position || '';\\n      const poldaDisposisi = informasiDasarData?.polda_disposisi || '';\\n      const polresDisposisi = informasiDasarData?.polres || '';\\n\\n      const expectedCasePositions = [\\n        `KASIPROPAM ${polresDisposisi} ${poldaDisposisi}`,\\n        `KANIT PAMINAL ${polresDisposisi} ${poldaDisposisi}`,\\n      ];\\n\\n      if (\\n        STATUS === 'Laporan Diterima' &&\\n        expectedCasePositions.includes(casePosition)\\n      ) {\\n        return true;\\n      }\\n      return false;\\n    }\\n\\n    if (item.value === 'KEMBALI_KE_KABID') {\\n      const casePosition = informasiDasarData?.case_position || '';\\n      const poldaDisposisi = informasiDasarData?.polda_disposisi || '';\\n      const polresDisposisi = informasiDasarData?.polres || '';\\n      const expectedCasePositions = [\\n        `KASIPROPAM ${polresDisposisi} ${poldaDisposisi}`,\\n        `KANIT PAMINAL ${polresDisposisi} ${poldaDisposisi}`,\\n      ];\\n\\n      if (\\n        STATUS === 'Laporan Diterima' &&\\n        expectedCasePositions.includes(casePosition)\\n      ) {\\n        return true;\\n      }\\n      return false;\\n    }\\n\\n    if (item.value === 'LIMPAH_KABID') {\\n      const casePosition = informasiDasarData?.case_position || '';\\n      const poldaDisposisi = informasiDasarData?.polda_disposisi || '';\\n      const userPermissionName = user?.permissionDetail?.name || '';\\n\\n      const allowedMapping = {\\n        'Kabid Propam': `KABID PROPAM ${poldaDisposisi}`,\\n      };\\n\\n      if (allowedMapping[userPermissionName]) {\\n        const expectedCasePosition = allowedMapping[userPermissionName];\\n\\n        if (casePosition !== expectedCasePosition) {\\n          return false;\\n        }\\n      } else {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'LIMPAH_BIRO') {\\n      const casePosition = informasiDasarData?.case_position || '';\\n      const status = informasiDasarData?.status || '';\\n\\n      const expectedCasePositions = [\\n        'KAUR BINPAM KORBRIMOB POLRI',\\n        'KASUBBID PAMINAL KORBRIMOB POLRI',\\n      ];\\n\\n      const expectedStatuses = [\\n        'Laporan Diterima',\\n        'Laporan Diterima Kasubbid Paminal',\\n      ];\\n\\n      if (\\n        expectedStatuses.includes(status) &&\\n        expectedCasePositions.includes(casePosition)\\n      ) {\\n        return true;\\n      }\\n\\n      if (status === 'Verifikasi Laporan') {\\n        return true;\\n      }\\n\\n      return false;\\n    }\\n\\n    if (\\n      item.value === 'LIMPAH' &&\\n      user?.permissionDetail?.name === 'Operator Trimlap' &&\\n      STATUS === 'Laporan diterima Bagyanduan & Di Review Kasubag Trimlap'\\n    ) {\\n      return false;\\n    }\\n\\n    if (item.value === 'TAMBAH_TERLAPOR') {\\n      const informasiTerlaporData = pages?.informasiTerlapor?.data?.[0];\\n      const policeReports = informasiTerlaporData?.police_reports || [];\\n\\n      const hasNullReportNumber = policeReports.some(\\n        (report: any) =>\\n          !report?.report_number ||\\n          report?.report_number === null ||\\n          report?.report_number === '',\\n      );\\n\\n      if (hasNullReportNumber) {\\n        return true;\\n      }\\n\\n      return false;\\n    }\\n\\n    if (item.value === 'LIMPAH_PERKARA') {\\n      const informasiTerlaporData = pages?.informasiTerlapor?.data?.[0];\\n      const policeReports = informasiTerlaporData?.police_reports || [];\\n\\n      const hasNullReportNumber = policeReports.some(\\n        (report: any) =>\\n          !report?.report_number ||\\n          report?.report_number === null ||\\n          report?.report_number === '',\\n      );\\n\\n      if (hasNullReportNumber) {\\n        return true;\\n      }\\n\\n      return false;\\n    }\\n\\n    if (item.value === 'PENCABUTAN_SETELAH_SPRIN_LIDIK') {\\n      const casePosition = informasiDasarData?.case_position;\\n\\n      if (casePosition === 'KABAG GAKKUM BIRO PROVOS') {\\n        return false;\\n      }\\n      if (casePosition === 'KABAG GAKETIKA BIRO WABPROF') {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'LIMPAH_BAG_REHABPERS') {\\n      const isStatusRestorativeJustice = STATUS === 'Restorative Justice';\\n      const isSubStatusDenganGelar = SUB_STATUS === 'Dengan Gelar';\\n\\n      if (isStatusRestorativeJustice && isSubStatusDenganGelar) {\\n        return false;\\n      }\\n      if (STATUS === 'Verifikasi Ankum') {\\n        return true;\\n      }\\n      if (STATUS === 'Gelar Perkara RJ' && SUB_STATUS === 'Tidak Terbukti') {\\n        return true;\\n      }\\n    }\\n\\n    if (item.value === 'LIDIK') {\\n      const casePosition = informasiDasarData?.case_position;\\n\\n      if (casePosition === 'KABAG GAKKUM BIRO PROVOS') {\\n        return false;\\n      }\\n      if (casePosition === 'KABAG GAKETIKA BIRO WABPROF') {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'LIMPAH_WASSIDIK') {\\n      const casePosition = informasiDasarData?.case_position;\\n\\n      if (casePosition === 'BIRO WASSIDIK') {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'KIRIM_SUBBID_PROVOS') {\\n      const reportNumber = policeReport?.report_number;\\n\\n      return !reportNumber;\\n    }\\n\\n    if (item.value === 'LIMPAH_SUBBID_PROVOS') {\\n      const isMatch =\\n        casePos.includes('KAUR BINPAM') && casePos.includes('SUBBID PAMINAL');\\n      if (!isMatch) return false;\\n    }\\n\\n    if (item.value === 'PENCABUTAN_SEBELUM_SPRIN_LIDIK') {\\n      if (isUnitAlreadySelected(informasiDasarData?.case_position)) {\\n        return false;\\n      }\\n    }\\n\\n    if (item.value === 'VERIFIKASI_UNIT_KORBRIMOB') {\\n      const casePos = currentCasePosition?.toUpperCase() || '';\\n\\n      const statusMatch = STATUS === 'Laporan Diterima';\\n\\n      const allowedPositions = [\\n        'KAUR BINPAM KORBRIMOB POLRI',\\n        'KAUR GAKKUM KORBRIMOB POLRI',\\n        'KAURGAK ETIKA WABPROF KORBRIMOB POLRI',\\n      ];\\n\\n      const positionMatch = allowedPositions.includes(casePos);\\n\\n      return statusMatch && positionMatch;\\n    }\\n\\n    // if (item.value === 'LIMPAH_YANDUAN') {\\n    //   const casePos = currentCasePosition?.toUpperCase() || '';\\n    //   const statusMatch = STATUS === 'Laporan Diterima';\\n    //   const positionMatch = casePos === 'KABID PROPAM KORBRIMOB POLRI';\\n    //   return statusMatch && positionMatch;\\n    // }\\n\\n    if (item.value === 'LIMPAH_BIRO') {\\n      const casePosition = informasiDasarData?.case_position || '';\\n      const status = informasiDasarData?.status || '';\\n\\n      const expectedCasePositions = [\\n        'KAUR BINPAM KORBRIMOB POLRI',\\n        'KASUBBID PAMINAL KORBRIMOB POLRI',\\n      ];\\n\\n      if (expectedCasePositions.includes(casePosition)) {\\n        return true;\\n      }\\n\\n      // Untuk verifikasi laporan\\n      if (status === '' || status === 'Verifikasi Laporan') {\\n        return true;\\n      }\\n\\n      return false;\\n    }\\n\\n    if (item.value === 'VERIFIKASI_SURAT') {\\n      const casePos = currentCasePosition?.toUpperCase() || '';\\n      return casePos === 'KADIV PROPAM MABES POLRI';\\n    }\\n    return true;\\n  });\\n\\n  // const DROPDOWN_CONFIG = DROPDOWN_OPTIONS.filter((item: any) =>\\n  //   item.compatiblePermission.includes(permissionParentName),\\n  // ).filter((item: any) => {\\n  //   // ========== CEK EXPLICIT PERMISSION DI USER ==========\\n  //   const hasExplicitPermission = user?.permissionDetail?.privileges?.some(\\n  //     (p: any) => p.privileges?.some((priv: any) => priv.value === item.value),\\n  //   );\\n\\n  //   if (!hasExplicitPermission) {\\n  //     return false;\\n  //   }\\n\\n  //   // ========== AMBIL PERMISSION ID ==========\\n  //   const permissionId = permissionMap[item.value];\\n  //   if (!permissionId) {\\n  //     console.log(`❌ ${item.value}: Permission ID tidak ditemukan`);\\n  //     return false;\\n  //   }\\n\\n  //   // ========== CEK DENGAN checkingPermissionAccess ==========\\n  //   const isAllowed = checkingPermissionAccess({\\n  //     id: permissionId,\\n  //     access: item.value,\\n  //     level: 'fusion-app',\\n  //   });\\n\\n  //   // JIKA TIDAK DIALLOW, RETURN FALSE\\n  //   if (!isAllowed) {\\n  //     console.log(\\n  //       `❌ ${item.value}: Tidak diizinkan oleh checkingPermissionAccess`,\\n  //     );\\n  //     return false;\\n  //   }\\n\\n  //   // console.log(`Permission ${item.value}:`, isAllowed);\\n\\n  //   let statusMatch;\\n  //   if (item.compatibleStatus.includes('all status')) {\\n  //     statusMatch = true; // Selalu true untuk all status\\n  //   } else {\\n  //     statusMatch = item.compatibleStatus.includes(STATUS);\\n  //   }\\n  //   if (!statusMatch) return false;\\n\\n  //   // === CHECK SUB STATUS ===\\n  //   let subMatch;\\n  //   if (item.compatibleSubStatus.length === 0) {\\n  //     subMatch = true;\\n  //   } else if (item.compatibleSubStatus.includes('all status')) {\\n  //     subMatch = true; // Selalu true untuk all status\\n  //   } else {\\n  //     subMatch = item.compatibleSubStatus.includes(SUB_STATUS);\\n  //   }\\n  //   if (!subMatch) return false;\\n  //   // == check posisi laporan ==\\n  //   const casePos = currentCasePosition?.toUpperCase() || '';\\n\\n  //   if (item.compatibleCasePosition && item.compatibleCasePosition.length > 0) {\\n  //     const positionMatch = item.compatibleCasePosition.includes(casePos);\\n  //     if (!positionMatch) return false;\\n  //   }\\n\\n  //   // === CHECK WUJUD PERBUATAN ===\\n  //   const wujudPerbuatan = forWujudData?.form_of_action?.toUpperCase() || '';\\n  //   if (\\n  //     item.compatibleWujudPerbuatan &&\\n  //     item.compatibleWujudPerbuatan.length > 0\\n  //   ) {\\n  //     const wujudMatch = item.compatibleWujudPerbuatan.includes(wujudPerbuatan);\\n  //     if (!wujudMatch) return false;\\n  //   }\\n\\n  //   // ========== KONDISI UNTUK VERIFIKASI_UNIT ==========\\n  //   if (item.value === 'VERIFIKASI_UNIT') {\\n  //     // Cek case_position apakah sudah termasuk dalam daftar unit options\\n  //     if (isUnitAlreadySelected(informasiDasarData?.case_position)) {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   // ========== KONDISI UNTUK VERIFIKASI_UNIT_POLDA ==========\\n  //   if (item.value === 'VERIFIKASI_UNIT_POLDA') {\\n  //     const selectedUnit = informasiDasarData?.unit_label;\\n\\n  //     const dynamicUnits = unitOptions.map((opt) => opt.value);\\n\\n  //     if (selectedUnit && dynamicUnits.includes(selectedUnit)) {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   // ========== KONDISI UNTUK VERIFIKASI_SUB_UNIT ==========\\n\\n  //   if (item.value === 'VERIFIKASI_SUB_UNIT') {\\n  //     // Jika sub_unit sudah ada, sembunyikan aksi\\n  //     if (informasiDasarData?.sub_unit) {\\n  //       return false;\\n  //     }\\n  //     // Jika case_position belum terisi dengan unit yang valid, sembunyikan aksi\\n  //     if (!isUnitAlreadySelected(informasiDasarData?.case_position)) {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'TERIMA_LAPORAN') {\\n  //     const casePosition = informasiDasarData?.case_position || '';\\n  //     const poldaDisposisi = informasiDasarData?.polda_disposisi || '';\\n  //     const userPermissionName = user?.permissionDetail?.name || '';\\n  //     const restrictedPositions = [\\n  //       'KABAG BAGYANDUAN',\\n  //       'KABAG BINPAM BIRO PAMINAL',\\n  //     ];\\n\\n  //     const allowedMapping = {\\n  //       'Kasubbag Yanduan Polda': `KASUBBAG YANDUAN ${poldaDisposisi}`,\\n  //       'Kabid Propam': `KABID PROPAM ${poldaDisposisi}`,\\n  //       'Kasubbid Paminal': `KASUBBID PAMINAL ${poldaDisposisi}`,\\n  //     };\\n\\n  //     if (allowedMapping[userPermissionName]) {\\n  //       const expectedCasePosition = allowedMapping[userPermissionName];\\n  //       if (casePosition !== expectedCasePosition) {\\n  //         return false;\\n  //       }\\n  //     }\\n  //     // if (\\n  //     //   STATUS === 'Laporan Diterima' &&\\n  //     //   casePosition === 'KABAG BAGYANDUAN' || casePosition === 'KABAG BINPAM BIRO PAMINAL'\\n  //     // ) {\\n  //     //   return false;\\n  //     // }\\n\\n  //     if (\\n  //       STATUS === 'Laporan Diterima' &&\\n  //       restrictedPositions.includes(casePosition)\\n  //     ) {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'LIMPAH_KABID') {\\n  //     const casePosition = informasiDasarData?.case_position || '';\\n  //     const poldaDisposisi = informasiDasarData?.polda_disposisi || '';\\n  //     const userPermissionName = user?.permissionDetail?.name || '';\\n\\n  //     const allowedMapping = {\\n  //       'Kabid Propam': `KABID PROPAM ${poldaDisposisi}`,\\n  //     };\\n\\n  //     if (allowedMapping[userPermissionName]) {\\n  //       const expectedCasePosition = allowedMapping[userPermissionName];\\n\\n  //       if (casePosition !== expectedCasePosition) {\\n  //         return false;\\n  //       }\\n  //     } else {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'TAMBAH_TERLAPOR') {\\n  //     const informasiTerlaporData = pages?.informasiTerlapor?.data?.[0];\\n  //     const policeReports = informasiTerlaporData?.police_reports || [];\\n\\n  //     const hasNullReportNumber = policeReports.some(\\n  //       (report: any) =>\\n  //         !report?.report_number ||\\n  //         report?.report_number === null ||\\n  //         report?.report_number === '',\\n  //     );\\n\\n  //     if (hasNullReportNumber) {\\n  //       return true;\\n  //     }\\n\\n  //     return false;\\n  //   }\\n\\n  //   if (item.value === 'LIMPAH_PERKARA') {\\n  //     const informasiTerlaporData = pages?.informasiTerlapor?.data?.[0];\\n  //     const policeReports = informasiTerlaporData?.police_reports || [];\\n\\n  //     const hasNullReportNumber = policeReports.some(\\n  //       (report: any) =>\\n  //         !report?.report_number ||\\n  //         report?.report_number === null ||\\n  //         report?.report_number === '',\\n  //     );\\n\\n  //     if (hasNullReportNumber) {\\n  //       return true;\\n  //     }\\n\\n  //     return false;\\n  //   }\\n\\n  //   if (item.value === 'PENCABUTAN_SETELAH_SPRIN_LIDIK') {\\n  //     const casePosition = informasiDasarData?.case_position;\\n\\n  //     if (casePosition === 'KABAG GAKKUM BIRO PROVOS') {\\n  //       return false;\\n  //     }\\n  //     if (casePosition === 'KABAG GAKETIKA BIRO WABPROF') {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'LIMPAH_BAG_REHABPERS') {\\n  //     const isStatusRestorativeJustice = STATUS === 'Restorative Justice';\\n  //     const isSubStatusDenganGelar = SUB_STATUS === 'Dengan Gelar';\\n\\n  //     if (isStatusRestorativeJustice && isSubStatusDenganGelar) {\\n  //       return false;\\n  //     }\\n  //     if (STATUS === 'Diterima Ankum' && currentCasePosition === 'Ankum') {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'LIDIK') {\\n  //     const casePosition = informasiDasarData?.case_position;\\n\\n  //     if (casePosition === 'KABAG GAKKUM BIRO PROVOS') {\\n  //       return false;\\n  //     }\\n  //     if (casePosition === 'KABAG GAKETIKA BIRO WABPROF') {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'LIMPAH_WASSIDIK') {\\n  //     const casePosition = informasiDasarData?.case_position;\\n\\n  //     if (casePosition === 'BIRO WASSIDIK') {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'KIRIM_SUBBID_PROVOS') {\\n  //     const reportNumber = policeReport?.report_number;\\n\\n  //     return !reportNumber;\\n  //   }\\n\\n  //   if (item.value === 'LIMPAH_SUBBID_PROVOS') {\\n  //     const isMatch =\\n  //       casePos.includes('KAUR BINPAM') && casePos.includes('SUBBID PAMINAL');\\n  //     if (!isMatch) return false;\\n  //   }\\n\\n  //   if (item.value === 'PENCABUTAN_SEBELUM_SPRIN_LIDIK') {\\n  //     if (isUnitAlreadySelected(informasiDasarData?.case_position)) {\\n  //       return false;\\n  //     }\\n  //   }\\n\\n  //   if (item.value === 'VERIFIKASI_SURAT') {\\n  //     const casePos = currentCasePosition?.toUpperCase() || '';\\n  //     return casePos === 'KADIV PROPAM MABES POLRI';\\n  //   }\\n  //   return true;\\n  // });\\n  const isInformasiDasarReady =\\n    !!informasiDasarData && Object.keys(informasiDasarData).length > 0;\\n  const isPermissionReady =\\n    !!user?.permissionDetail && Object.keys(permissionMap || {}).length > 0;\\n  const isDataReady = isInformasiDasarReady && isPermissionReady;\\n\\n  // const shouldHideDueToNoActions = isDataReady && DROPDOWN_CONFIG.length === 0;\\n\\n  // const shouldRenderActionButton =\\n  //   !shouldHideActions && !shouldHideDueToNoActions;\\n\\n  const isNoActionsAvailable = isDataReady && DROPDOWN_CONFIG.length === 0;\\n\\n  const shouldRenderActionButton = !shouldHideActions;\\n\\n  const handleClose = () => {\\n    setModalAction((prev) => ({\\n      ...prev,\\n      show: false,\\n      data: undefined,\\n    }));\\n  };\\n\\n  const handleClick = (item: any) => {\\n    setModalAction((prev) => ({\\n      ...prev,\\n      show: true,\\n      data: item,\\n    }));\\n  };\\n\\n  console.log('DROPDOWN', DROPDOWN_CONFIG);\\n\\n  return (\\n    <>\\n      {shouldRenderActionButton && (\\n        <div className=\\\"flex justify-end py-4\\\">\\n          <Dropdown as={ButtonGroup}>\\n            {/* ini konsep klo ada loading  */}\\n            {/* <Dropdown.Toggle\\n                disabled={loadingWidgetCalling}\\n                className=\\\"flex items-center gap-2\\\"\\n                style={{\\n                  backgroundColor: 'var(--primary-400)',\\n                  border: 'none',\\n                }}\\n              >\\n                {loadingWidgetCalling ? (\\n                  <span\\n                    className=\\\"spinner-border spinner-border-sm\\\"\\n                    role=\\\"status\\\"\\n                    aria-hidden=\\\"true\\\"\\n                    style={{ color: 'var(--white)' }}\\n                  ></span>\\n                ) : (\\n                  <i\\n                    className=\\\"fs-20 ph ph-dots-three-vertical\\\"\\n                    style={{ color: 'var(--white)' }}\\n                  ></i>\\n                )}\\n                Aksi\\n              </Dropdown.Toggle> */}\\n            {/* <StyledDropdownMenu>\\n                {DATA_ACTIONS?.map((item, i) => (\\n                  <Dropdown.Item key={i} onClick={() => handleClick(item)}>\\n                    {item.label}\\n                  </Dropdown.Item>\\n                ))}\\n              </StyledDropdownMenu> */}\\n\\n            <Dropdown.Toggle\\n              className=\\\"flex items-center gap-2\\\"\\n              style={{\\n                backgroundColor: 'var(--primary-400)',\\n                border: 'none',\\n              }}\\n            >\\n              <i\\n                className=\\\"fs-20 ph ph-dots-three-vertical\\\"\\n                style={{ color: 'var(--white)' }}\\n              ></i>\\n              Aksi\\n            </Dropdown.Toggle>\\n            {/* <StyledDropdownMenu>\\n                {DATA_ACTIONS?.map((item, i) => (\\n                  <Dropdown.Item key={i} onClick={() => handleClick(item)}>\\n                    {item.label}\\n                  </Dropdown.Item>\\n                ))}\\n              </StyledDropdownMenu> */}\\n            <StyledDropdownMenu>\\n              {DROPDOWN_CONFIG.length === 0 ? (\\n                <Dropdown.Item disabled className=\\\"text-muted\\\">\\n                  Tidak ada aksi\\n                </Dropdown.Item>\\n              ) : (\\n                DROPDOWN_CONFIG.map((item, i) => {\\n                  const itemLabel = item?.customName?.[groupName] || item.label;\\n                  const isEditLaporan = item.value === 'EDIT_LAPORAN';\\n                  const isTambahTerlapor = item.value === 'TAMBAH_TERLAPOR';\\n                  const prevItem = i > 0 ? DROPDOWN_CONFIG[i - 1] : null;\\n\\n                  return (\\n                    <React.Fragment key={i}>\\n                      {isEditLaporan &&\\n                        (!prevItem || prevItem.value !== 'EDIT_LAPORAN') && (\\n                          <div className=\\\"dropdown-divider\\\" />\\n                        )}\\n\\n                      <Dropdown.Item\\n                        onClick={() => handleClick(item, item?.actionNavigate)}\\n                      >\\n                        {itemLabel}\\n                      </Dropdown.Item>\\n                    </React.Fragment>\\n                  );\\n                })\\n              )}\\n            </StyledDropdownMenu>\\n          </Dropdown>\\n\\n          <StyledModal\\n            show={modalAction?.show}\\n            onHide={handleClose}\\n            centered\\n            dialogClassName={`\\n      ${!modalAction?.show ? 'animate__animated animate__zoomOut animate__faster' : 'animate__animated animate__zoomIn animate__faster'}`}\\n          >\\n            <Modal.Header closeButton className=\\\"border-bottom\\\">\\n              <div className=\\\"d-flex align-items-center gap-3\\\">\\n                <WrappIcon>\\n                  <i className={modalAction?.data?.icon} />\\n                </WrappIcon>\\n                <div className=\\\"d-flex flex-column gap-2\\\">\\n                  <Title>{modalAction?.data?.label}</Title>\\n                  <Description>{modalAction?.data?.description}</Description>\\n                </div>\\n              </div>\\n            </Modal.Header>\\n            <Modal.Body>\\n              <DynamicForm\\n                type={modalAction?.data?.value}\\n                pages={pages}\\n                getCurrentReportData={getCurrentReportData()}\\n                terlaporArray={terlaporArray}\\n                policeReport={policeReport}\\n                documentReport={documentReport}\\n                informasiDasar={informasiDasar}\\n                timelineData={timelineData}\\n                tabData={tabData}\\n                allTabData={allTab}\\n                onClose={handleClose}\\n                user={user}\\n                loading={loading}\\n                setLoading={setLoading}\\n                dispatchNotification={dispatchNotification}\\n              />\\n            </Modal.Body>\\n          </StyledModal>\\n        </div>\\n      )}\\n    </>\\n  );\\n}\\n\\nexport const Title = styled.p`\\n    font-size: 1.14286rem;\\n    font-style: normal;\\n    font-weight: 600;\\n    /* width: 90%; */\\n    margin-bottom: 0px;\\n  `;\\nconst StyledModal = styled(Modal)`\\n    .modal-dialog {\\n      max-width: 700px !important;\\n      width: 100%;\\n    }\\n    .modal-body{\\n    max-height:50rem;\\n    \\n    overflow-y:auto;\\n    }\\n   \\n    // .modal-content {\\n    //   overflow: visible;\\n    // }\\n    \\n    // .modal-body {\\n    //   overflow-y: visible;\\n    // }\\n  \\n  \\n    // .modal-body form {\\n    //   overflow: visible;\\n    // }\\n  \\n  \\n    // .react-select__menu-portal {\\n    //   z-index: 9999 !important;\\n    // }\\n    \\n    // .react-select__menu {\\n    //   z-index: 9999 !important;\\n    // }\\n  \\n  \\n    `;\\n\\nexport const Description = styled.p`\\n    font-size: 0.9rem;\\n    font-style: normal;\\n    font-weight: 400;\\n    margin-bottom: 0px;\\n    color: var(--black-350);\\n  `;\\n\\nconst WrappIcon = styled.div`\\n    display: flex;\\n    padding: 0.53333rem;\\n    justify-content: center;\\n    align-items: center;\\n    gap: 0.66667rem;\\n    border-radius: 0.53333rem;\\n    border: 1px solid var(--black-100);\\n    i {\\n      font-size: 1.6rem;\\n      color: var(--primary)\\n    }\\n  `;\\n\\nconst StyledDropdownMenu = styled(Dropdown.Menu)`\\n    border-radius: 0.5rem;\\n    border: 1px solid #e1e2e5;\\n    box-shadow: 0px 4px 12px rgba(0,0,0,0.15);\\n    padding: 0.5rem 0;\\n  \\n    .dropdown-item {\\n      padding: 0.5rem 1rem;\\n      font-size: 0.875rem;\\n      color: var(--black);\\n  \\n      &:hover {\\n        background-color: var(--black-50);\\n      }\\n      \\n      &.with-border-top {\\n        border-top: 1px solid #e1e2e5 !important;\\n        padding-top: 0.75rem !important;\\n        margin-top: 0.25rem !important;\\n      }\\n    }\\n  \\n    .dropdown-divider {\\n      margin: 0.25rem 0;\\n      border-top: 1px solid #e1e2e5;\\n      opacity: 1;\\n    }\\n  `;\\n\",\"html\":\"\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"145241a806c51ae5fe1f2283e06105aa\":false},\"limitData\":0,\"axis\":{\"radius\":\"\",\"center\":[]},\"series\":{\"opacity\":0},\"xAxis\":{\"interval\":0},\"yAxis\":{\"interval\":0}},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":true,\"actionCopy\":false,\"hiddenWidget\":false,\"pageState\":false,\"customLimit\":{\"status\":false},\"orderColumn\":false,\"shareAPI\":\"\",\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":false,\"dateFields\":\"\"},\"x\":11,\"y\":0},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-03-30 17:22:26.981000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":48,