ek\",\"alias\":\"polsek\",\"name\":\"polsek\",\"type\":\"string\"},{\"field\":\"status\",\"alias\":\"status\",\"name\":\"status\",\"type\":\"string\"},{\"field\":\"urgency_score_category\",\"alias\":\"urgency_score_category\",\"name\":\"urgency_score_category\",\"type\":\"string\"},{\"field\":\"sub_status\",\"alias\":\"sub_status\",\"name\":\"sub_status\",\"type\":\"string\"},{\"field\":\"case_position\",\"alias\":\"case_position\",\"name\":\"case_position\",\"type\":\"string\"},{\"field\":\"satker\",\"alias\":\"satker\",\"name\":\"satker\",\"type\":\"string\"},{\"field\":\"attachments\",\"alias\":\"attachments\",\"name\":\"attachments\",\"type\":\"string\"},{\"field\":\"prepetrator_name\",\"alias\":\"prepetrator_name\",\"name\":\"prepetrator_name\",\"type\":\"string\"},{\"field\":\"rank\",\"alias\":\"rank\",\"name\":\"rank\",\"type\":\"string\"},{\"field\":\"position\",\"alias\":\"position\",\"name\":\"position\",\"type\":\"string\"},{\"field\":\"birth_place\",\"alias\":\"birth_place\",\"name\":\"birth_place\",\"type\":\"string\"},{\"field\":\"birth_date\",\"alias\":\"birth_date\",\"name\":\"birth_date\",\"type\":\"string\"},{\"field\":\"prepetrator_phone\",\"alias\":\"prepetrator_phone\",\"name\":\"prepetrator_phone\",\"type\":\"string\"},{\"field\":\"gender\",\"alias\":\"gender\",\"name\":\"gender\",\"type\":\"string\"},{\"field\":\"identity_number\",\"alias\":\"identity_number\",\"name\":\"identity_number\",\"type\":\"string\"},{\"field\":\"professional_education\",\"alias\":\"professional_education\",\"name\":\"professional_education\",\"type\":\"string\"},{\"field\":\"graduation_year\",\"alias\":\"graduation_year\",\"name\":\"graduation_year\",\"type\":\"string\"},{\"field\":\"functional_assignment\",\"alias\":\"functional_assignment\",\"name\":\"functional_assignment\",\"type\":\"string\"},{\"field\":\"description\",\"alias\":\"description\",\"name\":\"description\",\"type\":\"string\"},{\"field\":\"type\",\"alias\":\"type\",\"name\":\"type\",\"type\":\"string\"},{\"field\":\"latest_updated_at\",\"alias\":\"latest_updated_at\",\"name\":\"latest_updated_at\",\"type\":\"date\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false}},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"id\",\"prepetrator_id\",\"sender_name\",\"sender_address\",\"phone_no\",\"type\",\"report_type\",\"report_number\",\"type_of_violation\",\"datetime\",\"short_description\",\"name\",\"birth_date\",\"birth_place\",\"rank\",\"identity_number\",\"division\",\"phone_number\",\"professional_education\",\"graduation_year\",\"gender\",\"functional_assignment\",\"position\",\"summary\",\"category\",\"sub_category\",\"form_of_action\",\"application_of_article\",\"report_updated_at\",\"articles\",\"articles_juncto\",\"persons_responsible\",\"witness\",\"evidence\",\"police_report_json\",\"attachments\"],[\"2026051200006\",\"2026051200006-00001\",\"Anonim\",\"Aceh\",\"433634434343\",\"Anggota Polri\",\"Wabprof\",\"LP-A /2026051200006/IV/2026/Rowabprof\",null,1777809600000,null,\"Ipda K. Barus\",988736400000,\"PATI\",\"ABRIP\",\"43115768\",\"BIDPROPAM POLDA BALI\",\"82376326263278\",\"AKPOL\",2030,\"laki-laki\",\"RESNARKOBA\",\"Provos\",\"Pelapor mengadu bahwa anggota Polri terlibat intimidasi selama penanganan perkara penganiayaan. Anggota tersebut menghubungi pelapor secara pribadi, menekan agar laporan dihapus, mengancam proses hukum akan memakan waktu lama dan menyulitkan pelapor jika tidak mengikuti arahan. Selain itu, ada dugaan anggota menerima uang dari pelapor untuk memperlambat pemeriksaan saksi dan penjadwalan perkara, berdasarkan bukti transfer rekening dan saksi internal. Perilaku tidak profesional ini membuat pelapor menilai penanganan perkara tidak sesuai kode etik.\",\"PELAGGARAN ETIKA PUBLIK & RUANG DIGITAL\",\"PENYALAHGUNAAN IDENTITAS POLRI DI RUANG DIGITAL\",\"MENGGUNAKAN IDENTITAS POLRI UNTUK MENGINTIMIDASI DI MEDIA SOSIAL (NON- PIDANA)\",\"kode-etik\",1779407902682,[{\"article_id\":\"8d6b001bd2a484b467541bea9dd81a88\",\"type\":\"PERPOL NOMOR 7 TH 2022\",\"kode_pasal\":\"10(1)A1\",\"description\":\"Melakukan perbuatan yang tidak sesuai dengan ketentuan peraturan perundang-undangan, dan/atau standar operasional prosedur dalam penegakan hukum.\"},{\"article_id\":\"8d6b001bd2a484b467541bea9dd81a88\",\"type\":\"PERPOL NOMOR 7 TH 2022\",\"kode_pasal\":\"10(1)A1\",\"description\":\"Melakukan perbuatan yang tidak sesuai dengan ketentuan peraturan perundang-undangan, dan/atau standar operasional prosedur dalam penegakan hukum.\"}],[{\"article_id\":\"e4366e65e410056fd5ae48c05e07feac\",\"type\":\"PERPOL NOMOR 7 TH 2022\",\"kode_pasal\":\"4B\",\"description\":\"Tidak menjaga keamanan dalam negeri yang meliputi terpeliharanya keamanan dan ketertiban masyarakat, tertib dan tegaknya hukum, terselenggaranya perlindungan, pengayoman, dan pelayanan masyarakat serta terbinanya ketentraman masyarakat dengan menjunjung tinggi hak asasi manusia.\"},{\"article_id\":\"c01fad1ea8604755e7bc72785dd35b6e\",\"type\":\"PERPOL NOMOR 7 TH 2022\",\"kode_pasal\":\"4A\",\"description\":\"Tidak setia kepada Negara Kesatuan Republik Indonesia yang berdasarkan Pancasila dan Undang-Undang Dasar Negara Republik Indonesia Tahun 1945.\"}],[{\"name\":\"Muniryanto\",\"type\":\"acknowledged_by\",\"nrp\":\"34216343\",\"rank\":\"KOMPOL\",\"unit\":\"BIDPROPAM POLDA DIY\",\"position\":null},{\"name\":\"Yantono\",\"type\":\"created_by\",\"nrp\":\"34512356\",\"rank\":\"KOMJEN POL\",\"unit\":\"BIDPROPAM POLDA BALI\",\"position\":\"Kabid Provos\"}],[\"Junaedi\",\"Yanto\"],[\"Meja\",\"Kursi\"],[{\"criminal_offense\":\"tidak\",\"criminal_lp_number\":null,\"criminal_article\":null,\"criminal_process_status\":null,\"criminal_article_description\":null,\"criminal_notes\":null,\"decision_number\":null,\"hearing_decision_date\":null}],[]]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"/* .information {\\n  width: 240px;\\n  font-size: 0.93333rem;\\n  font-weight: 400;\\n  line-height: 140%;\\n  word-break: break-word;\\n  color: var(--black-600);\\n} */\\n\\n\\n\\nprepetrator_id_article_juncto uraian_singkat .subtitle {\\n  font-size: 14px;\\n  font-weight: 500;\\n  color: var(--black);\\n}\\n\\n.card-ubahdata {\\n  display: flex;\\n  padding: 6px 12px 6px 8px;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 8px;\\n  border-radius: 8px;\\n  border: 1px solid var(--black-100);\\n  background: var(--white);\\n}\\n\\n.badge {\\n  display: flex;\\n  padding: 0.26667rem 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.4rem;\\n  border-radius: 0.4rem;\\n}\\n\\n.badge-penanganan {\\n  color: var(--Quinary-Base, #8E44AD);\\n\\n  background: var(--Quinary-Light, #F4ECF7);\\n}\\n\\n\\n.badge-masuk {\\n  background: var(--black-50);\\n  color: var(--black);\\n}\\n\\n\\n\\n.badge-selesai {\\n  background: var(--success-50);\\n  color: var(--success);\\n}\\n\\n.badge-dikembalikan {\\n  color: var(--Secondary-Base, #FF6F00);\\n  background: var(--Secondary-Light, #FFF1E6);\\n}\\n\\n.badge-disposisi {\\n  background: var(--warning-50);\\n  color: var(--warning);\\n}\\n\\n.badge-verifikasi {\\n  background: var(--primary-50);\\n  color: var(--primary);\\n}\\n\\n.badge-high {\\n  background: var(--danger-50);\\n  color: var(--danger);\\n}\\n\\n.badge-medium {\\n  background: var(--warning-50);\\n  color: var(--warning);\\n\\n}\\n\\n.badge-low {\\n  background: var(--success-50);\\n  color: var(--success);\\n\\n}\\n\\n.badge-laporan {\\n  background: var(--white);\\n  border: 1px solid var(--primary-50);\\n  color: var(--primary);\\n}\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useMemo } from 'react';\\nimport { useForm, Controller } from 'react-hook-form';\\nimport { Modal, Form, Row, Col, Button, InputGroup } from 'react-bootstrap';\\nimport styled from 'styled-components';\\nimport { DatePicker, TimePicker } from 'antd';\\nimport Select, { components } from 'react-select';\\nimport dayjs from 'dayjs';\\nimport axios from 'axios';\\nimport { dashboard } from '@store/app';\\n\\nconst FungsiOption = [\\n  { label: 'RESKRIM', value: 'RESKRIM' },\\n  { label: 'RESNARKOBA', value: 'RESNARKOBA' },\\n  { label: 'SABHARA', value: 'SABHARA' },\\n  { label: 'SAMAPTHA', value: 'SAMAPTHA' },\\n  { label: 'PAMOBVIT', value: 'PAMOBVIT' },\\n  { label: 'POLSATWA', value: 'POLSATWA' },\\n  { label: 'BINMAS', value: 'BINMAS' },\\n  { label: 'POLAIRUD', value: 'POLAIRUD' },\\n  { label: 'LANTAS', value: 'LANTAS' },\\n  { label: 'INTELKAM', value: 'INTELKAM' },\\n  { label: 'BRIMOB', value: 'BRIMOB' },\\n  { label: 'SPKT', value: 'SPKT' },\\n];\\n\\nconst PangkatOptions = [\\n  { label: 'JENDERAL POL', value: 'JENDERAL POL' },\\n  { label: 'KOMJEN POL', value: 'KOMJEN POL' },\\n  { label: 'IRJEN POL', value: 'IRJEN POL' },\\n  { label: 'BRIGJEN POL', value: 'BRIGJEN POL' },\\n  { label: 'KOMBES POL', value: 'KOMBES POL' },\\n  { label: 'AKBP', value: 'AKBP' },\\n  { label: 'KOMPOL', value: 'KOMPOL' },\\n  { label: 'AKP', value: 'AKP' },\\n  { label: 'IPTU', value: 'IPTU' },\\n  { label: 'IPDA', value: 'IPDA' },\\n  { label: 'AIPTU', value: 'AIPTU' },\\n  { label: 'AIPDA', value: 'AIPDA' },\\n  { label: 'BRIPKA', value: 'BRIPKA' },\\n  { label: 'BRIGADIR', value: 'BRIGADIR' },\\n  { label: 'BRIPTU', value: 'BRIPTU' },\\n  { label: 'BRIPDA', value: 'BRIPDA' },\\n  { label: 'ABRIP', value: 'ABRIP' },\\n  { label: 'ABRIPTU', value: 'ABRIPTU' },\\n  { label: 'ABRIPDA', value: 'ABRIPDA' },\\n  { label: 'BHARAKA', value: 'BHARAKA' },\\n  { label: 'BHARATU', value: 'BHARATU' },\\n  { label: 'BHARADA', value: 'BHARADA' },\\n];\\n\\nconst convertArticlesToPasal = (articles) => {\\n  if (!Array.isArray(articles)) return [];\\n  return articles.map((article) => ({\\n    value: article.article_id || article.kode_pasal,\\n    kode_pasal: article.kode_pasal,\\n    description: article.description,\\n    article_id: article.article_id,\\n    pasal: article.pasal,\\n    ayat: article.ayat,\\n    judul_bab: article.judul_bab,\\n    nama_bab: article.nama_bab,\\n    type: article.type,\\n    // type: article.type || '', // Tambahkan type field\\n  }));\\n};\\n\\n// Utility function untuk filter pasal berdasarkan type\\nconst filterPasalByType = (pasal, filterType) => {\\n  if (!filterType) return pasal;\\n  return pasal.filter((item) => item.type === filterType);\\n};\\n\\nexport default function InformasiLaporan({\\n  widget,\\n  data,\\n  G,\\n  pageState,\\n  user,\\n  userToken,\\n}) {\\n  const [groupedArticles, setGroupedArticles] = useState({});\\n  const dataArray = Array.isArray(data) ? data : [];\\n  const report = dataArray[0] || {};\\n\\n  const pages = {\\n    informasiTerlapor: pageState?.['b7b630239fb7ad396f2a432f47e876b2'],\\n    informasiDasar: pageState?.['dad5b834f5a7a46b8a119d6e54211dbd'],\\n  };\\n\\n  const informasiDasarData = pages?.informasiDasar?.data?.[0];\\n  const policeFunction = informasiDasarData?.police_function || '';\\n  const policeReportData = Array.isArray(report?.police_report_json)\\n    ? report.police_report_json[0]\\n    : {};\\n\\n  // console.log(policeFunction, 'police');\\n\\n  // Helper: extract person by type dari array persons_responsible\\n  const getPersonByType = (type) => {\\n    if (!Array.isArray(report?.persons_responsible)) return {};\\n    return report.persons_responsible.find((p) => p.type === type) || {};\\n  };\\n  const createdBy = getPersonByType('created_by');\\n  const acknowledgedBy = getPersonByType('acknowledged_by');\\n  const examiner = getPersonByType('examiner');\\n\\n  // Helper: filter articles by type name\\n  const filterArticlesByType = (keyword) => {\\n    if (!Array.isArray(report?.articles)) return [];\\n    if (!keyword) return report.articles;\\n    return report.articles.filter((a) =>\\n      (a.type || '').toLowerCase().includes(keyword.toLowerCase()),\\n    );\\n  };\\n  const articlesPPRI = filterArticlesByType('pp nomor 1');\\n  const articlesPerpol = filterArticlesByType('perpolri no 7');\\n\\n  const [showDetailModal, setShowDetailModal] = useState(false);\\n  const [selectedDetail, setSelectedDetail] = useState(null);\\n\\n  const [pasalOptionsAPI, setPasalOptionsAPI] = useState([]);\\n  const [loadingPasalAPI, setLoadingPasalAPI] = useState(false);\\n\\n  const handleDetailClick = (e, data) => {\\n    e.stopPropagation();\\n    setSelectedDetail(data);\\n    setShowDetailModal(true);\\n  };\\n  const pasalArticles = Array.isArray(report?.articles)\\n    ? report.articles.map((article) => ({\\n        value: article.article_id || article.kode_pasal,\\n        kode_pasal: article.kode_pasal,\\n        description: article.description,\\n      }))\\n    : [];\\n\\n  const pasalOptions = useMemo(() => {\\n    return convertArticlesToPasal(report?.articles || []);\\n  }, [report?.articles]);\\n\\n  useEffect(() => {\\n    if (pasalOptions.length > 0) {\\n      console.log('Pasal Options (dari articles):', pasalOptions);\\n    }\\n  }, [pasalOptions]);\\n\\n  useEffect(() => {\\n    if (report && Object.keys(report).length > 0) {\\n      console.log('Sync report data:', {\\n        type: report.type,\\n        form_of_action: report.form_of_action,\\n        application_of_article: report.application_of_article, // Tambahkan ini\\n      });\\n\\n      // Sync selectedTipeTerlapor\\n      if (report.type) {\\n        const trimmedType = report.type.trim();\\n        setSelectedTipeTerlapor(trimmedType);\\n        setValueEdit('urgency_score_category', trimmedType, {\\n          shouldValidate: false,\\n          shouldDirty: false,\\n        });\\n      }\\n\\n      // Sync selectedPenerapanPasal - GUNAKAN application_of_article\\n      if (report.application_of_article) {\\n        setSelectedPenerapanPasal(report.application_of_article);\\n        setValueEdit('application_of_article', report.application_of_article, {\\n          shouldValidate: false,\\n          shouldDirty: false,\\n        });\\n      }\\n    }\\n  }, [report]);\\n\\n  const [showModal, setShowModal] = useState<boolean>(false);\\n  const [activeTab, setActiveTab] = useState('data-terlapor');\\n  const [loading, setLoading] = useState(false);\\n  const [kesatuanData, setKesatuanData] = useState([]);\\n  const [loadingKesatuan, setLoadingKesatuan] = useState(false);\\n  const [showValidationError, setShowValidationError] = useState(false);\\n\\n  const [isDragging, setIsDragging] = useState(false);\\n  const [files, setFiles] = useState([]);\\n\\n  const [uploadedFiles, setUploadedFiles] = useState([]);\\n  const [step, setStep] = useState(1);\\n  const handleCloseWithReset = () => {\\n    setStep(1); // Reset ke step 1\\n    setSelectedTipeLaporan('provos');\\n    setSelectedTipeTerlapor(report?.type || 'Anggota ');\\n    setSelectedPenerapanPasal(report?.form_of_action || 'kode-etik');\\n    handleCloseEdit();\\n  };\\n\\n  // console.log(report, 'ini report');\\n\\n  const getStatusBadgeClass = (status) => {\\n    const s = status?.toLowerCase();\\n    if (s.includes('bagyanduan')) return 'badge-bagyanduan';\\n    if (s === 'Masuk') return 'badge-masuk';\\n    if (s === 'selesai' || s === 'disetujui') return 'badge-selesai';\\n    if (s === 'dikembalikan') return 'badge-dikembalikan';\\n    if (s === 'verifikasi') return 'badge-verifikasi';\\n    if (s === 'disposisi') return 'badge-disposisi';\\n    if (s === 'penanganan') return 'badge-penanganan';\\n    return '';\\n  };\\n\\n  const getUrgencyClass = (urgency) => {\\n    const u = urgency?.toLowerCase();\\n    if (u === 'tinggi') return 'badge-high';\\n    if (u === 'Asn Polri') return 'badge-medium';\\n    if (u === 'anggota') return 'badge-low';\\n    return '';\\n  };\\n\\n  const formatText = (text) => {\\n    return text\\n      ? text.charAt(0).toUpperCase() + text.slice(1).toLowerCase()\\n      : '-';\\n  };\\n\\n  const formatDateID = (dateString) => {\\n    if (!dateString) return '-';\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return '-';\\n    const hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n    const tahun = date.getFullYear().toString().slice(-2);\\n    const jam = date.getHours().toString().padStart(2, '0');\\n    const menit = date.getMinutes().toString().padStart(2, '0');\\n    return `${hari}, ${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n  };\\n\\n  // fetch Kesatuan Data\\n  const fetchKesatuanData = async () => {\\n    setLoadingKesatuan(true);\\n    try {\\n      const response = await axios.post(\\n        '/api/v1/apps/data/management/get-all',\\n        {\\n          orderBy: 'kesatuan',\\n          order: 'asc',\\n          page: 1,\\n          size: 1000,\\n          connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n          table: 'dimension.catalog_jajaran_propam',\\n          database: 'divpropam',\\n          filters: [],\\n        },\\n        {\\n          headers: {\\n            Authorization: `Bearer `,\\n            'Content-Type': 'application/json',\\n          },\\n        },\\n      );\\n\\n      console.log('Data Kesatuan :', response.data);\\n      setKesatuanData(response.data?.data || []);\\n    } catch (error) {\\n      console.error('Error fetch Kesatuan:', error);\\n    } finally {\\n      setLoadingKesatuan(false);\\n    }\\n  };\\n\\n  useEffect(() => {\\n    if (showModal) {\\n      fetchKesatuanData();\\n    }\\n  }, [showModal]);\\n\\n  const kesatuanOptions = useMemo(() => {\\n    const uniqueKesatuan = [\\n      ...new Set(kesatuanData.map((item) => item.kesatuan)),\\n    ];\\n    return uniqueKesatuan.map((kat) => ({\\n      label: kat,\\n      value: kat,\\n    }));\\n  }, [kesatuanData]);\\n\\n  const {\\n    register,\\n    watch,\\n    control,\\n    formState: { errors },\\n  } = useForm();\\n\\n  // Dummy data untuk prepetrator (data terlapor - disini saja belum bisa dari API)\\n  const dummyPrepetrator = {\\n    name: 'Bripka Ahmad Suryanto',\\n    nrp: '12345678900001',\\n    rank: 'Bripka',\\n    position: 'Patroli Polisanan',\\n    functional_assignment: 'Anggota Polri',\\n  };\\n\\n  // const pages = {\\n  //   informasiTerlapor: pageState?.['b7b630239fb7ad396f2a432f47e876b2'],\\n  // };\\n\\n  const dataTerlapor = pages?.informasiTerlapor?.data?.[0]?.prepetrator_data;\\n\\n  const {\\n    register: registerEdit,\\n    handleSubmit: handleSubmitEdit,\\n    watch: watchEdit,\\n    setValue: setValueEdit,\\n    reset: resetEdit,\\n    trigger: triggerEdit,\\n    control: controlEdit,\\n    formState: { errors: errorsEdit },\\n  } = useForm({\\n    mode: 'onChange',\\n  });\\n  // const [selectedTipeLaporan, setSelectedTipeLaporan] = useState(() => {\\n  //   if (policeFunction === 'PROVOS') return 'provos';\\n  //   if (policeFunction === 'WABPROF') return 'wabprof';\\n  //   return 'provos';\\n  // });\\n\\n  const [selectedTipeLaporan, setSelectedTipeLaporan] = useState(() => {\\n    const func = (policeFunction || '').toUpperCase();\\n    if (func === 'PROVOS') return 'provos';\\n    if (func === 'WABPROF') return 'wabprof';\\n    return 'provos';\\n  });\\n\\n  const isTipeLaporanDisabled =\\n    policeFunction === 'PROVOS' || policeFunction === 'WABPROF';\\n  // const [selectedTipeLaporan, setSelectedTipeLaporan] = useState('provos');\\n  const maxStep = selectedTipeLaporan === 'provos' ? 3 : 4;\\n\\n  const [selectedTipeTerlapor, setSelectedTipeTerlapor] = useState(\\n    report?.type || 'Anggota Polri',\\n  );\\n  const [selectedPenerapanPasal, setSelectedPenerapanPasal] = useState(\\n    report?.form_of_action || 'kode-etik',\\n  );\\n\\n  const handleOpenEdit = () => {\\n    resetEdit();\\n\\n    if (policeFunction === 'PROVOS') {\\n      setSelectedTipeLaporan('provos');\\n    } else if (policeFunction === 'WABPROF') {\\n      setSelectedTipeLaporan('wabprof');\\n    }\\n\\n    setTimeout(() => {\\n      // application_of_article\\n      if (report?.application_of_article) {\\n        setValueEdit('application_of_article', report.application_of_article);\\n        setSelectedPenerapanPasal(report.application_of_article);\\n      } else {\\n        setValueEdit('application_of_article', 'kode-etik');\\n        setSelectedPenerapanPasal('kode-etik');\\n      }\\n\\n      // urgency_score_category\\n      if (report?.type) {\\n        const trimmedType = report.type.trim();\\n        setValueEdit('urgency_score_category', trimmedType);\\n        setSelectedTipeTerlapor(trimmedType);\\n      } else {\\n        setValueEdit('urgency_score_category', 'Anggota Polri');\\n        setSelectedTipeTerlapor('Anggota Polri');\\n      }\\n\\n      if (report?.datetime) {\\n        setValueEdit('datetime', dayjs(report.datetime).toISOString());\\n      }\\n\\n      if (policeFunction === 'WABPROF') {\\n        const prd = report?.police_report_json?.[0] ?? {};\\n\\n        // Isi Laporan\\n        // setValueEdit('summary', report?.summary ?? '');\\n        setValueEdit('report_detail', report?.report_detail ?? '');\\n\\n        const criminalOffense = prd?.criminal_offense ?? 'tidak';\\n        setValueEdit('criminal_offense', criminalOffense);\\n\\n        setValueEdit('criminal_lp_number', prd?.criminal_lp_number ?? '');\\n\\n        setValueEdit('criminal_article', prd?.criminal_article ?? '');\\n\\n        setValueEdit(\\n          'criminal_article_description',\\n          prd?.criminal_article_description ?? '',\\n        );\\n\\n        setValueEdit(\\n          'criminal_process_status',\\n          prd?.criminal_process_status ?? '',\\n        );\\n\\n        setValueEdit(\\n          'tanggal_putusan_sidang',\\n          prd?.hearing_decision_date ?? '',\\n        );\\n\\n        setValueEdit('nomor_putusan_pidana', prd?.decision_number ?? '');\\n\\n        setValueEdit('catatan_pidana', prd?.criminal_notes ?? '');\\n\\n        const mappedFiles = (report?.attachments || [])\\n          .filter((f) => f?.type === 'PIDANA') // optional filter\\n          .map((f, idx) => ({\\n            id: idx,\\n            name: f.file_name,\\n            size: Number(f.size) || 0,\\n            url: f.url,\\n            isFromAPI: true, // penanda penting\\n          }));\\n\\n        setFiles(mappedFiles);\\n\\n        // Saksi & Bukti\\n        if (Array.isArray(report?.witness) && report.witness.length > 0) {\\n          setValueEdit(\\n            'witness',\\n            report.witness.map((w) =>\\n              typeof w === 'string' ? { name: w } : w,\\n            ),\\n          );\\n        }\\n        if (Array.isArray(report?.evidence) && report.evidence.length > 0) {\\n          setValueEdit(\\n            'evidence',\\n            report.evidence.map((e) =>\\n              typeof e === 'string' ? { name: e } : e,\\n            ),\\n          );\\n        }\\n\\n        // Yang Membuat Laporan (wabprof pakai prefix tanpa created_by_)\\n        setValueEdit('name', createdBy?.name || '');\\n        setValueEdit('position', createdBy?.position || '');\\n        setValueEdit('rank', createdBy?.rank || '');\\n        setValueEdit('nrp', createdBy?.nrp || '');\\n        setValueEdit('unit', createdBy?.unit || '');\\n\\n        // Mengetahui\\n        setValueEdit('examiner_name', acknowledgedBy?.name || '');\\n        setValueEdit('examiner_rank', acknowledgedBy?.rank || '');\\n        setValueEdit('examiner_nrp', acknowledgedBy?.nrp || '');\\n        setValueEdit('examiner_unit', acknowledgedBy?.unit || '');\\n      }\\n\\n      if (policeFunction === 'PROVOS') {\\n        // Yang Membuat Laporan (provos pakai prefix created_by_)\\n        setValueEdit('created_by_name', createdBy?.name || '');\\n        setValueEdit('created_by_position', createdBy?.position || '');\\n        setValueEdit('created_by_rank', createdBy?.rank || '');\\n        setValueEdit('created_by_nrp', createdBy?.nrp || '');\\n        setValueEdit('created_by_unit', createdBy?.unit || '');\\n\\n        // Pemeriksa\\n        setValueEdit('acknowledged_by_name', acknowledgedBy?.name || '');\\n        setValueEdit('acknowledged_by_rank', acknowledgedBy?.rank || '');\\n        setValueEdit('acknowledged_by_nrp', acknowledgedBy?.nrp || '');\\n        setValueEdit('acknowledged_by_unit', acknowledgedBy?.unit || '');\\n\\n        // Peneliti\\n        setValueEdit('examiner_name', examiner?.name || '');\\n        setValueEdit('examiner_rank', examiner?.rank || '');\\n        setValueEdit('examiner_nrp', examiner?.nrp || '');\\n        setValueEdit('examiner_unit', examiner?.unit || '');\\n\\n        // Provos fields\\n        setValueEdit('type_of_violation', report?.type_of_violation || '');\\n        setValueEdit('uraian_singkat', report?.short_description || '');\\n      }\\n      if (\\n        report?.chronology &&\\n        Array.isArray(report.chronology) &&\\n        report.chronology.length > 0\\n      ) {\\n        const chronologyFormatted = report.chronology.map((item) => ({\\n          description: item,\\n        }));\\n        setValueEdit('chronology', chronologyFormatted, {\\n          shouldValidate: false,\\n        });\\n      }\\n    }, 50);\\n\\n    // Set pasal data dari articles\\n    if (pasalArticles.length > 0) {\\n      setTimeout(() => {\\n        setValueEdit('pasal_ppri', pasalArticles, { shouldValidate: false });\\n        setValueEdit('pasal_perpol', pasalArticles, { shouldValidate: false });\\n        setValueEdit('pasal_disiplin_ppri', pasalArticles, {\\n          shouldValidate: false,\\n        });\\n        setValueEdit('pasal_disiplin_perpol', pasalArticles, {\\n          shouldValidate: false,\\n        });\\n      }, 100);\\n    }\\n\\n    // Set juncto values\\n    if (report?.prepetrator_id_article_juncto) {\\n      let junctoValues = [];\\n      const junctoData = report.prepetrator_id_article_juncto;\\n\\n      if (Array.isArray(junctoData)) {\\n        if (typeof junctoData[0] === 'string') {\\n          junctoValues = junctoData;\\n        } else if (junctoData[0]?.article_id || junctoData[0]?.id) {\\n          junctoValues = junctoData.map((item) => item.article_id || item.id);\\n        } else {\\n          junctoValues = junctoData;\\n        }\\n      }\\n\\n      setValueEdit('prepetrator_id_article_juncto', junctoValues, {\\n        shouldValidate: false,\\n      });\\n    }\\n\\n    setShowModal(true);\\n  };\\n  const handleCloseEdit = () => {\\n    setShowModal(false);\\n    resetEdit();\\n  };\\n\\n  const handleTabClick = (tabKey: string) => {\\n    setActiveTab(tabKey);\\n  };\\n  const handleRadioClick = (value) => {\\n    setValueEdit('urgency_score_category', value, {\\n      shouldValidate: true,\\n      shouldDirty: true,\\n    });\\n  };\\n\\n  // handler radio button\\n  const handleRadioKasusClick = (value) => {\\n    setValueEdit('status_level', value, {\\n      shouldValidate: true,\\n      shouldDirty: true,\\n    });\\n  };\\n\\n  // Helper function (string atau object)\\n  const getFieldValue = (value) => {\\n    if (!value) return '';\\n    if (typeof value === 'string') return value;\\n    if (typeof value === 'object' && value.value) return value.value;\\n    return value.value || value.label || '';\\n  };\\n\\n  const onSubmitEdit = async (formData) => {\\n    // console.log('=== SUBMIT CREATE ===');\\n    // console.log('Step saat ini:', step);\\n    // console.log('Form data:', formData);\\n    // console.log('Selected Tipe Terlapor:', selectedTipeTerlapor);\\n    // console.log('Selected Penerapan Pasal:', selectedPenerapanPasal);\\n\\n    setLoading(true);\\n\\n    try {\\n      if (!formData.datetime || formData.datetime.trim() === '') {\\n        alert('Tanggal wajib diisi');\\n        setLoading(false);\\n        return;\\n      }\\n\\n      if (selectedTipeLaporan === 'provos') {\\n        // Yang Membuat Laporan\\n        if (\\n          !formData.created_by_name ||\\n          formData.created_by_name.trim() === ''\\n        ) {\\n          alert('Nama Yang Membuat Laporan wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (\\n          !formData.created_by_position ||\\n          formData.created_by_position.trim() === ''\\n        ) {\\n          alert('Jabatan Yang Membuat Laporan wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!getFieldValue(formData.created_by_rank)) {\\n          alert('Pangkat Yang Membuat Laporan wajib dipilih');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.created_by_nrp || formData.created_by_nrp.trim() === '') {\\n          alert('NRP Yang Membuat Laporan wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n\\n        const nrpCleaned = formData.created_by_nrp?.replace(/\\\\D/g, '');\\n\\n        if (nrpCleaned.length !== 8) {\\n          alert('NRP harus terdiri dari 8 angka');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!getFieldValue(formData.created_by_unit)) {\\n          alert('Kesatuan Yang Membuat Laporan wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n\\n        // Pemeriksa\\n        if (\\n          !formData.acknowledged_by_name ||\\n          formData.acknowledged_by_name.trim() === ''\\n        ) {\\n          alert('Nama Pemeriksa wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!getFieldValue(formData.acknowledged_by_rank)) {\\n          alert('Pangkat Pemeriksa wajib dipilih');\\n          setLoading(false);\\n          return;\\n        }\\n        if (\\n          !formData.acknowledged_by_nrp ||\\n          formData.acknowledged_by_nrp.trim() === ''\\n        ) {\\n          alert('NRP Pemeriksa wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!getFieldValue(formData.acknowledged_by_unit)) {\\n          alert('Kesatuan Pemeriksa wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n      }\\n\\n      // Validasi examiner untuk semua tipe\\n      // const examinerLabel =\\n      //   selectedTipeLaporan === 'provos' ? 'Peneliti' : 'Mengetahui';\\n\\n      const examinerLabel =\\n        selectedTipeLaporan === 'provos' ? 'Pemeriksa' : 'Mengetahui';\\n\\n      if (!formData.examiner_name || formData.examiner_name.trim() === '') {\\n        alert(`Nama ${examinerLabel} wajib diisi`);\\n        setLoading(false);\\n        return;\\n      }\\n      if (!getFieldValue(formData.examiner_rank)) {\\n        alert(`Pangkat ${examinerLabel} wajib dipilih`);\\n        setLoading(false);\\n        return;\\n      }\\n      if (!formData.examiner_nrp || formData.examiner_nrp.trim() === '') {\\n        alert(`NRP ${examinerLabel} wajib diisi`);\\n        setLoading(false);\\n        return;\\n      }\\n      if (!getFieldValue(formData.examiner_unit)) {\\n        alert(`Kesatuan ${examinerLabel} wajib diisi`);\\n        setLoading(false);\\n        return;\\n      }\\n\\n      const buildEditData = () => {\\n        const baseData = {\\n          report_type: selectedTipeLaporan === 'provos' ? 'Provos' : 'Wabprof',\\n          reported_type: selectedTipeTerlapor || 'Anggota Polri',\\n          // type_of_violation: formData.type_of_violation || '',\\n          datetime: dayjs(formData.datetime).valueOf(),\\n          application_of_article: formData.application_of_article || '',\\n          prepetrator_id: report?.prepetrator_id || '',\\n          id: report?.id || report?.report_id || '',\\n          // short_description: formData.uraian_singkat || '',\\n        };\\n\\n        if (selectedTipeLaporan === 'provos') {\\n          baseData.short_description = formData.uraian_singkat || '';\\n          baseData.type_of_violation = formData.type_of_violation || '';\\n\\n          if (formData.chronology && formData.chronology.length > 0) {\\n            baseData.chronology = formData.chronology.map((item) =>\\n              typeof item === 'string' ? item : item.description,\\n            );\\n          }\\n        }\\n\\n        if (selectedTipeLaporan === 'wabprof') {\\n          // Isi Laporan (Step 1)\\n          baseData.report_detail = formData.report_detail || '';\\n\\n          // Saksi & Bukti (Step 3)\\n          if (formData.witness && formData.witness.length > 0) {\\n            baseData.witness = formData.witness.map((item) =>\\n              typeof item === 'string' ? item : item.name,\\n            );\\n          }\\n          if (formData.evidence && formData.evidence.length > 0) {\\n            baseData.evidence = formData.evidence.map((item) =>\\n              typeof item === 'string' ? item : item.name,\\n            );\\n          }\\n\\n          // Pelanggaran Pidana (Step 2)\\n          if (formData.criminal_offense === 'ya') {\\n            // baseData.police_report_json = [\\n            //   {\\n            //     criminal_offense: formData.criminal_offense || 'tidak',\\n            //     criminal_lp_number: formData.criminal_lp_number || null,\\n            //     criminal_article: formData.criminal_article || null,\\n            //     criminal_article_description:\\n            //       formData.criminal_article_description || null,\\n            //     criminal_process_status:\\n            //       formData.criminal_process_status || null,\\n            //   },\\n            // ];\\n            baseData.criminal_offense = formData.criminal_offense || 'tidak';\\n            baseData.criminal_lp_number = formData.criminal_lp_number || null;\\n            baseData.criminal_article = formData.criminal_article || null;\\n            baseData.criminal_article_description =\\n              formData.criminal_article_description || null;\\n            baseData.criminal_process_status =\\n              formData.criminal_process_status || null;\\n\\n            if (formData.criminal_process_status === 'sudah_sidang') {\\n              baseData.hearing_decision_date =\\n                formData.tanggal_putusan_sidang || '';\\n              baseData.decision_number = formData.nomor_putusan_pidana || '';\\n            }\\n\\n            baseData.criminal_notes = formData.catatan_pidana || '';\\n\\n            if (uploadedFiles.length > 0) {\\n              baseData.attachment = uploadedFiles;\\n            }\\n          } else if (formData.criminal_offense === 'tidak') {\\n            baseData.criminal_offense = 'tidak';\\n          }\\n\\n          // Pasal Juncto\\n          if (\\n            formData.prepetrator_id_article_juncto &&\\n            formData.prepetrator_id_article_juncto.length > 0\\n          ) {\\n            if (typeof formData.prepetrator_id_article_juncto[0] === 'string') {\\n              baseData.prepetrator_id_article_juncto =\\n                formData.prepetrator_id_article_juncto;\\n            } else if (formData.prepetrator_id_article_juncto[0]?.value) {\\n              baseData.prepetrator_id_article_juncto =\\n                formData.prepetrator_id_article_juncto.map(\\n                  (item) => item.value,\\n                );\\n            } else {\\n              baseData.prepetrator_id_article_juncto =\\n                formData.prepetrator_id_article_juncto;\\n            }\\n          } else if (report?.prepetrator_id_article_juncto) {\\n            baseData.prepetrator_id_article_juncto =\\n              report.prepetrator_id_article_juncto;\\n          }\\n        }\\n\\n        // Add persons_responsible\\n        //   const addPersonData = (prefix) => {\\n        //     const name = formData[`${prefix}_name`];\\n        //     const rank = getFieldValue(formData[`${prefix}_rank`]);\\n        //     const nrp = formData[`${prefix}_nrp`];\\n        //     const unit = getFieldValue(formData[`${prefix}_unit`]);\\n        //     const position = formData[`${prefix}_position`];\\n\\n        //     if (name) baseData[`${prefix}_name`] = name;\\n        //     if (rank) baseData[`${prefix}_rank`] = rank;\\n        //     if (nrp) baseData[`${prefix}_nrp`] = nrp;\\n        //     if (unit) baseData[`${prefix}_unit`] = unit;\\n        //     if (position) baseData[`${prefix}_position`] = position;\\n        //   };\\n\\n        //   addPersonData('created_by');\\n        //   addPersonData('acknowledged_by');\\n        //   addPersonData('examiner');\\n\\n        //   return baseData;\\n        // };\\n\\n        const personsResponsible = [];\\n\\n        if (selectedTipeLaporan === 'wabprof') {\\n          // Wabprof\\n          personsResponsible.push({\\n            type: 'created_by',\\n            name: formData.name || '',\\n            rank: getFieldValue(formData.rank) || '',\\n            nrp: formData.nrp || '',\\n            unit: getFieldValue(formData.unit) || '',\\n            position: formData.position || '',\\n          });\\n\\n          // personsResponsible.push({\\n          //   // type: 'examiner',\\n          //   // name: formData.examiner_name || '',\\n          //   // rank: getFieldValue(formData.examiner_rank) || '',\\n          //   // nrp: formData.examiner_nrp || '',\\n          //   // unit: getFieldValue(formData.examiner_unit) || '',\\n          //   type: 'acknowledged_by',\\n          //   name: formData.acknowledged_by_name || '',\\n          //   rank: getFieldValue(formData.acknowledged_by_rank) || '',\\n          //   nrp: formData.acknowledged_by_nrp || '',\\n          //   unit: getFieldValue(formData.acknowledged_by_unit) || '',\\n          // });\\n\\n          personsResponsible.push({\\n            type: 'acknowledged_by',\\n            name: formData.examiner_name || '',\\n            rank: getFieldValue(formData.examiner_rank) || '',\\n            nrp: formData.examiner_nrp || '',\\n            unit: getFieldValue(formData.examiner_unit) || '',\\n          });\\n        } else {\\n          personsResponsible.push({\\n            type: 'created_by',\\n            name: formData.created_by_name || '',\\n            rank: getFieldValue(formData.created_by_rank) || '',\\n            nrp: formData.created_by_nrp || '',\\n            unit: getFieldValue(formData.created_by_unit) || '',\\n            position: formData.created_by_position || '',\\n          });\\n\\n          // personsResponsible.push({\\n          //   // type: 'examiner',\\n          //   // name: formData.examiner_name || '',\\n          //   // rank: getFieldValue(formData.examiner_rank) || '',\\n          //   // nrp: formData.examiner_nrp || '',\\n          //   // unit: getFieldValue(formData.examiner_unit) || '',\\n          //   type: 'acknowledged_by',\\n          //   name: formData.acknowledged_by_name || '',\\n          //   rank: getFieldValue(formData.acknowledged_by_rank) || '',\\n          //   nrp: formData.acknowledged_by_nrp || '',\\n          //   unit: getFieldValue(formData.acknowledged_by_unit) || '',\\n          // });\\n\\n          personsResponsible.push({\\n            // type: 'examiner',\\n            type: 'acknowledged_by',\\n            name: formData.examiner_name || '',\\n            rank: getFieldValue(formData.examiner_rank) || '',\\n            nrp: formData.examiner_nrp || '',\\n            unit: getFieldValue(formData.examiner_unit) || '',\\n            // name: formData.acknowledged_by_name || '',\\n            // rank: getFieldValue(formData.acknowledged_by_rank) || '',\\n            // nrp: formData.acknowledged_by_nrp || '',\\n            // unit: getFieldValue(formData.acknowledged_by_unit) || '',\\n          });\\n\\n          personsResponsible.push({\\n            // type: 'acknowledged_by',\\n            type: 'examiner',\\n            name: formData.acknowledged_by_name || '',\\n            rank: getFieldValue(formData.acknowledged_by_rank) || '',\\n            nrp: formData.acknowledged_by_nrp || '',\\n            unit: getFieldValue(formData.acknowledged_by_unit) || '',\\n            // name: formData.examiner_name || '',\\n            // rank: getFieldValue(formData.examiner_rank) || '',\\n            // nrp: formData.examiner_nrp || '',\\n            // unit: getFieldValue(formData.examiner_unit) || '',\\n          });\\n        }\\n\\n        baseData.persons_responsible = personsResponsible;\\n\\n        return baseData;\\n      };\\n\\n      const editData = buildEditData();\\n\\n      // console.log(\\\"Payload yang akan dikirim:\\\", editData);\\n      // return;\\n\\n      // console.log('Edit payload:', editData);\\n      // console.log('=== DEBUGGING INFO ===');\\n      // console.log('Widget:', widget);\\n      // console.log('PageState:', pageState);\\n      // console.log('User:', user);\\n      // console.log('User ID:', user?.id);\\n      // console.log('Widget ID:', widget?.id);\\n      // console.log('Widget Dashboard ID:', widget?.dashboardId);\\n      // console.log('PageState Dashboard ID:', pageState?.dashboard?.id);\\n      // console.log('prepertrator_id :', report?.prepetrator_id);\\n      // console.log('data id :', report?.data_id);\\n\\n      // KIRIM KE API\\n      const dashboardId =\\n        widget?.dashboardId || pageState?.dashboard?.id || widget?.id || '';\\n\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: 'f40eaea98985a03ec204e8d7194a42b4',\\n        params: editData,\\n        body: {},\\n        headers: {},\\n        additionalPath: '',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id || '',\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboardId,\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n        metaData: {\\n          widgetId: 'e977bc958df20460d8d9e8ed2ebfdb06',\\n          widgetName: 'Laporan Polisi',\\n          menuId: '01f63e60376afe827638ed614e1cea76',\\n          menuName: 'Detail Laporan',\\n          dashboardId: '1769155096865',\\n          dashboardName: 'Propam Aduan',\\n          userId: user?.id,\\n          domain: '',\\n        },\\n      };\\n\\n      console.log('Sending to gateway:', requestPayload);\\n\\n      const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: {\\n          'Content-Type': 'application/json',\\n        },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!gatewayResponse.ok) {\\n        const errorText = await gatewayResponse.text();\\n        throw new Error(\\n          `Gateway error: ${gatewayResponse.status} - ${errorText}`,\\n        );\\n      }\\n\\n      const gatewayResult = await gatewayResponse.json();\\n      console.log('Create success:', gatewayResult);\\n\\n      // Notifikasi sukses\\n      if (typeof dispatchNotification === 'function') {\\n        dispatchNotification('Laporan berhasil dibuat!', 'success');\\n      }\\n\\n      alert('Data laporan berhasil dibuat!');\\n\\n      setShowModal(false);\\n      resetEdit();\\n      setStep(1);\\n      setFiles([]);\\n      setUploadedFiles([]);\\n    } catch (err) {\\n      console.error('Error creating laporan:', err);\\n\\n      // Notifikasi error\\n      if (typeof dispatchNotification === 'function') {\\n        dispatchNotification(`Error: ${err.message}`, 'danger');\\n      }\\n\\n      alert(`Gagal membuat data: ${err.message}`);\\n    } finally {\\n      setLoading(false);\\n    }\\n  };\\n\\n  const sanitizeSvg = async (file) => {\\n    return file;\\n  };\\n\\n  const handleFileChange = async (e) => {\\n    const selectedFiles = Array.from(e.target.files || []);\\n\\n    if (selectedFiles.length === 0) return;\\n\\n    for (const file of selectedFiles) {\\n      let fileToUpload = file;\\n      if (file.type === 'image/svg+xml') {\\n        const safeFile = await sanitizeSvg(file);\\n        if (!safeFile) {\\n          dispatchNotification(\\n            `SVG \\\"${file.name}\\\" is unsafe and has been blocked.`,\\n            'danger',\\n          );\\n          continue;\\n        }\\n        fileToUpload = safeFile;\\n      }\\n\\n      setFiles((prev) => [...prev, fileToUpload]);\\n      await handleFileUpload(fileToUpload);\\n    }\\n\\n    e.target.value = '';\\n  };\\n\\n  const handleDrop = async (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n\\n    const droppedFiles = Array.from(e.dataTransfer.files || []);\\n\\n    for (const file of droppedFiles) {\\n      setFiles((prev) => [...prev, file]);\\n      await handleFileUpload(file);\\n    }\\n  };\\n\\n  const handleDragOver = (e) => {\\n    e.preventDefault();\\n    setIsDragging(true);\\n  };\\n\\n  const handleDragLeave = (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n  };\\n\\n  const newFiles = files.filter((f) => !f.isFromAPI);\\n  const existingFiles = files.filter((f) => f.isFromAPI);\\n\\n  const removeFile = (fileToRemove) => {\\n    setFiles((prev) => prev.filter((f) => f !== fileToRemove));\\n  };\\n  const removeExistingFile = (fileUrl) => {\\n    // Remove from existing files display (this is just UI, actual deletion might need API call)\\n    console.log('Removing existing file:', fileUrl);\\n  };\\n\\n  const handleFileUpload = async (file) => {\\n    console.log('Uploading file:', file.name, file.size);\\n\\n    const dashboardIdForUpload =\\n      widget?.dashboardId || pageState?.dashboard?.id || widget?.id || '';\\n    console.log('Dashboard ID for upload:', dashboardIdForUpload);\\n\\n    const queryParams = new URLSearchParams({\\n      folder: 'agent',\\n      workspaceId: user?.workspaceId || '',\\n      dashboardId: dashboardIdForUpload,\\n      createdBy: user?.id || '',\\n      extractFile: 'false',\\n    }).toString();\\n\\n    const formData = new FormData();\\n    formData.append('file', file);\\n    formData.append('tags', 'assets');\\n\\n    try {\\n      const res = await fetch(\\n        `/api/v1/apps/upload/upload-file?${queryParams}`,\\n        {\\n          method: 'POST',\\n          body: formData,\\n        },\\n      );\\n\\n      console.log('Upload response status:', res.status);\\n\\n      if (!res.ok) {\\n        const errorText = await res.text();\\n        console.error('Upload failed:', errorText);\\n        throw new Error(`Upload gagal: ${res.status} - ${errorText}`);\\n      }\\n\\n      const result = await res.json();\\n      console.log('Upload success:', result);\\n\\n      const uploadedFileInfo = result?.data?.path || '';\\n\\n      setUploadedFiles((prev) => [...prev, uploadedFileInfo]);\\n\\n      return uploadedFileInfo;\\n    } catch (err) {\\n      console.error('Error upload file:', err);\\n      dispatchNotification(\\n        `Error uploading ${file.name}: ${err.message}`,\\n        'danger',\\n      );\\n      return null;\\n    }\\n  };\\n\\n  const getFileIcon = (file) => {\\n    const name = file?.name?.toLowerCase() || '';\\n    const ext = name.split('.').pop();\\n\\n    switch (ext) {\\n      case 'jpg':\\n      case 'jpeg':\\n      case 'png':\\n      case 'gif':\\n        return <i className=\\\"ph-fill ph-image\\\"></i>;\\n\\n      case 'pdf':\\n        return <i className=\\\"ph-fill ph-file-pdf\\\"></i>;\\n\\n      case 'doc':\\n      case 'docx':\\n        return <i className=\\\"ph-fill ph-file-doc\\\"></i>;\\n\\n      case 'txt':\\n        return <i className=\\\"ph-fill ph-file-text\\\"></i>;\\n\\n      case 'xls':\\n      case 'xlsx':\\n        return <i className=\\\"ph-fill ph-file-xls\\\"></i>;\\n\\n      case 'mp4':\\n      case 'mov':\\n      case 'avi':\\n      case 'mkv':\\n        return <i className=\\\"ph ph-video\\\"></i>;\\n\\n      case 'mp3':\\n      case 'wav':\\n        return <i className=\\\"ph-fill ph-microphone\\\"></i>;\\n\\n      default:\\n        return <i className=\\\"ph-fill ph-file\\\"></i>;\\n    }\\n  };\\n\\n  const getFileIconFromUrl = (url) => {\\n    const fileName = url.split('/').pop() || '';\\n    const ext = fileName.split('.').pop()?.toLowerCase();\\n\\n    switch (ext) {\\n      case 'jpg':\\n      case 'jpeg':\\n      case 'png':\\n      case 'gif':\\n        return <i className=\\\"ph-fill ph-image\\\"></i>;\\n\\n      case 'pdf':\\n        return <i className=\\\"ph-fill ph-file-pdf\\\"></i>;\\n\\n      case 'doc':\\n      case 'docx':\\n        return <i className=\\\"ph-fill ph-file-doc\\\"></i>;\\n\\n      case 'txt':\\n        return <i className=\\\"ph-fill ph-file-text\\\"></i>;\\n\\n      case 'xls':\\n      case 'xlsx':\\n        return <i className=\\\"ph-fill ph-file-xls\\\"></i>;\\n\\n      case 'mp4':\\n      case 'mov':\\n      case 'avi':\\n      case 'mkv':\\n        return <i className=\\\"ph ph-video\\\"></i>;\\n\\n      case 'mp3':\\n      case 'wav':\\n        return <i className=\\\"ph-fill ph-microphone\\\"></i>;\\n\\n      default:\\n        return <i className=\\\"ph-fill ph-file\\\"></i>;\\n    }\\n  };\\n  const triggerFileInput = () => {\\n    const fileInput = document.getElementById('fileInput');\\n    if (fileInput) fileInput.click();\\n  };\\n\\n  // Format fungsi untuk mengkonversi URL S3 (sama seperti di LaporanCard)\\n  const convertS3Url = (url) => {\\n    if (!url) return null;\\n    if (url.startsWith('http://192.168.180.99:8000')) {\\n      return url.replace(\\n        'http://192.168.180.99:8000',\\n        'https://asura-s3.stellardata.ai/fusion/agent',\\n      );\\n    }\\n    if (url.startsWith('s3://')) {\\n      return url.replace('s3://', 'https://asura-s3.stellardata.ai/');\\n    }\\n    return url;\\n  };\\n\\n  // Fungsi untuk mendownload file\\n  const handleDownloadFile = (item) => {\\n    try {\\n      const convertedUrl = convertS3Url(item.url);\\n      const downloadUrl = convertedUrl;\\n\\n      if (!downloadUrl) throw new Error('URL tidak valid');\\n\\n      const link = document.createElement('a');\\n      link.href = downloadUrl;\\n      link.download = item.file_name || 'file';\\n      link.target = '_blank';\\n      document.body.appendChild(link);\\n      link.click();\\n      document.body.removeChild(link);\\n    } catch (error) {\\n      console.error('Error downloading file:', error);\\n      alert(`Gagal mengunduh file: ${error.message}`);\\n    }\\n  };\\n\\n  // Fungsi untuk handle next/previous\\n  const handleNext = async () => {\\n    let isValid = true;\\n\\n    // Validation berdasarkan step dan tipe laporan\\n    if (step === 1) {\\n      // Step 1: Validasi Data Laporan\\n      if (selectedTipeLaporan === 'provos') {\\n        // Validasi untuk Provos\\n        if (\\n          !watchEdit('type_of_violation') ||\\n          watchEdit('type_of_violation').trim() === ''\\n        ) {\\n          alert('Macam Pelanggaran wajib diisi');\\n          isValid = false;\\n        }\\n      } else if (selectedTipeLaporan === 'wabprof') {\\n        // Validasi untuk Wabprof\\n        if (\\n          !watchEdit('report_detail') ||\\n          watchEdit('report_detail').trim() === ''\\n        ) {\\n          alert('Isi Laporan wajib diisi');\\n          isValid = false;\\n        }\\n      }\\n\\n      // Validasi tanggal (untuk kedua tipe)\\n      if (!watchEdit('datetime') || watchEdit('datetime').trim() === '') {\\n        alert('Tanggal dan Waktu wajib diisi');\\n        isValid = false;\\n      }\\n    } else if (step === 2) {\\n      // Step 2: Validasi berdasarkan tipe laporan\\n      if (selectedTipeLaporan === 'provos') {\\n        // Step 2 Provos: Kronologi & Uraian Singkat\\n        if (\\n          !watchEdit('uraian_singkat') ||\\n          watchEdit('uraian_singkat').trim() === ''\\n        ) {\\n          alert('Uraian Singkat wajib diisi');\\n          isValid = false;\\n        }\\n\\n        if (!watchEdit('chronology') || watchEdit('chronology').length === 0) {\\n          alert('Minimal 1 kronologi wajib ditambahkan');\\n          isValid = false;\\n        } else {\\n          // Validasi setiap kronologi tidak boleh kosong\\n          const chronologyList = watchEdit('chronology') || [];\\n          const hasEmptyChronology = chronologyList.some(\\n            (item) => !item.description || item.description.trim() === '',\\n          );\\n          if (hasEmptyChronology) {\\n            alert('Semua kronologi harus diisi');\\n            isValid = false;\\n          }\\n        }\\n      } else if (selectedTipeLaporan === 'wabprof') {\\n        // Step 2 Wabprof: Pelanggaran Tindak Pidana\\n        if (!watchEdit('criminal_offense')) {\\n          alert('Pelanggaran Pidana wajib dipilih');\\n          isValid = false;\\n        } else if (watchEdit('criminal_offense') === 'ya') {\\n          // Validasi jika memilih \\\"Ya\\\"\\n          if (\\n            !watchEdit('criminal_lp_number') ||\\n            watchEdit('criminal_lp_number').trim() === ''\\n          ) {\\n            alert('No. LP Pidana wajib diisi');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('criminal_article') ||\\n            watchEdit('criminal_article').trim() === ''\\n          ) {\\n            alert('Pasal Pidana wajib diisi');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('criminal_article_description') ||\\n            watchEdit('criminal_article_description').trim() === ''\\n          ) {\\n            alert('Deskripsi Pasal wajib diisi');\\n            isValid = false;\\n          } else if (!watchEdit('criminal_process_status')) {\\n            alert('Status Proses Pidana wajib dipilih');\\n            isValid = false;\\n          } else if (\\n            watchEdit('criminal_process_status') === 'sudah_sidang' &&\\n            (!watchEdit('tanggal_putusan_sidang') ||\\n              watchEdit('tanggal_putusan_sidang').trim() === '')\\n          ) {\\n            alert('Tanggal Putusan Sidang wajib diisi');\\n            isValid = false;\\n          } else if (\\n            watchEdit('criminal_process_status') === 'sudah_sidang' &&\\n            (!watchEdit('nomor_putusan_pidana') ||\\n              watchEdit('nomor_putusan_pidana').trim() === '')\\n          ) {\\n            alert('Nomor Putusan Pidana wajib diisi');\\n            isValid = false;\\n          }\\n        }\\n      }\\n    } else if (step === 3) {\\n      // Step 3: Validasi berdasarkan tipe laporan\\n      if (selectedTipeLaporan === 'provos') {\\n        // Step 3 Provos: Penanggung Jawab (Yang Membuat Laporan, Pemeriksa, Peneliti)\\n\\n        // Validasi Yang Membuat Laporan\\n        if (\\n          !watchEdit('created_by_name') ||\\n          watchEdit('created_by_name').trim() === ''\\n        ) {\\n          alert('Nama Yang Membuat Laporan wajib diisi');\\n          isValid = false;\\n        } else if (\\n          !watchEdit('created_by_position') ||\\n          watchEdit('created_by_position').trim() === ''\\n        ) {\\n          alert('Jabatan Yang Membuat Laporan wajib diisi');\\n          isValid = false;\\n        } else if (\\n          !watchEdit('created_by_rank') ||\\n          watchEdit('created_by_rank').trim() === ''\\n        ) {\\n          alert('Pangkat Yang Membuat Laporan wajib dipilih');\\n          isValid = false;\\n        } else if (\\n          !watchEdit('created_by_nrp') ||\\n          watchEdit('created_by_nrp').trim() === ''\\n        ) {\\n          alert('NRP Yang Membuat Laporan wajib diisi');\\n          isValid = false;\\n        } else {\\n          const nrpCleaned = watchEdit('created_by_nrp').replace(/\\\\D/g, '');\\n          if (nrpCleaned.length !== 8) {\\n            alert('NRP Yang Membuat Laporan harus terdiri dari 8 angka');\\n            isValid = false;\\n          }\\n        }\\n\\n        if (\\n          isValid &&\\n          (!watchEdit('created_by_unit') ||\\n            watchEdit('created_by_unit').trim() === '')\\n        ) {\\n          alert('Kesatuan Yang Membuat Laporan wajib dipilih');\\n          isValid = false;\\n        }\\n\\n        // Validasi Pemeriksa\\n        if (isValid) {\\n          if (\\n            !watchEdit('acknowledged_by_name') ||\\n            watchEdit('acknowledged_by_name').trim() === ''\\n          ) {\\n            alert('Nama Pemeriksa wajib diisi');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('acknowledged_by_rank') ||\\n            watchEdit('acknowledged_by_rank').trim() === ''\\n          ) {\\n            alert('Pangkat Pemeriksa wajib dipilih');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('acknowledged_by_nrp') ||\\n            watchEdit('acknowledged_by_nrp').trim() === ''\\n          ) {\\n            alert('NRP Pemeriksa wajib diisi');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('acknowledged_by_unit') ||\\n            watchEdit('acknowledged_by_unit').trim() === ''\\n          ) {\\n            alert('Kesatuan Pemeriksa wajib dipilih');\\n            isValid = false;\\n          }\\n        }\\n\\n        // Validasi Peneliti\\n        if (isValid) {\\n          if (\\n            !watchEdit('examiner_name') ||\\n            watchEdit('examiner_name').trim() === ''\\n          ) {\\n            alert('Nama Peneliti wajib diisi');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('examiner_rank') ||\\n            watchEdit('examiner_rank').trim() === ''\\n          ) {\\n            alert('Pangkat Peneliti wajib dipilih');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('examiner_nrp') ||\\n            watchEdit('examiner_nrp').trim() === ''\\n          ) {\\n            alert('NRP Peneliti wajib diisi');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('examiner_unit') ||\\n            watchEdit('examiner_unit').trim() === ''\\n          ) {\\n            alert('Kesatuan Peneliti wajib dipilih');\\n            isValid = false;\\n          }\\n        }\\n      } else if (selectedTipeLaporan === 'wabprof') {\\n        // Step 3 Wabprof: Saksi & Bukti\\n\\n        // Validasi Saksi\\n        if (!watchEdit('witness') || watchEdit('witness').length === 0) {\\n          alert('Minimal 1 saksi wajib ditambahkan');\\n          isValid = false;\\n        } else {\\n          // Validasi setiap saksi tidak boleh kosong\\n          const witnessList = watchEdit('witness') || [];\\n          const hasEmptyWitness = witnessList.some(\\n            (item) => !item.name || item.name.trim() === '',\\n          );\\n          if (hasEmptyWitness) {\\n            alert('Semua nama saksi harus diisi');\\n            isValid = false;\\n          }\\n        }\\n\\n        // Validasi Barang Bukti\\n        if (isValid) {\\n          if (!watchEdit('evidence') || watchEdit('evidence').length === 0) {\\n            alert('Minimal 1 barang bukti wajib ditambahkan');\\n            isValid = false;\\n          } else {\\n            // Validasi setiap barang bukti tidak boleh kosong\\n            const evidenceList = watchEdit('evidence') || [];\\n            const hasEmptyEvidence = evidenceList.some(\\n              (item) => !item.name || item.name.trim() === '',\\n            );\\n            if (hasEmptyEvidence) {\\n              alert('Semua nama barang bukti harus diisi');\\n              isValid = false;\\n            }\\n          }\\n        }\\n      }\\n    } else if (step === 4) {\\n      // Step 4: Hanya untuk Wabprof - Validasi Penanggung Jawab\\n\\n      if (selectedTipeLaporan === 'wabprof') {\\n        // Validasi Mengetahui SAJA\\n\\n        if (\\n          !watchEdit('examiner_name') ||\\n          watchEdit('examiner_name').trim() === ''\\n        ) {\\n          alert('Nama Mengetahui wajib diisi');\\n          isValid = false;\\n        } else if (\\n          !watchEdit('examiner_rank') ||\\n          watchEdit('examiner_rank').trim() === ''\\n        ) {\\n          alert('Pangkat Mengetahui wajib dipilih');\\n          isValid = false;\\n        } else if (\\n          !watchEdit('examiner_nrp') ||\\n          watchEdit('examiner_nrp').trim() === ''\\n        ) {\\n          alert('NRP Mengetahui wajib diisi');\\n          isValid = false;\\n        } else {\\n          const nrpCleaned = watchEdit('examiner_nrp').replace(/\\\\D/g, '');\\n          if (nrpCleaned.length !== 8) {\\n            alert('NRP Mengetahui harus terdiri dari 8 angka');\\n            isValid = false;\\n          } else if (\\n            !watchEdit('examiner_unit') ||\\n            watchEdit('examiner_unit').trim() === ''\\n          ) {\\n            alert('Kesatuan Mengetahui wajib dipilih');\\n            isValid = false;\\n          }\\n        }\\n      }\\n    }\\n\\n    // Jika valid dan masih ada step selanjutnya\\n    if (isValid && step < maxStep) {\\n      setStep(step + 1);\\n    }\\n  };\\n\\n  const handlePrevious = () => {\\n    if (step > 1) {\\n      setStep(step - 1);\\n    }\\n  };\\n\\n  const attachmentData =\\n    report?.attachment?.length > 0\\n      ? report.attachment\\n      : report?.attachments?.map((f) => ({\\n          url: f.url,\\n          name: f.file_name,\\n        })) || [];\\n\\n  return (\\n    <>\\n      <div\\n        className=\\\"h-100\\\"\\n        style={{\\n          border: '1px solid var(--black-100)',\\n          borderRadius: '0.8rem',\\n          backgroundColor: 'var(--white)',\\n        }}\\n      >\\n        <div\\n          className=\\\"flex justify-between items-center\\\"\\n          style={{\\n            borderBottom: '1px solid var(--black-100)',\\n            padding: '12px 16px',\\n          }}\\n        >\\n          <div className=\\\"widget-title\\\">{widget?.name || 'Detail Laporan'}</div>\\n          <div className=\\\"d-flex gap-2 align-items-center\\\">\\n            <div className=\\\"card-ubahdata\\\" onClick={handleOpenEdit}>\\n              <i class=\\\"ph ph-pencil-simple-line\\\"></i>\\n              <div> Ubah Data</div>\\n            </div>\\n          </div>\\n        </div>\\n\\n        {/* Body */}\\n\\n        <BodyContainer>\\n          {/* Data Laporan */}\\n          <div className=\\\"subtitle\\\">Data Laporan</div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Tipe Laporan</div>\\n            <div className=\\\"value\\\">{report?.report_type || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Nomor Laporan</div>\\n            <div className=\\\"fs-12 fw-400\\\">{report?.report_number || '-'}</div>\\n          </div>\\n\\n          {/* Macam Pelanggaran - Hanya untuk Provos */}\\n          {policeFunction?.toLowerCase() !== 'wabprof' && (\\n            <div className=\\\"flex items-center\\\">\\n              <div className=\\\"information\\\">Macam Pelanggaran</div>\\n              <div className=\\\"fs-12 fw-400\\\">\\n                {report?.type_of_violation || '-'}\\n              </div>\\n            </div>\\n          )}\\n\\n          {/* Isi Laporan - Hanya untuk Wabprof */}\\n          {policeFunction?.toLowerCase() === 'wabprof' && (\\n            <div className=\\\"flex items-center\\\">\\n              <div className=\\\"information\\\">Isi Laporan</div>\\n              <div className=\\\"fs-12 fw-400\\\">{report?.report_detail || '-'}</div>\\n            </div>\\n          )}\\n\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Tanggal & Waktu</div>\\n            <div className=\\\"fs-12 fw-400\\\">\\n              {formatDateID(report?.datetime) || '-'}\\n            </div>\\n          </div>\\n\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Penerapan Pasal</div>\\n            <div className=\\\"fs-12 fw-400\\\">\\n              {report?.application_of_article || '-'}\\n            </div>\\n          </div>\\n          {/* \\n          <WrapperPasal>\\n            <div className=\\\"information mb-2\\\">PPRI No. 1 Tahun 2003</div>\\n            {articlesPPRI.length > 0 ? (\\n              <SelectedItemsList>\\n                {articlesPPRI.map((item, index) => (\\n                  <SelectedItemCard key={item.article_id || index}>\\n                    <SelectedItemContent>\\n                      <SelectedItemHeader>\\n                        <SelectedItemCode>\\n                          {item.kode_pasal || item.pasal || '-'}\\n                        </SelectedItemCode>\\n                        <DetailLink onClick={(e) => handleDetailClick(e, item)}>\\n                          Lihat detail\\n                        </DetailLink>\\n                      </SelectedItemHeader>\\n                    </SelectedItemContent>\\n                  </SelectedItemCard>\\n                ))}\\n              </SelectedItemsList>\\n            ) : (\\n              <div\\n                style={{\\n                  padding: '1rem',\\n                  textAlign: 'center',\\n                  color: 'var(--black-400)',\\n                  backgroundColor: 'var(--black-25)',\\n                  borderRadius: '0.5rem',\\n                  border: '1px dashed var(--black-100)',\\n                }}\\n              >\\n                <i\\n                  className=\\\"ph ph-file-text\\\"\\n                  style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n                ></i>\\n                <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                  Tidak ada pasal yang dikenakan\\n                </p>\\n              </div>\\n            )}\\n          </WrapperPasal> */}\\n          {report?.articles?.length > 0 ? (\\n            [...new Set(report.articles.map((a) => a.type))].map(\\n              (typePasal) => (\\n                <WrapperPasal key={typePasal}>\\n                  <div className=\\\"information mb-2\\\">{typePasal}</div>\\n                  <SelectedItemsList>\\n                    {report.articles\\n                      .filter((a) => a.type === typePasal)\\n                      .map((item, index) => (\\n                        <SelectedItemCard key={item.article_id || index}>\\n                          <SelectedItemContent>\\n                            <SelectedItemHeader>\\n                              <SelectedItemCode>\\n                                {item.kode_pasal || item.pasal || '-'}\\n                              </SelectedItemCode>\\n                              <DetailLink\\n                                onClick={(e) => handleDetailClick(e, item)}\\n                              >\\n                                Lihat detail\\n                              </DetailLink>\\n                            </SelectedItemHeader>\\n                          </SelectedItemContent>\\n                        </SelectedItemCard>\\n                      ))}\\n                  </SelectedItemsList>\\n                </WrapperPasal>\\n              ),\\n            )\\n          ) : (\\n            <div\\n              style={{\\n                padding: '1rem',\\n                textAlign: 'center',\\n                color: 'var(--black-400)',\\n                backgroundColor: 'var(--black-25)',\\n                borderRadius: '0.5rem',\\n                border: '1px dashed var(--black-100)',\\n              }}\\n            >\\n              <i\\n                className=\\\"ph ph-file-text\\\"\\n                style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n              ></i>\\n              <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                Tidak ada pasal yang dikenakan\\n              </p>\\n            </div>\\n          )}\\n\\n          {/* <WrapperPasal>\\n            <div className=\\\"information mb-2\\\">Pasal Perpol 7 Tahun 2022</div>\\n            {articlesPerpol.length > 0 ? (\\n              <SelectedItemsList>\\n                {articlesPerpol.map((item, index) => (\\n                  <SelectedItemCard key={item.article_id || index}>\\n                    <SelectedItemContent>\\n                      <SelectedItemHeader>\\n                        <SelectedItemCode>\\n                          {item.kode_pasal || item.pasal || 'Pasal'}\\n                        </SelectedItemCode>\\n                        <DetailLink onClick={(e) => handleDetailClick(e, item)}>\\n                          Lihat detail\\n                        </DetailLink>\\n                      </SelectedItemHeader>\\n                    </SelectedItemContent>\\n                  </SelectedItemCard>\\n                ))}\\n              </SelectedItemsList>\\n            ) : (\\n              <div\\n                style={{\\n                  padding: '1rem',\\n                  textAlign: 'center',\\n                  color: 'var(--black-400)',\\n                  backgroundColor: 'var(--black-25)',\\n                  borderRadius: '0.5rem',\\n                  border: '1px dashed var(--black-100)',\\n                }}\\n              >\\n                <i\\n                  className=\\\"ph ph-file-text\\\"\\n                  style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n                ></i>\\n                <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                  Tidak ada pasal yang dikenakan\\n                </p>\\n              </div>\\n            )}\\n          </WrapperPasal> */}\\n\\n          {/* Pasal Juncto - Hanya untuk Wabprof */}\\n          {policeFunction?.toLowerCase() === 'wabprof' &&\\n            report?.prepetrator_id_article_juncto?.length > 0 && (\\n              <WrapperPasal>\\n                <div className=\\\"information mb-2\\\">\\n                  Pasal Juncto Perpol 7 Tahun 2022\\n                </div>\\n                <SelectedItemsList>\\n                  {(Array.isArray(report.prepetrator_id_article_juncto)\\n                    ? report.prepetrator_id_article_juncto\\n                    : []\\n                  ).map((item, index) => {\\n                    const pasalItem =\\n                      typeof item === 'object'\\n                        ? item\\n                        : { kode_pasal: item, description: item };\\n                    return (\\n                      <SelectedItemCard key={index}>\\n                        <SelectedItemContent>\\n                          <SelectedItemHeader>\\n                            <SelectedItemCode>\\n                              {pasalItem.kode_pasal || pasalItem || '-'}\\n                            </SelectedItemCode>\\n                            {pasalItem.description && (\\n                              <DetailLink\\n                                onClick={(e) => handleDetailClick(e, pasalItem)}\\n                              >\\n                                Lihat detail\\n                              </DetailLink>\\n                            )}\\n                          </SelectedItemHeader>\\n                        </SelectedItemContent>\\n                      </SelectedItemCard>\\n                    );\\n                  })}\\n                </SelectedItemsList>\\n              </WrapperPasal>\\n            )}\\n\\n          {/* Hanya Provos yang punya Kronologi Singkat */}\\n          {policeFunction?.toLowerCase() !== 'wabprof' && (\\n            <>\\n              <hr style={{ border: '1px solid var(--black-100)' }} />\\n              <div className=\\\"flex flex-column\\\">\\n                <div className=\\\"subtitle\\\">Kronologi Singkat</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.short_description || '-'}\\n                </div>\\n              </div>\\n            </>\\n          )}\\n          {/* ==================== PELANGGARAN TINDAK PIDANA (WABPROF ONLY) ==================== */}\\n          {policeFunction?.toLowerCase() === 'wabprof' && (\\n            <>\\n              <hr\\n                style={{\\n                  border: '1px solid var(--black-200)',\\n                  marginTop: '1rem',\\n                  marginBottom: '1rem',\\n                }}\\n              />\\n\\n              {/* <div className=\\\"subtitle\\\">Pelanggaran Tindak Pidana</div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Pelanggaran Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.criminal_offense || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">No. LP Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.criminal_lp_number || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Pasal Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.criminal_article || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Status Proses Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.criminal_process_status || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Tanggal Putusan Sidang</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.hearing_decision_date\\n                    ? formatDateID(report?.hearing_decision_date)\\n                    : '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Nomor Putusan Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.decision_number || '-'}\\n                </div>\\n              </div> */}\\n\\n              <div className=\\\"subtitle\\\">Pelanggaran Tindak Pidana</div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Pelanggaran Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {policeReportData?.criminal_offense ||\\n                    report?.criminal_offense ||\\n                    '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">No. LP Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {policeReportData?.criminal_lp_number || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Pasal Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {policeReportData?.criminal_article || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Deskripsi Pasal</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {policeReportData?.criminal_article_description || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Status Proses Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {policeReportData?.criminal_process_status || '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Tanggal Putusan Sidang</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.hearing_decision_date\\n                    ? formatDateID(report?.hearing_decision_date)\\n                    : '-'}\\n                </div>\\n              </div>\\n\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Nomor Putusan Pidana</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {report?.decision_number || '-'}\\n                </div>\\n              </div>\\n\\n              {/* Dokumen Pidana */}\\n              <div className=\\\"flex flex-column\\\">\\n                <div className=\\\"information mb-2\\\">Dokumen Pidana</div>\\n                <div className=\\\"d-flex flex-wrap gap-2\\\">\\n                  {Array.isArray(attachmentData) &&\\n                  attachmentData.length > 0 ? (\\n                    attachmentData.map((doc, idx) => (\\n                      <div\\n                        key={idx}\\n                        className=\\\"d-flex align-items-center gap-2\\\"\\n                      >\\n                        <i\\n                          className=\\\"ph ph-file-text\\\"\\n                          style={{ color: 'var(--primary)' }}\\n                        ></i>\\n                        <a\\n                          href={doc.url}\\n                          target=\\\"_blank\\\"\\n                          rel=\\\"noopener noreferrer\\\"\\n                          style={{\\n                            fontSize: '0.875rem',\\n                            color: 'var(--primary)',\\n                            textDecoration: 'none',\\n                          }}\\n                        >\\n                          {doc.name || `Dokumen ${idx + 1}`}\\n                        </a>\\n                      </div>\\n                    ))\\n                  ) : (\\n                    <div\\n                      className=\\\"fs-12 fw-400\\\"\\n                      style={{ color: 'var(--black-400)' }}\\n                    >\\n                      -\\n                    </div>\\n                  )}\\n                </div>\\n              </div>\\n\\n              <hr\\n                style={{\\n                  border: '1px solid var(--black-200)',\\n                  marginTop: '1rem',\\n                  marginBottom: '1rem',\\n                }}\\n              />\\n\\n              {/* ==================== SAKSI & BUKTI (WABPROF ONLY) ==================== */}\\n              <div className=\\\"subtitle\\\">Saksi & Bukti</div>\\n\\n              <Row className=\\\"align-items-stretch\\\">\\n                <Col md={6}>\\n                  <CardWrapper style={{ height: '100%' }}>\\n                    <div className=\\\"flex flex-column\\\">\\n                      <div className=\\\"information mb-2\\\">Saksi</div>\\n                      <div className=\\\"d-flex flex-wrap gap-2\\\">\\n                        {Array.isArray(report?.witness) &&\\n                        report.witness.length > 0 ? (\\n                          report.witness.map((witness, idx) => (\\n                            <div key={idx}>\\n                              {idx + 1}.{' '}\\n                              {typeof witness === 'string'\\n                                ? witness\\n                                : witness.name || '-'}\\n                            </div>\\n                          ))\\n                        ) : (\\n                          <div\\n                            className=\\\"fs-12 fw-400\\\"\\n                            style={{ color: 'var(--black-400)' }}\\n                          >\\n                            -\\n                          </div>\\n                        )}\\n                      </div>\\n                    </div>\\n                  </CardWrapper>\\n                </Col>\\n\\n                <Col md={6}>\\n                  <CardWrapper style={{ height: '100%' }}>\\n                    <div className=\\\"flex flex-column\\\">\\n                      <div className=\\\"information mb-2\\\">Barang Bukti</div>\\n                      <div className=\\\"d-flex flex-wrap gap-2\\\">\\n                        {Array.isArray(report?.evidence) &&\\n                        report.evidence.length > 0 ? (\\n                          report.evidence.map((evidence, idx) => (\\n                            <div key={idx}>\\n                              {idx + 1}.{' '}\\n                              {typeof evidence === 'string'\\n                                ? evidence\\n                                : evidence.name || '-'}\\n                            </div>\\n                          ))\\n                        ) : (\\n                          <div\\n                            className=\\\"fs-12 fw-400\\\"\\n                            style={{ color: 'var(--black-400)' }}\\n                          >\\n                            -\\n                          </div>\\n                        )}\\n                      </div>\\n                    </div>\\n                  </CardWrapper>\\n                </Col>\\n              </Row>\\n            </>\\n          )}\\n          <hr\\n            style={{\\n              border: '1px solid var(--black-200)',\\n              marginTop: '1rem',\\n              marginBottom: '1rem',\\n            }}\\n          />\\n\\n          {/* ==================== PENANGGUNG JAWAB ==================== */}\\n          <div className=\\\"subtitle\\\">Penanggung Jawab</div>\\n\\n          {/* Yang Membuat Laporan - Ada untuk semua tipe */}\\n          <div className=\\\"subtitle\\\" style={{ marginTop: '0.5rem' }}>\\n            Yang Membuat Laporan\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Nama</div>\\n            <div className=\\\"fs-12 fw-400\\\">{createdBy?.name || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Pangkat</div>\\n            <div className=\\\"fs-12 fw-400\\\">{createdBy?.rank || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">NRP</div>\\n            <div className=\\\"fs-12 fw-400\\\">{createdBy?.nrp || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Kesatuan</div>\\n            <div className=\\\"fs-12 fw-400\\\">{createdBy?.unit || '-'}</div>\\n          </div>\\n\\n          <hr style={{ border: '1px solid var(--black-100)' }} />\\n\\n          {/* Pemeriksa - HANYA untuk Provos (bukan Wabprof) */}\\n          {policeFunction?.toLowerCase() !== 'wabprof' && (\\n            <>\\n              <div className=\\\"subtitle\\\">Pemeriksa</div>\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Nama</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {acknowledgedBy?.name || '-'}\\n                </div>\\n              </div>\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Pangkat</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {acknowledgedBy?.rank || '-'}\\n                </div>\\n              </div>\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">NRP</div>\\n                <div className=\\\"fs-12 fw-400\\\">{acknowledgedBy?.nrp || '-'}</div>\\n              </div>\\n              <div className=\\\"flex items-center\\\">\\n                <div className=\\\"information\\\">Kesatuan</div>\\n                <div className=\\\"fs-12 fw-400\\\">\\n                  {acknowledgedBy?.unit || '-'}\\n                </div>\\n              </div>\\n              <hr style={{ border: '1px solid var(--black-100)' }} />\\n            </>\\n          )}\\n\\n          {/* Peneliti (untuk Provos) / Mengetahui (untuk Wabprof) */}\\n          <div className=\\\"subtitle\\\">Mengetahui</div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Nama</div>\\n            <div className=\\\"fs-12 fw-400\\\">{acknowledgedBy?.name || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Pangkat</div>\\n            <div className=\\\"fs-12 fw-400\\\">{acknowledgedBy?.rank || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">NRP</div>\\n            <div className=\\\"fs-12 fw-400\\\">{acknowledgedBy?.nrp || '-'}</div>\\n          </div>\\n          <div className=\\\"flex items-center\\\">\\n            <div className=\\\"information\\\">Kesatuan</div>\\n            <div className=\\\"fs-12 fw-400\\\">{acknowledgedBy?.unit || '-'}</div>\\n          </div>\\n        </BodyContainer>\\n      </div>\\n\\n      <StyledModal centered size=\\\"lg\\\" show={showModal} onHide={handleCloseEdit}>\\n        <Form onSubmit={handleSubmitEdit(onSubmitEdit)}>\\n          <ModalHeader closeButton>\\n            <WrappIcon>\\n              <i\\n                className=\\\"ph-duotone ph-user\\\"\\n                style={{ fontSize: '1.6rem', color: 'var(--primary)' }}\\n              ></i>\\n            </WrappIcon>\\n            <div className=\\\"d-flex flex-column gap-1\\\">\\n              <TitleHeader>Input Laporan Polisi</TitleHeader>\\n              <DescHeader>Sesuaikan isi laporan</DescHeader>\\n            </div>\\n          </ModalHeader>\\n          <ModalBody>\\n            <TitleInput\\n              className=\\\"pb-2\\\"\\n              style={{ color: 'var(--black-600)', fontSize: '1.14286rem' }}\\n            >\\n              {selectedTipeLaporan === 'provos' && (\\n                <>\\n                  {step === 1 && 'Data Laporan'}\\n                  {step === 2 && 'Kronologi & Uraian Singkat'}\\n                  {step === 3 && 'Penanggung Jawab'}\\n                </>\\n              )}\\n              {selectedTipeLaporan === 'wabprof' && (\\n                <>\\n                  {step === 1 && 'Data Laporan'}\\n                  {step === 2 && 'Pelanggaran Tindak Pidana'}\\n                  {step === 3 && 'Saksi & Bukti'}\\n                  {step === 4 && 'Penanggung Jawab'}\\n                </>\\n              )}\\n            </TitleInput>\\n\\n            {/* RADIO BUTTON TIPE LAPORAN DAN TIPE TERLAPOR - HANYA DI STEP 1 */}\\n            {step === 1 && (\\n              <div className=\\\"d-flex flex-column flex-md-row justify-content-between gap-3 mb-4 w-100\\\">\\n                {/* Kolom 1 - Tipe Laporan (Selalu tampil di Step 1) */}\\n                <div\\n                  className=\\\"d-flex flex-column\\\"\\n                  style={{ width: '100%', maxWidth: '48%' }}\\n                >\\n                  <Form.Group className=\\\"d-flex flex-column gap-2 w-100\\\">\\n                    <TitleInput className=\\\"mb-3\\\">\\n                      Tipe Laporan <span className=\\\"text-danger\\\">*</span>\\n                    </TitleInput>\\n\\n                    <div className=\\\"d-flex gap-2\\\">\\n                      <RadioButtonContainer\\n                        isSelected={selectedTipeLaporan === 'provos'}\\n                        onClick={() =>\\n                          !isTipeLaporanDisabled &&\\n                          setSelectedTipeLaporan('provos')\\n                        }\\n                        type=\\\"button\\\"\\n                        disabled={isTipeLaporanDisabled}\\n                        style={{\\n                          opacity: isTipeLaporanDisabled ? 0.6 : 1,\\n                          cursor: isTipeLaporanDisabled\\n                            ? 'not-allowed'\\n                            : 'pointer',\\n                        }}\\n                      >\\n                        <FormCheckStyled\\n                          type=\\\"radio\\\"\\n                          checked={selectedTipeLaporan === 'provos'}\\n                          onChange={() =>\\n                            !isTipeLaporanDisabled &&\\n                            setSelectedTipeLaporan('provos')\\n                          }\\n                          name=\\\"tipe-laporan\\\"\\n                          disabled={isTipeLaporanDisabled}\\n                        />\\n                        <p>Provos</p>\\n                      </RadioButtonContainer>\\n\\n                      <RadioButtonContainer\\n                        isSelected={selectedTipeLaporan === 'wabprof'}\\n                        onClick={() =>\\n                          !isTipeLaporanDisabled &&\\n                          setSelectedTipeLaporan('wabprof')\\n                        }\\n                        type=\\\"button\\\"\\n                        disabled={isTipeLaporanDisabled}\\n                        style={{\\n                          opacity: isTipeLaporanDisabled ? 0.6 : 1,\\n                          cursor: isTipeLaporanDisabled\\n                            ? 'not-allowed'\\n                            : 'pointer',\\n                        }}\\n                      >\\n                        <FormCheckStyled\\n                          type=\\\"radio\\\"\\n                          checked={selectedTipeLaporan === 'wabprof'}\\n                          onChange={() =>\\n                            !isTipeLaporanDisabled &&\\n                            setSelectedTipeLaporan('wabprof')\\n                          }\\n                          name=\\\"tipe-laporan\\\"\\n                          disabled={isTipeLaporanDisabled}\\n                        />\\n                        <p>Wabprof</p>\\n                      </RadioButtonContainer>\\n                    </div>\\n                  </Form.Group>\\n                </div>\\n\\n                {/* Kolom 2 - Tipe Terlapor (Hanya untuk Provos dan hanya di Step 1) */}\\n                {/* Kolom 2 - Tipe Terlapor (Hanya untuk Provos dan hanya di Step 1) */}\\n                {selectedTipeLaporan === 'provos' && (\\n                  <div\\n                    className=\\\"d-flex flex-column\\\"\\n                    style={{ width: '100%', maxWidth: '48%' }}\\n                  >\\n                    <Form.Group className=\\\"d-flex flex-column gap-2 w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">\\n                        Tipe Terlapor <span className=\\\"text-danger\\\">*</span>\\n                      </TitleInput>\\n\\n                      <Controller\\n                        name=\\\"urgency_score_category\\\"\\n                        control={controlEdit}\\n                        rules={{ required: 'Tipe Terlapor wajib dipilih' }}\\n                        render={({ field }) => (\\n                          <>\\n                            <div className=\\\"d-flex gap-2 w-100\\\">\\n                              <RadioButtonContainer\\n                                isSelected={field.value === 'Anggota Polri'}\\n                                onClick={() => {\\n                                  // Tidak melakukan apa-apa karena disabled\\n                                }}\\n                                type=\\\"button\\\"\\n                                disabled={true} // Tambahkan ini\\n                                style={{\\n                                  opacity: 0.6, // Tambahkan ini\\n                                  cursor: 'not-allowed', // Tambahkan ini\\n                                }}\\n                              >\\n                                <FormCheckStyled\\n                                  type=\\\"radio\\\"\\n                                  checked={field.value === 'Anggota Polri'}\\n                                  onChange={() => {\\n                                    // Tidak melakukan apa-apa karena disabled\\n                                  }}\\n                                  name=\\\"tipe-terlapor\\\"\\n                                  disabled={true} // Tambahkan ini\\n                                />\\n                                <p>Anggota Polri</p>\\n                              </RadioButtonContainer>\\n\\n                              <RadioButtonContainer\\n                                isSelected={field.value === 'Asn Polri'}\\n                                onClick={() => {\\n                                  // Tidak melakukan apa-apa karena disabled\\n                                }}\\n                                type=\\\"button\\\"\\n                                disabled={true} // Tambahkan ini\\n                                style={{\\n                                  opacity: 0.6, // Tambahkan ini\\n                                  cursor: 'not-allowed', // Tambahkan ini\\n                                }}\\n                              >\\n                                <FormCheckStyled\\n                                  type=\\\"radio\\\"\\n                                  checked={field.value === 'Asn Polri'}\\n                                  onChange={() => {\\n                                    // Tidak melakukan apa-apa karena disabled\\n                                  }}\\n                                  name=\\\"tipe-terlapor\\\"\\n                                  disabled={true} // Tambahkan ini\\n                                />\\n                                <p>ASN Polri</p>\\n                              </RadioButtonContainer>\\n                            </div>\\n\\n                            {errorsEdit.urgency_score_category && (\\n                              <ErrorText>\\n                                {errorsEdit.urgency_score_category.message}\\n                              </ErrorText>\\n                            )}\\n                          </>\\n                        )}\\n                      />\\n                    </Form.Group>\\n                  </div>\\n                )}\\n              </div>\\n            )}\\n\\n            {/* STEP 1 - Provos */}\\n            {step === 1 && selectedTipeLaporan === 'provos' && (\\n              <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                {/* Macam Pelanggaran */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Macam Pelanggaran</TitleInput>\\n                  <StyledTextarea\\n                    type=\\\"text\\\"\\n                    as={'textarea'}\\n                    rows={2}\\n                    placeholder=\\\"Macam Pelanggaran\\\"\\n                    {...registerEdit('type_of_violation')}\\n                  />\\n                </Form.Group>\\n\\n                {/* Tanggal & Waktu */}\\n                <Form.Group>\\n                  <TitleInput className=\\\"mb-3\\\">Tanggal dan Waktu</TitleInput>\\n                  <NativeDateWrapper>\\n                    <DateIconAddon>\\n                      <i className=\\\"ph ph-calendar-blank\\\"></i>\\n                    </DateIconAddon>\\n                    <StyledDatePicker\\n                      showTime\\n                      format=\\\"YYYY-MM-DD HH:mm\\\"\\n                      {...registerEdit('datetime')}\\n                      value={\\n                        watchEdit('datetime')\\n                          ? dayjs(watchEdit('datetime'))\\n                          : null\\n                      }\\n                      onChange={(date) => {\\n                        setValueEdit(\\n                          'datetime',\\n                          date ? date.toISOString() : null,\\n                        );\\n                      }}\\n                    />\\n                  </NativeDateWrapper>\\n                </Form.Group>\\n\\n                <hr\\n                  style={{\\n                    color: 'var(--black-200)',\\n                    marginTop: '1rem',\\n                    marginBottom: '1rem',\\n                  }}\\n                />\\n\\n                {/* Penerapan Pasal (Display Only - Disabled) */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Penerapan Pasal</TitleInput>\\n                  <div className=\\\"d-flex gap-2 w-100\\\">\\n                    <RadioButtonContainer\\n                      isSelected={\\n                        watchEdit('application_of_article') === 'kode-etik'\\n                      }\\n                      onClick={() => {}}\\n                      type=\\\"button\\\"\\n                      disabled\\n                      style={{ opacity: 0.6, cursor: 'not-allowed' }}\\n                    >\\n                      <FormCheckStyled\\n                        type=\\\"radio\\\"\\n                        checked={\\n                          watchEdit('application_of_article') === 'kode-etik'\\n                        }\\n                        onChange={() => {}}\\n                        name=\\\"penerapan-pasal\\\"\\n                        disabled\\n                      />\\n                      <p>Kode Etik</p>\\n                    </RadioButtonContainer>\\n\\n                    <RadioButtonContainer\\n                      isSelected={\\n                        watchEdit('application_of_article') === 'disiplin'\\n                      }\\n                      onClick={() => {}}\\n                      type=\\\"button\\\"\\n                      disabled\\n                      style={{ opacity: 0.6, cursor: 'not-allowed' }}\\n                    >\\n                      <FormCheckStyled\\n                        type=\\\"radio\\\"\\n                        checked={\\n                          watchEdit('application_of_article') === 'disiplin'\\n                        }\\n                        onChange={() => {}}\\n                        name=\\\"penerapan-pasal\\\"\\n                        disabled\\n                      />\\n                      <p>Disiplin</p>\\n                    </RadioButtonContainer>\\n                  </div>\\n                </Form.Group>\\n\\n                {/* Pasal menggunakan PasalSelect untuk preview design */}\\n                {selectedTipeTerlapor === 'Anggota Polri' && (\\n                  <>\\n                    {watchEdit('application_of_article') === 'kode-etik' && (\\n                      <>\\n                        <Form.Group className=\\\"w-100\\\">\\n                          <PasalSelect\\n                            control={controlEdit}\\n                            name=\\\"pasal_perpol\\\"\\n                            label=\\\"PERPOL NOMOR 7 TH 2022\\\"\\n                            placeholder=\\\"Pilih pasal\\\"\\n                            filterType=\\\"PERPOL NOMOR 7 TH 2022\\\"\\n                            pasalOptions={pasalOptions}\\n                          />\\n                        </Form.Group>\\n                      </>\\n                    )}\\n\\n                    {watchEdit('application_of_article') === 'disiplin' && (\\n                      <>\\n                        <Form.Group className=\\\"w-100\\\">\\n                          <PasalSelect\\n                            control={controlEdit}\\n                            name=\\\"pasal_ppri\\\"\\n                            label=\\\"PPRI NOMOR 2 TAHUN 2003\\\"\\n                            placeholder=\\\"Pilih pasal\\\"\\n                            filterType=\\\"PPRI NOMOR 2 TAHUN 2003\\\"\\n                            pasalOptions={pasalOptions}\\n                          />\\n                        </Form.Group>\\n                      </>\\n                    )}\\n                  </>\\n                )}\\n\\n                {selectedTipeTerlapor === 'Asn Polri' && (\\n                  <>\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <PasalSelect\\n                        control={controlEdit}\\n                        name=\\\"pasal_disiplin_perpol\\\"\\n                        label=\\\"PPRI NOMOR 94 TAHUN 2021\\\"\\n                        placeholder=\\\"Pilih pasal disiplin\\\"\\n                        filterType=\\\"PPRI NOMOR 94 TAHUN 2021\\\"\\n                        pasalOptions={pasalOptions}\\n                      />\\n                    </Form.Group>\\n                  </>\\n                )}\\n\\n                {/* Hidden Input */}\\n                <Form.Control\\n                  type=\\\"hidden\\\"\\n                  {...registerEdit('prepetrator_id')}\\n                />\\n              </div>\\n            )}\\n\\n            {/* STEP 1 - Wabprof */}\\n\\n            {step === 1 && selectedTipeLaporan === 'wabprof' && (\\n              <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                {/* Tanggal & Waktu */}\\n                <Form.Group>\\n                  <TitleInput className=\\\"mb-3\\\">Tanggal dan Waktu</TitleInput>\\n                  <NativeDateWrapper>\\n                    <DateIconAddon>\\n                      <i className=\\\"ph ph-calendar-blank\\\"></i>\\n                    </DateIconAddon>\\n                    <StyledDatePicker\\n                      showTime\\n                      format=\\\"YYYY-MM-DD HH:mm\\\"\\n                      {...registerEdit('datetime')}\\n                      value={\\n                        watchEdit('datetime')\\n                          ? dayjs(watchEdit('datetime'))\\n                          : null\\n                      }\\n                      onChange={(date) => {\\n                        setValueEdit(\\n                          'datetime',\\n                          date ? date.toISOString() : null,\\n                        );\\n                      }}\\n                    />\\n                  </NativeDateWrapper>\\n                </Form.Group>\\n\\n                <hr\\n                  style={{\\n                    borderColor: 'var(--black-100)',\\n                    marginTop: '1rem',\\n                    marginBottom: '1rem',\\n                  }}\\n                />\\n\\n                {/* Data Terlapor - DUMMY & DISABLED */}\\n                <TitleInput className=\\\"mb-0\\\">Data Terlapor</TitleInput>\\n\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                  <StyledInput\\n                    type=\\\"text\\\"\\n                    placeholder=\\\"Nama\\\"\\n                    {...registerEdit('prepetrator_name')}\\n                    value={dataTerlapor?.[0]?.name || ''}\\n                    disabled\\n                  />\\n                </Form.Group>\\n\\n                {/* Pangkat & NRP - DISABLED */}\\n                <Row className=\\\"g-3\\\">\\n                  <Col md={6}>\\n                    <Form.Group>\\n                      <LabelInput className=\\\"mb-3\\\">Pangkat</LabelInput>\\n                      <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"Pangkat\\\"\\n                        {...registerEdit('prepetrator_rank')}\\n                        value={dataTerlapor?.[0]?.rank || ''}\\n                        disabled\\n                      />\\n                    </Form.Group>\\n                  </Col>\\n                  <Col md={6}>\\n                    <Form.Group>\\n                      <TitleInput className=\\\"mb-3\\\">NRP</TitleInput>\\n                      <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"NRP\\\"\\n                        {...registerEdit('prepetrator_nrp')}\\n                        value={dataTerlapor?.[0]?.identity_number || ''}\\n                        disabled\\n                      />\\n                    </Form.Group>\\n                  </Col>\\n                </Row>\\n\\n                {/* Jabatan & Fungsi - DISABLED */}\\n                <Row className=\\\"g-3\\\">\\n                  <Col md={6}>\\n                    <Form.Group>\\n                      <TitleInput className=\\\"mb-3\\\">Jabatan</TitleInput>\\n                      <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"Jabatan\\\"\\n                        {...registerEdit('prepetrator_position')}\\n                        value={dataTerlapor?.[0]?.position || ''}\\n                        disabled\\n                      />\\n                    </Form.Group>\\n                  </Col>\\n                  <Col md={6}>\\n                    <Form.Group>\\n                      <LabelInput className=\\\"mb-3\\\">Fungsi</LabelInput>\\n                      <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"Fungsi\\\"\\n                        {...registerEdit('prepetrator_functional_assignment')}\\n                        value={dataTerlapor?.[0]?.functional_assignment || ''}\\n                        disabled\\n                      />\\n                    </Form.Group>\\n                  </Col>\\n                </Row>\\n\\n                <hr\\n                  style={{\\n                    borderColor: 'var(--black-100)',\\n                    marginTop: '1rem',\\n                    marginBottom: '1rem',\\n                  }}\\n                />\\n\\n                {/* Isi Laporan */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Isi Laporan</TitleInput>\\n                  <StyledTextarea\\n                    type=\\\"text\\\"\\n                    as={'textarea'}\\n                    rows={2}\\n                    placeholder=\\\"Isi Laporan\\\"\\n                    {...registerEdit('report_detail')}\\n                  />\\n                </Form.Group>\\n\\n                {/* Penerapan Pasal (Display Only) */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Penerapan Pasal</TitleInput>\\n                  <div className=\\\"d-flex gap-2 w-100\\\">\\n                    <RadioButtonContainer\\n                      isSelected={\\n                        watchEdit('application_of_article') === 'kode-etik'\\n                      }\\n                      onClick={() => {}}\\n                      type=\\\"button\\\"\\n                      disabled\\n                      style={{ opacity: 0.6, cursor: 'not-allowed' }}\\n                    >\\n                      <FormCheckStyled\\n                        type=\\\"radio\\\"\\n                        checked={\\n                          watchEdit('application_of_article') === 'kode-etik'\\n                        }\\n                        onChange={() => {}}\\n                        name=\\\"penerapan-pasal\\\"\\n                        disabled\\n                      />\\n                      <p>Kode Etik</p>\\n                    </RadioButtonContainer>\\n\\n                    <RadioButtonContainer\\n                      isSelected={\\n                        watchEdit('application_of_article') === 'disiplin'\\n                      }\\n                      onClick={() => {}}\\n                      type=\\\"button\\\"\\n                      disabled\\n                      style={{ opacity: 0.6, cursor: 'not-allowed' }}\\n                    >\\n                      <FormCheckStyled\\n                        type=\\\"radio\\\"\\n                        checked={\\n                          watchEdit('application_of_article') === 'disiplin'\\n                        }\\n                        onChange={() => {}}\\n                        name=\\\"penerapan-pasal\\\"\\n                        disabled\\n                      />\\n                      <p>Disiplin</p>\\n                    </RadioButtonContainer>\\n                  </div>\\n                </Form.Group>\\n\\n                {/* Pasal PPRI No. 1 Tahun 2003 - Display Only */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <PasalSelect\\n                    control={controlEdit}\\n                    name=\\\"pasal_ppri\\\"\\n                    label=\\\"Pasal PPRI No. 1 Tahun 2003\\\"\\n                    placeholder=\\\"Pilih pasal\\\"\\n                    filterType=\\\"PPRI NOMOR 1 TAHUN 2003\\\"\\n                    pasalOptions={pasalOptions}\\n                  />\\n                </Form.Group>\\n\\n                {/* Pasal Perpol 7 Tahun 2022 - Display Only */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <PasalSelect\\n                    control={controlEdit}\\n                    name=\\\"pasal_perpol\\\"\\n                    label=\\\"Pasal Perpol 7 Tahun 2022\\\"\\n                    placeholder=\\\"Pilih pasal\\\"\\n                    filterType=\\\"PERPOL NOMOR 7 TH 2022\\\"\\n                    pasalOptions={pasalOptions}\\n                  />\\n                </Form.Group>\\n\\n                {/* NEW: Pasal Juncto Perpol 7 Tahun 2022 - Selectable */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <PasalSelectable\\n                    control={controlEdit}\\n                    name=\\\"prepetrator_id_article_juncto\\\"\\n                    label=\\\"Pasal Juncto Perpol 7 Tahun 2022\\\"\\n                    placeholder=\\\"Cari dan pilih pasal...\\\"\\n                    filterType=\\\"PERPOL NOMOR 7 TH 2022\\\"\\n                    initialValue={(() => {\\n                      // Ambil data Juncto dari report\\n                      const junctoData =\\n                        report?.prepetrator_id_article_juncto || [];\\n                      if (Array.isArray(junctoData) && junctoData.length > 0) {\\n                        return junctoData.map((item) => ({\\n                          value: item.article_id || item.id || item,\\n                          kode_pasal: item.kode_pasal,\\n                          description: item.description,\\n                          ...item,\\n                        }));\\n                      }\\n                      return [];\\n                    })()}\\n                    isMulti={true}\\n                    isLoading={loadingPasalAPI}\\n                  />\\n                </Form.Group>\\n\\n                {/* Hidden Input */}\\n                <Form.Control\\n                  type=\\\"hidden\\\"\\n                  {...registerEdit('prepetrator_id')}\\n                />\\n              </div>\\n            )}\\n            {/* STEP 2 - Provos: Kronologi */}\\n            {step === 2 && selectedTipeLaporan === 'provos' && (\\n              <>\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Uraian Singkat</TitleInput>\\n                  <StyledTextarea\\n                    as=\\\"textarea\\\"\\n                    rows={4}\\n                    placeholder=\\\"Masukan Catatan\\\"\\n                    {...registerEdit('uraian_singkat', {\\n                      required: 'Catatan wajib diisi',\\n                    })}\\n                  />\\n                  {errors.uraian_singkat && (\\n                    <div className=\\\"text-danger\\\">\\n                      {errors.uraian_singkat.message}\\n                    </div>\\n                  )}\\n                </Form.Group>\\n                <Form.Group className=\\\"w-100\\\">\\n                  <div className=\\\"d-flex justify-content-between align-items-center mb-3\\\">\\n                    <TitleInput>Kronologi</TitleInput>\\n                    <button\\n                      type=\\\"button\\\"\\n                      onClick={() => {\\n                        const current = watchEdit('chronology') || [];\\n                        setValueEdit('chronology', [\\n                          ...current,\\n                          { description: '' },\\n                        ]);\\n                      }}\\n                      style={{\\n                        background: 'none',\\n                        border: 'none',\\n                        color: 'var(--primary)',\\n                        fontWeight: '600',\\n                        cursor: 'pointer',\\n                        padding: 0,\\n                        fontSize: '0.875rem',\\n                      }}\\n                    >\\n                      + Tambah Kronologi\\n                    </button>\\n                  </div>\\n\\n                  {(watchEdit('chronology') || []).length > 0 ? (\\n                    <div\\n                      style={{\\n                        display: 'flex',\\n                        flexDirection: 'column',\\n                        gap: '0.75rem',\\n                      }}\\n                    >\\n                      {(watchEdit('chronology') || []).map((item, index) => (\\n                        <div\\n                          key={index}\\n                          style={{\\n                            width: '100%',\\n                            padding: '1rem',\\n                            background: 'var(--white)',\\n                            overflow: 'hidden',\\n                            borderRadius: 10,\\n                            outline: '1px var(--black-100) solid',\\n                            outlineOffset: '-1px',\\n                            justifyContent: 'flex-start',\\n                            alignItems: 'flex-start',\\n                            gap: 8,\\n                            display: 'inline-flex',\\n                          }}\\n                        >\\n                          <CustomStyledTextarea\\n                            as=\\\"textarea\\\"\\n                            rows={2}\\n                            placeholder=\\\"Masukkan kronologi\\\"\\n                            value={item.description || ''}\\n                            onChange={(e) => {\\n                              const current = watchEdit('chronology') || [];\\n                              const updated = current.map((item, i) =>\\n                                i === index\\n                                  ? { ...item, description: e.target.value }\\n                                  : item,\\n                              );\\n                              setValueEdit('chronology', updated);\\n                            }}\\n                            style={{\\n                              flex: '1 1 0',\\n                              padding: '0rem',\\n                            }}\\n                          />\\n                          <button\\n                            type=\\\"button\\\"\\n                            onClick={() => {\\n                              const updated = (\\n                                watchEdit('chronology') || []\\n                              ).filter((_, i) => i !== index);\\n                              setValueEdit('chronology', updated);\\n                            }}\\n                            style={{\\n                              width: 16,\\n                              justifyContent: 'flex-start',\\n                              alignItems: 'center',\\n                              gap: 10,\\n                              display: 'flex',\\n                              background: 'none',\\n                              border: 'none',\\n                              cursor: 'pointer',\\n                              padding: 0,\\n                              minWidth: 16,\\n                              flexShrink: 0,\\n                            }}\\n                          >\\n                            <i className=\\\"ph ph-x\\\" style={{ fontSize: 16 }}></i>\\n                          </button>\\n                        </div>\\n                      ))}\\n                    </div>\\n                  ) : (\\n                    <div\\n                      style={{\\n                        padding: '1rem',\\n                        textAlign: 'center',\\n                        color: 'var(--black-400)',\\n                        backgroundColor: 'var(--black-25)',\\n                        borderRadius: '0.5rem',\\n                        border: '1px dashed var(--black-100)',\\n                        fontSize: '0.875rem',\\n                      }}\\n                    >\\n                      Belum ada kronologi. Klik \\\"Tambah Kronologi\\\" untuk\\n                      menambahkan.\\n                    </div>\\n                  )}\\n                </Form.Group>\\n              </>\\n            )}\\n\\n            {/* STEP 2 - Wabprof Pelanggaran Tindak Pidana */}\\n            {step === 2 && selectedTipeLaporan === 'wabprof' && (\\n              <>\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">\\n                    Pelanggaran Pidana <span className=\\\"text-danger\\\">*</span>\\n                  </TitleInput>\\n                  <div className=\\\"d-flex gap-3\\\">\\n                    <RadioButtonContainer\\n                      isSelected={watchEdit('criminal_offense') === 'ya'}\\n                      onClick={() => setValueEdit('criminal_offense', 'ya')}\\n                      type=\\\"button\\\"\\n                    >\\n                      <FormCheckStyled\\n                        type=\\\"radio\\\"\\n                        checked={watchEdit('criminal_offense') === 'ya'}\\n                        onChange={() => setValueEdit('criminal_offense', 'ya')}\\n                        name=\\\"criminal_offense\\\"\\n                        value=\\\"ya\\\"\\n                      />\\n                      <p>Ya</p>\\n                    </RadioButtonContainer>\\n\\n                    <RadioButtonContainer\\n                      isSelected={watchEdit('criminal_offense') === 'tidak'}\\n                      onClick={() => setValueEdit('criminal_offense', 'tidak')}\\n                      type=\\\"button\\\"\\n                    >\\n                      <FormCheckStyled\\n                        type=\\\"radio\\\"\\n                        checked={watchEdit('criminal_offense') === 'tidak'}\\n                        onChange={() =>\\n                          setValueEdit('criminal_offense', 'tidak')\\n                        }\\n                        name=\\\"criminal_offense\\\"\\n                        value=\\\"tidak\\\"\\n                      />\\n                      <p>Tidak</p>\\n                    </RadioButtonContainer>\\n                  </div>\\n                </Form.Group>\\n\\n                {/* No LP Pidana - Muncul jika Pelanggaran Pidana = Ya */}\\n                {watchEdit('criminal_offense') === 'ya' && (\\n                  <>\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">No. LP Pidana</TitleInput>\\n                      <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"Masukkan No. LP Pidana\\\"\\n                        {...registerEdit('criminal_lp_number')}\\n                      />\\n                    </Form.Group>\\n\\n                    {/* Pasal Pidana */}\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">Pasal Pidana</TitleInput>\\n                      <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"Masukkan Pasal Pidana\\\"\\n                        {...registerEdit('criminal_article')}\\n                      />\\n                    </Form.Group>\\n\\n                    {/* Deskripsi Pasal */}\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">Deskripsi Pasal</TitleInput>\\n                      <StyledTextarea\\n                        as=\\\"textarea\\\"\\n                        rows={3}\\n                        placeholder=\\\"Masukkan deskripsi pasal\\\"\\n                        {...registerEdit('criminal_article_description')}\\n                      />\\n                    </Form.Group>\\n\\n                    {/* Status Proses Pidana */}\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">\\n                        Status Proses Pidana\\n                      </TitleInput>\\n                      <div className=\\\"d-flex gap-3\\\">\\n                        <RadioButtonContainer\\n                          isSelected={\\n                            watchEdit('criminal_process_status') ===\\n                            'sudah_sidang'\\n                          }\\n                          onClick={() =>\\n                            setValueEdit(\\n                              'criminal_process_status',\\n                              'sudah_sidang',\\n                            )\\n                          }\\n                          type=\\\"button\\\"\\n                        >\\n                          <FormCheckStyled\\n                            type=\\\"radio\\\"\\n                            checked={\\n                              watchEdit('criminal_process_status') ===\\n                              'sudah_sidang'\\n                            }\\n                            onChange={() =>\\n                              setValueEdit(\\n                                'criminal_process_status',\\n                                'sudah_sidang',\\n                              )\\n                            }\\n                            name=\\\"criminal_process_status\\\"\\n                          />\\n                          <p>Sudah Sidang</p>\\n                        </RadioButtonContainer>\\n\\n                        <RadioButtonContainer\\n                          isSelected={\\n                            watchEdit('criminal_process_status') ===\\n                            'belum_sidang'\\n                          }\\n                          onClick={() =>\\n                            setValueEdit(\\n                              'criminal_process_status',\\n                              'belum_sidang',\\n                            )\\n                          }\\n                          type=\\\"button\\\"\\n                        >\\n                          <FormCheckStyled\\n                            type=\\\"radio\\\"\\n                            checked={\\n                              watchEdit('criminal_process_status') ===\\n                              'belum_sidang'\\n                            }\\n                            onChange={() =>\\n                              setValueEdit(\\n                                'criminal_process_status',\\n                                'belum_sidang',\\n                              )\\n                            }\\n                            name=\\\"criminal_process_status\\\"\\n                          />\\n                          <p>Belum Sidang</p>\\n                        </RadioButtonContainer>\\n                      </div>\\n                    </Form.Group>\\n\\n                    {/* Tanggal Putusan Sidang - hanya muncul jika status \\\"Sudah Sidang\\\" */}\\n                    {watchEdit('criminal_process_status') ===\\n                      'sudah_sidang' && (\\n                      <>\\n                        <Form.Group className=\\\"w-100\\\">\\n                          <TitleInput className=\\\"mb-3\\\">\\n                            Tanggal Putusan Sidang\\n                          </TitleInput>\\n                          <NativeDateWrapper>\\n                            <DateIconAddon>\\n                              <i className=\\\"ph ph-calendar-blank\\\"></i>\\n                            </DateIconAddon>\\n                            <StyledDatePicker\\n                              format=\\\"YYYY-MM-DD\\\"\\n                              placeholder=\\\"Pilih tanggal\\\"\\n                              value={\\n                                watchEdit('tanggal_putusan_sidang')\\n                                  ? dayjs(watchEdit('tanggal_putusan_sidang'))\\n                                  : null\\n                              }\\n                              onChange={(date) => {\\n                                setValueEdit(\\n                                  'tanggal_putusan_sidang',\\n                                  date ? date.toISOString() : null,\\n                                );\\n                              }}\\n                            />\\n                          </NativeDateWrapper>\\n                        </Form.Group>\\n\\n                        {/* Nomor Putusan Pidana */}\\n                        <Form.Group className=\\\"w-100\\\">\\n                          <TitleInput className=\\\"mb-3\\\">\\n                            Nomor Putusan Pidana\\n                          </TitleInput>\\n                          <StyledInput\\n                            type=\\\"text\\\"\\n                            placeholder=\\\"Masukkan nomor putusan pidana\\\"\\n                            {...registerEdit('nomor_putusan_pidana')}\\n                          />\\n                        </Form.Group>\\n                      </>\\n                    )}\\n\\n                    {/* Catatan */}\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">Catatan</TitleInput>\\n                      <StyledTextarea\\n                        as=\\\"textarea\\\"\\n                        rows={3}\\n                        placeholder=\\\"Masukkan catatan\\\"\\n                        {...registerEdit('catatan_pidana')}\\n                      />\\n                    </Form.Group>\\n\\n                    {/* Upload Dokumen Pidana */}\\n                    <Form.Group className=\\\"w-100\\\">\\n                      <TitleInput className=\\\"mb-3\\\">\\n                        Upload Dokumen Pidana\\n                      </TitleInput>\\n                      <UploadBox\\n                        isDragging={isDragging}\\n                        onDragOver={handleDragOver}\\n                        onDragLeave={handleDragLeave}\\n                        onDrop={handleDrop}\\n                        onClick={triggerFileInput}\\n                      >\\n                        <i\\n                          className=\\\"ph ph-upload-simple\\\"\\n                          style={{\\n                            fontSize: '2rem',\\n                            color: 'var(--black-400)',\\n                          }}\\n                        ></i>\\n                        <p\\n                          className=\\\"mb-1\\\"\\n                          style={{ color: 'var(--black-600)' }}\\n                        >\\n                          <span\\n                            style={{\\n                              color: 'var(--primary)',\\n                              fontWeight: '600',\\n                            }}\\n                          >\\n                            Click to upload\\n                          </span>{' '}\\n                          or drag and drop\\n                        </p>\\n                        <small style={{ color: 'var(--black-400)' }}>\\n                          doc, txt, png, jpg, jpeg, pdf only. 10MB max size.\\n                        </small>\\n                      </UploadBox>\\n                      <input\\n                        id=\\\"fileInput\\\"\\n                        type=\\\"file\\\"\\n                        multiple\\n                        onChange={handleFileChange}\\n                        style={{ display: 'none' }}\\n                        accept=\\\".doc,.txt,.png,.jpg,.jpeg,.pdf\\\"\\n                      />\\n\\n                      {/* Daftar File yang diupload */}\\n                      {/*{files.length > 0 && (\\n                        <FileList className=\\\"mt-3\\\">\\n                          {files.map((file, index) => (\\n                            <FileItem key={index}>\\n                              <div className=\\\"d-flex align-items-center gap-2\\\">\\n                                {getFileIcon(file)}\\n                                <FileName>{file.name}</FileName>\\n                                <small>\\n                                  ({(file.size / 1024).toFixed(2)} KB)\\n                                </small>\\n                              </div>\\n                              <Button\\n                                variant=\\\"link\\\"\\n                                className=\\\"p-0 text-danger\\\"\\n                                onClick={() => removeFile(file)}\\n                              >\\n                                <i className=\\\"ph ph-trash\\\"></i>\\n                              </Button>\\n                            </FileItem>\\n                          ))}\\n                        </FileList>\\n                      )}*/}\\n                      {files.map((file, index) => (\\n                        <FileItem key={index}>\\n                          <div className=\\\"d-flex align-items-center gap-2\\\">\\n                            {getFileIcon(file)}\\n                            <FileName>{file.name || file.file_name}</FileName>\\n                            <small>\\n                              ({((file.size || 0) / 1024).toFixed(2)} KB)\\n                            </small>\\n                          </div>\\n\\n                          <div className=\\\"d-flex align-items-center gap-2\\\">\\n                            {file.url && (\\n                              <a\\n                                href={file.url}\\n                                target=\\\"_blank\\\"\\n                                rel=\\\"noopener noreferrer\\\"\\n                                style={{ fontSize: '0.75rem' }}\\n                              >\\n                                Lihat\\n                              </a>\\n                            )}\\n\\n                            <Button\\n                              variant=\\\"link\\\"\\n                              className=\\\"p-0 text-danger\\\"\\n                              onClick={() => removeFile(file)}\\n                            >\\n                              <i className=\\\"ph ph-trash\\\"></i>\\n                            </Button>\\n                          </div>\\n                        </FileItem>\\n                      ))}\\n                    </Form.Group>\\n                  </>\\n                )}\\n\\n                {/* Jika Pelanggaran Pidana = Tidak, tampilkan pesan atau langsung lanjut */}\\n                {watchEdit('criminal_offense') === 'tidak' && (\\n                  <div\\n                    style={{\\n                      padding: '1.5rem',\\n                      textAlign: 'center',\\n                      color: 'var(--black-600)',\\n                      backgroundColor: 'var(--black-25)',\\n                      borderRadius: '0.5rem',\\n                      border: '1px dashed var(--black-100)',\\n                      marginTop: '1rem',\\n                      width: '100%',\\n                    }}\\n                  >\\n                    <i\\n                      className=\\\"ph ph-check-circle\\\"\\n                      style={{\\n                        fontSize: '2rem',\\n                        color: 'var(--success)',\\n                        marginBottom: '0.5rem',\\n                      }}\\n                    ></i>\\n                    <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                      Tidak ada pelanggaran pidana\\n                    </p>\\n                  </div>\\n                )}\\n              </>\\n            )}\\n\\n            {/* STEP 3 - Wabprof: Saksi & Bukti */}\\n            {step === 3 && selectedTipeLaporan === 'wabprof' && (\\n              <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                {/* Saksi Section */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <div className=\\\"d-flex justify-content-between align-items-center mb-3\\\">\\n                    <LabelInput>Saksi</LabelInput>\\n                    <button\\n                      type=\\\"button\\\"\\n                      onClick={() => {\\n                        const current = watchEdit('witness') || [];\\n                        setValueEdit('witness', [...current, { name: '' }]);\\n                      }}\\n                      style={{\\n                        background: 'none',\\n                        border: 'none',\\n                        color: 'var(--primary)',\\n                        fontWeight: '600',\\n                        cursor: 'pointer',\\n                        padding: 0,\\n                        fontSize: '0.875rem',\\n                      }}\\n                    >\\n                      + Tambah Saksi\\n                    </button>\\n                  </div>\\n                  {(watchEdit('witness') || []).length > 0 ? (\\n                    <div\\n                      style={{\\n                        display: 'flex',\\n                        flexDirection: 'column',\\n                        gap: '0.75rem',\\n                      }}\\n                    >\\n                      {(watchEdit('witness') || []).map((witness, index) => (\\n                        <div\\n                          key={index}\\n                          style={{\\n                            width: '100%',\\n                            paddingLeft: 16,\\n                            paddingRight: 16,\\n                            paddingTop: 11,\\n                            paddingBottom: 11,\\n                            background: 'white',\\n                            overflow: 'hidden',\\n                            borderRadius: 10,\\n                            outline: '1px #E6E9F0 solid',\\n                            outlineOffset: '-1px',\\n                            justifyContent: 'space-between',\\n                            alignItems: 'center',\\n                            gap: 8,\\n                            display: 'flex',\\n                          }}\\n                        >\\n                          <input\\n                            type=\\\"text\\\"\\n                            placeholder=\\\"Masukkan nama saksi\\\"\\n                            value={witness.name || ''}\\n                            onChange={(e) => {\\n                              const current = [...(watchEdit('witness') || [])];\\n                              const updated = current.map((item, i) =>\\n                                i === index\\n                                  ? { ...item, name: e.target.value }\\n                                  : item,\\n                              );\\n                              setValueEdit('witness', updated);\\n                            }}\\n                            style={{\\n                              flex: '1 1 0',\\n                              color: witness.name ? '#050505' : '#A0A3AA',\\n                              fontSize: 14,\\n                              fontFamily: 'Inter',\\n                              fontWeight: '400',\\n                              lineHeight: '19.60px',\\n                              wordWrap: 'break-word',\\n                              border: 'none',\\n                              outline: 'none',\\n                              background: 'transparent',\\n                            }}\\n                          />\\n                          <button\\n                            type=\\\"button\\\"\\n                            onClick={() => {\\n                              const updated = (\\n                                watchEdit('witness') || []\\n                              ).filter((_, i) => i !== index);\\n                              setValueEdit('witness', updated);\\n                            }}\\n                            style={{\\n                              width: 16,\\n                              height: 16,\\n                              position: 'relative',\\n                              background: 'none',\\n                              border: 'none',\\n                              cursor: 'pointer',\\n                              padding: 0,\\n                              display: 'flex',\\n                              alignItems: 'center',\\n                              justifyContent: 'center',\\n                            }}\\n                          >\\n                            <i className=\\\"ph ph-x\\\" style={{ fontSize: 16 }} />\\n                          </button>\\n                        </div>\\n                      ))}\\n                    </div>\\n                  ) : (\\n                    <div\\n                      style={{\\n                        padding: '1rem',\\n                        textAlign: 'center',\\n                        color: 'var(--black-400)',\\n                        backgroundColor: 'var(--black-25)',\\n                        borderRadius: '0.5rem',\\n                        border: '1px dashed var(--black-100)',\\n                        fontSize: '0.875rem',\\n                      }}\\n                    >\\n                      Belum ada saksi. Klik \\\"Tambah Saksi\\\" untuk menambahkan.\\n                    </div>\\n                  )}\\n                </Form.Group>\\n\\n                {/* Barang Bukti Section */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <div className=\\\"d-flex justify-content-between align-items-center mb-3\\\">\\n                    <LabelInput>Barang Bukti</LabelInput>\\n                    <button\\n                      type=\\\"button\\\"\\n                      onClick={() => {\\n                        const current = watchEdit('evidence') || [];\\n                        setValueEdit('evidence', [...current, { name: '' }]);\\n                      }}\\n                      style={{\\n                        background: 'none',\\n                        border: 'none',\\n                        color: 'var(--primary)',\\n                        fontWeight: '600',\\n                        cursor: 'pointer',\\n                        padding: 0,\\n                        fontSize: '0.875rem',\\n                      }}\\n                    >\\n                      + Tambah Barang Bukti\\n                    </button>\\n                  </div>\\n                  {(watchEdit('evidence') || []).length > 0 ? (\\n                    <div\\n                      style={{\\n                        display: 'flex',\\n                        flexDirection: 'column',\\n                        gap: '0.75rem',\\n                      }}\\n                    >\\n                      {(watchEdit('evidence') || []).map((item, index) => (\\n                        <div\\n                          key={index}\\n                          style={{\\n                            width: '100%',\\n                            paddingLeft: 16,\\n                            paddingRight: 16,\\n                            paddingTop: 11,\\n                            paddingBottom: 11,\\n                            background: 'white',\\n                            overflow: 'hidden',\\n                            borderRadius: 10,\\n                            outline: '1px #E6E9F0 solid',\\n                            outlineOffset: '-1px',\\n                            justifyContent: 'space-between',\\n                            alignItems: 'center',\\n                            gap: 8,\\n                            display: 'flex',\\n                          }}\\n                        >\\n                          <input\\n                            type=\\\"text\\\"\\n                            placeholder=\\\"Masukkan nama barang bukti\\\"\\n                            value={item.name || ''}\\n                            onChange={(e) => {\\n                              const current = [\\n                                ...(watchEdit('evidence') || []),\\n                              ];\\n                              const updated = current.map((item, i) =>\\n                                i === index\\n                                  ? { ...item, name: e.target.value }\\n                                  : item,\\n                              );\\n                              setValueEdit('evidence', updated);\\n                            }}\\n                            style={{\\n                              flex: '1 1 0',\\n                              color: item.name ? '#050505' : '#A0A3AA',\\n                              fontSize: 14,\\n                              fontFamily: 'Inter',\\n                              fontWeight: '400',\\n                              lineHeight: '19.60px',\\n                              wordWrap: 'break-word',\\n                              border: 'none',\\n                              outline: 'none',\\n                              background: 'transparent',\\n                            }}\\n                          />\\n                          <button\\n                            type=\\\"button\\\"\\n                            onClick={() => {\\n                              const updated = (\\n                                watchEdit('evidence') || []\\n                              ).filter((_, i) => i !== index);\\n                              setValueEdit('evidence', updated);\\n                            }}\\n                            style={{\\n                              width: 16,\\n                              height: 16,\\n                              position: 'relative',\\n                              background: 'none',\\n                              border: 'none',\\n                              cursor: 'pointer',\\n                              padding: 0,\\n                              display: 'flex',\\n                              alignItems: 'center',\\n                              justifyContent: 'center',\\n                            }}\\n                          >\\n                            <i className=\\\"ph ph-x\\\" style={{ fontSize: 16 }} />\\n                          </button>\\n                        </div>\\n                      ))}\\n                    </div>\\n                  ) : (\\n                    <div\\n                      style={{\\n                        padding: '1rem',\\n                        textAlign: 'center',\\n                        color: 'var(--black-400)',\\n                        backgroundColor: 'var(--black-25)',\\n                        borderRadius: '0.5rem',\\n                        border: '1px dashed var(--black-100)',\\n                        fontSize: '0.875rem',\\n                      }}\\n                    >\\n                      Belum ada barang bukti. Klik \\\"Tambah Barang Bukti\\\" untuk\\n                      menambahkan.\\n                    </div>\\n                  )}\\n                </Form.Group>\\n              </div>\\n            )}\\n\\n            {/* STEP 3 - Provos: Penanggung Jawab */}\\n            {step === 3 && selectedTipeLaporan === 'provos' && (\\n              <>\\n                {/* Membuat Laporan */}\\n                <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                  <TitleInput className=\\\"mb-4\\\">Yang Membuat Laporan</TitleInput>\\n                  {/* Nama dan Pangkat */}\\n                  <Form.Group>\\n                    <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                    <StyledInput\\n                      type=\\\"text\\\"\\n                      placeholder=\\\"Nama\\\"\\n                      {...registerEdit('created_by_name')}\\n                    />\\n                  </Form.Group>\\n                  <Row className=\\\"g-3 w-100\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Jabatan</TitleInput>\\n                        <StyledInput\\n                          type=\\\"text\\\"\\n                          placeholder=\\\"Jabatan\\\"\\n                          {...registerEdit('created_by_position')}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <LabelInput className=\\\"mb-3\\\">Pangkat</LabelInput>\\n                        <Controller\\n                          name=\\\"created_by_rank\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Pangkat wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={PangkatOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Pangkat\\\"\\n                              value={PangkatOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                              onChange={(val) => {\\n                                field.onChange(val?.value);\\n                              }}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.created_by_rank && (\\n                          <ErrorText>\\n                            {errorsEdit.created_by_rank.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n\\n                  {/* NRP dan Kesatuan */}\\n                  <Row className=\\\"g-3 w-100\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">NRP</TitleInput>\\n                        <Controller\\n                          name=\\\"created_by_nrp\\\"\\n                          control={controlEdit}\\n                          rules={{\\n                            required: 'NRP wajib diisi',\\n                            validate: (value) => {\\n                              const cleaned = value?.replace(/\\\\D/g, '') || '';\\n                              if (cleaned.length !== 8) {\\n                                return 'NRP harus terdiri dari 8 angka';\\n                              }\\n                              return true;\\n                            },\\n                          }}\\n                          render={({ field }) => (\\n                            <StyledInput\\n                              {...field}\\n                              type=\\\"text\\\"\\n                              placeholder=\\\"NRP (8 digit angka)\\\"\\n                              onChange={(e) => {\\n                                const numericOnly = e.target.value.replace(\\n                                  /\\\\D/g,\\n                                  '',\\n                                );\\n                                const limited = numericOnly.slice(0, 8);\\n                                field.onChange(limited);\\n                              }}\\n                              maxLength={8}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.created_by_nrp && (\\n                          <ErrorText>\\n                            {errorsEdit.created_by_nrp.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-2\\\">Kesatuan</TitleInput>\\n                        <Controller\\n                          name=\\\"created_by_unit\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Kesatuan wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={kesatuanOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Kesatuan\\\"\\n                              isLoading={loadingKesatuan}\\n                              value={kesatuanOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.created_by_unit && (\\n                          <ErrorText>\\n                            {errorsEdit.created_by_unit.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                </div>\\n                {/* Pemeriksa */}\\n                <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                  <TitleInput className=\\\"mb-4\\\">Pemeriksa</TitleInput>\\n                  {/* Nama dan Pangkat */}\\n                  <Row className=\\\"g-3 w-100\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                        <StyledInput\\n                          type=\\\"text\\\"\\n                          placeholder=\\\"Nama\\\"\\n                          {...registerEdit('acknowledged_by_name')}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <LabelInput className=\\\"mb-3\\\">Pangkat</LabelInput>\\n                        <Controller\\n                          name=\\\"acknowledged_by_rank\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Pangkat wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={PangkatOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Pangkat\\\"\\n                              value={PangkatOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                              onChange={(val) => {\\n                                field.onChange(val?.value);\\n                              }}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.acknowledged_by_rank && (\\n                          <ErrorText>\\n                            {errorsEdit.acknowledged_by_rank.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n\\n                  {/* NRP dan Kesatuan */}\\n                  <Row className=\\\"g-3 w-100\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">NRP</TitleInput>\\n                        <Controller\\n                          name=\\\"acknowledged_by_nrp\\\"\\n                          control={controlEdit}\\n                          rules={{\\n                            required: 'NRP wajib diisi',\\n                            validate: (value) => {\\n                              const cleaned = value?.replace(/\\\\D/g, '') || '';\\n                              if (cleaned.length !== 8) {\\n                                return 'NRP harus terdiri dari 8 angka';\\n                              }\\n                              return true;\\n                            },\\n                          }}\\n                          render={({ field }) => (\\n                            <StyledInput\\n                              {...field}\\n                              type=\\\"text\\\"\\n                              placeholder=\\\"NRP (8 digit angka)\\\"\\n                              onChange={(e) => {\\n                                const numericOnly = e.target.value.replace(\\n                                  /\\\\D/g,\\n                                  '',\\n                                );\\n                                const limited = numericOnly.slice(0, 8);\\n                                field.onChange(limited);\\n                              }}\\n                              maxLength={8}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.acknowledged_by_nrp && (\\n                          <ErrorText>\\n                            {errorsEdit.acknowledged_by_nrp.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-2\\\">Kesatuan</TitleInput>\\n                        <Controller\\n                          name=\\\"acknowledged_by_unit\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Kesatuan wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={kesatuanOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Kesatuan\\\"\\n                              isLoading={loadingKesatuan}\\n                              value={kesatuanOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.acknowledged_by_unit && (\\n                          <ErrorText>\\n                            {errorsEdit.acknowledged_by_unit.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                </div>\\n                {/* Peneliti */}\\n                <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                  <TitleInput className=\\\"mb-4\\\">Peneliti</TitleInput>\\n                  {/* Nama dan Pangkat */}\\n                  <Row className=\\\"g-3 w-100\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                        <StyledInput\\n                          type=\\\"text\\\"\\n                          placeholder=\\\"Nama\\\"\\n                          {...registerEdit('examiner_name')}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <LabelInput className=\\\"mb-3\\\">Pangkat</LabelInput>\\n                        <Controller\\n                          name=\\\"examiner_rank\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Pangkat wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={PangkatOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Pangkat\\\"\\n                              value={PangkatOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                              onChange={(val) => {\\n                                field.onChange(val?.value);\\n                              }}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.examiner_rank && (\\n                          <ErrorText>\\n                            {errorsEdit.examiner_rank.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n\\n                  {/* NRP dan Kesatuan */}\\n                  <Row className=\\\"g-3 w-100\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">NRP</TitleInput>\\n                        <Controller\\n                          name=\\\"examiner_nrp\\\"\\n                          control={controlEdit}\\n                          rules={{\\n                            required: 'NRP wajib diisi',\\n                            validate: (value) => {\\n                              const cleaned = value?.replace(/\\\\D/g, '') || '';\\n                              if (cleaned.length !== 8) {\\n                                return 'NRP harus terdiri dari 8 angka';\\n                              }\\n                              return true;\\n                            },\\n                          }}\\n                          render={({ field }) => (\\n                            <StyledInput\\n                              {...field}\\n                              type=\\\"text\\\"\\n                              placeholder=\\\"NRP (8 digit angka)\\\"\\n                              onChange={(e) => {\\n                                const numericOnly = e.target.value.replace(\\n                                  /\\\\D/g,\\n                                  '',\\n                                );\\n                                const limited = numericOnly.slice(0, 8);\\n                                field.onChange(limited);\\n                              }}\\n                              maxLength={8}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.examiner_nrp && (\\n                          <ErrorText>\\n                            {errorsEdit.examiner_nrp.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-2\\\">Kesatuan</TitleInput>\\n                        <Controller\\n                          name=\\\"examiner_unit\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Kesatuan wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={kesatuanOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Kesatuan\\\"\\n                              isLoading={loadingKesatuan}\\n                              value={kesatuanOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.examiner_unit && (\\n                          <ErrorText>\\n                            {errorsEdit.examiner_unit.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                </div>\\n              </>\\n            )}\\n\\n            {/* STEP 4 - Wabprof: Penanggung Jawab */}\\n            {step === 4 && selectedTipeLaporan === 'wabprof' && (\\n              <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                {/* Yang Membuat Laporan Section */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Yang Membuat Laporan</TitleInput>\\n                  <Form.Group className=\\\"mb-3\\\">\\n                    <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                    <StyledInput\\n                      type=\\\"text\\\"\\n                      placeholder=\\\"Nama\\\"\\n                      {...registerEdit('name')}\\n                    />\\n                  </Form.Group>\\n                  <Row className=\\\"g-3\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Jabatan</TitleInput>\\n                        <StyledInput\\n                          type=\\\"text\\\"\\n                          placeholder=\\\"Jabatan\\\"\\n                          {...registerEdit('position')}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Pangkat</TitleInput>\\n                        <Controller\\n                          name=\\\"rank\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Pangkat wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={PangkatOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Pangkat\\\"\\n                              value={PangkatOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                              onChange={(val) => {\\n                                field.onChange(val?.value);\\n                              }}\\n                            />\\n                          )}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                  <Row className=\\\"g-3\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"my-3\\\">NRP</TitleInput>\\n                        <Controller\\n                          name=\\\"nrp\\\"\\n                          control={controlEdit}\\n                          rules={{\\n                            required: 'NRP wajib diisi',\\n                            validate: (value) => {\\n                              const cleaned = value?.replace(/\\\\D/g, '') || '';\\n                              if (cleaned.length !== 8) {\\n                                return 'NRP harus terdiri dari 8 angka';\\n                              }\\n                              return true;\\n                            },\\n                          }}\\n                          render={({ field }) => (\\n                            <StyledInput\\n                              {...field}\\n                              type=\\\"text\\\"\\n                              placeholder=\\\"NRP (8 digit angka)\\\"\\n                              onChange={(e) => {\\n                                const numericOnly = e.target.value.replace(\\n                                  /\\\\D/g,\\n                                  '',\\n                                );\\n                                const limited = numericOnly.slice(0, 8);\\n                                field.onChange(limited);\\n                              }}\\n                              maxLength={8}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.nrp && (\\n                          <ErrorText>{errorsEdit.nrp.message}</ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"my-3\\\">Kesatuan</TitleInput>\\n                        <Controller\\n                          name=\\\"unit\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Kesatuan wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={kesatuanOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Kesatuan\\\"\\n                              isLoading={loadingKesatuan}\\n                              value={kesatuanOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.unit && (\\n                          <ErrorText>{errorsEdit.unit.message}</ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                </Form.Group>\\n\\n                {/* Divider */}\\n                <hr\\n                  style={{\\n                    borderColor: 'var(--black-100)',\\n                    marginTop: '1rem',\\n                    marginBottom: '1rem',\\n                  }}\\n                />\\n\\n                {/* Mengetahui Section */}\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Mengetahui</TitleInput>\\n                  <Row className=\\\"g-3\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                        <StyledInput\\n                          type=\\\"text\\\"\\n                          placeholder=\\\"Nama\\\"\\n                          {...registerEdit('examiner_name')}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"mb-3\\\">Pangkat</TitleInput>\\n                        <Controller\\n                          name=\\\"examiner_rank\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Pangkat wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={PangkatOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Pangkat\\\"\\n                              value={PangkatOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                              onChange={(val) => {\\n                                field.onChange(val?.value);\\n                              }}\\n                            />\\n                          )}\\n                        />\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                  <Row className=\\\"g-3\\\">\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"my-3\\\">NRP</TitleInput>\\n                        <Controller\\n                          name=\\\"examiner_nrp\\\"\\n                          control={controlEdit}\\n                          rules={{\\n                            required: 'NRP wajib diisi',\\n                            validate: (value) => {\\n                              const cleaned = value?.replace(/\\\\D/g, '') || '';\\n                              if (cleaned.length !== 8) {\\n                                return 'NRP harus terdiri dari 8 angka';\\n                              }\\n                              return true;\\n                            },\\n                          }}\\n                          render={({ field }) => (\\n                            <StyledInput\\n                              {...field}\\n                              type=\\\"text\\\"\\n                              placeholder=\\\"NRP (8 digit angka)\\\"\\n                              onChange={(e) => {\\n                                const numericOnly = e.target.value.replace(\\n                                  /\\\\D/g,\\n                                  '',\\n                                );\\n                                const limited = numericOnly.slice(0, 8);\\n                                field.onChange(limited);\\n                              }}\\n                              maxLength={8}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.examiner_nrp && (\\n                          <ErrorText>\\n                            {errorsEdit.examiner_nrp.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                    <Col md={6}>\\n                      <Form.Group>\\n                        <TitleInput className=\\\"my-3\\\">Kesatuan</TitleInput>\\n                        <Controller\\n                          name=\\\"examiner_unit\\\"\\n                          control={controlEdit}\\n                          rules={{ required: 'Kesatuan wajib dipilih' }}\\n                          render={({ field }) => (\\n                            <Select\\n                              {...field}\\n                              options={kesatuanOptions}\\n                              styles={ReactSelectStyle}\\n                              placeholder=\\\"Pilih Kesatuan\\\"\\n                              isLoading={loadingKesatuan}\\n                              value={kesatuanOptions.find(\\n                                (o) => o.value === field.value,\\n                              )}\\n                            />\\n                          )}\\n                        />\\n                        {errorsEdit.examiner_unit && (\\n                          <ErrorText>\\n                            {errorsEdit.examiner_unit.message}\\n                          </ErrorText>\\n                        )}\\n                      </Form.Group>\\n                    </Col>\\n                  </Row>\\n                </Form.Group>\\n              </div>\\n            )}\\n          </ModalBody>\\n          <ModalFooter>\\n            <ProgressWrapper>\\n              <ProgressBase>\\n                <ProgressFill step={step} maxStep={maxStep} />\\n              </ProgressBase>\\n            </ProgressWrapper>\\n            <div className=\\\"d-flex gap-3\\\">\\n              <Button variant=\\\"outline-primary\\\" onClick={handleCloseWithReset}>\\n                Batal\\n              </Button>\\n              {step > 1 && (\\n                <Button variant=\\\"outline-secondary\\\" onClick={handlePrevious}>\\n                  Kembali\\n                </Button>\\n              )}\\n              {step < maxStep ? (\\n                <Button variant=\\\"primary\\\" onClick={handleNext}>\\n                  Selanjutnya\\n                </Button>\\n              ) : (\\n                <Button\\n                  variant=\\\"primary\\\"\\n                  onClick={handleSubmitEdit(onSubmitEdit)}\\n                  disabled={loading}\\n                >\\n                  {loading ? 'Menyimpan...' : 'Simpan'}\\n                </Button>\\n              )}\\n            </div>\\n          </ModalFooter>\\n        </Form>\\n      </StyledModal>\\n      <DetailModal\\n        show={showDetailModal}\\n        onHide={() => setShowDetailModal(false)}\\n        data={selectedDetail}\\n      />\\n    </>\\n  );\\n}\\n\\nconst ProgressWrapper = styled.div`\\n  flex: 1;\\n  display: flex;\\n  align-items: center;\\n`;\\n\\nconst ProgressBase = styled.div`\\n  width: 5.71429rem;\\n  height: 0.57143rem;\\n  background-color: var(--primary-50);\\n  border-radius: 1.71429rem;\\n  position: relative;\\n  overflow: hidden;\\n`;\\n\\nconst ErrorText = styled.span`\\n  color: var(--danger);\\n  font-size: 0.75rem;\\n  margin-top: 0.25rem;\\n  display: block;\\n`;\\n\\nconst ProgressFill = styled.div`\\n  position: absolute;\\n  top: 0;\\n  left: 0;\\n  height: 100%;\\n  width: ${(props) => {\\n    switch (props.step) {\\n      case 1:\\n        return '25%';\\n      case 2:\\n        return '50%';\\n      case 3:\\n        return '75%';\\n      case 4:\\n        return '100%';\\n      default:\\n        return '0%';\\n    }\\n  }};\\n  background-color: var(--primary-500);\\n  transition: width 0.4s ease;\\n  border-radius: 1.71429rem;\\n`;\\n\\nconst StepIndicator = styled.span`\\n  margin-left: 1rem;\\n  font-size: 0.875rem;\\n  color: var(--black-400);\\n  font-weight: 500;\\n`;\\nconst StyledModal = styled(Modal)`\\n  .modal-dialog {\\n    max-width: 670px;\\n  }\\n\\n  .modal-body {\\n    max-height: 50vh;\\n    overflow-y: auto;\\n  }\\n`;\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst ModalBody = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n`;\\n\\nconst ModalFooter = styled(Modal.Footer)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem 1.06667rem 1.33333rem;\\n  justify-content: flex-end;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst DescHeader = styled.p`\\n  color: var(--black-400);\\n  font-size: 0.93333rem;\\n  font-style: normal;\\n  font-weight: 400;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\nconst TabsHeader = styled.div`\\n  display: flex;\\n  width: 100%;\\n  background: var(--black-25);\\n  border-radius: 12px;\\n  padding: 4px;\\n  gap: 4px;\\n`;\\n\\nconst TabButton = styled.button`\\n  flex: 1;\\n  padding: 0.75rem 1rem;\\n  border: none;\\n  background: ${(props) => (props.active ? 'var(--white)' : 'transparent')};\\n  color: ${(props) => (props.active ? 'var(--black)' : '#6C757D')};\\n  font-weight: ${(props) => (props.active ? '600' : '500')};\\n  border-radius: 8px;\\n  cursor: pointer;\\n  transition: all 0.2s;\\n  box-shadow: ${(props) =>\\n    props.active ? '0 2px 8px 0 rgba(51, 51, 51, 0.07)' : 'none'};\\n\\n  &:hover {\\n    background: ${(props) =>\\n      props.active ? 'var(--white)' : 'var(--black-50)'};\\n  }\\n`;\\n\\nconst RadioButtonContainer = styled.div`\\n  border: 1px solid\\n    ${({ isSelected }) => (isSelected ? 'var(--primary)' : 'var(--black-100)')};\\n  border-radius: 0.57143rem;\\n  padding: 0.4rem 0.53333rem;\\n  gap: 0.1rem;\\n  position: relative;\\n  display: flex;\\n  align-items: center;\\n  cursor: pointer;\\n\\n  .form-check-input {\\n    position: relative;\\n    margin-left: 0;\\n    margin-top: 0;\\n  }\\n\\n  p {\\n    font-size: 0.85714rem;\\n    font-style: normal;\\n    font-weight: 600;\\n    margin: 0;\\n    color: ${({ isSelected }) =>\\n      isSelected ? 'var(--primary)' : 'var(--black)'};\\n  }\\n`;\\n\\nconst FormCheckStyled = styled(Form.Check)`\\n  display: flex;\\n  align-items: center;\\n\\n  .form-check-input {\\n    margin-right: 0.5rem;\\n\\n    &:checked {\\n      background-color: var(--primary);\\n      border-color: var(--primary);\\n    }\\n  }\\n`;\\nconst TitleInput = styled.div`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;\\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid #e1e2e5;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  font-family: Inter;\\n  box-shadow: none;\\n  background-color:var(--white);\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst CustomStyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  font-family: Inter;\\n\\n  border: none;\\n  outline: none;\\n  box-shadow: none;\\n  background: transparent;\\n\\n  resize: none;\\n\\n  &:focus {\\n    outline: none;\\n    box-shadow: none;\\n  }\\n`;\\n\\nconst InputGroupText = styled(InputGroup.Text)`\\n  border-radius: 0.57rem 0rem 0rem 0.57rem !important;\\n  background: var(--black-25) !important;\\n  justify-content: center;\\n  align-items: center;\\n`;\\n// const FormControlCustom = styled(Form.Control)`\\n//   border-radius: 0 0.57rem 0.57rem 0 !important;\\n// `;\\n\\nconst StyledInputGroup = styled(InputGroup)`\\n  border: 1px solid #e9ecef;\\n  border-radius: 8px;\\n  overflow: hidden;\\n  background-color: var(--white);\\n\\n  &:focus-within {\\n    border-color: var(--primary);\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst InputGroupTextCustom = styled(InputGroup.Text)`\\n  background-color: var(--black-50);\\n  border: none;\\n  border-right: 1px solid #e9ecef;\\n  color: #6c757d;\\n  font-size: 0.9rem;\\n  padding: 0 12px;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  min-width: 45px;\\n`;\\n\\nconst NativeDateWrapper = styled.div`\\n  display: flex;\\n  align-items: stretch;\\n  width: 100%;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  background-color: var(--white);\\n\\n  &:focus-within {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst DateIconAddon = styled.div`\\n  background-color: var(--black-25);\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  padding: 0 12px;\\n  border-right: 1px solid var(--black-25);\\n  color: #64748b;\\n`;\\n\\nconst ContentGrid = styled.div`\\n  padding: 12px;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 1rem;\\n  // height: 80rem;\\n  // overflow-y: auto;\\n  padding-right: 0.4rem;\\n  // scrollbar-width: thin;\\n  // scrollbar-color: var(--black-200) transparent;\\n\\n  //  /* styling scrollbar untuk Chrome/Safari */\\n  // &::-webkit-scrollbar {\\n  //   width: 6px;\\n  // }\\n\\n  // &::-webkit-scrollbar-track {\\n  //   background: transparent;\\n  // }\\n\\n  // &::-webkit-scrollbar-thumb {\\n  //   background-color: var(--black-300);\\n  //   border-radius: 4px;\\n  // }\\n`;\\n\\nconst StyledCard = styled.div`\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  padding: 12px;\\n  background: var(--white);\\n`;\\nconst FallbackIcon = styled.div`\\n  position: absolute;\\n  inset: 0;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n`;\\n\\nconst ImageWrapper = styled.div`\\n  position: relative;\\n  width: 30px;\\n  height: 40px;\\n  min-width: 40px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  cursor: pointer;\\n\\n  img {\\n    width: 100%;\\n    height: 100%;\\n    object-fit: cover;\\n  }\\n`;\\n\\nconst FallbackIconWrapper = styled.div`\\n  width: 60px;\\n  height: 60px;\\n  min-width: 60px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  flex-shrink: 0;\\n`;\\n\\nconst FileName = styled.div`\\n  overflow: hidden;\\n  text-overflow: ellipsis;\\n  display: -webkit-box;\\n  -webkit-line-clamp: 2;\\n  -webkit-box-orient: vertical;\\n  line-height: 1.2;\\n`;\\n\\nconst StyledNativeDate = styled.input`\\n  flex: 1;\\n  border: none !important;\\n  padding: 0.75rem 1rem;\\n  font-size: 0.875rem;\\n  outline: none !important;\\n  background: transparent;\\n  color: #495057;\\n\\n  &::-webkit-calendar-picker-indicator {\\n    cursor: pointer;\\n    opacity: 0.6;\\n    filter: invert(0.5);\\n  }\\n`;\\n\\nconst UploadBox = styled.div`\\n  border-radius: 0.75rem;\\n  background: var(--black-25);\\n  padding: 3rem 0.75rem;\\n  text-align: center;\\n  cursor: pointer;\\n  ${(props) => props.isDragging && 'background: #e0e7ff;'}\\n\\n  p {\\n    font-size: 0.875rem;\\n  }\\n\\n  small {\\n    font-size: 0.75rem;\\n  }\\n\\n  @media (max-width: 480px) {\\n    p {\\n      font-size: 0.8rem;\\n    }\\n    small {\\n      font-size: 0.7rem;\\n    }\\n  }\\n`;\\n\\nconst FileList = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n`;\\n\\nconst FileItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  justify-content: space-between;\\n  border-radius: 0.5rem;\\n  border: 1px solid var(--black-100);\\n  background: var(--black-25);\\n  padding: 0.5rem;\\n  font-size: 0.875rem;\\n  gap: 1rem;\\n`;\\n\\nconst FileIcon = styled.div`\\n  font-size: 1.25rem;\\n  line-height: 0;\\n  color: var(--white);\\n`;\\n\\nconst FormControlCustom = styled(Form.Control)`\\n  border: none !important;\\n  padding: 10px 14px;\\n  font-size: 0.9rem;\\n\\n  &:focus {\\n    box-shadow: none !important;\\n  }\\n\\n  & + .react-datepicker__calendar-icon {\\n    display: none;\\n  }\\n  &::placeholder {\\n    color: #adb5bd;\\n  }\\n`;\\n\\nconst DownloadButton = styled(Button)`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  width: min-content;\\n  gap: 0.53333rem;\\n  background-color: none;\\n  border: 1px solid var(--black-100);\\n`;\\nconst BodyContainer = styled.div`\\n  flex: 1;\\n  overflow-y: auto;\\n  padding: 16px;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 8px;\\n  max-height: 41rem;\\n\\n  /* Styling scrollbar */\\n  &::-webkit-scrollbar {\\n    width: 6px;\\n  }\\n\\n  &::-webkit-scrollbar-track {\\n    background: transparent;\\n  }\\n\\n  &::-webkit-scrollbar-thumb {\\n    background-color: var(--black-300);\\n    border-radius: 4px;\\n  }\\n\\n  .information {\\n    width: 200px;\\n    font-size: 0.93333rem;\\n    font-weight: 400;\\n    line-height: 140%;\\n    color: var(--black-600);\\n    flex-shrink: 0;\\n  }\\n\\n  .subtitle {\\n    font-size: 14px;\\n    font-weight: 500;\\n    color: var(--black);\\n    margin-top: 8px;\\n\\n    &:first-child {\\n      margin-top: 0;\\n    }\\n  }\\n\\n  .flex.items-center {\\n    display: flex;\\n    align-items: center;\\n    width: 100%;\\n    gap: 16px;\\n    margin-bottom: 8px;\\n  }\\n\\n  .fs-12,\\n  .fw-400,\\n  .value {\\n    font-size: 0.93333rem;\\n    font-weight: 400;\\n    color: var(--black);\\n    flex: 1;\\n    word-break: break-word;\\n  }\\n`;\\nconst StyledFile = styled.div`\\n  display: flex;\\n  padding: 8px;\\n  align-items: center;\\n  gap: 10px;\\n  border-radius: 8px;\\n  background: var(--primary-500);\\n`;\\nconst StyledDatePicker = styled(DatePicker)`\\n  flex: 1;\\n  border: none !important;\\n  &.ant-picker {\\n    padding: 0;\\n    height: 36px;\\n  }\\n  .ant-picker-input {\\n    input {\\n      font-size: 0.875rem;\\n      padding: 0.75rem 1rem;\\n      height: 36px;\\n      &::placeholder {\\n        color: #adb5bd;\\n      }\\n    }\\n  }\\n\\n  .ant-picker-suffix {\\n    display: none; /* Sembunyikan icon kanan */\\n  }\\n\\n  .ant-picker-clear {\\n    display: none;\\n  }\\n`;\\n\\nconst StyledTimePicker = styled(TimePicker)`\\n  flex: 1;\\n  border: none !important;\\n\\n  &.ant-picker {\\n    padding: 0;\\n    height: 36px;\\n  }\\n  .ant-picker-input {\\n    input {\\n      font-size: 0.875rem;\\n      padding: 0.75rem 1rem;\\n      height: 36px;\\n\\n      &::placeholder {\\n        color: #adb5bd;\\n      }\\n    }\\n  }\\n\\n  .ant-picker-suffix {\\n    display: none; /* Sembunyikan icon kanan */\\n  }\\n\\n  .ant-picker-clear {\\n    display: none;\\n  }\\n`;\\nconst StyledYearPicker = styled(DatePicker)`\\n  flex: 1;\\n  border: none !important;\\n\\n  &.ant-picker {\\n    padding: 0;\\n    height: 36px;\\n  }\\n  .ant-picker-input {\\n    input {\\n      font-size: 0.875rem;\\n      padding: 0.75rem 1rem;\\n      height: 36px;\\n\\n      &::placeholder {\\n        color: #adb5bd;\\n      }\\n    }\\n  }\\n\\n  .ant-picker-suffix {\\n    display: none; /* Sembunyikan icon kanan */\\n  }\\n\\n  .ant-picker-clear {\\n    display: none;\\n  }\\n`;\\n\\nconst ReactSelectStyle = {\\n  control: (styles: any, { isDisabled }: any) => ({\\n    ...styles,\\n    backgroundColor: isDisabled ? 'var(--black-25)' : 'var(--white)',\\n    borderColor: 'var(--black-150)',\\n    color: '$input-color',\\n    padding: '0rem 0.8rem',\\n    borderRadius: '0.8rem',\\n    borderWidth: '1px',\\n    // fontFamily: 'Outfit',\\n    transition: 'none',\\n    '&:focus': {\\n      ...styles[':focus'],\\n      backgroundColor: 'var(--primary-25)',\\n      borderColor: 'var(--primary-400)',\\n      boxShadow: '0 0 0 0.25rem rgba(var(--primary-rgb), 0.25)',\\n    },\\n    ':hover': {\\n      ...styles[':hover'],\\n      borderColor: 'var(--primary-400)',\\n    },\\n    ':active': {\\n      ...styles[':active'],\\n      borderColor: 'var(--primary-400)',\\n    },\\n    minHeight: '1.85rem',\\n    // width: '40rem',\\n  }),\\n  input: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black-800)',\\n    margin: '0',\\n    // fontFamily: 'Outfit',\\n  }),\\n  placeholder: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black-300)',\\n    // fontFamily: 'Outfit',\\n    // fontSize: '$input-font-size',\\n    fontSize: '0.875rem',\\n    fontStyle: 'normal',\\n    fontWeight: '400',\\n    lineHeight: '1.4rem',\\n  }),\\n  valueContainer: (styles: any) => ({\\n    ...styles,\\n    padding: '0',\\n    textOverflow: 'ellipsis',\\n\\n    textWrap: 'nowrap',\\n  }),\\n  indicatorSeparator: (styles: any) => ({\\n    ...styles,\\n    backgroundColor: 'transparent',\\n    marginTop: '6px',\\n    marginBottom: '6px',\\n    padding: 0,\\n  }),\\n  indicatorsContainer: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black)',\\n    padding: '0',\\n  }),\\n  indicatorContainer: (styles: any) => ({\\n    ...styles,\\n    padding: 0,\\n  }),\\n  singleValue: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black)',\\n    fontWeight: '500',\\n    // fontFamily: 'Outfit',\\n  }),\\n  multiValue: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black-500)',\\n    backgroundColor: 'var(--black-25)',\\n    fontWeight: '500',\\n    // fontFamily: 'Outfit',\\n  }),\\n  multiValueLabel: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black-500)',\\n    backgroundColor: 'var(--black-25)',\\n    fontWeight: '500',\\n    // fontFamily: 'Outfit',\\n  }),\\n  multiValueRemove: (styles: any) => ({\\n    ...styles,\\n    color: 'var(--black-500)',\\n    backgroundColor: 'var(--black-25)',\\n    ':hover': {\\n      color: 'var(--black)',\\n      backgroundColor: 'var(--primary-300)',\\n    },\\n  }),\\n  menu: (styles: any) => ({\\n    ...styles,\\n    backgroundColor: 'var(--white)',\\n    zIndex: 9999,\\n    // fontFamily: 'Outfit',\\n  }),\\n\\n  option: (styles: any) => ({\\n    ...styles,\\n    backgroundColor: 'var(--white)',\\n    // fontFamily: 'Outfit',\\n    color: 'var(--black)',\\n    ':hover': {\\n      ...styles[':hover'],\\n      backgroundColor: 'var(--primary-50)',\\n    },\\n    ':focus': {\\n      ...styles[':focus'],\\n      backgroundColor: 'var(--primary-50)',\\n    },\\n  }),\\n};\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\nconst customStyles = {\\n  ...ReactSelectStyle, // Ambil style global (base)\\n\\n  // HAPUS atau MODIFIKASI valueContainer - jangan pakai flexDirection column\\n  valueContainer: (provided) => ({\\n    ...provided,\\n    padding: '0 8px',\\n    // Hapus flexDirection: 'column' agar selected items tetap di dalam baris\\n  }),\\n\\n  // Override MultiValue agar tidak terlihat seperti 'tag' kecil\\n  multiValue: (provided) => ({\\n    ...provided,\\n    backgroundColor: 'var(--primary-50)',\\n    borderRadius: '4px',\\n    padding: '2px',\\n    margin: '2px',\\n  }),\\n  multiValueLabel: (provided) => ({\\n    ...provided,\\n    color: 'var(--primary-700)',\\n    fontWeight: '500',\\n    padding: '2px 4px',\\n  }),\\n  multiValueRemove: (provided) => ({\\n    ...provided,\\n    color: 'var(--primary-700)',\\n    display: 'flex', // Tampilkan X\\n    ':hover': {\\n      backgroundColor: 'var(--primary-100)',\\n      color: 'var(--primary-900)',\\n    },\\n  }),\\n\\n  // Style untuk dropdown option-nya\\n  option: (provided, state) => ({\\n    ...provided,\\n    padding: '12px 16px',\\n    borderBottom: '1px solid #e9ecef',\\n    backgroundColor: state.isFocused ? 'var(--primary-25)' : 'white',\\n    color: 'var(--black)',\\n    whiteSpace: 'normal',\\n    wordBreak: 'break-word',\\n    ':last-child': { borderBottom: 'none' },\\n    ':active': { backgroundColor: 'var(--primary-50)' },\\n  }),\\n\\n  menu: (provided) => ({\\n    ...provided,\\n    boxShadow: '0 4px 12px rgba(0,0,0,0.15)',\\n    borderRadius: '8px',\\n    zIndex: 9999,\\n  }),\\n};\\n\\nconst PasalSelect = ({\\n  control,\\n  name,\\n  label,\\n  placeholder = 'Pilih',\\n  filterType,\\n  disabled = false,\\n  pasalOptions = [], // Tambahkan prop untuk pasalOptions\\n}) => {\\n  const [showDetailModal, setShowDetailModal] = useState(false);\\n  const [selectedDetail, setSelectedDetail] = useState(null);\\n\\n  // Filter pasal berdasarkan filterType\\n  const filteredPasal = useMemo(() => {\\n    return filterPasalByType(pasalOptions, filterType);\\n  }, [pasalOptions, filterType]);\\n\\n  const handleDetailClick = (e, data) => {\\n    e.stopPropagation();\\n    setSelectedDetail(data);\\n    setShowDetailModal(true);\\n  };\\n\\n  return (\\n    <>\\n      <Form.Group className=\\\"w-100\\\">\\n        <TitleInput className=\\\"mb-3\\\">{label}</TitleInput>\\n\\n        <Controller\\n          name={name}\\n          control={control}\\n          render={({ field }) => {\\n            return (\\n              <>\\n                {/* Display filtered pasal items - View Only */}\\n                {filteredPasal.length > 0 ? (\\n                  <SelectedItemsContainer>\\n                    <SelectedItemsHeader>\\n                      <span>Pasal yang tersedia ({filteredPasal.length})</span>\\n                    </SelectedItemsHeader>\\n                    <SelectedItemsList>\\n                      {filteredPasal.map((item) => (\\n                        <SelectedItemCard key={item.value}>\\n                          <SelectedItemContent>\\n                            <SelectedItemHeader>\\n                              <SelectedItemCode>\\n                                {item.kode_pasal || item.pasal || 'Pasal'}\\n                              </SelectedItemCode>\\n                              <DetailLink\\n                                onClick={(e) => handleDetailClick(e, item)}\\n                              >\\n                                Lihat detail\\n                              </DetailLink>\\n                            </SelectedItemHeader>\\n                          </SelectedItemContent>\\n                        </SelectedItemCard>\\n                      ))}\\n                    </SelectedItemsList>\\n                  </SelectedItemsContainer>\\n                ) : (\\n                  <div\\n                    style={{\\n                      padding: '1rem',\\n                      textAlign: 'center',\\n                      color: 'var(--black-400)',\\n                      backgroundColor: 'var(--black-25)',\\n                      borderRadius: '0.5rem',\\n                      border: '1px dashed var(--black-100)',\\n                    }}\\n                  >\\n                    <i\\n                      className=\\\"ph ph-file-text\\\"\\n                      style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n                    ></i>\\n                    <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                      Tidak ada pasal yang dikenakan\\n                    </p>\\n                  </div>\\n                )}\\n              </>\\n            );\\n          }}\\n        />\\n      </Form.Group>\\n\\n      <DetailModal\\n        show={showDetailModal}\\n        onHide={() => setShowDetailModal(false)}\\n        data={selectedDetail}\\n      />\\n    </>\\n  );\\n};\\n\\n// Modal untuk seleksi Pasal dengan filter berdasarkan type\\n\\n// Modal Detail Pasal\\nconst DetailModal = ({ show, onHide, data }) => {\\n  if (!data) return null;\\n\\n  return (\\n    <StyledModal\\n      centered\\n      size=\\\"md\\\"\\n      show={show}\\n      onHide={onHide}\\n      enforceFocus={false}\\n    >\\n      <HeaderDetail closeButton>\\n        <TitleHeader>{data.kode_pasal}</TitleHeader>\\n      </HeaderDetail>\\n      <BodyDetail>\\n        <p style={{ color: '#5B5D63', lineHeight: '1.6' }}>\\n          {data.description || 'Tidak ada deskripsi.'}\\n        </p>\\n      </BodyDetail>\\n    </StyledModal>\\n  );\\n};\\n\\nconst HeaderDetail = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n`;\\n\\nconst WrapperPasal = styled.div`\\n  background-color: var(--white);\\n  border: 1px solid var(--black-100);\\n  padding: 0.85714rem;\\n  border-radius: 0.85714rem;\\n`;\\n\\nconst BodyDetail = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n`;\\n\\nconst SelectedItemsContainer = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  margin-top: 1rem;\\n  width: 100%;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  background: var(--white);\\n`;\\n\\nconst SelectedItemsHeader = styled.div`\\n  padding: 0.75rem 1rem;\\n  background: var(--black-25);\\n  border-bottom: 1px solid var(--black-100);\\n  border-radius: 0.5rem 0.5rem 0 0;\\n  font-weight: 600;\\n  font-size: 0.875rem;\\n  color: var(--black);\\n`;\\n\\nconst SelectedItemsList = styled.div`\\n  max-height: 200px;\\n  overflow-y: auto;\\n  padding: 0.5rem;\\n\\n  &::-webkit-scrollbar {\\n    width: 6px;\\n  }\\n\\n  &::-webkit-scrollbar-track {\\n    background: transparent;\\n  }\\n\\n  &::-webkit-scrollbar-thumb {\\n    background-color: var(--black-300);\\n    border-radius: 4px;\\n  }\\n`;\\n\\nconst SelectedItemCard = styled.div`\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  background: var(--black-25);\\n  width: 100%;\\n  margin-bottom: 0.5rem;\\n  transition: all 0.2s ease;\\n\\n  &:last-child {\\n    margin-bottom: 0;\\n  }\\n\\n  &:hover {\\n    border-color: var(--primary-300);\\n    background: var(--primary-25);\\n  }\\n`;\\n\\nconst SelectedItemContent = styled.div`\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n  padding: 0.75rem 1rem;\\n  width: 100%;\\n`;\\n\\nconst SelectedItemHeader = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.25rem;\\n  flex: 1;\\n`;\\n\\nconst SelectedItemCode = styled.div`\\n  font-weight: 600;\\n  font-size: 0.875rem;\\n  color: var(--black);\\n`;\\n\\nconst DetailLink = styled.span`\\n  font-size: 0.75rem;\\n  color: var(--primary);\\n  cursor: pointer;\\n  text-decoration: underline;\\n  display: inline-block;\\n\\n  &:hover {\\n    color: var(--primary-700);\\n  }\\n`;\\n\\nconst PasalSelectable = ({\\n  control,\\n  name,\\n  label,\\n  placeholder = 'Pilih',\\n  filterType,\\n  initialValue = [],\\n}) => {\\n  const [options, setOptions] = useState([]);\\n  const [loading, setLoading] = useState(false);\\n  const [showDetailModal, setShowDetailModal] = useState(false);\\n  const [selectedDetail, setSelectedDetail] = useState(null);\\n  const [selectedItems, setSelectedItems] = useState([]);\\n  const [inputValue, setInputValue] = useState('');\\n\\n  useEffect(() => {\\n    if (initialValue && initialValue.length > 0) {\\n      // Convert initialValue ke format yang sesuai dengan options\\n      const formattedItems = initialValue.map((item) => {\\n        // Jika item sudah dalam format object\\n        if (typeof item === 'object' && item.kode_pasal) {\\n          return {\\n            value: item.value || item.article_id || item.id,\\n            kode_pasal: item.kode_pasal,\\n            description: item.description,\\n            label: `${item.kode_pasal} - ${item.description?.substring(0, 50)}...`,\\n            fullLabel: `${item.kode_pasal} - ${item.description}`,\\n            ...item,\\n          };\\n        }\\n        // Jika item adalah ID string, cari dari options\\n        return { value: item };\\n      });\\n      setSelectedItems(formattedItems);\\n    }\\n  }, [initialValue]);\\n\\n  const fetchPasalData = async (search = '') => {\\n    setLoading(true);\\n    try {\\n      const requestPayload = {\\n        orderBy: 'type',\\n        order: 'asc',\\n        page: 1,\\n        size: 100,\\n        connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n        table: 'dimension.catalog_pasal',\\n        database: 'divpropam',\\n        filters: [],\\n      };\\n\\n      if (filterType) {\\n        requestPayload.filters.push({\\n          field: 'type',\\n          operator: 'is',\\n          table: 'dimension.catalog_pasal',\\n          fieldType: 'text',\\n          value: { is: filterType },\\n        });\\n      }\\n\\n      if (search) {\\n        requestPayload.filters = [];\\n        requestPayload.filters.push({\\n          field: 'description',\\n          operator: 'contains',\\n          table: 'dimension.catalog_pasal',\\n          fieldType: 'text',\\n          value: search,\\n        });\\n      }\\n\\n      const response = await axios.post(\\n        '/api/v1/apps/data/management/get-all',\\n        requestPayload,\\n        {\\n          headers: {\\n            'Content-Type': 'application/json',\\n            Authorization: `Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiN2ZjZGYwOTgyNDY0ZTIyNGRkZjc4YjE4NTE5ZjNjNTEiLCJleHBpcmUiOjE3NDA2MDcyOTEuMzY5NjE4NH0.7RhnmP89eVgwbCx4BfhalzzzCPeXjmBRP5mE17CGvQY`,\\n          },\\n        },\\n      );\\n\\n      const items = response.data?.data || [];\\n\\n      const mappedOptions = items.map((item) => ({\\n        label: `${item.kode_pasal} - ${item.description?.substring(0, 50)}...`,\\n        value: item.id,\\n        kode_pasal: item.kode_pasal,\\n        pasal: item.pasal,\\n        ayat: item.ayat,\\n        sub_huruf: item.sub_huruf,\\n        description: item.description,\\n        type: item.type,\\n        fullLabel: `${item.kode_pasal} - ${item.description}`,\\n      }));\\n\\n      setOptions(mappedOptions);\\n\\n      if (initialValue.length > 0 && selectedItems.length === 0) {\\n        const matchedItems = initialValue\\n          .map((initItem) => {\\n            const matched = mappedOptions.find(\\n              (opt) =>\\n                opt.value ===\\n                (initItem.value || initItem.article_id || initItem),\\n            );\\n            if (matched) return matched;\\n            // Jika tidak match, buat item dari initialValue\\n            if (typeof initItem === 'object' && initItem.kode_pasal) {\\n              return {\\n                value: initItem.value || initItem.article_id,\\n                kode_pasal: initItem.kode_pasal,\\n                description: initItem.description,\\n                label: `${initItem.kode_pasal} - ${initItem.description?.substring(0, 50)}...`,\\n                fullLabel: `${initItem.kode_pasal} - ${initItem.description}`,\\n              };\\n            }\\n            return { value: initItem };\\n          })\\n          .filter(Boolean);\\n\\n        if (matchedItems.length > 0) {\\n          setSelectedItems(matchedItems);\\n        }\\n      }\\n    } catch (error) {\\n      console.error('Error fetching pasal data:', error);\\n      setOptions([]);\\n    } finally {\\n      setLoading(false);\\n    }\\n  };\\n\\n  useEffect(() => {\\n    fetchPasalData();\\n  }, []);\\n\\n  const handleInputChange = (inputValue) => {\\n    setInputValue(inputValue);\\n    if (inputValue.length > 2) {\\n      fetchPasalData(inputValue);\\n    }\\n    return inputValue;\\n  };\\n\\n  const handleDetailClick = (e, data) => {\\n    e.stopPropagation();\\n    setSelectedDetail(data);\\n    setShowDetailModal(true);\\n  };\\n\\n  const handleRemoveItem = (itemToRemove, field) => {\\n    const newSelectedItems = selectedItems.filter(\\n      (item) => item.value !== itemToRemove.value,\\n    );\\n    setSelectedItems(newSelectedItems);\\n    field.onChange(newSelectedItems.map((v) => v.value) || []);\\n  };\\n\\n  const formatOptionLabel = (data, { selectValue }) => {\\n    const isSelected = selectValue.some((v) => v.value === data.value);\\n\\n    return (\\n      <div\\n        style={{\\n          display: 'flex',\\n          justifyContent: 'space-between',\\n          alignItems: 'center',\\n          width: '100%',\\n          padding: '8px 4px',\\n        }}\\n      >\\n        <div style={{ flex: 1 }}>\\n          <div style={{ fontWeight: '600', fontSize: '0.9rem', color: '#333' }}>\\n            {data.kode_pasal || 'Pasal'}\\n          </div>\\n          <span\\n            style={{\\n              fontSize: '0.75rem',\\n              color: '#0d6efd',\\n              cursor: 'pointer',\\n              textDecoration: 'underline',\\n            }}\\n            onClick={(e) => handleDetailClick(e, data)}\\n          >\\n            Lihat detail\\n          </span>\\n        </div>\\n        <div\\n          style={{\\n            width: '20px',\\n            height: '20px',\\n            border: isSelected ? 'none' : '2px solid #dee2e6',\\n            borderRadius: '4px',\\n            backgroundColor: isSelected ? '#0d6efd' : 'transparent',\\n            display: 'flex',\\n            alignItems: 'center',\\n            justifyContent: 'center',\\n            color: 'white',\\n            fontSize: '14px',\\n          }}\\n        >\\n          {isSelected && (\\n            <i className=\\\"ph ph-check\\\" style={{ fontWeight: 'bold' }}></i>\\n          )}\\n        </div>\\n      </div>\\n    );\\n  };\\n\\n  const customStyles = {\\n    ...ReactSelectStyle,\\n    multiValue: () => ({}),\\n    multiValueLabel: () => ({}),\\n    multiValueRemove: () => ({}),\\n    valueContainer: (provided) => ({\\n      ...provided,\\n      padding: '0 8px',\\n      display: 'flex',\\n      flexWrap: 'wrap',\\n      alignItems: 'center',\\n    }),\\n    placeholder: (provided, state) => ({\\n      ...provided,\\n      display: state.hasValue ? 'none' : 'block',\\n      color: 'var(--black-300)',\\n      fontSize: '0.875rem',\\n    }),\\n    option: (provided, state) => ({\\n      ...provided,\\n      padding: '12px 16px',\\n      borderBottom: '1px solid #e9ecef',\\n      backgroundColor: state.isFocused ? 'var(--primary-25)' : 'white',\\n      color: 'var(--black)',\\n      whiteSpace: 'normal',\\n      wordBreak: 'break-word',\\n      ':last-child': { borderBottom: 'none' },\\n      ':active': { backgroundColor: 'var(--primary-50)' },\\n    }),\\n    menu: (provided) => ({\\n      ...provided,\\n      boxShadow: '0 4px 12px rgba(0,0,0,0.15)',\\n      borderRadius: '8px',\\n      zIndex: 9999,\\n      marginBottom: '8px',\\n    }),\\n    input: (provided) => ({\\n      ...provided,\\n      margin: 0,\\n      padding: 0,\\n      '& input': {\\n        height: '36px !important',\\n      },\\n    }),\\n    control: (provided) => ({\\n      ...provided,\\n      cursor: 'pointer',\\n    }),\\n    dropdownIndicator: (provided) => ({\\n      ...provided,\\n      cursor: 'pointer',\\n    }),\\n    // Menampilkan teks di input\\n    singleValue: (provided, state) => ({\\n      ...provided,\\n      display: 'flex',\\n      alignItems: 'center',\\n      color: 'var(--black)',\\n      fontWeight: '500',\\n    }),\\n  };\\n\\n  return (\\n    <>\\n      <Form.Group className=\\\"w-100\\\">\\n        <TitleInput className=\\\"mb-3\\\">{label}</TitleInput>\\n\\n        <Controller\\n          name={name}\\n          control={control}\\n          render={({ field }) => (\\n            <>\\n              <Select\\n                {...field}\\n                isMulti\\n                options={options}\\n                styles={customStyles}\\n                placeholder={placeholder}\\n                isClearable={false}\\n                isLoading={loading}\\n                onInputChange={handleInputChange}\\n                inputValue={inputValue}\\n                value={selectedItems}\\n                onChange={(val) => {\\n                  const newSelectedItems = val || [];\\n                  setSelectedItems(newSelectedItems);\\n                  field.onChange(newSelectedItems.map((v) => v.value) || []);\\n                }}\\n                formatOptionLabel={formatOptionLabel}\\n                getOptionLabel={(o) => o.fullLabel}\\n                getOptionValue={(o) => o.value}\\n                noOptionsMessage={() =>\\n                  loading ? 'Loading...' : 'Tidak ada data'\\n                }\\n                closeMenuOnSelect={false}\\n                hideSelectedOptions={false}\\n                menuPlacement=\\\"top\\\"\\n                components={{\\n                  MultiValue: () => null,\\n                }}\\n              />\\n\\n              {/* Badge jumlah item yang dipilih - tampil di luar input */}\\n              {selectedItems.length > 0 && (\\n                <SelectedBadgeWrapper>\\n                  <SelectedBadge>\\n                    <i className=\\\"ph ph-check-circle\\\"></i>\\n                    <span>{selectedItems.length} pasal dipilih</span>\\n                  </SelectedBadge>\\n                </SelectedBadgeWrapper>\\n              )}\\n\\n              {/* Selected items dengan scroll */}\\n              {selectedItems.length > 0 && (\\n                <SelectedItemsContainer>\\n                  <SelectedItemsHeader>\\n                    <span>Pasal yang dipilih ({selectedItems.length})</span>\\n                  </SelectedItemsHeader>\\n                  <SelectedItemsList>\\n                    {selectedItems.map((item) => (\\n                      <SelectedItemCard key={item.value}>\\n                        <SelectedItemContent>\\n                          <SelectedItemHeader>\\n                            <SelectedItemCode>\\n                              {item.kode_pasal}\\n                            </SelectedItemCode>\\n                            <DetailLink\\n                              onClick={(e) => handleDetailClick(e, item)}\\n                            >\\n                              Lihat detail\\n                            </DetailLink>\\n                          </SelectedItemHeader>\\n                          <RemoveButton\\n                            onClick={() => handleRemoveItem(item, field)}\\n                          >\\n                            <i className=\\\"ph ph-x\\\"></i>\\n                          </RemoveButton>\\n                        </SelectedItemContent>\\n                      </SelectedItemCard>\\n                    ))}\\n                  </SelectedItemsList>\\n                </SelectedItemsContainer>\\n              )}\\n            </>\\n          )}\\n        />\\n      </Form.Group>\\n\\n      <DetailModal\\n        show={showDetailModal}\\n        onHide={() => setShowDetailModal(false)}\\n        data={selectedDetail}\\n      />\\n    </>\\n  );\\n};\\n\\n// Modal Detail Pasal\\n\\nconst SelectedBadgeWrapper = styled.div`\\n  margin-top: 0.5rem;\\n  width: 100%;\\n`;\\n\\nconst SelectedBadge = styled.div`\\n  display: inline-flex;\\n  align-items: center;\\n  gap: 0.5rem;\\n  padding: 0.5rem 1rem;\\n  background: var(--primary-50);\\n  border-radius: 2rem;\\n  color: var(--primary-700);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  border: 1px solid var(--primary-200);\\n\\n  i {\\n    color: var(--primary-600);\\n    font-size: 1rem;\\n  }\\n`;\\n\\nconst BadgeSaksi = styled.div`\\n  border-radius: 0.85714rem;\\n  border: 1px solid var(--black-100);\\n  background: var(--black-25);\\n  padding: 0.85714rem;\\n`;\\nconst CardWrapper = styled.div`\\n  display: flex;\\n  padding: 12px;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 12px;\\n  flex: 1 0 0;\\n  align-self: stretch;\\n\\n  border-radius: 12px;\\n  border: 1px solid var(--Border-Primary, #e6e9f0);\\n  background: var(--Background-Secondary, #f5f7fa);\\n`;\\nconst RemoveButton = styled.button`\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  padding: 0.25rem;\\n  border: none;\\n  background: transparent;\\n  color: var(--black-400);\\n  cursor: pointer;\\n  border-radius: 0.25rem;\\n\\n  &:hover {\\n    background: var(--black-50);\\n    color: var(--danger);\\n  }\\n\\n  i {\\n    font-size: 1.125rem;\\n  }\\n`;\\n\",\"html\":\"import React from 'react';\\nconst dummyData = [\\n{\\nid: '-',\\nstatus: '-',\\nposisi: '-',\\nurgency_score_category: '-',\\ncreated_date: '-',\\ndetail_where: '-',\\ntype_of_violation: '-',\\ncategory: '-',\\npolda: '-',\\npolres: '-',\\npolsek: '-',\\n},\\n{\\nid: '-',\\nstatus: '-',\\nposisi: '-',\\nurgency_score_category: '-',\\ncreated_date: '-',\\ndetail_where: '-',\\ntype_of_violation: '-',\\ncategory: '-',\\npolda: '-',\\npolres: '-',\\npolsek: '-',\\n},\\n];\\n\\nexport default function MyCode({ widget, data, G }) {\\nconst activeData = data && data.length > 0 ? data : dummyData;\\nconst report = activeData[0];\\n\\nconst getStatusBadgeClass = (status) => {\\nconst s = status?.toLowerCase();\\nif (s.includes('bagyanduan')) return 'badge-bagyanduan';\\nif (s === 'Masuk') return 'badge-masuk';\\nif (s === 'selesai' || s === 'disetujui') return 'badge-selesai';\\nif (s === 'dikembalikan') return 'badge-dikembalikan';\\nif (s === 'verifikasi') return 'badge-verifikasi';\\nif (s === 'disposisi') return 'badge-disposisi';\\nif (s === 'penanganan') return 'badge-penanganan';\\nreturn '';\\n};\\n\\nconst getUrgencyClass = (urgency) => {\\nconst u = urgency?.toLowerCase();\\nif (u === 'tinggi') return 'badge-high';\\nif (u === 'sedang') return 'badge-medium';\\nif (u === 'rendah') return 'badge-low';\\nreturn '';\\n};\\n\\nconst formatText = (text) => {\\nreturn text\\n? text.charAt(0).toUpperCase() + text.slice(1).toLowerCase()\\n: '-';\\n};\\n\\nconst formatDateID = (dateString) => {\\nif (!dateString) return '-';\\nconst date = new Date(dateString);\\nif (isNaN(date)) return '-';\\nconst hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\nconst tanggal = date.getDate().toString().padStart(2, '0');\\nconst bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\nconst tahun = date.getFullYear().toString().slice(-2);\\nconst jam = date.getHours().toString().padStart(2, '0');\\nconst menit = date.getMinutes().toString().padStart(2, '0');\\nreturn `${hari}, ${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n};\\nreturn (\\n<div className=\\\"bg-white h-100\\\" style={{ border: '1px solid var(--black-100)', borderRadius: '0.8rem' }}>\\n  <div className=\\\"flex flex-col\\\" style={{ borderBottom: '1px solid var(--black-100)', padding: '16px' }}>\\n    <div className=\\\"widget-title\\\">{widget?.name || 'Detail Laporan'}</div>\\n  </div>\\n\\n  {/* Body */}\\n\\n  <div className=\\\"flex flex-col report-body-container\\\" style={{\\n          gap: '0.53333rem',\\n          padding: '16px',\\n          height: '85%',\\n        }}>\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Nomor Laporan</div>\\n      <div className=\\\"value\\\">{report?.id}</div>\\n    </div>\\n    {/* Status Utama */}\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Status</div>\\n      <div className={`badge ${getStatusBadgeClass(report?.status)} fs-12 fw-400`}>\\n        {formatText(report?.status)}\\n      </div>\\n    </div>\\n\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Posisi Laporan</div>\\n      <div className={`badge ${ report?.case_position ? getStatusBadgeClass(report.case_position) : 'badge-low' } fs-12 fw-400`}>\\n        {report?.case_position ? formatText(report.case_position) : '-'}\\n      </div>\\n    </div>\\n\\n    {/* Waktu Lapor */}\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Waktu Lapor</div>\\n      <div className=\\\"value\\\">\\n        {report?.created_date ? formatDateID(report.created_date) : '-'}\\n      </div>\\n    </div>\\n\\n    <div className=\\\"flex items-start\\\">\\n      <div className=\\\"information\\\">Lokasi Kejadian</div>\\n      <div className=\\\"value\\\" // style={{\\n            //   flex: 1,\\n            //   maxHeight: '4.2em',\\n            //   overflowY: 'auto',\\n            //   paddingRight: '8px',\\n            //   wordBreak: 'break-word',\\n            // }}>\\n        {report?.detail_where || '-'}\\n      </div>\\n    </div>\\n\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Kategori</div>\\n      <div className=\\\"value\\\">{formatText(report?.category)}</div>\\n    </div>\\n\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Sub Kategori</div>\\n      <div className=\\\"value\\\">{formatText(report?.category)}</div>\\n    </div>\\n\\n    <div className=\\\"flex items-start\\\">\\n      <div className=\\\"information\\\">Satuan</div>\\n      <div className=\\\"flex flex-col\\\">\\n        <div className=\\\"value\\\">{formatText(report?.polda)}</div>\\n        <div className=\\\"value\\\">{formatText(report?.polres)}</div>\\n        {/* <div className=\\\"value\\\">{formatText(report?.polsek)}</div> */}\\n      </div>\\n    </div>\\n  </div>\\n</div>\\n);\\n}\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":[\"latest_updated_at\",\"created_date\",\"updated_at\"],\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":true,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false},\"shareAPI\":\"\",\"useAsFilterConfig\":{\"enable\":false},\"pageState\":true,\"orderColumn\":false,\"manageOrderColumn\":{\"orderColumn\":{\"enable\":false,\"columns\":[]}},\"filterdByWorkspace\":false},\"x\":0,\"y\":253},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-03-17 07:15:07.097000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":47,\"id\":\"1b4585af9dd59ba73d7b220c4b1a0a5a\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"queryId\":\"fcc2ae98ceb45de19e73d0ecc04cce56\",\"query\":null,\"name\":\"Informasi Dasar Laporan\",\"chart\":\"table\",\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"sourceId\":[\"56c565c5896a5d1966aae657ed113a34\",\"450bbebba0f02fae55daab5ef1b15874\",\"2bf60c8295b82b4bbf351a1a728661db\",\"e3dd3c5e53fa4350bb2d65e687708e7c\"],\"database_type\":\"postgresql\"}},\"name\":\"Data Terlapor\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":301,\"w\":8,\"h\":47}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"b5e923912240161c067592321042f60a\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Informasi Dasar Laporan\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"1b4585af9dd59ba73d7b220c4b1a0a5a\":{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"fcc2ae98ceb45de19e73d0ecc04cce56\",\"sourceId\":[\"56c565c5896a5d1966aae657ed113a34\",\"450bbebba0f02fae55daab5ef1b15874\",\"2bf60c8295b82b4bbf351a1a728661db\",\"e3dd3c5e53fa4350bb2d65e687708e7c\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"id\",\"alias\":\"id\",\"name\":\"id\",\"type\":\"string\"},{\"field\":\"title\",\"alias\":\"title\",\"name\":\"title\",\"type\":\"string\"},{\"field\":\"created_date\",\"alias\":\"status\",\"name\":\"created_date\",\"type\":\"date\"},{\"field\":\"updated_at\",\"alias\":\"urgency_score_category\",\"name\":\"updated_at\",\"type\":\"date\"},{\"field\":\"category\",\"alias\":\"type\",\"name\":\"category\",\"type\":\"string\"},{\"field\":\"sub_category\",\"alias\":\"method\",\"name\":\"sub_category\",\"type\":\"string\"},{\"field\":\"sender_name\",\"alias\":\"created_date\",\"name\":\"sender_name\",\"type\":\"string\"},{\"field\":\"sender_phone\",\"alias\":\"phone_no\",\"name\":\"sender_phone\",\"type\":\"string\"},{\"field\":\"sender_address\",\"alias\":\"polda\",\"name\":\"sender_address\",\"type\":\"string\"},{\"field\":\"kategori\",\"alias\":\"polres\",\"name\":\"kategori\",\"type\":\"string\"},{\"field\":\"sub_kategori\",\"alias\":\"polsek\",\"name\":\"sub_kategori\",\"type\":\"string\"},{\"field\":\"wujud_perbuatan\",\"alias\":\"category\",\"name\":\"wujud_perbuatan\",\"type\":\"string\"},{\"field\":\"pasal_list\",\"alias\":\"type_of_violation\",\"name\":\"pasal_list\",\"type\":\"string\"},{\"field\":\"disposisi_updated_at\",\"alias\":\"detail_where\",\"name\":\"disposisi_updated_at\",\"type\":\"number\"},{\"field\":\"polda\",\"alias\":\"updated_at\",\"name\":\"polda\",\"type\":\"string\"},{\"field\":\"polres\",\"alias\":\"polres\",\"name\":\"polres\",\"type\":\"string\"},{\"field\":\"polsek\",\"alias\":\"polsek\",\"name\":\"polsek\",\"type\":\"string\"},{\"field\":\"status\",\"alias\":\"status\",\"name\":\"status\",\"type\":\"string\"},{\"field\":\"urgency_score_category\",\"alias\":\"urgency_score_category\",\"name\":\"urgency_score_category\",\"type\":\"string\"},{\"field\":\"sub_status\",\"alias\":\"sub_status\",\"name\":\"sub_status\",\"type\":\"string\"},{\"field\":\"case_position\",\"alias\":\"case_position\",\"name\":\"case_position\",\"type\":\"string\"},{\"field\":\"satker\",\"alias\":\"satker\",\"name\":\"satker\",\"type\":\"string\"},{\"field\":\"attachments\",\"alias\":\"attachments\",\"name\":\"attachments\",\"type\":\"string\"},{\"field\":\"prepetrator_name\",\"alias\":\"prepetrator_name\",\"name\":\"prepetrator_name\",\"type\":\"string\"},{\"field\":\"rank\",\"alias\":\"rank\",\"name\":\"rank\",\"type\":\"string\"},{\"field\":\"position\",\"alias\":\"position\",\"name\":\"position\",\"type\":\"string\"},{\"field\":\"birth_place\",\"alias\":\"birth_place\",\"name\":\"birth_place\",\"type\":\"string\"},{\"field\":\"birth_date\",\"alias\":\"birth_date\",\"name\":\"birth_date\",\"type\":\"string\"},{\"field\":\"prepetrator_phone\",\"alias\":\"prepetrator_phone\",\"name\":\"prepetrator_phone\",\"type\":\"string\"},{\"field\":\"gender\",\"alias\":\"gender\",\"name\":\"gender\",\"type\":\"string\"},{\"field\":\"identity_number\",\"alias\":\"identity_number\",\"name\":\"identity_number\",\"type\":\"string\"},{\"field\":\"professional_education\",\"alias\":\"professional_education\",\"name\":\"professional_education\",\"type\":\"string\"},{\"field\":\"graduation_year\",\"alias\":\"graduation_year\",\"name\":\"graduation_year\",\"type\":\"string\"},{\"field\":\"functional_assignment\",\"alias\":\"functional_assignment\",\"name\":\"functional_assignment\",\"type\":\"string\"},{\"field\":\"description\",\"alias\":\"description\",\"name\":\"description\",\"type\":\"string\"},{\"field\":\"type\",\"alias\":\"type\",\"name\":\"type\",\"type\":\"string\"},{\"field\":\"latest_updated_at\",\"alias\":\"latest_updated_at\",\"name\":\"latest_updated_at\",\"type\":\"date\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false}},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"id\",\"prepetrator_id\",\"sender_name\",\"sender_address\",\"phone_no\",\"type\",\"report_type\",\"report_number\",\"type_of_violation\",\"datetime\",\"short_description\",\"name\",\"birth_date\",\"birth_place\",\"rank\",\"identity_number\",\"division\",\"phone_number\",\"professional_education\",\"graduation_year\",\"gender\",\"functional_assignment\",\"position\",\"summary\",\"category\",\"sub_category\",\"form_of_action\",\"application_of_article\",\"witness\",\"evidence\",\"report_updated_at\",\"articles\",\"documents\",\"persons_responsible\"],[\"2026070200005\",\"2026070200005-00001\",\"Test-Prod-162748\",\"Jakarta\",\"6282244947780\",\"Anggota Polri\",null,null,null,null,null,\"Briptu Baskoro\",1782838800000,\"semarang\",\"AIPTU\",\"12345432\",\"DIVPROPAM\",\"88215478654\",\"SIPSS\",2020,\"laki-laki\",\"POLSATWA\",\"Kanit 2\",\"Pada pukul 16:27:48 WIB, Budi Santoso dihentikan di wilayah Simpang Cendana oleh anggota kepolisian Briptu Baskoro, anggota patroli. Briptu memeriksa dokumen kendaraan korban, menyatakan Budi diduga melanggar lalu lintas namun tidak menjelaskan detail pelanggaran. Ia mengarahkan korban ke pos patroli dan menuntut sejumlah uang untuk ‘menyelesaikan di tempat’, sekaligus mengancam akan membawa korban ke kantor polisi jika tidak memenuhi permintaan. Setelah Budi menyerahkan uang, Briptu membiarkan korban melanjutkan perjalanan tanpa memberikan bukti tilang atau dokumen resmi. Budi merasa dirugikan secara materiil dan psikologis, menilai tindakan Briptu sebagai penyalahgunaan kewenangan yang tidak sesuai prosedur dan kode etik kepolisian.\",\"PELANGGARAN ETIKA PUBLIK & RUANG DIGITAL\",\"PENYALAHGUNAAN IDENTITAS POLRI DI RUANG DIGITAL\",\"MENGGUNAKAN IDENTITAS POLRI UNTUK MENGINTIMIDASI DI MEDIA SOSIAL (NON- PIDANA)\",\"kode-etik\",null,null,null,[{\"article_id\":\"863316fb6f2f438c86f89de7777b2f7b\",\"type\":\"PERPOL NOMOR 7 TH 2022\",\"kode_pasal\":\"10(1)A4\",\"description\":\"Melakukan perbuatan yang tidak sesuai dengan ketentuan peraturan perundang-undangan, dan/atau standar operasional prosedur dalam penerbitan dokumen dan/atau produk Kepolisian terkait pelayanan masyarakat.\"}],[],[]]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"/* .information {\\n  width: 240px;\\n  font-size: 0.93333rem;\\n  font-weight: 400;\\n  line-height: 140%;\\n  word-break: break-word;\\n  color: var(--black-600);\\n} */\\n\\n\\n.subtitle {\\n  font-size: 14px;\\n  font-weight: 500;\\n  color: var(--black);\\n}\\n\\n.card-ubahdata {\\n  display: flex;\\n  padding: 6px 12px 6px 8px;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 8px;\\n  border-radius: 8px;\\n  border: 1px solid var(--black-100);\\n  background: var(--white);\\n}\\n\\n.badge {\\n  display: flex;\\n  padding: 0.26667rem 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.4rem;\\n  border-radius: 0.4rem;\\n}\\n\\n.badge-penanganan {\\n  color: var(--Quinary-Base, #8E44AD);\\n\\n  background: var(--Quinary-Light, #F4ECF7);\\n}\\n\\n\\n.badge-masuk {\\n  background: var(--black-50);\\n  color: var(--black);\\n}\\n\\n\\n\\n.badge-selesai {\\n  background: var(--success-50);\\n  color: var(--success);\\n}\\n\\n.badge-dikembalikan {\\n  color: var(--Secondary-Base, #FF6F00);\\n  background: var(--Secondary-Light, #FFF1E6);\\n}\\n\\n.badge-disposisi {\\n  background: var(--warning-50);\\n  color: var(--warning);\\n}\\n\\n.badge-verifikasi {\\n  background: var(--primary-50);\\n  color: var(--primary);\\n}\\n\\n.badge-high {\\n  background: var(--danger-50);\\n  color: var(--danger);\\n}\\n\\n.badge-medium {\\n  background: var(--warning-50);\\n  color: var(--warning);\\n\\n}\\n\\n.badge-low {\\n  background: var(--success-50);\\n  color: var(--success);\\n\\n}\\n\\n.badge-laporan {\\n  background: var(--white);\\n  border: 1px solid var(--primary-50);\\n  color: var(--primary);\\n}\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useMemo } from 'react';\\nimport { useForm, Controller } from 'react-hook-form';\\nimport { Modal, Form, Row, Col, Button, InputGroup } from 'react-bootstrap';\\nimport styled from 'styled-components';\\nimport { DatePicker } from 'antd';\\nimport Select, { components } from 'react-select';\\nimport dayjs from 'dayjs';\\nimport axios from 'axios';\\nimport { dashboard } from '@store/app';\\n\\nconst dummyData = [\\n    {\\n        report_id: '-',\\n        status: '-',\\n        posisi: '-',\\n        prepetrator_type: '-',\\n        created_date: '-',\\n        detail_where: '-',\\n        type_of_violation: '-',\\n        nama: '-',\\n        polda: '-',\\n        polres: '-',\\n        polsek: '-',\\n    },\\n    {\\n        report_id: '-',\\n        status: '-',\\n        posisi: '-',\\n        prepetrator_type: '-',\\n        created_date: '-',\\n        detail_where: '-',\\n        type_of_violation: '-',\\n        nama: '-',\\n        polda: '-',\\n        polres: '-',\\n        polsek: '-',\\n    },\\n];\\n\\nconst KATEGORI_OPTIONS = [\\n    {\\n        label: 'PERILAKU & INTEGRITAS PERSONAL',\\n        value: 'PERILAKU & INTEGRITAS PERSONAL',\\n    },\\n    {\\n        label: 'PENANGANAN PERKARA PIDANA',\\n        value: 'PENANGANAN PERKARA PIDANA',\\n    },\\n    {\\n        label: 'TUGAS KEDINASAN KEPOLISIAN',\\n        value: 'TUGAS KEDINASAN KEPOLISIAN',\\n    },\\n    {\\n        label: 'PELAYANAN KEPOLISIAN',\\n        value: 'PELAYANAN KEPOLISIAN',\\n    },\\n    {\\n        label: 'PELANGGARAN HUKUM / TINDAK PIDANA',\\n        value: 'PELANGGARAN HUKUM / TINDAK PIDANA',\\n    },\\n    {\\n        label: 'ETIKA PUBLIK & RUANG DIGITAL',\\n        value: 'ETIKA PUBLIK & RUANG DIGITAL',\\n    },\\n    {\\n        label: 'MARTABAT MANUSIA & HAK INDIVIDU',\\n        value: 'MARTABAT MANUSIA & HAK INDIVIDU',\\n    },\\n];\\n\\nconst SUB_KATEGORI_MAP = {\\n    'PERILAKU & INTEGRITAS PERSONAL': [\\n        {\\n            label: 'PERILAKU MORAL & KESUSILAAN',\\n            value: 'PERILAKU MORAL & KESUSILAAN',\\n        },\\n        {\\n            label: 'KEHIDUPAN KELUARGA, KEWAJIBAN DOMESTIK & TANGGUNG JAWAB PRIBADI',\\n            value: 'KEHIDUPAN KELUARGA, KEWAJIBAN DOMESTIK & TANGGUNG JAWAB PRIBADI',\\n        },\\n        {\\n            label: 'INTEGRITAS KEUANGAN & KEJUJURAN PRIBADI',\\n            value: 'INTEGRITAS KEUANGAN & KEJUJURAN PRIBADI',\\n        },\\n        {\\n            label: 'PERILAKU SOSIAL & HUBUNGAN BERMASYARAKAT',\\n            value: 'PERILAKU SOSIAL & HUBUNGAN BERMASYARAKAT',\\n        },\\n        {\\n            label: 'PENAMPILAN, ETIKA PRIBADI & KEPATUTAN PERILAKU',\\n            value: 'PENAMPILAN, ETIKA PRIBADI & KEPATUTAN PERILAKU',\\n        },\\n        {\\n            label:\\n                'PENYALAHGUNAAN STATUS PRIBADI SEBAGAI POLRI (TIDAK DALAM KONTEKS KEDINASAN)',\\n            value:\\n                'PENYALAHGUNAAN STATUS PRIBADI SEBAGAI POLRI (TIDAK DALAM KONTEKS KEDINASAN)',\\n        },\\n        {\\n            label: 'PERILAKU LAIN YANG MENCERMINKAN RENDAHNYA INTEGRITAS PRIBADI',\\n            value: 'PERILAKU LAIN YANG MENCERMINKAN RENDAHNYA INTEGRITAS PRIBADI',\\n        },\\n    ],\\n\\n    'PENANGANAN PERKARA PIDANA': [\\n        {\\n            label: 'PELANGGARAN TAHAP PENERIMAAN LAPORAN / PENGADUAN',\\n            value: 'PELANGGARAN TAHAP PENERIMAAN LAPORAN / PENGADUAN',\\n        },\\n        {\\n            label: 'PELANGGARAN TAHAP PENYELIDIKAN',\\n            value: 'PELANGGARAN TAHAP PENYELIDIKAN',\\n        },\\n        {\\n            label: 'PELANGGARAN TAHAP PENYIDIKAN',\\n            value: 'PELANGGARAN TAHAP PENYIDIKAN',\\n        },\\n        {\\n            label: 'PELANGGARAN BARANG BUKTI & PROSES TEKNIS',\\n            value: 'PELANGGARAN BARANG BUKTI & PROSES TEKNIS',\\n        },\\n        {\\n            label: 'PELANGGARAN GELAR PERKARA & ADMINISTRASI PENYIDIKAN',\\n            value: 'PELANGGARAN GELAR PERKARA & ADMINISTRASI PENYIDIKAN',\\n        },\\n        {\\n            label: 'PELANGGARAN PENGIRIMAN BERKAS & KOORDINASI PENYIDIKAN',\\n            value: 'PELANGGARAN PENGIRIMAN BERKAS & KOORDINASI PENYIDIKAN',\\n        },\\n        {\\n            label: 'PELANGGARAN YANG MENGHAMBAT HAK MASYARAKAT DAN PROSES PERADILAN',\\n            value: 'PELANGGARAN YANG MENGHAMBAT HAK MASYARAKAT DAN PROSES PERADILAN',\\n        },\\n        {\\n            label: 'PELANGGARAN INTEGRITAS DALAM PENYIDIKAN',\\n            value: 'PELANGGARAN INTEGRITAS DALAM PENYIDIKAN',\\n        },\\n        {\\n            label: 'PELANGGARAN PENGAWASAN INTERNAL PENYIDIKAN',\\n            value: 'PELANGGARAN PENGAWASAN INTERNAL PENYIDIKAN',\\n        },\\n        {\\n            label: 'PRINSIP UMUM (UMBRELLA PROVISIONS)',\\n            value: 'PRINSIP UMUM (UMBRELLA PROVISIONS)',\\n        },\\n    ],\\n\\n    'TUGAS KEDINASAN KEPOLISIAN': [\\n        {\\n            label: 'PENGGUNAAN WEWENANG & DISKRESI KEDINASAN',\\n            value: 'PENGGUNAAN WEWENANG & DISKRESI KEDINASAN',\\n        },\\n        {\\n            label: 'KEDISIPLINAN DALAM MELAKSANAKAN TUGAS',\\n            value: 'KEDISIPLINAN DALAM MELAKSANAKAN TUGAS',\\n        },\\n        {\\n            label: 'PELAKSANAAN OPERASI & PENGAMANAN',\\n            value: 'PELAKSANAAN OPERASI & PENGAMANAN',\\n        },\\n        {\\n            label: 'PENGELOLAAN INVENTARIS DINAS & FASILITAS POLRI',\\n            value: 'PENGELOLAAN INVENTARIS DINAS & FASILITAS POLRI',\\n        },\\n        {\\n            label: 'KINERJA ADMINISTRASI KEDINASAN (NON-PERKARA)',\\n            value: 'KINERJA ADMINISTRASI KEDINASAN (NON-PERKARA)',\\n        },\\n        {\\n            label: 'KESIAPSIAGAAN & PROFESIONALITAS OPERASIONAL',\\n            value: 'KESIAPSIAGAAN & PROFESIONALITAS OPERASIONAL',\\n        },\\n        {\\n            label: 'SUPERVISI & KOMANDO DALAM TUGAS DINAS',\\n            value: 'SUPERVISI & KOMANDO DALAM TUGAS DINAS',\\n        },\\n        {\\n            label: 'PELAKSANAAN TUGAS KHUSUS / OPERASI POLISIONIL',\\n            value: 'PELAKSANAAN TUGAS KHUSUS / OPERASI POLISIONIL',\\n        },\\n        {\\n            label: 'PENUGASAN KHUSUS & TANGGUNG JAWAB PENEMPATAN',\\n            value: 'PENUGASAN KHUSUS & TANGGUNG JAWAB PENEMPATAN',\\n        },\\n    ],\\n\\n    'PELAYANAN KEPOLISIAN': [\\n        {\\n            label: 'PENOLAKAN LAYANAN TANPA DASAR HUKUM',\\n            value: 'PENOLAKAN LAYANAN TANPA DASAR HUKUM',\\n        },\\n        {\\n            label:\\n                'PELAYANAN YANG TIDAK PROFESIONAL, TIDAK RAMAH, ATAU DISKRIMINATIF',\\n            value:\\n                'PELAYANAN YANG TIDAK PROFESIONAL, TIDAK RAMAH, ATAU DISKRIMINATIF',\\n        },\\n        {\\n            label: 'KUALITAS LAYANAN RENDAH & MALADMINISTRASI PUBLIK',\\n            value: 'KUALITAS LAYANAN RENDAH & MALADMINISTRASI PUBLIK',\\n        },\\n        {\\n            label: 'PUNGUTAN LIAR & TRANSAKSI TIDAK RESMI (NON-PIDANA)',\\n            value: 'PUNGUTAN LIAR & TRANSAKSI TIDAK RESMI (NON-PIDANA)',\\n        },\\n        {\\n            label: 'PENGABAIAN TERHADAP PEMOHON LAYANAN',\\n            value: 'PENGABAIAN TERHADAP PEMOHON LAYANAN',\\n        },\\n        {\\n            label: 'PENGGUNAAN FASILITAS LAYANAN SECARA TIDAK PROPORSIONAL',\\n            value: 'PENGGUNAAN FASILITAS LAYANAN SECARA TIDAK PROPORSIONAL',\\n        },\\n        {\\n            label: 'KOMUNIKASI LAYANAN YANG TIDAK MEMENUHI STANDAR',\\n            value: 'KOMUNIKASI LAYANAN YANG TIDAK MEMENUHI STANDAR',\\n        },\\n        {\\n            label: 'AKUNTABILITAS & TRANSPARANSI LAYANAN',\\n            value: 'AKUNTABILITAS & TRANSPARANSI LAYANAN',\\n        },\\n        {\\n            label: 'PENYESATAN LAYANAN & ARAHAN JALUR TIDAK RESMI',\\n            value: 'PENYESATAN LAYANAN & ARAHAN JALUR TIDAK RESMI',\\n        },\\n    ],\\n\\n    'PELANGGARAN HUKUM / TINDAK PIDANA': [\\n        {\\n            label: 'TINDAK PIDANA TERHADAP KEKAYAAN (PROPERTY CRIMES)',\\n            value: 'TINDAK PIDANA TERHADAP KEKAYAAN (PROPERTY CRIMES)',\\n        },\\n        {\\n            label: 'TINDAK PIDANA KEKERASAN (CRIMES AGAINST PERSONS)',\\n            value: 'TINDAK PIDANA KEKERASAN (CRIMES AGAINST PERSONS)',\\n        },\\n        {\\n            label: 'TINDAK PIDANA KESUSILAAN',\\n            value: 'TINDAK PIDANA KESUSILAAN',\\n        },\\n        {\\n            label: 'PENGHINAAN, PENCEMARAN NAMA BAIK & UJARAN KEBENCIAN',\\n            value: 'PENGHINAAN, PENCEMARAN NAMA BAIK & UJARAN KEBENCIAN',\\n        },\\n        {\\n            label: 'TINDAK PIDANA DI BIDANG ADMINISTRASI NEGARA & KEPEMERINTAHAN',\\n            value: 'TINDAK PIDANA DI BIDANG ADMINISTRASI NEGARA & KEPEMERINTAHAN',\\n        },\\n        {\\n            label: 'TINDAK PIDANA KEUANGAN, PERBANKAN, DAN TPPU',\\n            value: 'TINDAK PIDANA KEUANGAN, PERBANKAN, DAN TPPU',\\n        },\\n        {\\n            label: 'TINDAK PIDANA TERHADAP KETERTIBAN UMUM',\\n            value: 'TINDAK PIDANA TERHADAP KETERTIBAN UMUM',\\n        },\\n        {\\n            label: 'TINDAK PIDANA NARKOTIKA',\\n            value: 'TINDAK PIDANA NARKOTIKA',\\n        },\\n        {\\n            label: 'TINDAK PIDANA DI BIDANG INFORMASI & TRANSAKSI ELEKTRONIK',\\n            value: 'TINDAK PIDANA DI BIDANG INFORMASI & TRANSAKSI ELEKTRONIK',\\n        },\\n        {\\n            label: 'TINDAK PIDANA KHUSUS LAINNYA',\\n            value: 'TINDAK PIDANA KHUSUS LAINNYA',\\n        },\\n        {\\n            label: 'TINDAK PIDANA BERAT / SERIUS',\\n            value: 'TINDAK PIDANA BERAT / SERIUS',\\n        },\\n    ],\\n\\n    'ETIKA PUBLIK & RUANG DIGITAL': [\\n        {\\n            label: 'ETIKA PUBLIK (OFFLINE / FISIK)',\\n            value: 'ETIKA PUBLIK (OFFLINE / FISIK)',\\n        },\\n        {\\n            label: 'ETIKA KOMUNIKASI PUBLIK',\\n            value: 'ETIKA KOMUNIKASI PUBLIK',\\n        },\\n        {\\n            label: 'RUANG DIGITAL & MEDIA SOSIAL',\\n            value: 'RUANG DIGITAL & MEDIA SOSIAL',\\n        },\\n        {\\n            label: 'NETRALITAS & ETIKA ELEKTORAL',\\n            value: 'NETRALITAS & ETIKA ELEKTORAL',\\n        },\\n        {\\n            label: 'KOMERSIALISASI IDENTITAS POLRI',\\n            value: 'KOMERSIALISASI IDENTITAS POLRI',\\n        },\\n        {\\n            label: 'KONTEN MERUSAK KEPERCAYAAN PUBLIK (NON-PIDANA)',\\n            value: 'KONTEN MERUSAK KEPERCAYAAN PUBLIK (NON-PIDANA)',\\n        },\\n        {\\n            label: 'PENYALAHGUNAAN IDENTITAS POLRI DIGITAL',\\n            value: 'PENYALAHGUNAAN IDENTITAS POLRI DIGITAL',\\n        },\\n        {\\n            label: 'ETIKA PUBLIK DALAM PERILAKU SIMBOLIK',\\n            value: 'ETIKA PUBLIK DALAM PERILAKU SIMBOLIK',\\n        },\\n    ],\\n\\n    'MARTABAT MANUSIA & HAK INDIVIDU': [\\n        {\\n            label: 'PERILAKU MERENDAHKAN MARTABAT MANUSIA',\\n            value: 'PERILAKU MERENDAHKAN MARTABAT MANUSIA',\\n        },\\n        {\\n            label: 'INTIMIDASI & TEKANAN PSIKOLOGIS (NON-PIDANA)',\\n            value: 'INTIMIDASI & TEKANAN PSIKOLOGIS (NON-PIDANA)',\\n        },\\n        {\\n            label: 'PENGABAIAN HAK-HAK DASAR INDIVIDU',\\n            value: 'PENGABAIAN HAK-HAK DASAR INDIVIDU',\\n        },\\n        {\\n            label: 'PELANGGARAN MARTABAT DALAM INTERAKSI DINAS',\\n            value: 'PELANGGARAN MARTABAT DALAM INTERAKSI DINAS',\\n        },\\n        {\\n            label: 'PELANGGARAN MARTABAT MELALUI TINDAKAN SIMBOLIK',\\n            value: 'PELANGGARAN MARTABAT MELALUI TINDAKAN SIMBOLIK',\\n        },\\n        {\\n            label: 'PELANGGARAN MARTABAT DI RUANG DIGITAL (NON-PIDANA)',\\n            value: 'PELANGGARAN MARTABAT DI RUANG DIGITAL (NON-PIDANA)',\\n        },\\n        {\\n            label: 'PENGABAIAN KEWAJIBAN KEMANUSIAAN DALAM DARURAT',\\n            value: 'PENGABAIAN KEWAJIBAN KEMANUSIAAN DALAM DARURAT',\\n        },\\n    ],\\n};\\nconst PendidikanOptions = [\\n    { label: 'AKPOL', value: 'AKPOL' },\\n    { label: 'SIPSS', value: 'SIPSS' },\\n    { label: 'BINTARA', value: 'BINTARA' },\\n    { label: 'TAMTAMA', value: 'TAMTAMA' },\\n    { label: 'SIP', value: 'SIP' },\\n    { label: 'PAG', value: 'PAG' },\\n    { label: 'SEKOLAH BINTARA POLISI', value: 'SEKOLAH BINTARA POLISI' },\\n];\\n\\nconst normalizeString = (str) => {\\n    if (!str) return '';\\n    return str.trim().toUpperCase();\\n};\\n\\nconst findMatchingOption = (options, value) => {\\n    if (!value || !options || options.length === 0) return null;\\n    const normalizedValue = normalizeString(value);\\n    return options.find((opt) => normalizeString(opt.value) === normalizedValue);\\n};\\n\\nconst getNormalizedValue = (options, currentValue) => {\\n    if (!currentValue) return '';\\n    const matched = findMatchingOption(options, currentValue);\\n    return matched ? matched.value : currentValue;\\n};\\n\\nexport default function InformasiLaporan({\\n    widget,\\n    data,\\n    G,\\n    pageState,\\n    userToken,\\n    user,\\n}) {\\n    // Normalisasi data — pola sama seperti di api-gateway.jsx (line 964)\\n    const rawData = Array.isArray(data) ? data : data?.data || [];\\n    const activeData = rawData.length > 0 ? rawData : dummyData;\\n    const [items, setItems] = useState(activeData);\\n    const [showModal, setShowModal] = useState(false);\\n    const [activeTab, setActiveTab] = useState('data-terlapor');\\n    const [loading, setLoading] = useState(false);\\n    const [allKategoriData, setAllKategoriData] = useState([]);\\n    const [loadingKategori, setLoadingKategori] = useState(false);\\n    const [showValidationError, setShowValidationError] = useState(false);\\n    const [allKesatuanData, setAllKesatuanData] = useState([]);\\n    const [isDragging, setIsDragging] = useState(false);\\n    const [files, setFiles] = useState([]);\\n    const [pangkatOptions, setPangkatOptions] = useState([]);\\n    const [loadingPangkat, setLoadingPangkat] = useState(false);\\n    const [pangkatSearchTimeout, setPangkatSearchTimeout] = useState(null);\\n\\n    const [showDetailModal, setShowDetailModal] = useState(false);\\n    const [selectedDetail, setSelectedDetail] = useState(null);\\n\\n    const [pasalPPRI, setPasalPPRI] = useState([]);\\n    const [pasalPerpol, setPasalPerpol] = useState([]);\\n    const [pasalDisiplinPPRI, setPasalDisiplinPPRI] = useState([]);\\n    const [pasalDisiplinPerpol, setPasalDisiplinPerpol] = useState([]);\\n    const [functionalOptions, setFunctionalOptions] = useState([]);\\n    const [loadingFunctional, setLoadingFunctional] = useState(false);\\n    const [functionalSearchTimeout, setFunctionalSearchTimeout] = useState(null);\\n\\n    const handleDetailClick = (e, data) => {\\n        e.stopPropagation();\\n        setSelectedDetail(data);\\n        setShowDetailModal(true);\\n    };\\n\\n    const [uploadedFiles, setUploadedFiles] = useState([]);\\n    const report = activeData[0];\\n\\n    // Ganti state yang lama dengan satu state grouping ini\\n    const [groupedArticles, setGroupedArticles] = useState({});\\n\\n    useEffect(() => {\\n        // console.log('=== PROCESSING ARTICLES ===');\\n\\n        if (report && report?.articles && Array.isArray(report.articles)) {\\n            const articles = report.articles;\\n            // console.log('Total articles:', articles.length);\\n\\n            // Mengelompokkan data secara dinamis berdasarkan 'type'\\n            const grouped = articles.reduce((acc, item) => {\\n                // Jika type null/kosong, beri nama default \\\"Lainnya\\\"\\n                const typeName = item.type || 'Lainnya';\\n\\n                if (!acc[typeName]) {\\n                    acc[typeName] = [];\\n                }\\n\\n                acc[typeName].push(item);\\n                return acc;\\n            }, {});\\n\\n            // console.log('Grouped Articles by Type:', grouped);\\n\\n            // Update state dengan data yang sudah dikelompokkan\\n            setGroupedArticles(grouped);\\n        } else {\\n            console.log('No articles found in report');\\n            setGroupedArticles({});\\n        }\\n    }, [report]);\\n\\n    useEffect(() => {\\n        // console.log('=== PROCESSING ARTICLES ===');\\n\\n        // Pastikan report dan articles ada\\n        if (report && report.articles && Array.isArray(report.articles)) {\\n            const articles = report.articles;\\n            // console.log('Total articles:', articles.length);\\n\\n            // Filter untuk PPRI (PP Nomor 1 TH 2003)\\n            const filteredPPRI = articles.filter((item) => {\\n                const type = item.type || '';\\n                // Match dengan \\\"PP Nomor 1 TH 2003\\\"\\n                return type === 'PP Nomor 1 TH 2003' || type.includes('PP Nomor');\\n            });\\n\\n            // Filter untuk Perpol (Perpolri No 7 Tahun 2022)\\n            const filteredPerpol = articles.filter((item) => {\\n                const type = item.type || '';\\n                // Match dengan \\\"Perpolri No 7 Tahun 2022\\\"\\n                return type === 'Perpolri No 7 Tahun 2022' || type.includes('Perpolri');\\n            });\\n\\n            // console.log(\\n            //   'Filtered PPRI (should be articles with type PP Nomor):',\\n            //   filteredPPRI,\\n            // );\\n            // console.log(\\n            //   'Filtered Perpol (should be articles with type Perpolri):',\\n            //   filteredPerpol,\\n            // );\\n\\n            // Update state\\n            setPasalPPRI(filteredPPRI);\\n            setPasalPerpol(filteredPerpol);\\n        } else {\\n            console.log('No articles found in report');\\n            console.log('report?.articles:', report?.articles);\\n        }\\n    }, [report]); // Hanya dependensi pada report\\n\\n    const perpetratorData = report || {};\\n\\n    const [step, setStep] = useState(1);\\n    const handleCloseWithReset = () => {\\n        setStep(1); // Reset ke step 1\\n        setSelectedTipeTerlapor(\\n            report?.type || report?.reported_type || 'Anggota Polri',\\n        );\\n        setSelectedGender(report?.gender || 'laki-laki');\\n        setSelectedPenerapanPasal(report?.application_of_article || 'kode-etik');\\n        handleCloseEdit();\\n    };\\n\\n    // console.log('report (activeData[0]):', report);\\n\\n    const getStatusBadgeClass = (status) => {\\n        const s = status?.toLowerCase();\\n        if (s.includes('bagyanduan')) return 'badge-bagyanduan';\\n        if (s === 'Masuk') return 'badge-masuk';\\n        if (s === 'selesai' || s === 'disetujui') return 'badge-selesai';\\n        if (s === 'dikembalikan') return 'badge-dikembalikan';\\n        if (s === 'verifikasi') return 'badge-verifikasi';\\n        if (s === 'disposisi') return 'badge-disposisi';\\n        if (s === 'penanganan') return 'badge-penanganan';\\n        return '';\\n    };\\n\\n    const getUrgencyClass = (urgency) => {\\n        const u = urgency?.toLowerCase();\\n        if (u === 'tinggi') return 'badge-high';\\n        if (u === 'ASN Polri') return 'badge-medium';\\n        if (u === 'Anggota Polri') return 'badge-low';\\n        return '';\\n    };\\n\\n    const filterValidFiles = (files) => {\\n        const allowedExtensions = [\\n            '.pdf',\\n            '.jpg',\\n            '.jpeg',\\n            '.png',\\n            '.doc',\\n            '.docx',\\n            '.mp4',\\n        ];\\n        const MAX_FILE_SIZE = 10 * 1024 * 1024;\\n        const validFiles = [];\\n        const invalidFiles = [];\\n\\n        files.forEach((file) => {\\n            const fileName = file.name.toLowerCase();\\n            const isValidExt = allowedExtensions.some((ext) =>\\n                fileName.endsWith(ext),\\n            );\\n            const isValidSize = file.size <= MAX_FILE_SIZE;\\n\\n            if (isValidExt && isValidSize) {\\n                validFiles.push(file);\\n            } else {\\n                if (!isValidExt) {\\n                    invalidFiles.push(`${file.name} (format tidak diizinkan)`);\\n                } else if (!isValidSize) {\\n                    invalidFiles.push(`${file.name} (melebihi 10MB)`);\\n                }\\n            }\\n        });\\n\\n        if (invalidFiles.length > 0) {\\n            alert(\\n                `File ditolak:\\\\n${invalidFiles.join('\\\\n')}\\\\n\\\\nFormat yang diizinkan: ${allowedExtensions.join(', ')}`,\\n            );\\n        }\\n\\n        return validFiles;\\n    };\\n    const formatText = (text) => {\\n        return text\\n            ? text.charAt(0).toUpperCase() + text.slice(1).toLowerCase()\\n            : '-';\\n    };\\n\\n    const formatBorn = (dateString) => {\\n        if (!dateString) return '-';\\n        const date = new Date(dateString);\\n        if (isNaN(date)) return '-';\\n\\n        const tanggal = date.getDate().toString().padStart(2, '0');\\n        const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n        const tahun = date.getFullYear();\\n\\n        return `${tanggal} ${bulan} ${tahun}`;\\n    };\\n\\n    const simpleHash32 = (str) => {\\n        let hash = 0;\\n        let result = '';\\n\\n        for (let i = 0; i < str.length; i++) {\\n            const char = str.charCodeAt(i);\\n            hash = (hash << 5) - hash + char;\\n            hash = hash & hash;\\n\\n            const hex = Math.abs(hash).toString(16).padStart(8, '0');\\n            result += hex;\\n\\n            if (result.length >= 32) break;\\n        }\\n\\n        while (result.length < 32) {\\n            result += '0';\\n        }\\n\\n        return result.substring(0, 32);\\n    };\\n\\n    const getFileExtension = (filename) => {\\n        return filename.split('.').pop() || '';\\n    };\\n\\n    const generateHashedPath = (originalFilename) => {\\n        const hash = simpleHash32(originalFilename);\\n        const extension = getFileExtension(originalFilename);\\n        const timestamp = Date.now();\\n        const random = Math.random().toString(36).substring(2, 8);\\n\\n        return `${hash}_${timestamp}_${random}.${extension}`;\\n    };\\n    const {\\n        register,\\n        watch,\\n        control,\\n        formState: { errors },\\n    } = useForm();\\n\\n    const {\\n        register: registerEdit,\\n        handleSubmit: handleSubmitEdit,\\n        watch: watchEdit,\\n        setValue: setValueEdit,\\n        reset: resetEdit,\\n        trigger: triggerEdit,\\n        control: controlEdit,\\n        formState: { errors: errorsEdit },\\n    } = useForm({\\n        defaultValues: {\\n            // DATA TERLAPOR (flat structure)\\n            prepetrator_type:\\n                report?.type || report?.reported_type || 'Anggota Polri',\\n            prepetrator_name: report?.name || '',\\n            prepetrator_birth_place: report?.birth_place || '',\\n            prepetrator_birth_date: report?.birth_date || '',\\n            prepetrator_rank: report?.rank || '',\\n            prepetrator_id_number: report?.identity_number || '',\\n            prepetrator_position: report?.position || '',\\n            prepetrator_phone: report?.phone_number || '',\\n            prepetrator_education: report?.professional_education || '',\\n            prepetrator_graduation_year: report?.graduation_year || '',\\n            prepetrator_gender: report?.gender || 'laki-laki',\\n            prepetrator_functional: report?.functional_assignment || '',\\n            prepetrator_division: report?.division || '',\\n\\n            // DATA PELANGGARAN\\n            prepetrator_description: report?.description || '',\\n            prepetrator_category: report?.category || report?.category || '',\\n            prepetrator_sub_category:\\n                report?.sub_category || report?.sub_category || '',\\n            prepetrator_form_of_action: report?.form_of_action || '',\\n            application_article: report?.application_of_article || '',\\n\\n            pasal_ppri: [],\\n            pasal_perpol: [],\\n            pasal_disiplin_ppri: [],\\n            pasal_disiplin_perpol: [],\\n\\n            // DATA PENDUMAS\\n            sender_name: report?.sender_name || '',\\n            phone_no: report?.phone_no || '',\\n            sender_address: report?.sender_address || '',\\n\\n            // ID\\n            report_id: report?.report_id || report?.id || '',\\n        },\\n        mode: 'onChange',\\n    });\\n\\n    const DEFAULT_TIPE_TERLAPOR = 'Anggota Polri';\\n    const [selectedTipeTerlapor, setSelectedTipeTerlapor] = useState(\\n        report?.type || report?.reported_type || DEFAULT_TIPE_TERLAPOR,\\n    );\\n    const [selectedGender, setSelectedGender] = useState(\\n        report?.gender || 'laki-laki',\\n    );\\n    const [selectedPenerapanPasal, setSelectedPenerapanPasal] = useState(\\n        report?.application_of_article || 'kode-etik',\\n    );\\n\\n    const handleOpenEdit = () => {\\n        resetEdit({\\n            // Data Terlapor (flat structure)\\n            prepetrator_type: report?.type || report?.reported_type || '',\\n            prepetrator_name: report?.name || '',\\n            birth_place: report?.birth_place || '',\\n            birth_date: report?.birth_date || '',\\n            rank: report?.rank || '',\\n            identity_number: report?.identity_number || '',\\n            position: report?.position || '',\\n            prepetrator_phone: report?.phone_number || '',\\n            prepetrator_education: report?.professional_education || '',\\n            graduation_year: report?.graduation_year || '',\\n            gender: report?.gender || 'laki-laki',\\n            functional_assignment: report?.functional_assignment || '',\\n            prepetrator_division: report?.division || '',\\n\\n            // Data Pelanggaran\\n            description: report?.description || '',\\n            kategori: getNormalizedValue(\\n                kategoriOptions,\\n                report?.category || report?.kategori || '',\\n            ),\\n            sub_kategori: getNormalizedValue(\\n                subKategoriOptions,\\n                report?.sub_category || report?.sub_kategori || '',\\n            ),\\n            wujud_perbuatan: getNormalizedValue(\\n                wujudPerbuatanOptions,\\n                report?.form_of_action || '',\\n            ),\\n            form_of_action: report?.application_of_article || 'kode-etik',\\n\\n            pasal_perpol: (report?.articles || [])\\n                .filter((a) => a.type === 'PERPOL NOMOR 7 TH 2022')\\n                .map((a) => a.article_id),\\n            pasal_ppri: (report?.articles || [])\\n                .filter((a) => a.type === 'PPRI NOMOR 1 TAHUN 2003')\\n                .map((a) => a.article_id),\\n\\n            pasal_disiplin_ppri: (report?.articles || [])\\n                .filter((a) => a.type === 'PPRI NOMOR 2 TAHUN 2003')\\n                .map((a) => a.article_id),\\n\\n            // Data Pendumas\\n            sender_name: report?.sender_name || '',\\n            sender_phone: report?.phone_no || '',\\n            sender_address: report?.sender_address || '',\\n\\n            // ID\\n            report_id: report?.report_id || report?.id || '',\\n        });\\n\\n        setSelectedTipeTerlapor(\\n            report?.type || report?.reported_type || 'Anggota Polri',\\n        );\\n        setSelectedGender(report?.gender || 'laki-laki');\\n        setSelectedPenerapanPasal(report?.application_of_article || 'kode-etik');\\n\\n        setShowModal(true);\\n    };\\n    const handleCloseEdit = () => {\\n        setShowModal(false);\\n        resetEdit();\\n    };\\n\\n    const handleTabClick = (tabKey) => {\\n        setActiveTab(tabKey);\\n    };\\n    const handleRadioClick = (value) => {\\n        setValueEdit('prepetrator_type', value, {\\n            shouldValidate: true,\\n            shouldDirty: true,\\n        });\\n    };\\n\\n    // Tambahkan handler untuk radio button Tingkat Kasus\\n    const handleRadioKasusClick = (value) => {\\n        setValueEdit('status_level', value, {\\n            shouldValidate: true,\\n            shouldDirty: true,\\n        });\\n    };\\n\\n    const fetchAllKategori = async () => {\\n        setLoadingKategori(true);\\n        try {\\n            const response = await axios.post(\\n                '/api/v1/apps/data/management/get-all',\\n                {\\n                    orderBy: 'kategori',\\n                    order: 'asc',\\n                    page: 1,\\n                    size: 1000,\\n                    connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n                    table: 'dimension.catalog_kategori_perbuatan',\\n                    database: 'divpropam',\\n                    filters: [],\\n                },\\n                {\\n                    headers: {\\n                        'Content-Type': 'application/json',\\n                        Authorization: `Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiN2ZjZGYwOTgyNDY0ZTIyNGRkZjc4YjE4NTE5ZjNjNTEiLCJleHBpcmUiOjE3NDA2MDcyOTEuMzY5NjE4NH0.7RhnmP89eVgwbCx4BfhalzzzCPeXjmBRP5mE17CGvQY`,\\n                    },\\n                },\\n            );\\n\\n            // console.log('Kategori data:', response.data);\\n            setAllKategoriData(response.data?.data || []);\\n        } catch (error) {\\n            console.error('Error fetch kategori:', error);\\n        } finally {\\n            setLoadingKategori(false);\\n        }\\n    };\\n\\n    const fetchAllKesatuan = async () => {\\n        setLoadingKategori(true);\\n        try {\\n            const response = await axios.post(\\n                '/api/v1/apps/data/management/get-all',\\n                {\\n                    orderBy: 'polda_name',\\n                    order: 'asc',\\n                    page: 1,\\n                    size: 1000,\\n                    connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n                    table: 'dimension.catalog_kesatuan_terlapor',\\n                    database: 'divpropam',\\n                    filters: [],\\n                },\\n                {\\n                    headers: {\\n                        'Content-Type': 'application/json',\\n                        Authorization: `Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiN2ZjZGYwOTgyNDY0ZTIyNGRkZjc4YjE4NTE5ZjNjNTEiLCJleHBpcmUiOjE3NDA2MDcyOTEuMzY5NjE4NH0.7RhnmP89eVgwbCx4BfhalzzzCPeXjmBRP5mE17CGvQY`,\\n                    },\\n                },\\n            );\\n\\n            // console.log('Kategori data:', response.data);\\n            setAllKesatuanData(response.data?.data || []);\\n        } catch (error) {\\n            console.error('Error fetch kategori:', error);\\n        } finally {\\n            setLoadingKategori(false);\\n        }\\n    };\\n\\n    const fetchPangkat = async (typePrepetrator, search = '') => {\\n        setLoadingPangkat(true);\\n        try {\\n            const actualType =\\n                typePrepetrator === 'Anonim' ? 'Anggota Polri' : typePrepetrator;\\n\\n            const requestPayload = {\\n                orderBy: 'pangkat',\\n                order: 'asc',\\n                page: 1,\\n                size: 1000,\\n                connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n                table: 'dimension.catalog_pangkat',\\n                database: 'divpropam',\\n                filters: [\\n                    {\\n                        field: 'type',\\n                        operator: 'is',\\n                        table: 'dimension.catalog_pangkat',\\n                        fieldType: 'text',\\n                        value: {\\n                            is: actualType, // Gunakan actualType bukan typePrepetrator\\n                        },\\n                    },\\n                ],\\n            };\\n\\n            if (search && search.trim() !== '') {\\n                requestPayload.search = search;\\n                requestPayload.search_by = ['pangkat'];\\n            }\\n\\n            const response = await axios.post(\\n                '/api/v1/apps/data/management/get-all',\\n                requestPayload,\\n                {\\n                    headers: {\\n                        Authorization: `Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiN2ZjZGYwOTgyNDY0ZTIyNGRkZjc4YjE4NTE5ZjNjNTEiLCJleHBpcmUiOjE3NDA2MDcyOTEuMzY5NjE4NH0.7RhnmP89eVgwbCx4BfhalzzzCPeXjmBRP5mE17CGvQY`,\\n                        'Content-Type': 'application/json',\\n                    },\\n                },\\n            );\\n\\n            const rawData = response.data?.data || [];\\n\\n            const formattedOptions = rawData.map((item) => ({\\n                label: item.pangkat,\\n                value: item.pangkat,\\n                id: item.id,\\n                pangkat: item.pangkat,\\n                type: item.type,\\n            }));\\n\\n            setPangkatOptions(formattedOptions);\\n        } catch (error) {\\n            console.error('Error fetch Pangkat:', error);\\n            setPangkatOptions([]);\\n        } finally {\\n            setLoadingPangkat(false);\\n        }\\n    };\\n\\n    const fetchFunctional = async (search = '') => {\\n        setLoadingFunctional(true);\\n        try {\\n            const requestPayload = {\\n                orderBy: 'function',\\n                order: 'asc',\\n                page: 1,\\n                size: 1000,\\n                connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n                table: 'dimension.catalog_function',\\n                database: 'divpropam',\\n                filters: [],\\n            };\\n\\n            if (search && search.trim() !== '') {\\n                requestPayload.filters.push({\\n                    field: 'function',\\n                    operator: 'contains',\\n                    table: 'dimension.catalog_function',\\n                    fieldType: 'text',\\n                    value: search,\\n                });\\n            }\\n\\n            const response = await axios.post(\\n                '/api/v1/apps/data/management/get-all',\\n                requestPayload,\\n                {\\n                    headers: {\\n                        'Content-Type': 'application/json',\\n                        Authorization: `Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiN2ZjZGYwOTgyNDY0ZTIyNGRkZjc4YjE4NTE5ZjNjNTEiLCJleHBpcmUiOjE3NDA2MDcyOTEuMzY5NjE4NH0.7RhnmP89eVgwbCx4BfhalzzzCPeXjmBRP5mE17CGvQY`,\\n                    },\\n                },\\n            );\\n\\n            const rawData = response.data?.data || [];\\n\\n            const formattedOptions = rawData.map((item) => ({\\n                label: item.function,\\n                value: item.function,\\n            }));\\n\\n            setFunctionalOptions(formattedOptions);\\n        } catch (error) {\\n            console.error('Error fetch Fungsi:', error);\\n            setFunctionalOptions([]);\\n        } finally {\\n            setLoadingFunctional(false);\\n        }\\n    };\\n\\n    const handleFunctionalSearch = (inputValue) => {\\n        if (functionalSearchTimeout) {\\n            clearTimeout(functionalSearchTimeout);\\n        }\\n\\n        const timeout = setTimeout(() => {\\n            fetchFunctional(inputValue);\\n        }, 500);\\n\\n        setFunctionalSearchTimeout(timeout);\\n    };\\n\\n    const handlePangkatSearch = (inputValue) => {\\n        if (pangkatSearchTimeout) {\\n            clearTimeout(pangkatSearchTimeout);\\n        }\\n\\n        const timeout = setTimeout(() => {\\n            if (selectedTipeTerlapor) {\\n                fetchPangkat(selectedTipeTerlapor, inputValue);\\n            }\\n        }, 500);\\n\\n        setPangkatSearchTimeout(timeout);\\n    };\\n\\n    // Effect untuk fetch pangkat ketika selectedTipeTerlapor berubah\\n    useEffect(() => {\\n        if (showModal && selectedTipeTerlapor) {\\n            fetchPangkat(selectedTipeTerlapor);\\n        }\\n    }, [showModal, selectedTipeTerlapor]);\\n\\n    // Effect untuk reset pangkat ketika tipe terlapor berubah di modal\\n    useEffect(() => {\\n        if (showModal && selectedTipeTerlapor) {\\n            fetchPangkat(selectedTipeTerlapor);\\n\\n            setValueEdit('rank', '');\\n        }\\n    }, [selectedTipeTerlapor]);\\n\\n    useEffect(() => {\\n        const loadAllModalData = async () => {\\n            await Promise.all([\\n                fetchAllKategori(),\\n                fetchAllKesatuan(),\\n                fetchFunctional(),\\n            ]);\\n        };\\n\\n        if (showModal) {\\n            loadAllModalData();\\n        }\\n    }, [showModal]);\\n\\n    useEffect(() => {\\n        if (report && Object.keys(report).length > 0) {\\n            const type = report?.type || report?.reported_type || 'Anggota Polri';\\n            setSelectedTipeTerlapor(type);\\n            setSelectedGender(report?.gender || 'laki-laki');\\n            setSelectedPenerapanPasal(report?.application_of_article || 'kode-etik');\\n        }\\n    }, [report]);\\n\\n    const kesatuanOptions = useMemo(() => {\\n        return allKesatuanData.map((item) => ({\\n            label: item.polda_name || item.nama_kesatuan || '-',\\n            value: item.polda_name || item.nama_kesatuan,\\n        }));\\n    }, [allKesatuanData]);\\n\\n    const kategoriOptions = useMemo(() => {\\n        const uniqueKategori = [\\n            ...new Set(allKategoriData.map((item) => item.kategori)),\\n        ];\\n        return uniqueKategori.map((kat) => ({\\n            label: kat,\\n            value: kat,\\n            normalizedValue: normalizeString(kat),\\n        }));\\n    }, [allKategoriData]);\\n\\n    const subKategoriOptions = useMemo(() => {\\n        const selectedKat = watchEdit('kategori');\\n        if (!selectedKat) return [];\\n\\n        const normalizedSelectedKat = normalizeString(selectedKat);\\n\\n        const filtered = allKategoriData.filter(\\n            (item) => normalizeString(item.kategori) === normalizedSelectedKat,\\n        );\\n\\n        const uniqueSub = [\\n            ...new Map(\\n                filtered.map((item) => [normalizeString(item.sub_kategori), item]),\\n            ).values(),\\n        ];\\n\\n        return uniqueSub.map((item) => ({\\n            label: item.sub_kategori,\\n            value: item.sub_kategori,\\n            normalizedValue: normalizeString(item.sub_kategori),\\n        }));\\n    }, [allKategoriData, watchEdit('kategori')]);\\n\\n    const wujudPerbuatanOptions = useMemo(() => {\\n        const selectedKat = watchEdit('kategori');\\n        const selectedSub = watchEdit('sub_kategori');\\n\\n        if (!selectedKat) return [];\\n\\n        const normalizedSelectedKat = normalizeString(selectedKat);\\n        const normalizedSelectedSub = selectedSub\\n            ? normalizeString(selectedSub)\\n            : null;\\n\\n        const filtered = allKategoriData.filter((item) => {\\n            const katMatch = normalizeString(item.kategori) === normalizedSelectedKat;\\n            if (selectedSub && normalizedSelectedSub) {\\n                const subMatch =\\n                    normalizeString(item.sub_kategori) === normalizedSelectedSub;\\n                return katMatch && subMatch;\\n            }\\n            return katMatch;\\n        });\\n\\n        return filtered.map((item) => ({\\n            label: item.wujud_perbuatan,\\n            value: item.wujud_perbuatan,\\n            id: item.id,\\n            kategori: item.kategori,\\n            sub_kategori: item.sub_kategori,\\n            normalizedValue: normalizeString(item.wujud_perbuatan),\\n        }));\\n    }, [allKategoriData, watchEdit('kategori'), watchEdit('sub_kategori')]);\\n\\n    const onSubmitEdit = async (formData) => {\\n        // console.log('=== SUBMIT EDIT ===');\\n        // console.log('Step saat ini:', step);\\n        // console.log('Form data:', formData);\\n        // console.log('Selected Tipe Terlapor:', selectedTipeTerlapor);\\n        // console.log('Selected Gender:', selectedGender);\\n        // console.log('Selected Penerapan Pasal:', selectedPenerapanPasal);\\n\\n        setLoading(true);\\n\\n        try {\\n            // Validasi final sebelum submit - SEMUA STEP\\n            // Step 1 - Data Terlapor\\n            if (!selectedTipeTerlapor) {\\n                alert('Tipe Terlapor wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.prepetrator_name) {\\n                alert('Nama wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.birth_place) {\\n                alert('Tempat Lahir wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.birth_date) {\\n                alert('Tanggal Lahir wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.rank) {\\n                alert('Pangkat wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.identity_number) {\\n                alert('NRP wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            const nrpCleaned = formData.identity_number.replace(/\\\\D/g, '');\\n            if (nrpCleaned.length !== 8) {\\n                alert('NRP harus terdiri dari 8 angka');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.position) {\\n                alert('Jabatan wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.prepetrator_phone) {\\n                alert('Nomor Telepon wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.prepetrator_education) {\\n                alert('Pendidikan Kepolisian wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.graduation_year) {\\n                alert('Tahun Lulus wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!selectedGender) {\\n                alert('Jenis Kelamin wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.functional_assignment) {\\n                alert('Fungsi wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.prepetrator_division) {\\n                alert('Kesatuan wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n\\n            // Step 2 - Data Pelanggaran\\n            if (!formData.description) {\\n                alert('Kronologi Singkat wajib diisi');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.kategori) {\\n                alert('Kategori wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.sub_kategori) {\\n                alert('Sub Kategori wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!formData.wujud_perbuatan) {\\n                alert('Wujud Perbuatan wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n            if (!selectedPenerapanPasal) {\\n                alert('Penerapan Pasal wajib dipilih');\\n                setLoading(false);\\n                return;\\n            }\\n\\n            // Validasi pasal berdasarkan tipe terlapor dan penerapan pasal\\n            // if (selectedTipeTerlapor === 'Anggota Polri') {\\n            //   if (selectedPenerapanPasal === 'kode-etik') {\\n            //     if (!formData.pasal_ppri || formData.pasal_ppri.length === 0) {\\n            //       alert('Pasal PPRI No. 1 Tahun 2003 wajib dipilih minimal 1');\\n            //       setLoading(false);\\n            //       return;\\n            //     }\\n            //     if (!formData.pasal_perpol || formData.pasal_perpol.length === 0) {\\n            //       alert('Pasal Perpol 7 Tahun 2022 wajib dipilih minimal 1');\\n            //       setLoading(false);\\n            //       return;\\n            //     }\\n            //   } else if (selectedPenerapanPasal === 'disiplin') {\\n            //     if (\\n            //       !formData.pasal_disiplin_ppri ||\\n            //       formData.pasal_disiplin_ppri.length === 0\\n            //     ) {\\n            //       alert('Pasal PPRI No. 2 Tahun 2003 wajib dipilih minimal 1');\\n            //       setLoading(false);\\n            //       return;\\n            //     }\\n            //     if (\\n            //       !formData.pasal_disiplin_perpol ||\\n            //       formData.pasal_disiplin_perpol.length === 0\\n            //     ) {\\n            //       alert('Pasal PPRI No. 94 Tahun 2021 wajib dipilih minimal 1');\\n            //       setLoading(false);\\n            //       return;\\n            //     }\\n            //   }\\n            // } else if (selectedTipeTerlapor === 'ASN Polri') {\\n            //   // Untuk ASN Polri, hanya validasi pasal PPRI No. 94 Tahun 2021\\n            //   if (\\n            //     !formData.pasal_disiplin_perpol ||\\n            //     formData.pasal_disiplin_perpol.length === 0\\n            //   ) {\\n            //     alert('Pasal PPRI No. 94 Tahun 2021 wajib dipilih minimal 1');\\n            //     setLoading(false);\\n            //     return;\\n            //   }\\n            // }\\n\\n            if (\\n                selectedTipeTerlapor === 'Anggota Polri' ||\\n                selectedTipeTerlapor === 'Anonim'\\n            ) {\\n                if (selectedPenerapanPasal === 'kode-etik') {\\n                    const pasalPpri = formData.pasal_ppri || [];\\n                    const pasalPerpol = formData.pasal_perpol || [];\\n\\n                    if (pasalPpri.length === 0 && pasalPerpol.length === 0) {\\n                        alert(\\n                            'Pilih minimal 1 pasal dari PERPOL NOMOR 7 TH 2022 atau PPRI NOMOR 1 TAHUN 2003',\\n                        );\\n                        setLoading(false);\\n                        return;\\n                    }\\n                } else if (selectedPenerapanPasal === 'disiplin') {\\n                    const pasalDisiplinValue = formData.pasal_disiplin_ppri;\\n\\n                    console.log(\\n                        'Pasal Disiplin value (PPRI NOMOR 2 TAHUN 2003):',\\n                        pasalDisiplinValue,\\n                    );\\n\\n                    if (\\n                        !pasalDisiplinValue ||\\n                        (Array.isArray(pasalDisiplinValue) &&\\n                            pasalDisiplinValue.length === 0)\\n                    ) {\\n                        alert('PPRI NOMOR 2 TAHUN 2003 wajib dipilih minimal 1');\\n                        setLoading(false);\\n                        return;\\n                    }\\n                }\\n            } else if (selectedTipeTerlapor === 'ASN Polri') {\\n                const pasalAsnValue = formData.pasal_disiplin_ppri;\\n\\n                console.log(\\n                    'Pasal ASN value (PPRI NOMOR 94 TAHUN 2021):',\\n                    pasalAsnValue,\\n                );\\n\\n                if (\\n                    !pasalAsnValue ||\\n                    (Array.isArray(pasalAsnValue) && pasalAsnValue.length === 0)\\n                ) {\\n                    alert('PPRI NOMOR 94 TAHUN 2021 wajib dipilih minimal 1');\\n                    setLoading(false);\\n                    return;\\n                }\\n            }\\n\\n            // Step 3 - Data Pendumas\\n            if (!formData.sender_name) {\\n            alert('Nama Pendumas wajib diisi');\\n            setLoading(false);\\n            return;\\n        }\\n        if (!formData.sender_phone) {\\n            alert('Nomor Telepon wajib diisi');\\n            setLoading(false);\\n            return;\\n        }\\n        if (!formData.sender_address) {\\n            alert('Alamat wajib diisi');\\n            setLoading(false);\\n            return;\\n        }\\n\\n        // Siapkan data untuk dikirim\\n        const editData = {\\n            // ID Laporan\\n            report_id: report?.report_id || report?.id || report?._id,\\n            id: report?.report_id || report?.id || report?._id,\\n            prepetrator_id: report?.prepetrator_id,\\n\\n            // DATA TERLAPOR\\n            prepetrator_type: selectedTipeTerlapor,\\n            prepetrator_name: formData.prepetrator_name,\\n            prepetrator_birth_place: formData.birth_place,\\n            prepetrator_birth_date: formData.birth_date,\\n            prepetrator_rank: formData.rank,\\n            prepetrator_id_number: formData.identity_number,\\n            prepetrator_position: formData.position,\\n            prepetrator_phone: formData.prepetrator_phone,\\n            prepetrator_education: formData.prepetrator_education,\\n            prepetrator_graduation_year: formData.graduation_year,\\n            prepetrator_gender: selectedGender,\\n            prepetrator_functional: formData.functional_assignment,\\n            prepetrator_division: formData.prepetrator_division,\\n\\n            // DATA PELANGGARAN\\n            prepetrator_description: formData.description,\\n            prepetrator_category: formData.kategori,\\n            prepetrator_sub_category: formData.sub_kategori,\\n            prepetrator_form_of_action: formData.wujud_perbuatan,\\n            application_article: selectedPenerapanPasal,\\n\\n            // prepetrator_id_article_ppri:\\n            //   formData.pasal_ppri || formData.pasal_disiplin_ppri || [],\\n            // prepetrator_id_article_perpol:\\n            //   formData.pasal_perpol || formData.pasal_disiplin_perpol || [],\\n\\n            // prepetrator_id_article_ppri: (() => {\\n            //   if (selectedTipeTerlapor === 'Anggota Polri') {\\n            //     if (selectedPenerapanPasal === 'kode-etik') {\\n            //       return formData.pasal_ppri || [];\\n            //     } else if (selectedPenerapanPasal === 'disiplin') {\\n            //       return formData.pasal_disiplin_ppri || [];\\n            //     }\\n            //   }\\n            //   return [];\\n            // })(),\\n\\n            // prepetrator_id_article_perpol: (() => {\\n            //   if (selectedTipeTerlapor === 'Anggota Polri') {\\n            //     if (selectedPenerapanPasal === 'kode-etik') {\\n            //       return formData.pasal_ppri || [];\\n            //     } else if (selectedPenerapanPasal === 'disiplin') {\\n            //       return formData.pasal_disiplin_perpol || [];\\n            //     }\\n            //   } else if (selectedTipeTerlapor === 'ASN Polri') {\\n            //     return formData.pasal_disiplin_perpol || [];\\n            //   }\\n            //   return [];\\n            // })(),\\n\\n            // Pasal-pasal\\n            // prepetrator_id_article: [\\n            //   ...(formData.pasal_ppri || []),\\n            //   ...(formData.pasal_perpol || []),\\n            //   ...(formData.pasal_disiplin_ppri || []),\\n            //   ...(formData.pasal_disiplin_perpol || []),\\n            // ],\\n\\n            // DATA PENDUMAS\\n            sender_name: formData.sender_name,\\n            phone_no: formData.sender_phone,\\n            sender_address: formData.sender_address,\\n\\n            // DOKUMEN\\n            attachments:\\n                uploadedFiles.length > 0 ? uploadedFiles : report?.attachments || [],\\n        };\\n\\n        // console.log('Edit payload:', editData);\\n\\n        if (\\n            selectedTipeTerlapor === 'Anggota Polri' &&\\n            selectedPenerapanPasal === 'kode-etik'\\n        ) {\\n            editData.prepetrator_id_article_perpol = formData.pasal_perpol || [];\\n            editData.prepetrator_id_article_ppri = formData.pasal_ppri || [];\\n            //         editData.prepetrator_id_article_perpol = [\\n            //   ...(formData.pasal_perpol || []),\\n            //   ...(formData.pasal_ppri || [])\\n            // ];\\n        } else if (\\n            selectedTipeTerlapor === 'Anggota Polri' &&\\n            selectedPenerapanPasal === 'disiplin'\\n        ) {\\n            editData.prepetrator_id_article_ppri =\\n                formData.pasal_disiplin_ppri || [];\\n        } else if (selectedTipeTerlapor === 'ASN Polri') {\\n            editData.prepetrator_id_article_ppri =\\n                formData.pasal_disiplin_ppri || [];\\n        }\\n\\n        // KIRIM KE API\\n        const requestPayload = {\\n            client: 'Propam Polri',\\n            gatewayId: '20270a4ffc0bc262b68aa142418d9b42',\\n            params: {},\\n            body: editData,\\n            headers: {},\\n            additionalPath: '',\\n            additionalParams: {},\\n            additionalFileParams: {},\\n            tags: ['Propam Polri'],\\n            createdBy: user?.id || '',\\n            startDate: '',\\n            endDate: '',\\n            dashboardId: dashboard?.id || '',\\n            sessionId: '',\\n            logging: false,\\n            appendedLog: false,\\n            metaData: {\\n                widgetId: '1b4585af9dd59ba73d7b220c4b1a0a5a',\\n                widgetName: 'Data Terlapor',\\n                menuId: '01f63e60376afe827638ed614e1cea76',\\n                menuName: 'Detail Laporan',\\n                dashboardId: '1769155096865',\\n                dashboardName: 'Propam Aduan',\\n                userId: user?.id,\\n                domain: '',\\n            },\\n        };\\n\\n        // console.log('Sending to gateway:', requestPayload);\\n\\n        const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n            method: 'POST',\\n            headers: {\\n                'Content-Type': 'application/json',\\n            },\\n            body: JSON.stringify(requestPayload),\\n        });\\n\\n        if (!gatewayResponse.ok) {\\n            const errorText = await gatewayResponse.text();\\n            throw new Error(\\n                `Gateway error: ${gatewayResponse.status} - ${errorText}`,\\n            );\\n        }\\n\\n        const gatewayResult = await gatewayResponse.json();\\n        // console.log('Edit success:', gatewayResult);\\n\\n        // Notifikasi sukses\\n        if (typeof dispatchNotification === 'function') {\\n            dispatchNotification('Laporan berhasil diedit!', 'success');\\n        }\\n\\n        alert('Data laporan berhasil diperbarui!');\\n\\n        setShowModal(false);\\n        resetEdit();\\n        setStep(1);\\n        setFiles([]);\\n        setUploadedFiles([]);\\n    } catch (err) {\\n        console.error('Error editing laporan:', err);\\n\\n        // Notifikasi error\\n        if (typeof dispatchNotification === 'function') {\\n            dispatchNotification(`Error: ${err.message}`, 'danger');\\n        }\\n\\n        alert(`Gagal mengupdate data: ${err.message}`);\\n    } finally {\\n        setLoading(false);\\n    }\\n};\\n\\nconst sanitizeSvg = async (file) => {\\n    return file;\\n};\\n\\n// const handleFileChange = async (e) => {\\n//   const selectedFiles = Array.from(e.target.files || []);\\n\\n//   if (selectedFiles.length === 0) return;\\n\\n//   for (const file of selectedFiles) {\\n//     let fileToUpload = file;\\n//     if (file.type === 'image/svg+xml') {\\n//       const safeFile = await sanitizeSvg(file);\\n//       if (!safeFile) {\\n//         dispatchNotification(\\n//           `SVG \\\"${file.name}\\\" is unsafe and has been blocked.`,\\n//           'danger',\\n//         );\\n//         continue;\\n//       }\\n//       fileToUpload = safeFile;\\n//     }\\n\\n//     setFiles((prev) => [...prev, fileToUpload]);\\n//     await handleFileUpload(fileToUpload);\\n//   }\\n\\n//   e.target.value = '';\\n// };\\n\\n// const handleDrop = async (e) => {\\n//   e.preventDefault();\\n//   setIsDragging(false);\\n\\n//   const droppedFiles = Array.from(e.dataTransfer.files || []);\\n\\n//   for (const file of droppedFiles) {\\n//     setFiles((prev) => [...prev, file]);\\n//     await handleFileUpload(file);\\n//   }\\n// };\\n\\nconst handleFileChange = async (e) => {\\n    const selectedFiles = Array.from(e.target.files || []);\\n\\n    if (selectedFiles.length === 0) return;\\n\\n    const validFiles = filterValidFiles(selectedFiles);\\n    if (validFiles.length === 0) {\\n        e.target.value = '';\\n        return;\\n    }\\n\\n    for (const file of validFiles) {\\n        let fileToUpload = file;\\n        if (file.type === 'image/svg+xml') {\\n            const safeFile = await sanitizeSvg(file);\\n            if (!safeFile) {\\n                dispatchNotification(\\n                    `SVG \\\"${file.name}\\\" is unsafe and has been blocked.`,\\n                    'danger',\\n                );\\n                continue;\\n            }\\n            fileToUpload = safeFile;\\n        }\\n\\n        setFiles((prev) => [...prev, fileToUpload]);\\n        await handleFileUpload(fileToUpload);\\n    }\\n\\n    e.target.value = '';\\n};\\nconst handleDrop = async (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n\\n    const droppedFiles = Array.from(e.dataTransfer.files || []);\\n\\n    // FILTER FILE\\n    const validFiles = filterValidFiles(droppedFiles);\\n    if (validFiles.length === 0) return;\\n\\n    for (const file of validFiles) {\\n        // Ganti droppedFiles => validFiles\\n        setFiles((prev) => [...prev, file]);\\n        await handleFileUpload(file);\\n    }\\n};\\n\\nconst handleDragOver = (e) => {\\n    e.preventDefault();\\n    setIsDragging(true);\\n};\\n\\nconst handleDragLeave = (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n};\\n\\nconst removeFile = (file) => {\\n    setFiles((prev) => prev.filter((f) => f !== file));\\n    setUploadedFiles((prev) => prev.filter((f) => f.name !== file.name));\\n};\\n\\nconst removeExistingFile = (fileUrl) => {\\n    // Remove from existing files display (this is just UI, actual deletion might need API call)\\n    console.log('Removing existing file:', fileUrl);\\n};\\n\\n// const handleFileUpload = async (file) => {\\n//   console.log('Uploading file:', file.name, file.size);\\n\\n//   const queryParams = new URLSearchParams({\\n//     folder: 'agent',\\n//     workspaceId: user?.workspaceId || '',\\n//     dashboardId: dashboard?.id || '',\\n//     createdBy: user?.id || '',\\n//     extractFile: 'false',\\n//   }).toString();\\n\\n//   const formData = new FormData();\\n//   formData.append('file', file);\\n//   formData.append('tags', 'assets');\\n\\n//   try {\\n//     const res = await fetch(\\n//       `/api/v1/apps/upload/upload-file?${queryParams}`,\\n//       {\\n//         method: 'POST',\\n//         body: formData,\\n//       },\\n//     );\\n\\n//     console.log('Upload response status:', res.status);\\n\\n//     if (!res.ok) {\\n//       const errorText = await res.text();\\n//       console.error('Upload failed:', errorText);\\n//       throw new Error(`Upload gagal: ${res.status} - ${errorText}`);\\n//     }\\n\\n//     const result = await res.json();\\n//     console.log('Upload success:', result);\\n\\n//     const uploadedFileInfo = result?.data?.path || '';\\n\\n//     setUploadedFiles((prev) => [...prev, uploadedFileInfo]);\\n\\n//     return uploadedFileInfo;\\n//   } catch (err) {\\n//     console.error('Error upload file:', err);\\n//     dispatchNotification(\\n//       `Error uploading ${file.name}: ${err.message}`,\\n//       'danger',\\n//     );\\n//     return null;\\n//   }\\n// };\\nconst handleFileUpload = async (file) => {\\n    // Generate hashed filename untuk path\\n    const hashedPath = generateHashedPath(file.name);\\n    const fileHash = simpleHash32(file.name);\\n    const createdByValue = `agent_${fileHash.substring(0, 8)}`;\\n\\n    const queryParams = new URLSearchParams({\\n        folder: 'agent',\\n        workspaceId: user?.workspaceId || '',\\n        dashboardId: dashboard?.id || '',\\n        createdBy: createdByValue,\\n        extractFile: 'false',\\n        filename: hashedPath,\\n    }).toString();\\n\\n    const formData = new FormData();\\n    formData.append('file', file);\\n    formData.append('tags', 'assets');\\n\\n    try {\\n        const res = await fetch(\\n            `/api/v1/apps/upload/upload-file?${queryParams}`,\\n            {\\n                method: 'POST',\\n                body: formData,\\n            },\\n        );\\n        if (!res.ok) throw new Error('Upload gagal');\\n\\n        const result = await res.json();\\n        const uploadedFileInfo = {\\n            id: result?.data?.id || 'unknown_id',\\n            url: result?.data?.path || '',\\n            size: result?.data?.filesize\\n                ? `${(result.data.filesize / (1024 * 1024)).toFixed(1)}MB`\\n                : `${(file.size / (1024 * 1024)).toFixed(1)}MB`,\\n            detail: file.name.split('.').pop(),\\n            name: file.name,\\n        };\\n\\n        setUploadedFiles((prev) => [...prev, uploadedFileInfo]);\\n        return uploadedFileInfo;\\n    } catch (err) {\\n        console.error('Error upload file:', err);\\n        alert(`Error uploading ${file.name}: ${err.message}`);\\n        return null;\\n    }\\n};\\n\\nconst getFileIcon = (file) => {\\n    const name = file?.name?.toLowerCase() || '';\\n    const ext = name.split('.').pop();\\n\\n    switch (ext) {\\n        case 'jpg':\\n        case 'jpeg':\\n        case 'png':\\n        case 'gif':\\n            return <i className=\\\"ph-fill ph-image\\\"></i>;\\n\\n        case 'pdf':\\n            return <i className=\\\"ph-fill ph-file-pdf\\\"></i>;\\n\\n        case 'doc':\\n        case 'docx':\\n            return <i className=\\\"ph-fill ph-file-doc\\\"></i>;\\n\\n        case 'txt':\\n            return <i className=\\\"ph-fill ph-file-text\\\"></i>;\\n\\n        case 'xls':\\n        case 'xlsx':\\n            return <i className=\\\"ph-fill ph-file-xls\\\"></i>;\\n\\n        case 'mp4':\\n        case 'mov':\\n        case 'avi':\\n        case 'mkv':\\n            return <i className=\\\"ph ph-video\\\"></i>;\\n\\n        case 'mp3':\\n        case 'wav':\\n            return <i className=\\\"ph-fill ph-microphone\\\"></i>;\\n\\n        default:\\n            return <i className=\\\"ph-fill ph-file\\\"></i>;\\n    }\\n};\\n\\nconst getFileIconFromUrl = (url) => {\\n    const fileName = url.split('/').pop() || '';\\n    const ext = fileName.split('.').pop()?.toLowerCase();\\n\\n    switch (ext) {\\n        case 'jpg':\\n        case 'jpeg':\\n        case 'png':\\n        case 'gif':\\n            return <i className=\\\"ph-fill ph-image\\\"></i>;\\n\\n        case 'pdf':\\n            return <i className=\\\"ph-fill ph-file-pdf\\\"></i>;\\n\\n        case 'doc':\\n        case 'docx':\\n            return <i className=\\\"ph-fill ph-file-doc\\\"></i>;\\n\\n        case 'txt':\\n            return <i className=\\\"ph-fill ph-file-text\\\"></i>;\\n\\n        case 'xls':\\n        case 'xlsx':\\n            return <i className=\\\"ph-fill ph-file-xls\\\"></i>;\\n\\n        case 'mp4':\\n        case 'mov':\\n        case 'avi':\\n        case 'mkv':\\n            return <i className=\\\"ph ph-video\\\"></i>;\\n\\n        case 'mp3':\\n        case 'wav':\\n            return <i className=\\\"ph-fill ph-microphone\\\"></i>;\\n\\n        default:\\n            return <i className=\\\"ph-fill ph-file\\\"></i>;\\n    }\\n};\\nconst triggerFileInput = () => {\\n    const fileInput = document.getElementById('fileInput');\\n    if (fileInput) fileInput.click();\\n};\\n\\n// Format fungsi untuk mengkonversi URL S3 (sama seperti di LaporanCard)\\nconst convertS3Url = (url) => {\\n    if (!url) return '';\\n\\n    if (url.startsWith('s3://fusion/agent/')) {\\n        const path = url.replace('s3://fusion/agent/', '');\\n        const encodedPath = path\\n            .split('/')\\n            .map((part) => encodeURIComponent(part))\\n            .join('/');\\n        if (\\n            encodedPath.includes('/cdn/media') ||\\n            encodedPath.startsWith('cdn/media')\\n        ) {\\n            return `https://gajamada-propam.polri.go.id/fusion/agent/${encodedPath}`;\\n        } else {\\n            return `https://gajamada-propam.polri.go.id/cdn/media/fusion/agent/${encodedPath}`;\\n        }\\n    }\\n\\n    // Handle s3:// lainnya\\n    if (url.startsWith('s3://')) {\\n        return url.replace('s3://', 'https://asura-s3.stellardata.ai/');\\n    }\\n\\n    if (url.startsWith('http://192.168.180.99:8000')) {\\n        return url.replace(\\n            'http://192.168.180.99:8000',\\n            'https://asura-s3.ebdesk.com',\\n        );\\n    }\\n\\n    if (url.startsWith('https://yanduan-s3.polri.go.id:9000')) {\\n        const path = url.replace('https://yanduan-s3.polri.go.id:9000', '');\\n\\n        if (path.includes('/cdn/media')) {\\n            return `https://gajamada-propam.polri.go.id${path}`;\\n        } else {\\n            return `https://gajamada-propam.polri.go.id/cdn/media${path}`;\\n        }\\n    }\\n\\n    return url;\\n};\\n\\nconst handleDownloadFile = (item) => {\\n    try {\\n        const fileUrl = convertS3Url(item.url);\\n\\n        if (!fileUrl) {\\n            console.error('URL file tidak valid');\\n            return;\\n        }\\n\\n        // Ambil ekstensi\\n        let fileExtension = item.file_type || '';\\n        if (!fileExtension) {\\n            const ext = fileUrl.split('.').pop()?.toLowerCase() || 'pdf';\\n            fileExtension = ext.split('?')[0];\\n        }\\n\\n        // Bersihkan nama file\\n        let fileName = item.file_name || 'document';\\n        fileName = fileName.replace(/[<>:\\\"/\\\\\\\\|?*]/g, '');\\n        fileName = fileName.replace(/\\\\.[^/.]+$/, '');\\n\\n        console.log('Downloading:', `${fileName}.${fileExtension}`);\\n\\n        // Download dengan link biasa\\n        const link = document.createElement('a');\\n        link.href = fileUrl;\\n        link.download = `${fileName}.${fileExtension}`;\\n        link.target = '_blank';\\n        document.body.appendChild(link);\\n        link.click();\\n        document.body.removeChild(link);\\n    } catch (error) {\\n        console.error('Error:', error);\\n        alert(`Gagal mengunduh file: ${error.message}`);\\n    }\\n};\\n\\n// Tambahkan fungsi untuk handle next/previous\\n// const handleNext = async () => {\\n//   // Validasi berdasarkan step saat ini\\n\\n//   let isValid = true;\\n\\n//   if (step === 1) {\\n//     // Validasi Data Terlapor - hanya 5 field yang aktif\\n//     if (!selectedTipeTerlapor) {\\n//       alert('Tipe Terlapor wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('prepetrator_name')) {\\n//       alert('Nama wajib diisi');\\n//       isValid = false;\\n//     } else if (watchEdit('identity_number').replace(/\\\\D/g, '').length !== 8) {\\n//       alert('NRP harus terdiri dari 8 angka');\\n//       isValid = false;\\n//     } else if (!watchEdit('prepetrator_phone')) {\\n//       alert('Nomor Telepon wajib diisi');\\n//       isValid = false;\\n//     } else if (!selectedGender) {\\n//       alert('Jenis Kelamin wajib dipilih');\\n//       isValid = false;\\n//     }\\n\\n//     // Validasi lainnya dikomentari\\n//     if (!watchEdit('birth_place')) {\\n//       alert('Tempat Lahir wajib diisi');\\n//       isValid = false;\\n//     } else if (!watchEdit('birth_date')) {\\n//       alert('Tanggal Lahir wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('rank')) {\\n//       alert('Pangkat wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('position')) {\\n//       alert('Jabatan wajib diisi');\\n//       isValid = false;\\n//     } else if (!watchEdit('prepetrator_education')) {\\n//       alert('Pendidikan Kepolisian wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('graduation_year')) {\\n//       alert('Tahun Lulus wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('functional_assignment')) {\\n//       alert('Fungsi wajib diisi');\\n//       isValid = false;\\n//     } else if (!watchEdit('prepetrator_division')) {\\n//       alert('Kesatuan wajib diisi');\\n//       isValid = false;\\n//     }\\n//   } else if (step === 2) {\\n//     // Validasi Data Pelanggaran - SEMUA DIKOMENTARI\\n//     if (!watchEdit('description')) {\\n//       alert('Kronologi Singkat wajib diisi');\\n//       isValid = false;\\n//     } else if (!watchEdit('kategori')) {\\n//       alert('Kategori wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('sub_kategori')) {\\n//       alert('Sub Kategori wajib dipilih');\\n//       isValid = false;\\n//     } else if (!watchEdit('wujud_perbuatan')) {\\n//       alert('Wujud Perbuatan wajib dipilih');\\n//       isValid = false;\\n//     } else if (!selectedPenerapanPasal) {\\n//       alert('Penerapan Pasal wajib dipilih');\\n//       isValid = false;\\n//     } else {\\n//       // Validasi pasal dikomentari juga\\n//       if (\\n//         selectedTipeTerlapor === 'Anggota Polri' ||\\n//         selectedTipeTerlapor === 'Anonim'\\n//       ) {\\n//         if (selectedPenerapanPasal === 'kode-etik') {\\n//           const ppri = watchEdit('pasal_ppri') || [];\\n//           const perpol = watchEdit('pasal_perpol') || [];\\n\\n//           if (ppri.length === 0 && perpol.length === 0) {\\n//             alert(\\n//               'Pilih minimal 1 pasal dari PERPOL NOMOR 7 TH 2022 atau PPRI NOMOR 1 TAHUN 2003',\\n//             );\\n//             isValid = false;\\n//           }\\n//         } else if (selectedPenerapanPasal === 'disiplin') {\\n//         if (selectedPenerapanPasal === 'kode-etik') {\\n//           // Gunakan watchEdit, bukan formData\\n//           const ppri = watchEdit('pasal_ppri') || [];\\n//           const perpol = watchEdit('pasal_perpol') || [];\\n\\n//           if (ppri.length === 0 && perpol.length === 0) {\\n//             alert(\\n//               'Pilih minimal 1 pasal dari PERPOL NOMOR 7 TH 2022 atau PPRI NOMOR 1 TAHUN 2003',\\n//             );\\n//             isValid = false;\\n//           }\\n//         } else if (selectedTipeTerlapor === 'ASN Polri') {\\n//         if (\\n//           !watchEdit('pasal_disiplin_ppri') ||\\n//           watchEdit('pasal_disiplin_ppri').length === 0\\n//         ) {\\n//           alert('PPRI NOMOR 94 TAHUN 2021 wajib dipilih minimal 1');\\n//           isValid = false;\\n//         }\\n//       }\\n//     }\\n//   } else if (step === 3) {\\n//     // Validasi Data Pendumas - SEMUA DIKOMENTARI\\n//     if (!watchEdit('sender_name')) {\\n//       alert('Nama Pendumas wajib diisi');\\n//       isValid = false;\\n//     } else if (!watchEdit('sender_phone')) {\\n//       alert('Nomor Telepon wajib diisi');\\n//       isValid = false;\\n//     } else if (!watchEdit('sender_address')) {\\n//       alert('Alamat wajib diisi');\\n//       isValid = false;\\n//     }\\n//   }\\n//   // Step 4 (Dokumen) opsional, tidak wajib\\n\\n//   if (isValid && step < 4) {\\n//     setStep(step + 1);\\n//   }\\n// };\\n\\nconst handleNext = async () => {\\n    let isValid = true;\\n\\n    if (step === 1) {\\n        if (!selectedTipeTerlapor) { alert('Tipe Terlapor wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('prepetrator_name')) { alert('Nama wajib diisi'); isValid = false; }\\n        else if (watchEdit('identity_number').replace(/\\\\D/g, '').length !== 8) { alert('NRP harus terdiri dari 8 angka'); isValid = false; }\\n        else if (!watchEdit('prepetrator_phone')) { alert('Nomor Telepon wajib diisi'); isValid = false; }\\n        else if (!selectedGender) { alert('Jenis Kelamin wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('birth_place')) { alert('Tempat Lahir wajib diisi'); isValid = false; }\\n        else if (!watchEdit('birth_date')) { alert('Tanggal Lahir wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('rank')) { alert('Pangkat wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('position')) { alert('Jabatan wajib diisi'); isValid = false; }\\n        else if (!watchEdit('prepetrator_education')) { alert('Pendidikan Kepolisian wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('graduation_year')) { alert('Tahun Lulus wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('functional_assignment')) { alert('Fungsi wajib diisi'); isValid = false; }\\n        else if (!watchEdit('prepetrator_division')) { alert('Kesatuan wajib diisi'); isValid = false; }\\n\\n    } else if (step === 2) {\\n        if (!watchEdit('description')) { alert('Kronologi Singkat wajib diisi'); isValid = false; }\\n        else if (!watchEdit('kategori')) { alert('Kategori wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('sub_kategori')) { alert('Sub Kategori wajib dipilih'); isValid = false; }\\n        else if (!watchEdit('wujud_perbuatan')) { alert('Wujud Perbuatan wajib dipilih'); isValid = false; }\\n        else if (!selectedPenerapanPasal) { alert('Penerapan Pasal wajib dipilih'); isValid = false; }\\n        else {\\n            if (selectedTipeTerlapor === 'Anggota Polri' || selectedTipeTerlapor === 'Anonim') {\\n                if (selectedPenerapanPasal === 'kode-etik') {\\n                    const ppri = watchEdit('pasal_ppri') || [];\\n                    const perpol = watchEdit('pasal_perpol') || [];\\n                    if (ppri.length === 0 && perpol.length === 0) {\\n                        alert('Pilih minimal 1 pasal dari PERPOL NOMOR 7 TH 2022 atau PPRI NOMOR 1 TAHUN 2003');\\n                        isValid = false;\\n                    }\\n                } else if (selectedPenerapanPasal === 'disiplin') {\\n                    const disiplinPpri = watchEdit('pasal_disiplin_ppri') || [];\\n                    if (disiplinPpri.length === 0) {\\n                        alert('PPRI NOMOR 2 TAHUN 2003 wajib dipilih minimal 1');\\n                        isValid = false;\\n                    }\\n                }\\n            } else if (selectedTipeTerlapor === 'ASN Polri') {\\n                const asnDisiplin = watchEdit('pasal_disiplin_ppri') || [];\\n                if (asnDisiplin.length === 0) {\\n                    alert('PPRI NOMOR 94 TAHUN 2021 wajib dipilih minimal 1');\\n                    isValid = false;\\n                }\\n            }\\n        }\\n    } else if (step === 3) {\\n        if (!watchEdit('sender_name')) { alert('Nama Pendumas wajib diisi'); isValid = false; }\\n        else if (!watchEdit('sender_phone')) { alert('Nomor Telepon wajib diisi'); isValid = false; }\\n        else if (!watchEdit('sender_address')) { alert('Alamat wajib diisi'); isValid = false; }\\n    }\\n\\n    if (isValid && step < 4) {\\n        setStep(step + 1);\\n    }\\n};\\n\\nconst handlePrevious = () => {\\n    if (step > 1) {\\n        setStep(step - 1);\\n    }\\n};\\nreturn (\\n    <>\\n        <div\\n            className=\\\"h-100\\\"\\n            style={{\\n                border: '1px solid var(--black-100)',\\n                borderRadius: '0.8rem',\\n                backgroundColor: 'var(--white)',\\n            }}\\n        >\\n            <div\\n                className=\\\"flex justify-between items-center\\\"\\n                style={{\\n                    borderBottom: '1px solid var(--black-100)',\\n                    padding: '12px 16px',\\n                }}\\n            >\\n                <div className=\\\"widget-title\\\">{widget?.name || 'Detail Laporan'}</div>\\n                <div className=\\\"card-ubahdata\\\" onClick={handleOpenEdit}>\\n                    <i class=\\\"ph ph-pencil-simple-line\\\"></i>\\n                    <div> Ubah Data</div>\\n                </div>\\n            </div>\\n\\n            {/* Body */}\\n\\n            <BodyContainer>\\n                {/* Data Terlapor - flat structure dari API */}\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Tipe Terlapor</div>\\n                    <div className=\\\"value\\\">\\n                        {report?.type || report?.report_type || '-'}\\n                    </div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Nama</div>\\n                    <div className=\\\"value\\\">{report?.name || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Tempat Lahir</div>\\n                    <div className=\\\"value\\\">{report?.birth_place || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Tanggal Lahir</div>\\n                    <div className=\\\"value\\\">\\n                        {report?.birth_date ? formatBorn(report?.birth_date) : '-'}\\n                    </div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Pangkat</div>\\n                    <div className=\\\"value\\\">{report?.rank || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">NRP</div>\\n                    <div className=\\\"value\\\">{report?.identity_number || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Jabatan</div>\\n                    <div className=\\\"value\\\">{report?.position || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Nomor Telepon</div>\\n                    <div className=\\\"value\\\">\\n                        {report?.phone_number || report?.phone_no || '-'}\\n                    </div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Pendidikan Kepolisian</div>\\n                    <div className=\\\"value\\\">{report?.professional_education || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Tahun Lulus</div>\\n                    <div className=\\\"value\\\">{report?.graduation_year || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Jenis Kelamin</div>\\n                    <div className=\\\"value\\\">{report?.gender || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Fungsi</div>\\n                    <div className=\\\"value\\\">{report?.functional_assignment || '-'}</div>\\n                </div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Kesatuan</div>\\n                    <div className=\\\"value\\\">{report?.division || '-'}</div>\\n                </div>\\n\\n                <hr style={{ border: '1px solid var(--black-100)' }} />\\n\\n                <div className=\\\"subtitle\\\">Data Pelanggaran</div>\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Kronologi Singkat</div>\\n                    {/* <div className=\\\"fs-12 fw-400\\\">\\n              {Array.isArray(report?.chronology)\\n                ? report.chronology.map((text, i) => (\\n                    <p key={i} style={{ margin: '0 0 0.5rem 0' }}>\\n                      {text}\\n                    </p>\\n                  ))\\n                : report?.chronology || report?.description || '-'}\\n            </div> */}\\n                    <div className=\\\"fs-12 fw-400\\\">{report?.description || '-'}</div>\\n                </div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Kategori</div>\\n                    <div className=\\\"fs-12 fw-400\\\">\\n                        {report?.category || report?.kategori || '-'}\\n                    </div>\\n                </div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Sub Kategori</div>\\n                    <div className=\\\"fs-12 fw-400\\\">\\n                        {report?.sub_category || report?.sub_kategori || '-'}\\n                    </div>\\n                </div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Wujud Perbuatan</div>\\n                    <div className=\\\"fs-12 fw-400\\\">{report?.form_of_action || '-'}</div>\\n                </div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Penerapan Pasal</div>\\n                    <div className=\\\"fs-12 fw-400\\\">\\n                        {report?.application_of_article || '-'}\\n                    </div>\\n                </div>\\n\\n                {/* <WrapperPasal>\\n            <div className=\\\"information\\\"> PPRI No. 1 Tahun 2003</div>\\n\\n            {pasalPPRI.length > 0 ? (\\n              <SelectedItemsList>\\n                {pasalPPRI.map((item, index) => (\\n                  <SelectedItemCard key={index}>\\n                    <SelectedItemContent>\\n                      <SelectedItemHeader>\\n                        <SelectedItemCode>\\n                          {item.kode_pasal || item.pasal || '-'}\\n                        </SelectedItemCode>\\n                        <DetailLink\\n                          onClick={(e) => {\\n                            e.stopPropagation();\\n                            setSelectedDetail(item);\\n                            setShowDetailModal(true);\\n                          }}\\n                        >\\n                          Lihat detail\\n                        </DetailLink>\\n                        {item.uraian && (\\n                          <Small style={{ color: 'var(--black-600)' }}>\\n                            {item.uraian}\\n                          </Small>\\n                        )}\\n                      </SelectedItemHeader>\\n                    </SelectedItemContent>\\n                  </SelectedItemCard>\\n                ))}\\n              </SelectedItemsList>\\n            ) : (\\n              <div\\n                style={{\\n                  padding: '1rem',\\n                  textAlign: 'center',\\n                  color: 'var(--black-400)',\\n                  backgroundColor: 'var(--black-25)',\\n                  borderRadius: '0.5rem',\\n                  border: '1px dashed var(--black-100)',\\n                }}\\n              >\\n                <i\\n                  className=\\\"ph ph-file-text\\\"\\n                  style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n                ></i>\\n                <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                  Tidak ada pasal yang dikenakan\\n                </p>\\n              </div>\\n            )}\\n          </WrapperPasal>\\n\\n          <WrapperPasal>\\n            <div className=\\\"information\\\">Pasal Perpol 7 Tahun 2022</div>\\n\\n            {pasalPerpol.length > 0 ? (\\n              <SelectedItemsList>\\n                {pasalPerpol.map((item, index) => (\\n                  <SelectedItemCard key={index}>\\n                    <SelectedItemContent>\\n                      <SelectedItemHeader>\\n                        <SelectedItemCode>\\n                          {item.kode_pasal || item.pasal || '-'}\\n                        </SelectedItemCode>\\n                        <DetailLink\\n                          onClick={(e) => {\\n                            e.stopPropagation();\\n                            setSelectedDetail(item);\\n                            setShowDetailModal(true);\\n                          }}\\n                        >\\n                          Lihat detail\\n                        </DetailLink>\\n                        {item.uraian && (\\n                          <Small style={{ color: 'var(--black-600)' }}>\\n                            {item.uraian}\\n                          </Small>\\n                        )}\\n                      </SelectedItemHeader>\\n                    </SelectedItemContent>\\n                  </SelectedItemCard>\\n                ))}\\n              </SelectedItemsList>\\n            ) : (\\n              <div\\n                style={{\\n                  padding: '1rem',\\n                  textAlign: 'center',\\n                  color: 'var(--black-400)',\\n                  backgroundColor: 'var(--black-25)',\\n                  borderRadius: '0.5rem',\\n                  border: '1px dashed var(--black-100)',\\n                }}\\n              >\\n                <i\\n                  className=\\\"ph ph-file-text\\\"\\n                  style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n                ></i>\\n                <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                  Tidak ada pasal yang dikenakan\\n                </p>\\n              </div>\\n            )}\\n          </WrapperPasal> */}\\n\\n                {/* Looping object groupedArticles */}\\n                {Object.keys(groupedArticles).length > 0 ? (\\n                    Object.entries(groupedArticles).map(\\n                        ([type, articles], groupIndex) => (\\n                            <WrapperPasal key={groupIndex}>\\n                                {/* Tampilkan Nama Tipe secara Dinamis (misal: \\\"PP Nomor 2 TH 2003\\\") */}\\n                                <div className=\\\"information\\\">{type}</div>\\n\\n                                {articles.length > 0 ? (\\n                                    <SelectedItemsList>\\n                                        {articles.map((item, index) => (\\n                                            <SelectedItemCard key={item.article_id || index}>\\n                                                <SelectedItemContent>\\n                                                    <SelectedItemHeader>\\n                                                        <SelectedItemCode>\\n                                                            {item.kode_pasal || item.pasal || '-'}\\n                                                        </SelectedItemCode>\\n\\n                                                        <DetailLink\\n                                                            onClick={(e) => {\\n                                                                e.stopPropagation();\\n                                                                setSelectedDetail(item);\\n                                                                setShowDetailModal(true);\\n                                                            }}\\n                                                        >\\n                                                            Lihat detail\\n                                                        </DetailLink>\\n\\n                                                        {/* Antisipasi jika datanya bernama description (dari JSON) atau uraian */}\\n                                                    </SelectedItemHeader>\\n                                                </SelectedItemContent>\\n                                            </SelectedItemCard>\\n                                        ))}\\n                                    </SelectedItemsList>\\n                                ) : (\\n                                    <div\\n                                        style={{\\n                                            padding: '1rem',\\n                                            textAlign: 'center',\\n                                            color: 'var(--black-400)',\\n                                            backgroundColor: 'var(--black-25)',\\n                                            borderRadius: '0.5rem',\\n                                            border: '1px dashed var(--black-100)',\\n                                        }}\\n                                    >\\n                                        <i\\n                                            className=\\\"ph ph-file-text\\\"\\n                                            style={{ fontSize: '1.25rem', marginBottom: '0.25rem' }}\\n                                        ></i>\\n                                        <p style={{ margin: 0, fontSize: '0.875rem' }}>\\n                                            Tidak ada pasal yang dikenakan\\n                                        </p>\\n                                    </div>\\n                                )}\\n                            </WrapperPasal>\\n                        ),\\n                    )\\n                ) : (\\n                    // Tampilan Global jika seluruh 'report.articles' kosong / tidak ada data sama sekali\\n                    <div\\n                        style={{\\n                            padding: '2rem',\\n                            textAlign: 'center',\\n                            color: 'var(--black-500)',\\n                        }}\\n                    >\\n                        Belum ada data pasal yang ditemukan.\\n                    </div>\\n                )}\\n\\n                <hr style={{ border: '1px solid var(--black-100)' }} />\\n\\n                <div className=\\\"subtitle\\\">Data Pendumas</div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Nama</div>\\n                    <div className=\\\"fs-12 fw-400\\\">{report?.sender_name || '-'}</div>\\n                </div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Nomor Telepon</div>\\n                    <div className=\\\"fs-12 fw-400\\\">\\n                        {report?.phone_no || report?.sender_phone || '-'}\\n                    </div>\\n                </div>\\n\\n                <div className=\\\"flex items-center\\\">\\n                    <div className=\\\"information\\\">Alamat</div>\\n                    <div className=\\\"fs-12 fw-400\\\">{report?.sender_address || '-'}</div>\\n                </div>\\n\\n                <hr style={{ border: '1px solid var(--black-100)' }} />\\n\\n                <div className=\\\"subtitle\\\">Dokumen Upload</div>\\n                <ContentGrid>\\n                    {(() => {\\n                        // API baru menggunakan `documents`, fallback ke `attachments`\\n                        const attachments =\\n                            report?.documents || report?.attachments || [];\\n\\n                        if (attachments.length === 0) {\\n                            return (\\n                                <div className=\\\"flex flex-col items-center justify-center py-10 text-muted col-span-full\\\">\\n                                    <img\\n                                        src=\\\"/cdn/media/fusion/assets/1731748832639/Group 1 (4).svg\\\"\\n                                        alt=\\\"no-data\\\"\\n                                        style={{ width: '150px', marginBottom: '1rem' }}\\n                                    />\\n                                    <p className=\\\"m-0\\\">Belum ada dokumen yang diupload</p>\\n                                </div>\\n                            );\\n                        }\\n\\n                        return attachments.map((item, index) => (\\n                            <AttachmentCard\\n                                key={index}\\n                                item={item}\\n                                index={index}\\n                                convertS3Url={convertS3Url}\\n                                handleDownloadFile={handleDownloadFile}\\n                            />\\n                        ));\\n                    })()}\\n                </ContentGrid>\\n            </BodyContainer>\\n        </div>\\n\\n        <StyledModal centered size=\\\"lg\\\" show={showModal} onHide={handleCloseEdit}>\\n            <Form onSubmit={handleSubmitEdit(onSubmitEdit)}>\\n                <ModalHeader closeButton>\\n                    <WrappIcon>\\n                        <i\\n                            className=\\\"ph-duotone ph-user\\\"\\n                            style={{ fontSize: '1.6rem', color: 'var(--primary)' }}\\n                        ></i>\\n                    </WrappIcon>\\n                    <div className=\\\"d-flex flex-column gap-1\\\">\\n                        <TitleHeader>Input Data Terlapor</TitleHeader>\\n                        <DescHeader>Sesuaikan isi laporan</DescHeader>\\n                    </div>\\n                </ModalHeader>\\n                <ModalBody>\\n                    <TitleInput\\n                        className=\\\"pb-2\\\"\\n                        style={{ color: 'var(--black-600)', fontSize: '1.14286rem' }}\\n                    >\\n                        {step === 1 && 'Data Terlapor'}\\n                        {step === 2 && 'Data Pelanggaran'}\\n                        {step === 3 && 'Data Pendumas'}\\n                        {step === 4 && 'Dokumen Upload'}\\n                    </TitleInput>\\n\\n                    {/* STEP 1 - Data Terlapor */}\\n                    {step === 1 && (\\n                        <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n                            {/* Tipe Terlapor */}\\n                            <Form.Group className=\\\"d-flex flex-column gap-2 w-100\\\">\\n                                <TitleInput className=\\\"mb-3\\\">\\n                                    Tipe Terlapor <span className=\\\"text-danger\\\">*</span>\\n                                </TitleInput>\\n                                <Controller\\n                                    name=\\\"prepetrator_type\\\"\\n                                    control={controlEdit}\\n                                    rules={{ required: 'Tipe Terlapor wajib dipilih' }}\\n                                    render={({ field }) => (\\n                                        <>\\n                                            <div className=\\\"d-flex gap-2 w-100\\\">\\n                                                <RadioButtonContainer\\n                                                    isSelected={field.value === 'Anggota Polri'}\\n                                                    onClick={() => {\\n                                                        field.onChange('Anggota Polri');\\n                                                        setSelectedTipeTerlapor('Anggota Polri');\\n                                                        triggerEdit('prepetrator_type'); // Trigger validasi\\n                                                    }}\\n                                                    type=\\\"button\\\"\\n                                                >\\n                                                    <FormCheckStyled\\n                                                        type=\\\"radio\\\"\\n                                                        checked={field.value === 'Anggota Polri'}\\n                                                        onChange={() => {\\n                                                            field.onChange('Anggota Polri');\\n                                                            setSelectedTipeTerlapor('Anggota Polri');\\n                                                            triggerEdit('prepetrator_type'); // Trigger validasi\\n                                                        }}\\n                                                        name=\\\"tipe-terlapor\\\"\\n                                                    />\\n                                                    <p>Anggota Polri</p>\\n                                                </RadioButtonContainer>\\n\\n                                                <RadioButtonContainer\\n                                                    isSelected={field.value === 'ASN Polri'}\\n                                                    onClick={() => {\\n                                                        field.onChange('ASN Polri');\\n                                                        setSelectedTipeTerlapor('ASN Polri');\\n                                                        triggerEdit('prepetrator_type'); // Trigger validasi\\n                                                    }}\\n                                                    type=\\\"button\\\"\\n                                                >\\n                                                    <FormCheckStyled\\n                                                        type=\\\"radio\\\"\\n                                                        checked={field.value === 'ASN Polri'}\\n                                                        onChange={() => {\\n                                                            field.onChange('ASN Polri');\\n                                                            setSelectedTipeTerlapor('ASN Polri');\\n                                                            triggerEdit('prepetrator_type'); // Trigger validasi\\n                                                        }}\\n                                                        name=\\\"tipe-terlapor\\\"\\n                                                    />\\n                                                    <p>ASN Polri</p>\\n                                                </RadioButtonContainer>\\n\\n                                                <RadioButtonContainer\\n                                                    isSelected={field.value === 'Anonim'}\\n                                                    onClick={() => {\\n                                                        field.onChange('Anonim');\\n                                                        setSelectedTipeTerlapor('Anonim');\\n                                                        triggerEdit('prepetrator_type'); // Trigger validasi\\n                                                    }}\\n                                                    type=\\\"button\\\"\\n                                                >\\n                                                    <FormCheckStyled\\n                                                        type=\\\"radio\\\"\\n                                                        checked={field.value === 'Anonim'}\\n                                                        onChange={() => {\\n                                                            field.onChange('Anonim');\\n                                                            setSelectedTipeTerlapor('Anonim');\\n                                                            triggerEdit('prepetrator_type'); // Trigger validasi\\n                                                        }}\\n                                                        name=\\\"tipe-terlapor\\\"\\n                                                    />\\n                                                    <p>Anonim</p>\\n                                                </RadioButtonContainer>\\n                                            </div>\\n                                            {errorsEdit.prepetrator_type && (\\n                                                <ErrorText>\\n                                                    {errorsEdit.prepetrator_type.message}\\n                                                </ErrorText>\\n                                            )}\\n                                        </>\\n                                    )}\\n                                />\\n                            </Form.Group>\\n\\n                            {/* Nama */}\\n                            <Form.Group className=\\\"w-100\\\">\\n                                <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                                <StyledInput\\n                                    type=\\\"text\\\"\\n                                    placeholder=\\\"Nama\\\"\\n                                    {...registerEdit('prepetrator_name', {\\n                                        required: 'Nama wajib diisi',\\n                                    })}\\n                                />\\n                                {errorsEdit.prepetrator_name && (\\n                                    <ErrorText>{errorsEdit.prepetrator_name.message}</ErrorText>\\n                                )}\\n                            </Form.Group>\\n\\n                            {/* Tempat & Tanggal Lahir */}\\n                            <Row className=\\\"g-3\\\">\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Tempat Lahir</TitleInput>\\n                                        <StyledInput\\n                                            type=\\\"text\\\"\\n                                            placeholder=\\\"Tempat Lahir\\\"\\n                                            {...registerEdit('birth_place', {\\n                                                required: 'tempat lahir wajib diisi',\\n                                            })}\\n                                        />\\n\\n                                        {errorsEdit.birth_place && (\\n                                            <ErrorText>{errorsEdit.birth_place.message}</ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Tanggal Lahir</TitleInput>\\n                                        <NativeDateWrapper>\\n                                            <DateIconAddon>\\n                                                <i className=\\\"ph ph-calendar-blank\\\"></i>\\n                                            </DateIconAddon>\\n                                            <StyledDatePicker\\n                                                {...registerEdit('birth_date', {\\n                                                    required: 'Tanggal Lahir wajib dipilih',\\n                                                })}\\n                                                value={\\n                                                    watchEdit('birth_date')\\n                                                        ? dayjs(watchEdit('birth_date'))\\n                                                        : null\\n                                                }\\n                                                onChange={(date) => {\\n                                                    setValueEdit(\\n                                                        'birth_date',\\n                                                        date ? date.format('YYYY-MM-DD') : null,\\n                                                    );\\n                                                    triggerEdit('birth_date');\\n                                                }}\\n                                            />\\n                                        </NativeDateWrapper>\\n                                        {errorsEdit.birth_date && (\\n                                            <ErrorText>{errorsEdit.birth_date.message}</ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n\\n                            {/* Pangkat & NRP */}\\n                            <Row className=\\\"g-3\\\">\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <LabelInput className=\\\"mb-3\\\">Pangkat</LabelInput>\\n                                        <Controller\\n                                            name=\\\"rank\\\"\\n                                            control={controlEdit}\\n                                            rules={{ required: 'Pangkat wajib dipilih' }}\\n                                            render={({ field }) => (\\n                                                <Select\\n                                                    {...field}\\n                                                    options={pangkatOptions}\\n                                                    styles={ReactSelectStyle}\\n                                                    placeholder={\\n                                                        loadingPangkat\\n                                                            ? 'Memuat data...'\\n                                                            : 'Cari atau pilih Pangkat'\\n                                                    }\\n                                                    isLoading={loadingPangkat}\\n                                                    isDisabled={!selectedTipeTerlapor} // HAPUS loadingPangkat dari sini\\n                                                    value={pangkatOptions.find(\\n                                                        (o) => o.value === field.value,\\n                                                    )}\\n                                                    onChange={(val) => {\\n                                                        field.onChange(val?.value);\\n                                                    }}\\n                                                    onInputChange={(inputValue) => {\\n                                                        // Jangan panggil search kalau masih loading atau input kosong\\n                                                        if (\\n                                                            !loadingPangkat &&\\n                                                            inputValue &&\\n                                                            inputValue.length > 0\\n                                                        ) {\\n                                                            handlePangkatSearch(inputValue);\\n                                                        } else if (inputValue === '') {\\n                                                            // Reset ke data awal\\n                                                            fetchPangkat(selectedTipeTerlapor, '');\\n                                                        }\\n                                                        return inputValue;\\n                                                    }}\\n                                                    filterOption={() => true} // Matikan filter default react-select\\n                                                    noOptionsMessage={() =>\\n                                                        loadingPangkat\\n                                                            ? 'Memuat data...'\\n                                                            : 'Tidak ada data pangkat'\\n                                                    }\\n                                                />\\n                                            )}\\n                                        />\\n                                        {errorsEdit.rank && (\\n                                            <ErrorText>{errorsEdit.rank.message}</ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">NRP</TitleInput>\\n                                        {/* <StyledInput\\n                        type=\\\"text\\\"\\n                        placeholder=\\\"NRP\\\"\\n                        {...registerEdit('identity_number')}\\n                      /> */}\\n                                        <Controller\\n                                            name=\\\"identity_number\\\"\\n                                            control={controlEdit}\\n                                            rules={{\\n                                                required: 'NRP wajib diisi',\\n                                                validate: (value) => {\\n                                                    const cleaned = value?.replace(/\\\\D/g, '') || '';\\n                                                    if (cleaned.length !== 8) {\\n                                                        return 'NRP harus terdiri dari 8 angka';\\n                                                    }\\n                                                    return true;\\n                                                },\\n                                            }}\\n                                            render={({ field }) => (\\n                                                <StyledInput\\n                                                    {...field}\\n                                                    placeholder=\\\"NRP (8 digit angka)\\\"\\n                                                    onChange={(e) => {\\n                                                        const numericOnly = e.target.value.replace(\\n                                                            /\\\\D/g,\\n                                                            '',\\n                                                        );\\n                                                        field.onChange(numericOnly.slice(0, 8));\\n                                                    }}\\n                                                />\\n                                            )}\\n                                        />\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n\\n                            {/* Jabatan & No Telp */}\\n                            <Row className=\\\"g-3\\\">\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Jabatan</TitleInput>\\n                                        <StyledInput\\n                                            type=\\\"text\\\"\\n                                            placeholder=\\\"Jabatan\\\"\\n                                            {...registerEdit('position')}\\n                                        />\\n                                    </Form.Group>\\n                                </Col>\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Nomor Telepon</TitleInput>\\n                                        <StyledInputGroup>\\n                                            <InputGroupTextCustom>+62</InputGroupTextCustom>\\n                                            <FormControlCustom\\n                                                type=\\\"number\\\"\\n                                                placeholder=\\\"81234567890\\\"\\n                                                {...registerEdit('prepetrator_phone')}\\n                                            />\\n                                        </StyledInputGroup>\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n\\n                            {/* Pendidikan Kepolisian & Tahun Lulus */}\\n                            <Row className=\\\"g-3\\\">\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <LabelInput className=\\\"mb-3\\\">\\n                                            Pendidikan Kepolisian\\n                                        </LabelInput>\\n                                        <Controller\\n                                            name=\\\"prepetrator_education\\\"\\n                                            control={controlEdit}\\n                                            rules={{ required: 'Pendidikan Wajib dipilih' }}\\n                                            render={({ field }) => (\\n                                                <Select\\n                                                    {...field}\\n                                                    options={PendidikanOptions}\\n                                                    styles={ReactSelectStyle}\\n                                                    placeholder=\\\"Pilih\\\"\\n                                                    value={PendidikanOptions.find(\\n                                                        (o) => o.value === field.value,\\n                                                    )}\\n                                                    onChange={(val) => {\\n                                                        field.onChange(val?.value);\\n                                                    }}\\n                                                />\\n                                            )}\\n                                        />\\n                                        {errorsEdit.prepetrator_education && (\\n                                            <ErrorText>\\n                                                {errorsEdit.prepetrator_education.message}\\n                                            </ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Tahun Lulus</TitleInput>\\n                                        <NativeDateWrapper>\\n                                            <DateIconAddon>\\n                                                <i className=\\\"ph ph-calendar-blank\\\"></i>\\n                                            </DateIconAddon>\\n                                            <StyledYearPicker\\n                                                {...registerEdit('graduation_year')}\\n                                                value={\\n                                                    watchEdit('graduation_year')\\n                                                        ? dayjs(watchEdit('graduation_year'))\\n                                                        : null\\n                                                }\\n                                                onChange={(date) => {\\n                                                    setValueEdit(\\n                                                        'graduation_year',\\n                                                        date ? date.format('YYYY') : null,\\n                                                    );\\n                                                }}\\n                                                picker=\\\"year\\\"\\n                                                placeholder=\\\"Pilih tahun\\\"\\n                                                suffixIcon={null}\\n                                                allowClear={false}\\n                                            />\\n                                        </NativeDateWrapper>\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n\\n                            <Row className=\\\"g-3\\\">\\n                                <Col md={6}>\\n                                    <Form.Group className=\\\"w-100\\\">\\n                                        <TitleInput className=\\\"mb-3\\\">Fungsi</TitleInput>\\n                                        <Controller\\n                                            name=\\\"functional_assignment\\\"\\n                                            control={controlEdit}\\n                                            rules={{ required: 'Fungsi wajib dipilih' }}\\n                                            render={({ field }) => (\\n                                                <Select\\n                                                    {...field}\\n                                                    options={functionalOptions}\\n                                                    styles={ReactSelectStyle}\\n                                                    placeholder={\\n                                                        loadingFunctional\\n                                                            ? 'Memuat data...'\\n                                                            : 'Cari atau pilih Fungsi'\\n                                                    }\\n                                                    isLoading={loadingFunctional}\\n                                                    value={functionalOptions.find(\\n                                                        (o) => o.value === field.value,\\n                                                    )}\\n                                                    onChange={(val) => {\\n                                                        field.onChange(val?.value);\\n                                                    }}\\n                                                    onInputChange={(inputValue) => {\\n                                                        if (\\n                                                            !loadingFunctional &&\\n                                                            inputValue &&\\n                                                            inputValue.length > 0\\n                                                        ) {\\n                                                            handleFunctionalSearch(inputValue);\\n                                                        } else if (inputValue === '') {\\n                                                            fetchFunctional('');\\n                                                        }\\n                                                        return inputValue;\\n                                                    }}\\n                                                    filterOption={() => true}\\n                                                    noOptionsMessage={() =>\\n                                                        loadingFunctional\\n                                                            ? 'Memuat data...'\\n                                                            : 'Tidak ada data fungsi'\\n                                                    }\\n                                                />\\n                                            )}\\n                                        />\\n                                        {errorsEdit.functional_assignment && (\\n                                            <ErrorText>\\n                                                {errorsEdit.functional_assignment.message}\\n                                            </ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                                <Col md={6}>\\n                                    <Form.Group className=\\\"w-100\\\">\\n                                        <TitleInput className=\\\"mb-3\\\">Kesatuan</TitleInput>\\n                                        <Controller\\n                                            name=\\\"prepetrator_division\\\"\\n                                            control={controlEdit}\\n                                            rules={{ required: 'Kesatuan Wajib dipilih' }}\\n                                            render={({ field }) => (\\n                                                <Select\\n                                                    {...field}\\n                                                    options={kesatuanOptions}\\n                                                    styles={ReactSelectStyle}\\n                                                    placeholder=\\\"Pilih\\\"\\n                                                    value={kesatuanOptions.find(\\n                                                        (o) => o.value === field.value,\\n                                                    )}\\n                                                    onChange={(val) => {\\n                                                        field.onChange(val?.value);\\n                                                    }}\\n                                                />\\n                                            )}\\n                                        />\\n                                        {errorsEdit.prepetrator_division && (\\n                                            <ErrorText>\\n                                                {errorsEdit.prepetrator_division.message}\\n                                            </ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n                            {/* Jenis Kelamin */}\\n                            <Form.Group className=\\\"d-flex flex-column gap-2 w-100\\\">\\n                                <TitleInput className=\\\"mb-3\\\">Jenis Kelamin</TitleInput>\\n                                <div className=\\\"d-flex gap-2 w-100\\\">\\n                                    <RadioButtonContainer\\n                                        isSelected={selectedGender === 'laki-laki'}\\n                                        onClick={() => {\\n                                            setSelectedGender('laki-laki');\\n                                            setValueEdit('gender', 'laki-laki');\\n                                        }}\\n                                        type=\\\"button\\\"\\n                                    >\\n                                        <FormCheckStyled\\n                                            type=\\\"radio\\\"\\n                                            checked={selectedGender === 'laki-laki'}\\n                                            onChange={() => {\\n                                                setSelectedGender('laki-laki');\\n                                                setValueEdit('gender', 'laki-laki');\\n                                            }}\\n                                            name=\\\"gender\\\"\\n                                        />\\n                                        <p>Laki-Laki</p>\\n                                    </RadioButtonContainer>\\n\\n                                    <RadioButtonContainer\\n                                        isSelected={selectedGender === 'perempuan'}\\n                                        onClick={() => {\\n                                            setSelectedGender('perempuan');\\n                                            setValueEdit('gender', 'perempuan');\\n                                        }}\\n                                        type=\\\"button\\\"\\n                                    >\\n                                        <FormCheckStyled\\n                                            type=\\\"radio\\\"\\n                                            checked={selectedGender === 'perempuan'}\\n                                            onChange={() => {\\n                                                setSelectedGender('perempuan');\\n                                                setValueEdit('gender', 'perempuan');\\n                                            }}\\n                                            name=\\\"gender\\\"\\n                                        />\\n                                        <p>Perempuan</p>\\n                                    </RadioButtonContainer>\\n                                </div>\\n                            </Form.Group>\\n                        </div>\\n                    )}\\n\\n                    {/* STEP 2 - Data Pelanggaran */}\\n                    {/* STEP 2 - Data Pelanggaran */}\\n                    {step === 2 && (\\n                        <>\\n                            <Form.Group className=\\\"w-100\\\">\\n                                <TitleInput className=\\\"mb-3\\\">Kronologi Singkat</TitleInput>\\n                                <StyledTextarea\\n                                    type=\\\"text\\\"\\n                                    as={'textarea'}\\n                                    rows={3}\\n                                    placeholder=\\\"kronologi singkat\\\"\\n                                    {...registerEdit('description')}\\n                                />\\n                            </Form.Group>\\n\\n                            <Row className=\\\"g-3 w-100\\\">\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <LabelInput>\\n                                            Kategori <span className=\\\"text-danger\\\">*</span>\\n                                        </LabelInput>\\n                                        <Controller\\n                                            name=\\\"kategori\\\"\\n                                            control={controlEdit}\\n                                            rules={{ required: 'Kategori wajib dipilih' }}\\n                                            render={({ field }) => (\\n                                                <Select\\n                                                    {...field}\\n                                                    options={kategoriOptions}\\n                                                    styles={ReactSelectStyle}\\n                                                    placeholder=\\\"Pilih Kategori\\\"\\n                                                    isLoading={loadingKategori}\\n                                                    value={findMatchingOption(\\n                                                        kategoriOptions,\\n                                                        field.value,\\n                                                    )}\\n                                                    onChange={(val) => {\\n                                                        field.onChange(val?.value);\\n                                                        setValueEdit('sub_kategori', null); // reset sub kategori\\n                                                    }}\\n                                                />\\n                                            )}\\n                                        />\\n                                        {errors.kategori && (\\n                                            <ErrorText>{errors.kategori.message}</ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <LabelInput>\\n                                            Sub Kategori <span className=\\\"text-danger\\\">*</span>\\n                                        </LabelInput>\\n                                        <Controller\\n                                            name=\\\"sub_kategori\\\"\\n                                            control={controlEdit}\\n                                            rules={{ required: 'Subkategori wajib dipilih' }}\\n                                            render={({ field }) => (\\n                                                <Select\\n                                                    {...field}\\n                                                    options={subKategoriOptions}\\n                                                    styles={ReactSelectStyle}\\n                                                    placeholder={\\n                                                        watchEdit('kategori')\\n                                                            ? 'Pilih Sub Kategori'\\n                                                            : 'Pilih kategori dahulu...'\\n                                                    }\\n                                                    isLoading={loadingKategori}\\n                                                    isDisabled={!watchEdit('kategori')}\\n                                                    value={findMatchingOption(\\n                                                        subKategoriOptions,\\n                                                        field.value,\\n                                                    )}\\n                                                    onChange={(val) => {\\n                                                        field.onChange(val?.value);\\n                                                        setValueEdit('wujud_perbuatan', null);\\n                                                    }}\\n                                                />\\n                                            )}\\n                                        />\\n                                        {errors.sub_kategori && (\\n                                            <ErrorText>{errors.sub_kategori.message}</ErrorText>\\n                                        )}\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n\\n                            <Form.Group className=\\\"w-100\\\">\\n                                <TitleInput className=\\\"mb-3\\\">Wujud Perbuatan</TitleInput>\\n                                <Controller\\n                                    name=\\\"wujud_perbuatan\\\"\\n                                    control={controlEdit}\\n                                    render={({ field }) => (\\n                                        <Select\\n                                            {...field}\\n                                            options={wujudPerbuatanOptions}\\n                                            styles={ReactSelectStyle}\\n                                            placeholder={\\n                                                !watchEdit('kategori')\\n                                                    ? 'Pilih kategori dahulu...'\\n                                                    : !watchEdit('sub_kategori')\\n                                                        ? 'Pilih sub kategori dahulu...'\\n                                                        : 'Pilih wujud perbuatan'\\n                                            }\\n                                            isLoading={loadingKategori}\\n                                            isDisabled={\\n                                                !watchEdit('kategori') || !watchEdit('sub_kategori')\\n                                            }\\n                                            value={findMatchingOption(\\n                                                wujudPerbuatanOptions,\\n                                                field.value,\\n                                            )}\\n                                            onChange={(val) => field.onChange(val?.value)}\\n                                        />\\n                                    )}\\n                                />\\n                            </Form.Group>\\n\\n                            {/* ===== BAGIAN PENERAPAN PASAL - DIMODIFIKASI ===== */}\\n\\n                            {selectedTipeTerlapor === 'ASN Polri' ? (\\n                                <Form.Group className=\\\"w-100\\\">\\n                                    <TitleInput className=\\\"mb-3\\\">Penerapan Pasal</TitleInput>\\n                                    <div className=\\\"d-flex gap-2 w-100\\\">\\n                                        <RadioButtonContainer\\n                                            isSelected={false}\\n                                            disabled={true}\\n                                            style={{ opacity: 0.6, cursor: 'not-allowed' }}\\n                                        >\\n                                            <FormCheckStyled\\n                                                type=\\\"radio\\\"\\n                                                disabled={true}\\n                                                checked={false}\\n                                                name=\\\"penerapan-pasal-asn\\\"\\n                                            />\\n                                            <p style={{ color: 'var(--black-400)' }}>Kode Etik</p>\\n                                        </RadioButtonContainer>\\n\\n                                        <RadioButtonContainer\\n                                            isSelected={true}\\n                                            disabled={true}\\n                                            style={{ opacity: 0.6, cursor: 'not-allowed' }}\\n                                        >\\n                                            <FormCheckStyled\\n                                                type=\\\"radio\\\"\\n                                                disabled={true}\\n                                                checked={true}\\n                                                name=\\\"penerapan-pasal-asn\\\"\\n                                            />\\n                                            <p>Disiplin</p>\\n                                        </RadioButtonContainer>\\n                                    </div>\\n                                </Form.Group>\\n                            ) : (\\n                                <Form.Group className=\\\"d-flex flex-column gap-2 w-100\\\">\\n                                    <TitleInput className=\\\"mb-3\\\">Penerapan Pasal</TitleInput>\\n                                    <div className=\\\"d-flex gap-2 w-100\\\">\\n                                        <RadioButtonContainer\\n                                            isSelected={selectedPenerapanPasal === 'kode-etik'}\\n                                            onClick={() => {\\n                                                setSelectedPenerapanPasal('kode-etik');\\n                                                setValueEdit('form_of_action', 'kode-etik');\\n                                                setValueEdit('pasal_ppri', []);\\n                                                setValueEdit('pasal_perpol', []);\\n                                                setValueEdit('pasal_disiplin_ppri', []);\\n                                                setValueEdit('pasal_disiplin_perpol', []);\\n                                            }}\\n                                            type=\\\"button\\\"\\n                                        >\\n                                            <FormCheckStyled\\n                                                type=\\\"radio\\\"\\n                                                checked={selectedPenerapanPasal === 'kode-etik'}\\n                                                onChange={() => {\\n                                                    setSelectedPenerapanPasal('kode-etik');\\n                                                    setValueEdit('form_of_action', 'kode-etik');\\n                                                    setValueEdit('pasal_ppri', []);\\n                                                    setValueEdit('pasal_perpol', []);\\n                                                    setValueEdit('pasal_disiplin_ppri', []);\\n                                                    setValueEdit('pasal_disiplin_perpol', []);\\n                                                }}\\n                                                name=\\\"penerapan-pasal\\\"\\n                                            />\\n                                            <p>Kode Etik</p>\\n                                        </RadioButtonContainer>\\n\\n                                        <RadioButtonContainer\\n                                            isSelected={selectedPenerapanPasal === 'disiplin'}\\n                                            onClick={() => {\\n                                                setSelectedPenerapanPasal('disiplin');\\n                                                setValueEdit('form_of_action', 'disiplin');\\n                                                setValueEdit('pasal_ppri', []);\\n                                                setValueEdit('pasal_perpol', []);\\n                                                setValueEdit('pasal_disiplin_ppri', []);\\n                                                setValueEdit('pasal_disiplin_perpol', []);\\n                                            }}\\n                                            type=\\\"button\\\"\\n                                        >\\n                                            <FormCheckStyled\\n                                                type=\\\"radio\\\"\\n                                                checked={selectedPenerapanPasal === 'disiplin'}\\n                                                onChange={() => {\\n                                                    setSelectedPenerapanPasal('disiplin');\\n                                                    setValueEdit('form_of_action', 'disiplin');\\n                                                    setValueEdit('pasal_ppri', []);\\n                                                    setValueEdit('pasal_perpol', []);\\n                                                    setValueEdit('pasal_disiplin_ppri', []);\\n                                                    setValueEdit('pasal_disiplin_perpol', []);\\n                                                }}\\n                                                name=\\\"penerapan-pasal\\\"\\n                                            />\\n                                            <p>Disiplin</p>\\n                                        </RadioButtonContainer>\\n                                    </div>\\n                                </Form.Group>\\n                            )}\\n\\n                            {(selectedTipeTerlapor === 'Anggota Polri' ||\\n                                selectedTipeTerlapor === 'Anonim') && (\\n                                    <>\\n                                        {selectedPenerapanPasal === 'kode-etik' && (\\n                                            <Form.Group\\n                                                className=\\\"w-100 d-flex flex-column\\\"\\n                                                style={{ gap: '16px' }}\\n                                            >\\n                                                <PasalSelect\\n                                                    control={controlEdit}\\n                                                    name=\\\"pasal_perpol\\\"\\n                                                    label=\\\"PERPOL NOMOR 7 TH 2022\\\"\\n                                                    placeholder=\\\"Pilih pasal\\\"\\n                                                    filterType=\\\"PERPOL NOMOR 7 TH 2022\\\"\\n                                                    defaultValue={pasalPerpol.map((item) => item.article_id)}\\n                                                />\\n                                                <PasalSelect\\n                                                    control={controlEdit}\\n                                                    name=\\\"pasal_ppri\\\"\\n                                                    label=\\\"PPRI NOMOR 1 TAHUN 2003\\\"\\n                                                    placeholder=\\\"Pilih pasal\\\"\\n                                                    filterType=\\\"PPRI NOMOR 1 TAHUN 2003\\\"\\n                                                    defaultValue={pasalPPRI.map(\\n                                                        (item) => item.article_id,\\n                                                    )}\\n                                                />\\n                                            </Form.Group>\\n                                        )}\\n\\n                                        {selectedPenerapanPasal === 'disiplin' && (\\n                                            <Form.Group className=\\\"w-100\\\">\\n                                                <PasalSelect\\n                                                    control={controlEdit}\\n                                                    name=\\\"pasal_disiplin_ppri\\\"\\n                                                    label=\\\"PPRI NOMOR 2 TAHUN 2003\\\"\\n                                                    placeholder=\\\"Pilih pasal disiplin\\\"\\n                                                    filterType=\\\"PPRI NOMOR 2 TAHUN 2003\\\"\\n                                                    defaultValue={pasalDisiplinPPRI.map(\\n                                                        (item) => item.article_id,\\n                                                    )}\\n                                                />\\n                                            </Form.Group>\\n                                        )}\\n                                    </>\\n                                )}\\n\\n                            {selectedTipeTerlapor === 'ASN Polri' && (\\n                                <>\\n                                    <Form.Group className=\\\"w-100\\\">\\n                                        <PasalSelect\\n                                            control={controlEdit}\\n                                            name=\\\"pasal_disiplin_ppri\\\"\\n                                            label=\\\"PPRI NOMOR 94 TAHUN 2021\\\"\\n                                            placeholder=\\\"Pilih pasal disiplin\\\"\\n                                            filterType=\\\"PPRI NOMOR 94 TAHUN 2021\\\"\\n                                            defaultValue={pasalDisiplinPPRI.map(\\n                                                (item) => item.article_id,\\n                                            )}\\n                                        />\\n                                        {/* <PasalSelect\\n                        control={controlEdit}\\n                        name=\\\"pasal_disiplin_perpol\\\"\\n                        label=\\\"PPRI NO 94 TAHUN 2021\\\"\\n                        placeholder=\\\"Pilih pasal disiplin\\\"\\n                        filterType=\\\"PPRI NO 94 TAHUN 2021\\\"\\n                        defaultValue={pasalDisiplinPPRI.map(\\n                          (item) => item.article_id,\\n                        )}\\n                      /> */}\\n                                    </Form.Group>\\n                                </>\\n                            )}\\n\\n                            {/* Hidden Input */}\\n                            <Form.Control\\n                                type=\\\"hidden\\\"\\n                                {...registerEdit('prepetrator_id')}\\n                            />\\n                        </>\\n                    )}\\n\\n                    {/* STEP 3 - Data Pendumas */}\\n                    {step === 3 && (\\n                        <>\\n                            <Row className=\\\"g-3 w-100\\\">\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                                        <StyledInput\\n                                            type=\\\"text\\\"\\n                                            placeholder=\\\"Nama\\\"\\n                                            {...registerEdit('sender_name')}\\n                                        />\\n                                    </Form.Group>\\n                                </Col>\\n                                <Col md={6}>\\n                                    <Form.Group>\\n                                        <TitleInput className=\\\"mb-3\\\">Nomor Telepon</TitleInput>\\n                                        <StyledInputGroup>\\n                                            <InputGroupTextCustom>+62</InputGroupTextCustom>\\n                                            <FormControlCustom\\n                                                type=\\\"number\\\"\\n                                                placeholder=\\\"81234567890\\\"\\n                                                {...registerEdit('sender_phone')}\\n                                            />\\n                                        </StyledInputGroup>\\n                                    </Form.Group>\\n                                </Col>\\n                            </Row>\\n\\n                            <Form.Group className=\\\"w-100\\\">\\n                                <TitleInput className=\\\"mb-3\\\">Alamat</TitleInput>\\n                                <StyledTextarea\\n                                    type=\\\"text\\\"\\n                                    as={'textarea'}\\n                                    rows={3}\\n                                    placeholder=\\\"Alamat\\\"\\n                                    {...registerEdit('sender_address')}\\n                                />\\n                            </Form.Group>\\n                        </>\\n                    )}\\n\\n                    {/* STEP 4 - Dokumen Upload */}\\n                    {step === 4 && (\\n                        <>\\n                            {/* Upload New Files */}\\n                            <Form.Group className=\\\"w-100\\\">\\n                                <StyledInput\\n                                    id=\\\"fileInput\\\"\\n                                    type=\\\"file\\\"\\n                                    multiple\\n                                    style={{ display: 'none' }}\\n                                    onChange={handleFileChange}\\n                                    accept=\\\".doc,.docx,.png,.jpg,.jpeg,.pdf,.mp4\\\"\\n                                />\\n                                <UploadBox\\n                                    onDrop={handleDrop}\\n                                    onDragOver={handleDragOver}\\n                                    onDragLeave={handleDragLeave}\\n                                    onClick={triggerFileInput}\\n                                    isDragging={isDragging}\\n                                >\\n                                    <i\\n                                        className=\\\"ph ph-upload-simple pb-2\\\"\\n                                        style={{ fontSize: '2rem' }}\\n                                    ></i>\\n                                    <p\\n                                        style={{\\n                                            fontWeight: '400',\\n                                            fontSize: '0.875rem',\\n                                            pointerEvents: 'none',\\n                                        }}\\n                                    >\\n                                        <span\\n                                            style={{\\n                                                fontWeight: '600',\\n                                                color: 'var(--primary-500)',\\n                                            }}\\n                                        >\\n                                            Choose file\\n                                        </span>{' '}\\n                                        or drag and drop\\n                                    </p>\\n                                    <small style={{ pointerEvents: 'none' }}>\\n                                        doc, docx, png, jpg, jpeg, pdf, mp4 only. 10MB max size.\\n                                    </small>\\n                                </UploadBox>\\n\\n                                {/* New Files Being Uploaded */}\\n                                {files.length > 0 && (\\n                                    <>\\n                                        <TitleInput className=\\\"py-4\\\">\\n                                            File baru yang diupload\\n                                        </TitleInput>\\n                                        <FileList>\\n                                            {files.map((file, idx) => (\\n                                                <FileItem key={`new-${idx}`}>\\n                                                    <StyledFile>\\n                                                        <FileIcon>{getFileIcon(file)}</FileIcon>\\n                                                    </StyledFile>\\n                                                    <div style={{ flex: 1 }}>\\n                                                        <div className=\\\"fw-600\\\">{file.name}</div>\\n                                                        <small className=\\\"text-muted\\\">\\n                                                            {(file.size / (1024 * 1024)).toFixed(1)} MB\\n                                                        </small>\\n                                                    </div>\\n                                                    <button\\n                                                        type=\\\"button\\\"\\n                                                        onClick={() => removeFile(file)}\\n                                                        style={{\\n                                                            color: '#dc3545',\\n                                                            background: 'none',\\n                                                            border: 'none',\\n                                                            padding: '0.5rem',\\n                                                        }}\\n                                                    >\\n                                                        <i className=\\\"ph ph-x\\\"></i>\\n                                                    </button>\\n                                                </FileItem>\\n                                            ))}\\n                                        </FileList>\\n                                    </>\\n                                )}\\n\\n                                {/* Existing Files */}\\n                                {report?.attachments && report.attachments.length > 0 && (\\n                                    <>\\n                                        <TitleInput className=\\\"py-4\\\">\\n                                            File yang sudah diupload\\n                                        </TitleInput>\\n                                        <FileList className=\\\"mb-4\\\">\\n                                            {report.attachments.map((item, index) => {\\n                                                const fileName =\\n                                                    item.file_name || `Dokumen ${index + 1}`;\\n                                                const fileSize = item.file_size\\n                                                    ? `${(item.file_size / (1024 * 1024)).toFixed(1)} MB`\\n                                                    : '';\\n                                                const fileType =\\n                                                    item.file_type ||\\n                                                    item.url?.split('.').pop()?.toLowerCase() ||\\n                                                    '';\\n\\n                                                return (\\n                                                    <FileItem key={index} className=\\\"existing-file\\\">\\n                                                        <StyledFile>\\n                                                            <FileIcon>\\n                                                                {getFileIcon({ name: `file.${fileType}` })}\\n                                                            </FileIcon>\\n                                                        </StyledFile>\\n                                                        <div style={{ flex: 1 }}>\\n                                                            <div className=\\\"fw-600\\\">{fileName}</div>\\n                                                            {fileSize && (\\n                                                                <small className=\\\"text-muted\\\">\\n                                                                    {fileSize}\\n                                                                </small>\\n                                                            )}\\n                                                        </div>\\n                                                        <div className=\\\"d-flex gap-2\\\">\\n                                                            <Button\\n                                                                variant=\\\"link\\\"\\n                                                                size=\\\"sm\\\"\\n                                                                onClick={() => handleDownloadFile(item)}\\n                                                                style={{ color: 'var(--primary)' }}\\n                                                            >\\n                                                                <i className=\\\"ph ph-download-simple\\\"></i>\\n                                                            </Button>\\n                                                            <Button\\n                                                                variant=\\\"link\\\"\\n                                                                size=\\\"sm\\\"\\n                                                                onClick={() => removeExistingFile(item.url)}\\n                                                                style={{ color: '#dc3545' }}\\n                                                            >\\n                                                                <i className=\\\"ph ph-trash\\\"></i>\\n                                                            </Button>\\n                                                        </div>\\n                                                    </FileItem>\\n                                                );\\n                                            })}\\n                                        </FileList>\\n                                        <hr />\\n                                    </>\\n                                )}\\n                            </Form.Group>\\n                        </>\\n                    )}\\n                </ModalBody>\\n                <ModalFooter>\\n                    <ProgressWrapper>\\n                        <ProgressBase>\\n                            <ProgressFill step={step} />\\n                        </ProgressBase>\\n                    </ProgressWrapper>\\n                    <div className=\\\"d-flex gap-3\\\">\\n                        <Button variant=\\\"outline-primary\\\" onClick={handleCloseWithReset}>\\n                            Batal\\n                        </Button>\\n                        {step > 1 && (\\n                            <Button variant=\\\"outline-secondary\\\" onClick={handlePrevious}>\\n                                Kembali\\n                            </Button>\\n                        )}\\n                        {step < 4 ? (\\n                            <Button variant=\\\"primary\\\" onClick={handleNext}>\\n                                Selanjutnya\\n                            </Button>\\n                        ) : (\\n                            <Button\\n                                variant=\\\"primary\\\"\\n                                onClick={handleSubmitEdit(onSubmitEdit)}\\n                                disabled={loading}\\n                            >\\n                                {loading ? 'Menyimpan...' : 'Simpan'}\\n                            </Button>\\n                        )}\\n                    </div>\\n                </ModalFooter>\\n            </Form>\\n        </StyledModal>\\n        <DetailModal\\n            show={showDetailModal}\\n            onHide={() => setShowDetailModal(false)}\\n            data={selectedDetail}\\n        />\\n    </>\\n);\\n}\\n\\nconst ProgressWrapper = styled.div`\\n  flex: 1;\\n  display: flex;\\n  align-items: center;\\n`;\\n\\nconst ProgressBase = styled.div`\\n  width: 5.71429rem;\\n  height: 0.57143rem;\\n  background-color: var(--primary-50);\\n  border-radius: 1.71429rem;\\n  position: relative;\\n  overflow: hidden;\\n`;\\n\\nconst ErrorText = styled.span`\\n  color: var(--danger);\\n  font-size: 0.75rem;\\n  margin-top: 0.25rem;\\n  display: block;\\n`;\\n\\nconst ProgressFill = styled.div`\\n  position: absolute;\\n  top: 0;\\n  left: 0;\\n  height: 100%;\\n  width: ${(props) => {\\n        switch (props.step) {\\n            case 1:\\n                return '25%';\\n            case 2:\\n                return '50%';\\n            case 3:\\n                return '75%';\\n            case 4:\\n                return '100%';\\n            default:\\n                return '0%';\\n        }\\n    }};\\n  background-color: var(--primary-500);\\n  transition: width 0.4s ease;\\n  border-radius: 1.71429rem;\\n`;\\n\\nconst StepIndicator = styled.span`\\n  margin-left: 1rem;\\n  font-size: 0.875rem;\\n  color: var(--black-400);\\n  font-weight: 500;\\n`;\\nconst StyledModal = styled(Modal)`\\n  .modal-dialog {\\n    max-width: 670px; \\n  }\\n  .modal-body {\\n    max-height: 50vh;\\n    overflow-y: auto; \\n  }\\n  \\n`;\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst ModalBody = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n`;\\n\\nconst ModalFooter = styled(Modal.Footer)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem 1.06667rem 1.33333rem;\\n  justify-content: flex-end;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst DescHeader = styled.p`\\n  color: var(--black-400);\\n  font-size: 0.93333rem;\\n  font-style: normal;\\n  font-weight: 400;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\nconst TabsHeader = styled.div`\\n  display: flex;\\n  width: 100%;\\n  background: var(--black-25);\\n  border-radius: 12px;\\n  padding: 4px;\\n  gap: 4px;\\n`;\\n\\nconst TabButton = styled.button`\\n  flex: 1;\\n  padding: 0.75rem 1rem;\\n  border: none;\\n  background: ${(props) => (props.active ? 'var(--white)' : 'transparent')};\\n  color: ${(props) => (props.active ? 'var(--black)' : '#6C757D')};\\n  font-weight: ${(props) => (props.active ? '600' : '500')};\\n  border-radius: 8px;\\n  cursor: pointer;\\n  transition: all 0.2s;\\n  box-shadow: ${(props) => (props.active ? '0 2px 8px 0 rgba(51, 51, 51, 0.07)' : 'none')};\\n\\n  &:hover {\\n    background: ${(props) => (props.active ? 'var(--white)' : 'var(--black-50)')};\\n  }\\n`;\\n\\nconst RadioButtonContainer = styled.div`\\n  border: 1px solid ${({ isSelected }) => (isSelected ? 'var(--primary)' : 'var(--black-100)')};\\n  border-radius: 0.57143rem;\\n  padding: 0.4rem 0.53333rem;\\n  gap: 0.1rem;\\n  position: relative;\\n  display: flex;\\n  align-items: center;\\n  cursor: pointer;\\n\\n  .form-check-input {\\n    position: relative;\\n    margin-left: 0;\\n    margin-top: 0;\\n  }\\n\\n  p {\\n    font-size: 0.85714rem;\\n    font-style: normal;\\n    font-weight: 600;\\n    margin: 0;\\n    color: ${({ isSelected }) => (isSelected ? 'var(--primary)' : 'var(--black)')};\\n  }\\n`;\\n\\nconst FormCheckStyled = styled(Form.Check)`\\n  display: flex;\\n  align-items: center;\\n  \\n  .form-check-input {\\n    margin-right: 0.5rem;\\n    \\n    &:checked {\\n      background-color: var(--primary);\\n      border-color: var(--primary);\\n    }\\n  }\\n`;\\nconst TitleInput = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-weight: 500;\\nline-height: 140%; \\n\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;  \\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  font-family: Inter;\\n  box-shadow: none;\\n  background-color:var(--white);\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst InputGroupText = styled(InputGroup.Text)`\\n  border-radius:  0.57rem 0rem 0rem 0.57rem !important;\\n  background: var(--black-25) !important;\\n  justify-content: center;\\n  align-items: center;\\n`;\\n// const FormControlCustom = styled(Form.Control)`\\n//   border-radius: 0 0.57rem 0.57rem 0 !important;\\n// `;\\n\\nconst StyledInputGroup = styled(InputGroup)`\\n  border: 1px solid var(--black-100);\\n  border-radius: 8px;\\n  overflow: hidden;\\n  background-color: var(--white);\\n\\n  &:focus-within {\\n    border-color: var(--primary);\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst InputGroupTextCustom = styled(InputGroup.Text)`\\n  background-color: var(--black-50);\\n  border: none;\\n  border-right: 1px solid #e9ecef;\\n  color: #6c757d;\\n  font-size: 0.9rem;\\n  padding: 0 12px;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  min-width: 45px;\\n`;\\n\\nconst NativeDateWrapper = styled.div`\\n  display: flex;\\n  align-items: stretch;\\n  width: 100%;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  background-color: var(--white);\\n\\n  &:focus-within {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst DateIconAddon = styled.div`\\n  background-color: var(--black-25);\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  padding: 0 12px;\\n  border-right: 1px solid var(--black-25);\\n  color: #64748b;\\n`;\\n\\nconst ContentGrid = styled.div`\\npadding: 12px;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 1rem;\\n // height: 80rem; \\n // overflow-y: auto;\\n  padding-right: 0.4rem;\\n // scrollbar-width: thin;\\n // scrollbar-color: var(--black-200) transparent;\\n\\n //  /* styling scrollbar untuk Chrome/Safari */\\n // &::-webkit-scrollbar {\\n //   width: 6px;\\n // }\\n\\n // &::-webkit-scrollbar-track {\\n //   background: transparent;\\n // }\\n\\n // &::-webkit-scrollbar-thumb {\\n //   background-color: var(--black-300);\\n //   border-radius: 4px;\\n // }\\n`;\\n\\nconst StyledCard = styled.div`\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  padding:12px;\\n  background: var(--white);\\n`;\\nconst FallbackIcon = styled.div`\\n  position: absolute;\\n  inset: 0;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n`;\\n\\nconst ImageWrapper = styled.div`\\n  position: relative;\\n  width: 30px;\\n  height: 40px;\\n  min-width: 40px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  cursor: pointer;\\n  \\n  img {\\n    width: 100%;\\n    height: 100%;\\n    object-fit: cover;\\n  }\\n`;\\n\\nconst FallbackIconWrapper = styled.div`\\n  width: 60px;\\n  height: 60px;\\n  min-width: 60px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  flex-shrink: 0;\\n`;\\n\\nconst FileName = styled.div`\\n  overflow: hidden;\\n  text-overflow: ellipsis;\\n  display: -webkit-box;\\n  -webkit-line-clamp: 2;\\n  -webkit-box-orient: vertical;\\n  line-height: 1.2;\\n`;\\n\\nconst StyledNativeDate = styled.input`\\n  flex: 1;\\n  border: none !important;\\n  padding: 0.75rem 1rem;\\n  font-size: 0.875rem;\\n  outline: none !important;\\n  background: transparent;\\n  color: #495057;\\n\\n  &::-webkit-calendar-picker-indicator {\\n    cursor: pointer;\\n    opacity: 0.6;\\n    filter: invert(0.5); \\n  }\\n`;\\n\\nconst UploadBox = styled.div`\\n border-radius: 0.75rem;\\n  background: var(--black-25);\\n  padding: 3rem 0.75rem;\\n  text-align: center;\\n  cursor: pointer;\\n  ${(props) => props.isDragging && 'background: #e0e7ff;'}\\n  \\n  p {\\n    font-size: 0.875rem;\\n  }\\n\\n  small {\\n    font-size: 0.75rem;\\n  }\\n\\n  @media (max-width: 480px) {\\n    p {\\n      font-size: 0.8rem;\\n    }\\n    small {\\n      font-size: 0.7rem;\\n    }\\n  }\\n`;\\n\\nconst FileList = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n`;\\n\\nconst FileItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  justify-content: space-between;\\n  border-radius: 0.5rem;\\n  border: 1px solid var(--black-100);\\n  background: var(--black-25);\\n  padding: 0.5rem;\\n  font-size: 0.875rem;\\n  gap:1rem;\\n`;\\n\\nconst FileIcon = styled.div`\\n  font-size: 1.25rem;\\n  line-height: 0;\\n  color: var(--white);\\n`;\\n\\nconst FormControlCustom = styled(Form.Control)`\\n  border: none !important;\\n  padding: 10px 14px;\\n  font-size: 0.9rem;\\n\\n  &:focus {\\n    box-shadow: none !important;\\n  }\\n\\n& + .react-datepicker__calendar-icon {\\n    display: none;\\n  }\\n  &::placeholder {\\n    color: #adb5bd;\\n  }\\n`;\\n\\nconst DownloadButton = styled(Button)`\\n\\ndisplay: flex;\\npadding: 0.53333rem;\\njustify-content: center;\\nalign-items: center;\\nwidth:min-content;\\ngap: 0.53333rem;\\n  background-color:none;\\n  border:1px solid var(--black-100);\\n`;\\nconst BodyContainer = styled.div`\\n  flex: 1;\\n  overflow-y: auto;\\n  padding: 16px;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 8px;\\n  max-height: 41rem;\\n  \\n  /* Styling scrollbar */\\n  &::-webkit-scrollbar {\\n    width: 6px;\\n  }\\n  \\n  &::-webkit-scrollbar-track {\\n    background: transparent;\\n  }\\n  \\n  &::-webkit-scrollbar-thumb {\\n    background-color: var(--black-300);\\n    border-radius: 4px;\\n  }\\n\\n\\n  .information {\\n    width: 200px;\\n    font-size: 0.93333rem;\\n    font-weight: 400;\\n    line-height: 140%;\\n    color: var(--black-600);\\n    flex-shrink: 0;\\n  }\\n\\n  .subtitle {\\n    font-size: 14px;\\n    font-weight: 500;\\n    color: var(--black);\\n    margin-top: 8px;\\n    \\n    &:first-child {\\n      margin-top: 0;\\n    }\\n  }\\n\\n  .flex.items-center {\\n    display: flex;\\n    align-items: center;\\n    width: 100%;\\n    gap: 16px;\\n    margin-bottom: 8px;\\n  }\\n\\n  .fs-12, .fw-400, .value {\\n    font-size: 0.93333rem;\\n    font-weight: 400;\\n    color: var(--black);\\n    flex: 1;\\n    word-break: break-word;\\n  }\\n`;\\nconst StyledFile = styled.div`\\n  display: flex;\\n  padding: 8px;\\n  align-items: center;\\n  gap: 10px;\\n  border-radius: 8px;\\n  background: var(--primary-500);\\n`;\\nconst StyledDatePicker = styled(DatePicker)`\\n  flex: 1;\\n  border: none !important;\\n     &.ant-picker {\\n    padding:0;\\n       height:36px;\\n    }\\n  .ant-picker-input {\\n    input {\\n      font-size: 0.875rem;\\n      padding: 0.75rem 1rem;\\n         height: 36px;\\n      &::placeholder {\\n        color: #adb5bd;\\n      }\\n    }\\n  }\\n  \\n  .ant-picker-suffix {\\n    display: none; /* Sembunyikan icon kanan */\\n  }\\n  \\n  .ant-picker-clear {\\n    display: none;\\n  }\\n`;\\nconst StyledYearPicker = styled(DatePicker)`\\n  flex: 1;\\n  border: none !important;\\n\\n    &.ant-picker {\\n    padding:0;\\n        height:36px;\\n    }\\n  .ant-picker-input {\\n    input {\\n      font-size: 0.875rem;\\n      padding: 0.75rem 1rem;\\n          height:36px;\\n      \\n      &::placeholder {\\n        color: #adb5bd;\\n      }\\n    }\\n  }\\n  \\n  .ant-picker-suffix {\\n    display: none; /* Sembunyikan icon kanan */\\n  }\\n  \\n  .ant-picker-clear {\\n    display: none;\\n  }`;\\n\\nconst ReactSelectStyle = {\\n    control: (styles: any, { isDisabled }: any) => ({\\n        ...styles,\\n        backgroundColor: isDisabled ? 'var(--black-25)' : 'var(--white)',\\n        borderColor: 'var(--black-150)',\\n        color: '$input-color',\\n        padding: '0rem 0.8rem',\\n        borderRadius: '0.5rem',\\n        borderWidth: '1px',\\n        // fontFamily: 'Outfit',\\n        transition: 'none',\\n        '&:focus': {\\n            ...styles[':focus'],\\n            backgroundColor: 'var(--primary-25)',\\n            borderColor: 'var(--primary-400)',\\n            boxShadow: '0 0 0 0.25rem rgba(var(--primary-rgb), 0.25)',\\n        },\\n        ':hover': {\\n            ...styles[':hover'],\\n            borderColor: 'var(--primary-400)',\\n        },\\n        ':active': {\\n            ...styles[':active'],\\n            borderColor: 'var(--primary-400)',\\n        },\\n        minHeight: '1.85rem',\\n        // width: '40rem',\\n    }),\\n    input: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black-800)',\\n        margin: '0',\\n        // fontFamily: 'Outfit',\\n    }),\\n    placeholder: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black-300)',\\n        // fontFamily: 'Outfit',\\n        // fontSize: '$input-font-size',\\n        fontSize: '0.875rem',\\n        fontStyle: 'normal',\\n        fontWeight: '400',\\n        lineHeight: '1.4rem',\\n    }),\\n    valueContainer: (styles: any) => ({\\n        ...styles,\\n        padding: '0',\\n        textOverflow: 'ellipsis',\\n\\n        textWrap: 'nowrap',\\n    }),\\n    indicatorSeparator: (styles: any) => ({\\n        ...styles,\\n        backgroundColor: 'transparent',\\n        marginTop: '6px',\\n        marginBottom: '6px',\\n        padding: 0,\\n    }),\\n    indicatorsContainer: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black)',\\n        padding: '0',\\n    }),\\n    indicatorContainer: (styles: any) => ({\\n        ...styles,\\n        padding: 0,\\n    }),\\n    singleValue: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black)',\\n        fontWeight: '500',\\n        fontSize: '0.875rem',\\n        // fontFamily: 'Outfit',\\n    }),\\n    multiValue: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black-500)',\\n        backgroundColor: 'var(--black-25)',\\n        fontWeight: '500',\\n        fontSize: '0.875rem',\\n        // fontFamily: 'Outfit',\\n    }),\\n    multiValueLabel: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black-500)',\\n        backgroundColor: 'var(--black-25)',\\n        fontWeight: '500',\\n        fontSize: '0.875rem',\\n        // fontFamily: 'Outfit',\\n    }),\\n    multiValueRemove: (styles: any) => ({\\n        ...styles,\\n        color: 'var(--black-500)',\\n        backgroundColor: 'var(--black-25)',\\n        ':hover': {\\n            color: 'var(--black)',\\n            backgroundColor: 'var(--primary-300)',\\n        },\\n    }),\\n    menu: (styles: any) => ({\\n        ...styles,\\n        backgroundColor: 'var(--white)',\\n        zIndex: 9999,\\n        // fontFamily: 'Outfit',\\n    }),\\n\\n    option: (styles: any) => ({\\n        ...styles,\\n        backgroundColor: 'var(--white)',\\n        // fontFamily: 'Outfit',\\n        color: 'var(--black)',\\n        ':hover': {\\n            ...styles[':hover'],\\n            backgroundColor: 'var(--primary-50)',\\n        },\\n        ':focus': {\\n            ...styles[':focus'],\\n            backgroundColor: 'var(--primary-50)',\\n        },\\n    }),\\n};\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\nconst customStyles = {\\n    ...ReactSelectStyle, // Ambil style global (base)\\n\\n    // HAPUS atau MODIFIKASI valueContainer - jangan pakai flexDirection column\\n    valueContainer: (provided) => ({\\n        ...provided,\\n        padding: '0 8px',\\n        // Hapus flexDirection: 'column' agar selected items tetap di dalam baris\\n    }),\\n\\n    // Override MultiValue agar tidak terlihat seperti 'tag' kecil\\n    multiValue: (provided) => ({\\n        ...provided,\\n        backgroundColor: 'var(--primary-50)',\\n        borderRadius: '4px',\\n        padding: '2px',\\n        margin: '2px',\\n    }),\\n    multiValueLabel: (provided) => ({\\n        ...provided,\\n        color: 'var(--primary-700)',\\n        fontWeight: '500',\\n        padding: '2px 4px',\\n    }),\\n    multiValueRemove: (provided) => ({\\n        ...provided,\\n        color: 'var(--primary-700)',\\n        display: 'flex', // Tampilkan X\\n        ':hover': {\\n            backgroundColor: 'var(--primary-100)',\\n            color: 'var(--primary-900)',\\n        },\\n    }),\\n\\n    // Style untuk dropdown option-nya\\n    option: (provided, state) => ({\\n        ...provided,\\n        padding: '12px 16px',\\n        borderBottom: '1px solid #e9ecef',\\n        backgroundColor: state.isFocused ? 'var(--primary-25)' : 'white',\\n        color: 'var(--black)',\\n        whiteSpace: 'normal',\\n        wordBreak: 'break-word',\\n        ':last-child': { borderBottom: 'none' },\\n        ':active': { backgroundColor: 'var(--primary-50)' },\\n    }),\\n\\n    menu: (provided) => ({\\n        ...provided,\\n        boxShadow: '0 4px 12px rgba(0,0,0,0.15)',\\n        borderRadius: '8px',\\n        zIndex: 9999,\\n    }),\\n};\\n// Komponen terpisah agar useState bisa dipakai dengan benar (Rules of Hooks)\\nconst AttachmentCard = ({ item, index, convertS3Url, handleDownloadFile }) => {\\n    const [isImageLoaded, setIsImageLoaded] = useState(false);\\n\\n    const isImage = ['jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp'].includes(\\n        item.file_type?.toLowerCase() || item.url?.split('.').pop()?.toLowerCase(),\\n    );\\n\\n    const fileName = item.file_name || `Dokumen ${index + 1}`;\\n    const fileUrl = convertS3Url(item.url);\\n\\n    return (\\n        <StyledCard>\\n            <div className=\\\"flex items-center gap-4\\\">\\n                <ImageWrapper>\\n                    {isImage ? (\\n                        <>\\n                            <img\\n                                src={fileUrl}\\n                                alt=\\\"Preview\\\"\\n                                onLoad={() => setIsImageLoaded(true)}\\n                                onError={(e) => {\\n                                    e.target.style.display = 'none';\\n                                    setIsImageLoaded(false);\\n                                }}\\n                            />\\n                            {!isImageLoaded && (\\n                                <FallbackIcon>\\n                                    <i\\n                                        className=\\\"ph-fill ph-file\\\"\\n                                        style={{\\n                                            color: 'var(--primary-600)',\\n                                            fontSize: '2rem',\\n                                        }}\\n                                    ></i>\\n                                </FallbackIcon>\\n                            )}\\n                        </>\\n                    ) : (\\n                        <FallbackIcon>\\n                            <i\\n                                className=\\\"ph-fill ph-file\\\"\\n                                style={{\\n                                    color: 'var(--primary-600)',\\n                                    fontSize: '2rem',\\n                                }}\\n                            ></i>\\n                        </FallbackIcon>\\n                    )}\\n                </ImageWrapper>\\n\\n                <div className=\\\"flex justify-between w-100\\\">\\n                    <div className=\\\"flex flex-col flex-1\\\">\\n                        <div className=\\\"fs-14 fw-600\\\">{fileName}</div>\\n                        <div className=\\\"text-muted\\\">{item.created_at}</div>\\n                    </div>\\n\\n                    <DownloadButton\\n                        variant=\\\"secondary\\\"\\n                        size=\\\"sm\\\"\\n                        onClick={() => handleDownloadFile(item)}\\n                    >\\n                        <i className=\\\"ph ph-download-simple\\\"></i>\\n                    </DownloadButton>\\n                </div>\\n            </div>\\n        </StyledCard>\\n    );\\n};\\n\\nconst PasalSelect = ({\\n    control,\\n    name,\\n    label,\\n    placeholder = 'Pilih',\\n    filterType,\\n    defaultValue = [],\\n}) => {\\n    const [options, setOptions] = useState([]);\\n    const [loading, setLoading] = useState(false);\\n    const [showDetailModal, setShowDetailModal] = useState(false);\\n    const [selectedDetail, setSelectedDetail] = useState(null);\\n    const [inputValue, setInputValue] = useState('');\\n    const [pasalSearchTimeout, setPasalSearchTimeout] = useState(null);\\n\\n    const fetchPasalData = async (search = '') => {\\n        setLoading(true);\\n        try {\\n            const requestPayload = {\\n                orderBy: 'kode_pasal',\\n                order: 'asc',\\n                page: 1,\\n                size: 1000,\\n                connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n                table: 'dimension.catalog_pasal',\\n                database: 'divpropam',\\n                filters: [],\\n            };\\n\\n            if (filterType) {\\n                requestPayload.filters.push({\\n                    field: 'type',\\n                    operator: 'is',\\n                    table: 'dimension.catalog_pasal',\\n                    fieldType: 'text',\\n                    value: { is: filterType },\\n                });\\n            }\\n\\n            if (search && search.trim() !== '') {\\n                requestPayload.filters.push({\\n                    field: 'description',\\n                    operator: 'contains',\\n                    table: 'dimension.catalog_pasal',\\n                    fieldType: 'text',\\n                    value: search,\\n                });\\n            }\\n\\n            const response = await axios.post(\\n                '/api/v1/apps/data/management/get-all',\\n                requestPayload,\\n                {\\n                    headers: {\\n                        'Content-Type': 'application/json',\\n                        Authorization: `Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiN2ZjZGYwOTgyNDY0ZTIyNGRkZjc4YjE4NTE5ZjNjNTEiLCJleHBpcmUiOjE3NDA2MDcyOTEuMzY5NjE4NH0.7RhnmP89eVgwbCx4BfhalzzzCPeXjmBRP5mE17CGvQY`,\\n                    },\\n                },\\n            );\\n\\n            const items = response.data?.data || [];\\n\\n            const mappedOptions = items.map((item) => ({\\n                label: `${item.kode_pasal} - ${item.description?.substring(0, 50)}...`,\\n                value: item.article_id || item.id,\\n                kode_pasal: item.kode_pasal,\\n                pasal: item.pasal,\\n                ayat: item.ayat,\\n                sub_huruf: item.sub_huruf,\\n                description: item.description,\\n                type: item.type,\\n                fullLabel: `${item.kode_pasal} - ${item.description}`,\\n            }));\\n\\n            setOptions(mappedOptions);\\n        } catch (error) {\\n            console.error('Error fetching pasal data:', error);\\n            setOptions([]);\\n        } finally {\\n            setLoading(false);\\n        }\\n    };\\n\\n    useEffect(() => {\\n        fetchPasalData();\\n    }, [filterType]);\\n\\n    useEffect(() => {\\n        return () => {\\n            if (pasalSearchTimeout) {\\n                clearTimeout(pasalSearchTimeout);\\n            }\\n        };\\n    }, [pasalSearchTimeout]);\\n\\n    const handleInputChange = (inputValue) => {\\n        setInputValue(inputValue);\\n\\n        if (pasalSearchTimeout) {\\n            clearTimeout(pasalSearchTimeout);\\n        }\\n\\n        const timeout = setTimeout(() => {\\n            if (inputValue.length >= 1) {\\n                fetchPasalData(inputValue);\\n            } else if (inputValue === '') {\\n                fetchPasalData('');\\n            }\\n        }, 500);\\n\\n        setPasalSearchTimeout(timeout);\\n        return inputValue;\\n    };\\n\\n    const handleDetailClick = (e, data) => {\\n        e.stopPropagation();\\n        setSelectedDetail(data);\\n        setShowDetailModal(true);\\n    };\\n\\n    const formatOptionLabel = (data, { selectValue }) => {\\n        const isSelected = selectValue.some((v) => v.value === data.value);\\n\\n        return (\\n            <div\\n                style={{\\n                    display: 'flex',\\n                    justifyContent: 'space-between',\\n                    alignItems: 'center',\\n                    width: '100%',\\n                    padding: '8px 4px',\\n                }}\\n            >\\n                <div style={{ flex: 1 }}>\\n                    <div style={{ fontWeight: '600', fontSize: '0.9rem', color: '#333' }}>\\n                        {data.kode_pasal || 'Pasal'}\\n                    </div>\\n                    <span\\n                        style={{\\n                            fontSize: '0.75rem',\\n                            color: '#0d6efd',\\n                            cursor: 'pointer',\\n                            textDecoration: 'underline',\\n                        }}\\n                        onClick={(e) => handleDetailClick(e, data)}\\n                    >\\n                        Lihat detail\\n                    </span>\\n                </div>\\n                <div\\n                    style={{\\n                        width: '20px',\\n                        height: '20px',\\n                        border: isSelected ? 'none' : '2px solid #dee2e6',\\n                        borderRadius: '4px',\\n                        backgroundColor: isSelected ? '#0d6efd' : 'transparent',\\n                        display: 'flex',\\n                        alignItems: 'center',\\n                        justifyContent: 'center',\\n                        color: 'white',\\n                        fontSize: '14px',\\n                    }}\\n                >\\n                    {isSelected && (\\n                        <i className=\\\"ph ph-check\\\" style={{ fontWeight: 'bold' }}></i>\\n                    )}\\n                </div>\\n            </div>\\n        );\\n    };\\n\\n    const customStyles = {\\n        ...ReactSelectStyle,\\n        multiValue: () => ({}),\\n        multiValueLabel: () => ({}),\\n        multiValueRemove: () => ({}),\\n        valueContainer: (provided) => ({\\n            ...provided,\\n            padding: '0 8px',\\n            display: 'flex',\\n            flexWrap: 'wrap',\\n            alignItems: 'center',\\n        }),\\n        placeholder: (provided, state) => ({\\n            ...provided,\\n            display: state.hasValue ? 'none' : 'block',\\n            color: 'var(--black-300)',\\n            fontSize: '0.875rem',\\n        }),\\n        option: (provided, state) => ({\\n            ...provided,\\n            padding: '12px 16px',\\n            borderBottom: '1px solid #e9ecef',\\n            backgroundColor: state.isFocused ? 'var(--primary-25)' : 'white',\\n            color: 'var(--black)',\\n            whiteSpace: 'normal',\\n            wordBreak: 'break-word',\\n            ':last-child': { borderBottom: 'none' },\\n            ':active': { backgroundColor: 'var(--primary-50)' },\\n        }),\\n        menu: (provided) => ({\\n            ...provided,\\n            boxShadow: '0 4px 12px rgba(0,0,0,0.15)',\\n            borderRadius: '8px',\\n            zIndex: 9999,\\n            marginBottom: '8px',\\n        }),\\n        input: (provided) => ({\\n            ...provided,\\n            margin: 0,\\n            padding: 0,\\n            '& input': {\\n                height: '36px !important',\\n            },\\n        }),\\n        control: (provided) => ({\\n            ...provided,\\n            cursor: 'pointer',\\n        }),\\n        dropdownIndicator: (provided) => ({\\n            ...provided,\\n            cursor: 'pointer',\\n        }),\\n        singleValue: (provided, state) => ({\\n            ...provided,\\n            display: 'flex',\\n            alignItems: 'center',\\n            color: 'var(--black)',\\n            fontWeight: '500',\\n        }),\\n    };\\n\\n    return (\\n        <>\\n            <Form.Group className=\\\"w-100\\\">\\n                <TitleInput className=\\\"mb-3\\\">{label}</TitleInput>\\n\\n                <Controller\\n                    name={name}\\n                    control={control}\\n                    defaultValue={defaultValue}\\n                    render={({ field }) => {\\n                        const selectedItems = options.filter((opt) =>\\n                            field.value?.includes(opt.value),\\n                        );\\n\\n                        return (\\n                            <>\\n                                <Select\\n                                    {...field}\\n                                    isMulti\\n                                    options={options}\\n                                    styles={customStyles}\\n                                    placeholder={placeholder}\\n                                    isClearable={false}\\n                                    isLoading={loading}\\n                                    onInputChange={handleInputChange}\\n                                    inputValue={inputValue}\\n                                    value={selectedItems}\\n                                    onChange={(val) => {\\n                                        const newSelectedItems = val || [];\\n                                        field.onChange(newSelectedItems.map((v) => v.value) || []);\\n                                    }}\\n                                    formatOptionLabel={formatOptionLabel}\\n                                    getOptionLabel={(o) => o.fullLabel}\\n                                    getOptionValue={(o) => o.value}\\n                                    noOptionsMessage={() =>\\n                                        loading ? 'Loading...' : 'Tidak ada data'\\n                                    }\\n                                    closeMenuOnSelect={false}\\n                                    hideSelectedOptions={false}\\n                                    menuPlacement=\\\"top\\\"\\n                                    components={{\\n                                        MultiValue: () => null,\\n                                    }}\\n                                />\\n\\n                                {/* Badge jumlah item yang dipilih */}\\n                                {selectedItems.length > 0 && (\\n                                    <SelectedBadgeWrapper>\\n                                        <SelectedBadge>\\n                                            <i className=\\\"ph ph-check-circle\\\"></i>\\n                                            <span>{selectedItems.length} pasal dipilih</span>\\n                                        </SelectedBadge>\\n                                    </SelectedBadgeWrapper>\\n                                )}\\n\\n                                {/* Selected items dengan scroll */}\\n                                {selectedItems.length > 0 && (\\n                                    <SelectedItemsContainer>\\n                                        <SelectedItemsHeader>\\n                                            <span>Pasal yang dipilih ({selectedItems.length})</span>\\n                                        </SelectedItemsHeader>\\n                                        <SelectedItemsList>\\n                                            {selectedItems.map((item) => (\\n                                                <SelectedItemCard key={item.value}>\\n                                                    <SelectedItemContent>\\n                                                        <SelectedItemHeader>\\n                                                            <SelectedItemCode>\\n                                                                {item.kode_pasal}\\n                                                            </SelectedItemCode>\\n                                                            <DetailLink\\n                                                                onClick={(e) => handleDetailClick(e, item)}\\n                                                            >\\n                                                                Lihat detail\\n                                                            </DetailLink>\\n                                                        </SelectedItemHeader>\\n                                                        <RemoveButton\\n                                                            onClick={() => {\\n                                                                const newSelected = selectedItems.filter(\\n                                                                    (opt) => opt.value !== item.value,\\n                                                                );\\n                                                                field.onChange(newSelected.map((v) => v.value));\\n                                                            }}\\n                                                        >\\n                                                            <i className=\\\"ph ph-x\\\"></i>\\n                                                        </RemoveButton>\\n                                                    </SelectedItemContent>\\n                                                </SelectedItemCard>\\n                                            ))}\\n                                        </SelectedItemsList>\\n                                    </SelectedItemsContainer>\\n                                )}\\n                            </>\\n                        );\\n                    }}\\n                />\\n            </Form.Group>\\n\\n            <DetailModal\\n                show={showDetailModal}\\n                onHide={() => setShowDetailModal(false)}\\n                data={selectedDetail}\\n            />\\n        </>\\n    );\\n};\\n\\n// Modal Detail Pasal\\nconst DetailModal = ({ show, onHide, data }) => {\\n    if (!data) return null;\\n\\n    return (\\n        <StyledModal\\n            centered\\n            size=\\\"md\\\"\\n            show={show}\\n            onHide={onHide}\\n            enforceFocus={false}\\n        >\\n            <HeaderDetail closeButton>\\n                <TitleHeader>{data.kode_pasal}</TitleHeader>\\n            </HeaderDetail>\\n            <BodyDetail>\\n                <p style={{ color: '#5B5D63', lineHeight: '1.6' }}>\\n                    {data.description || 'Tidak ada deskripsi.'}\\n                </p>\\n            </BodyDetail>\\n        </StyledModal>\\n    );\\n};\\n\\nconst HeaderDetail = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n \\n`;\\n\\nconst WrapperPasal = styled.div`\\nbackground-color:var(--white);\\nborder:1px solid var(--black-100);\\npadding:0.85714rem;\\nborder-radius: 0.85714rem;\\n\\n`;\\n\\n// const SelectedItemCode = styled.div`\\n//   font-weight: 600;\\n//   font-size: 0.875rem;\\n//   color: var(--black);\\n// `;\\nconst BodyDetail = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n`;\\nconst SelectedBadgeWrapper = styled.div`\\n  margin-top: 0.5rem;\\n  width: 100%;\\n`;\\n\\nconst SelectedBadge = styled.div`\\n  display: inline-flex;\\n  align-items: center;\\n  gap: 0.5rem;\\n  padding: 0.5rem 1rem;\\n  background: var(--primary-50);\\n  border-radius: 2rem;\\n  color: var(--primary-700);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  border: 1px solid var(--primary-200);\\n  \\n  i {\\n    color: var(--primary-600);\\n    font-size: 1rem;\\n  }\\n`;\\n\\nconst SelectedItemsContainer = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  margin-top: 1rem;\\n  width: 100%;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  background: var(--white);\\n`;\\n\\nconst SelectedItemsHeader = styled.div`\\n  padding: 0.75rem 1rem;\\n  background: var(--black-25);\\n  border-bottom: 1px solid var(--black-100);\\n  border-radius: 0.5rem 0.5rem 0 0;\\n  font-weight: 600;\\n  font-size: 0.875rem;\\n  color: var(--black);\\n`;\\n\\nconst SelectedItemsList = styled.div`\\n  max-height: 200px;\\n  overflow-y: auto;\\n  padding: 0.5rem;\\n  \\n  &::-webkit-scrollbar {\\n    width: 6px;\\n  }\\n  \\n  &::-webkit-scrollbar-track {\\n    background: transparent;\\n  }\\n  \\n  &::-webkit-scrollbar-thumb {\\n    background-color: var(--black-300);\\n    border-radius: 4px;\\n  }\\n`;\\n\\nconst SelectedItemCard = styled.div`\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  background: var(--black-25);\\n  width: 100%;\\n  margin-bottom: 0.5rem;\\n  transition: all 0.2s ease;\\n  \\n  &:last-child {\\n    margin-bottom: 0;\\n  }\\n  \\n  &:hover {\\n    border-color: var(--primary-300);\\n    background: var(--primary-25);\\n  }\\n`;\\n\\nconst SelectedItemContent = styled.div`\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n  padding: 0.75rem 1rem;\\n  width: 100%;\\n`;\\n\\nconst SelectedItemHeader = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.25rem;\\n  flex: 1;\\n`;\\n\\nconst SelectedItemCode = styled.div`\\n  font-weight: 600;\\n  font-size: 0.875rem;\\n  color: var(--black);\\n`;\\n\\nconst DetailLink = styled.span`\\n  font-size: 0.75rem;\\n  color: var(--primary);\\n  cursor: pointer;\\n  text-decoration: underline;\\n  display: inline-block;\\n  \\n  &:hover {\\n    color: var(--primary-700);\\n  }\\n`;\\n\\nconst Small = styled.p`\\n  font-size: 0.933rem;\\n  line-height: 1.4rem; /* 150% */\\n  margin: 0;\\n`;\\n\\nconst RemoveButton = styled.button`\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  padding: 0.25rem;\\n  border: none;\\n  background: transparent;\\n  color: var(--black-400);\\n  cursor: pointer;\\n  border-radius: 0.25rem;\\n  \\n  &:hover {\\n    background: var(--black-50);\\n    color: var(--danger);\\n  }\\n  \\n  i {\\n    font-size: 1.125rem;\\n  }\\n`;\\n\",\"html\":\"import React from 'react';\\nconst dummyData = [\\n{\\nid: '-',\\nstatus: '-',\\nposisi: '-',\\nurgency_score_category: '-',\\ncreated_date: '-',\\ndetail_where: '-',\\ntype_of_violation: '-',\\ncategory: '-',\\npolda: '-',\\npolres: '-',\\npolsek: '-',\\n},\\n{\\nid: '-',\\nstatus: '-',\\nposisi: '-',\\nurgency_score_category: '-',\\ncreated_date: '-',\\ndetail_where: '-',\\ntype_of_violation: '-',\\ncategory: '-',\\npolda: '-',\\npolres: '-',\\npolsek: '-',\\n},\\n];\\n\\nexport default function MyCode({ widget, data, G }) {\\nconst activeData = data && data.length > 0 ? data : dummyData;\\nconst report = activeData[0];\\n\\nconst getStatusBadgeClass = (status) => {\\nconst s = status?.toLowerCase();\\nif (s.includes('bagyanduan')) return 'badge-bagyanduan';\\nif (s === 'Masuk') return 'badge-masuk';\\nif (s === 'selesai' || s === 'disetujui') return 'badge-selesai';\\nif (s === 'dikembalikan') return 'badge-dikembalikan';\\nif (s === 'verifikasi') return 'badge-verifikasi';\\nif (s === 'disposisi') return 'badge-disposisi';\\nif (s === 'penanganan') return 'badge-penanganan';\\nreturn '';\\n};\\n\\nconst getUrgencyClass = (urgency) => {\\nconst u = urgency?.toLowerCase();\\nif (u === 'tinggi') return 'badge-high';\\nif (u === 'sedang') return 'badge-medium';\\nif (u === 'rendah') return 'badge-low';\\nreturn '';\\n};\\n\\nconst formatText = (text) => {\\nreturn text\\n? text.charAt(0).toUpperCase() + text.slice(1).toLowerCase()\\n: '-';\\n};\\n\\nconst formatDateID = (dateString) => {\\nif (!dateString) return '-';\\nconst date = new Date(dateString);\\nif (isNaN(date)) return '-';\\nconst hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\nconst tanggal = date.getDate().toString().padStart(2, '0');\\nconst bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\nconst tahun = date.getFullYear().toString().slice(-2);\\nconst jam = date.getHours().toString().padStart(2, '0');\\nconst menit = date.getMinutes().toString().padStart(2, '0');\\nreturn `${hari}, ${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n};\\nreturn (\\n<div className=\\\"bg-white h-100\\\" style={{ border: '1px solid var(--black-100)', borderRadius: '0.8rem' }}>\\n  <div className=\\\"flex flex-col\\\" style={{ borderBottom: '1px solid var(--black-100)', padding: '16px' }}>\\n    <div className=\\\"widget-title\\\">{widget?.name || 'Detail Laporan'}</div>\\n  </div>\\n\\n  {/* Body */}\\n\\n  <div className=\\\"flex flex-col report-body-container\\\" style={{\\n          gap: '0.53333rem',\\n          padding: '16px',\\n          height: '85%',\\n        }}>\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Nomor Laporan</div>\\n      <div className=\\\"value\\\">{report?.id}</div>\\n    </div>\\n    {/* Status Utama */}\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Status</div>\\n      <div className={`badge ${getStatusBadgeClass(report?.status)} fs-12 fw-400`}>\\n        {formatText(report?.status)}\\n      </div>\\n    </div>\\n\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Posisi Laporan</div>\\n      <div className={`badge ${ report?.case_position ? getStatusBadgeClass(report.case_position) : 'badge-low' } fs-12 fw-400`}>\\n        {report?.case_position ? formatText(report.case_position) : '-'}\\n      </div>\\n    </div>\\n\\n    {/* Waktu Lapor */}\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Waktu Lapor</div>\\n      <div className=\\\"value\\\">\\n        {report?.created_date ? formatDateID(report.created_date) : '-'}\\n      </div>\\n    </div>\\n\\n    <div className=\\\"flex items-start\\\">\\n      <div className=\\\"information\\\">Lokasi Kejadian</div>\\n      <div className=\\\"value\\\" // style={{\\n            //   flex: 1,\\n            //   maxHeight: '4.2em',\\n            //   overflowY: 'auto',\\n            //   paddingRight: '8px',\\n            //   wordBreak: 'break-word',\\n            // }}>\\n        {report?.detail_where || '-'}\\n      </div>\\n    </div>\\n\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Kategori</div>\\n      <div className=\\\"value\\\">{formatText(report?.category)}</div>\\n    </div>\\n\\n    <div className=\\\"flex items-center\\\">\\n      <div className=\\\"information\\\">Sub Kategori</div>\\n      <div className=\\\"value\\\">{formatText(report?.category)}</div>\\n    </div>\\n\\n    <div className=\\\"flex items-start\\\">\\n      <div className=\\\"information\\\">Satuan</div>\\n      <div className=\\\"flex flex-col\\\">\\n        <div className=\\\"value\\\">{formatText(report?.polda)}</div>\\n        <div className=\\\"value\\\">{formatText(report?.polres)}</div>\\n        {/* <div className=\\\"value\\\">{formatText(report?.polsek)}</div> */}\\n      </div>\\n    </div>\\n  </div>\\n</div>\\n);\\n}\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":[\"latest_updated_at\",\"created_date\",\"updated_at\"],\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":true,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false},\"shareAPI\":\"\",\"useAsFilterConfig\":{\"enable\":false},\"pageState\":true,\"orderColumn\":false,\"manageOrderColumn\":{\"orderColumn\":{\"enable\":false}},\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false},\"x\":0,\"y\":301},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-03-04 11:28:39.993000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"filtersConfig\":[],\"h\":47,\"id\":\"3478e4a441eb264e8c19d839a5218d8a\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"251db3233e9bf2c8f818eff04b22c82f\",\"sourceId\":[\"a9f1664b82964894e86bfd8c3a0973b9\"],\"query\":null,\"name\":\"Form Penanganan\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Surat Perintah\",\"responsive\":{\"1024\":{\"x\":0,\"y\":206,\"w\":8,\"h\":47}},\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Form Penanganan\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"3478e4a441eb264e8c19d839a5218d8a\":{\"table\":\"aduan_masyarakat_v3.\\\"investigation_termination_letters\\\"\",\"field\":\"id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"251db3233e9bf2c8f818eff04b22c82f\",\"sourceId\":[\"a9f1664b82964894e86bfd8c3a0973b9\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[]}},\"showPagination\":false,\"customNoData\":true,\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"id\",\"alias\":\"report_id\",\"name\":\"id\",\"type\":\"string\"},{\"field\":\"type\",\"alias\":\"document_number\",\"name\":\"type\",\"type\":\"string\"},{\"field\":\"letter_number\",\"alias\":\"document_date\",\"name\":\"letter_number\",\"type\":\"string\"},{\"field\":\"consideration\",\"alias\":\"hearing_date\",\"name\":\"consideration\",\"type\":\"string\"},{\"field\":\"legal_basis\",\"alias\":\"hearing_place\",\"name\":\"legal_basis\",\"type\":\"string\"},{\"field\":\"assigned_to\",\"alias\":\"hearing_decision_number\",\"name\":\"assigned_to\",\"type\":\"string\"},{\"field\":\"assigned_action\",\"alias\":\"hearing_decision_date\",\"name\":\"assigned_action\",\"type\":\"string\"},{\"field\":\"decision\",\"alias\":\"offense_description\",\"name\":\"decision\",\"type\":\"string\"},{\"field\":\"notes\",\"alias\":\"notes\",\"name\":\"notes\",\"type\":\"string\"},{\"field\":\"issued_at_place\",\"alias\":\"issued_at_place\",\"name\":\"issued_at_place\",\"type\":\"string\"},{\"field\":\"issued_at_date\",\"alias\":\"issued_at_date\",\"name\":\"issued_at_date\",\"type\":\"date\"},{\"field\":\"official_position\",\"alias\":\"official_position\",\"name\":\"official_position\",\"type\":\"string\"},{\"field\":\"official_name\",\"alias\":\"official_name\",\"name\":\"official_name\",\"type\":\"string\"},{\"field\":\"official_rank\",\"alias\":\"official_rank\",\"name\":\"official_rank\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"date\"},{\"field\":\"rn\",\"alias\":\"rn\",\"name\":\"rn\",\"type\":\"number\"}]},\"customColorKey\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"id\",\"type\",\"letter_number\",\"consideration\",\"legal_basis\",\"assigned_to\",\"assigned_action\",\"decision\",\"notes\",\"issued_at_place\",\"issued_at_date\",\"official_position\",\"official_name\",\"official_rank\",\"updated_at\",\"rn\"],[\"251113000049-00001\",\"SP3\",\"SP.Henti.Lidik/251113000049-00001-A/XI/HUK.6.6/2025\",\"Pertimbangan untuk menghentikan penyelidikan\",[\"Pasal 1 Ayat 1\",\"Pasal 2 Ayat 2\"],\"Bripka Andi Setiawan , Unit Reskrim\",\"Teguran Lisan\",[\"Keputusan 1\",\"Keputusan 2\"],\"Catatan tambahan\",\"Polres Metro Kota Bekasi\",1746378000000,\"Kepala Unit Reskrim\",\"Bripka Andi Setiawan\",\"Bripka\",1776145993070,1],[\"260127000066-00001\",\"SP4\",\"SP4/260127000066-00001/I/2026/Divpropam\",\"Pertimbangan untuk menghentikan penyelidikan\",[\"Pasal 1 Ayat 1\",\"Pasal 2 Ayat 2\"],\"Bripka Andi Setiawan , Unit Reskrim\",\"Teguran Lisan\",[\"Keputusan 1\",\"Keputusan 2\"],null,\"Polres Metro Kota Bekasi\",1746378000000,\"Kepala Unit Reskrim\",\"Bripka Andi Setiawan\",\"Bripka\",1776145868638,1]],\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":\"\",\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"cache\":{\"status\":false},\"pageState\":true,\"orderColumn\":false,\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false,\"shareAPI\":\"\",\"useAsFilterConfig\":{\"enable\":false},\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect } from 'react';\\nimport { Modal, Form, Row, Col, Button } from 'react-bootstrap';\\nimport styled from 'styled-components';\\nimport Select from 'react-select';\\nimport { DatePicker } from 'antd';\\nimport dayjs from 'dayjs';\\nimport { dashboard } from '@store/app';\\n\\nexport default function ModalLidik({\\n  data,\\n  pageState,\\n  onSave,\\n  user,\\n  buttonText = 'Ubah Data',\\n}) {\\n  const [show, setShow] = useState(false);\\n  const [step, setStep] = useState(1);\\n  const [loading, setLoading] = useState(false);\\n  const dispatchNotification = (message, type) => {\\n    console.log(`${type}: ${message}`);\\n    alert(message);\\n  };\\n\\n  const pages = {\\n    informasiDasar: pageState?.['dad5b834f5a7a46b8a119d6e54211dbd'],\\n  };\\n\\n  const informasiDasar = pages?.informasiDasar?.data?.[0] || {};\\n  const police_function =\\n    informasiDasar?.police_function || informasiDasar?.fungsi_kepolisian || '';\\n\\n  const currentData = Array.isArray(data) ? data[0] : data;\\n\\n  const isSP4 = police_function === 'WABPROF';\\n  const title = isSP4 ? 'Terbit SP4' : 'Terbit SP3';\\n\\n  const [formData, setFormData] = useState({\\n    pertimbangan: '',\\n    dasar: [],\\n    diperintahkanKepada: [],\\n    diperintahkanUntuk: '',\\n    menetapkan: [],\\n    catatan: '',\\n    dikeluarkanDi: '',\\n    tanggal: '',\\n    nama: '',\\n    jabatan: null,\\n    pangkat: null,\\n  });\\n\\n  useEffect(() => {\\n    if (show && currentData) {\\n      setFormData({\\n        pertimbangan:\\n          currentData.consideration || currentData.pertimbangan || '',\\n        dasar: currentData.legal_basis || currentData.dasar || [],\\n        diperintahkanKepada: currentData.assigned_to\\n          ? [currentData.assigned_to]\\n          : currentData.diperintahkanKepada || [],\\n        diperintahkanUntuk:\\n          currentData.assigned_action || currentData.diperintahkanUntuk || '',\\n        menetapkan: currentData.decision || currentData.menetapkan || [],\\n        catatan: currentData.notes || currentData.catatan || '',\\n        dikeluarkanDi:\\n          currentData.issued_at_place || currentData.dikeluarkanDi || '',\\n        tanggal: currentData.issued_at_date\\n          ? dayjs(currentData.issued_at_date).format('YYYY-MM-DD')\\n          : currentData.tanggal || '',\\n        nama: currentData.official_name || currentData.nama || '',\\n        jabatan: currentData.official_position\\n          ? {\\n              label: currentData.official_position,\\n              value: currentData.official_position,\\n            }\\n          : null,\\n        pangkat: currentData.official_rank\\n          ? {\\n              label: currentData.official_rank,\\n              value: currentData.official_rank,\\n            }\\n          : null,\\n      });\\n    }\\n  }, [show, currentData]);\\n\\n  // const maxStep = isSP4 ? 2 : 3;\\n  const maxStep = 2;\\n\\n  // Handle array Dasar\\n  const handleDasarAdd = () => {\\n    setFormData((prev) => ({ ...prev, dasar: [...prev.dasar, ''] }));\\n  };\\n\\n  const handleDasarRemove = (index) => {\\n    setFormData((prev) => ({\\n      ...prev,\\n      dasar: prev.dasar.filter((_, i) => i !== index),\\n    }));\\n  };\\n\\n  const handleDasarChange = (index, value) => {\\n    setFormData((prev) => ({\\n      ...prev,\\n      dasar: prev.dasar.map((item, i) => (i === index ? value : item)),\\n    }));\\n  };\\n\\n  // Handle array Diperintahkan Kepada\\n  const handleArrayAdd = (field) => {\\n    setFormData((prev) => ({ ...prev, [field]: [...prev[field], ''] }));\\n  };\\n\\n  const handleArrayRemove = (field, index) => {\\n    setFormData((prev) => ({\\n      ...prev,\\n      [field]: prev[field].filter((_, i) => i !== index),\\n    }));\\n  };\\n\\n  const handleArrayChange = (field, index, value) => {\\n    setFormData((prev) => ({\\n      ...prev,\\n      [field]: prev[field].map((item, i) => (i === index ? value : item)),\\n    }));\\n  };\\n\\n  const handleMenetapkanAdd = () => {\\n    setFormData((prev) => ({ ...prev, menetapkan: [...prev.menetapkan, ''] }));\\n  };\\n\\n  const handleMenetapkanRemove = (index) => {\\n    setFormData((prev) => ({\\n      ...prev,\\n      menetapkan: prev.menetapkan.filter((_, i) => i !== index),\\n    }));\\n  };\\n\\n  const handleMenetapkanChange = (index, value) => {\\n    setFormData((prev) => ({\\n      ...prev,\\n      menetapkan: prev.menetapkan.map((item, i) =>\\n        i === index ? value : item,\\n      ),\\n    }));\\n  };\\n\\n  const handleNext = () => {\\n    if (step < maxStep) setStep(step + 1);\\n  };\\n\\n  const handleBack = () => {\\n    if (step > 1) setStep(step - 1);\\n  };\\n\\n  const handleSave = () => {\\n    const savedData = {\\n      consideration: formData.pertimbangan,\\n      legal_basis: formData.dasar,\\n      // assigned_to: formData.diperintahkanKepada.join(', '),\\n      assigned_action: formData.diperintahkanUntuk,\\n      decision: formData.menetapkan,\\n      notes: formData.catatan,\\n      issued_at_place: formData.dikeluarkanDi,\\n      issued_at_date: formData.tanggal\\n        ? dayjs(formData.tanggal).valueOf()\\n        : null,\\n      official_name: formData.nama,\\n      official_position: formData.jabatan?.value || formData.jabatan,\\n      official_rank: formData.pangkat?.value || formData.pangkat,\\n    };\\n    onSave?.(savedData);\\n    setShow(false);\\n    setStep(1);\\n  };\\n\\n  const handleClose = () => {\\n    setShow(false);\\n    setStep(1);\\n  };\\n\\n  const onSubmitSuratPerintah = async (formData) => {\\n    if (setLoading) setLoading(true);\\n    console.log('Starting submit surat perintah...');\\n\\n    const reportId = informasiDasar?.prepetrator_id;\\n\\n    if (!reportId) {\\n      alert('Error: ID laporan tidak ditemukan');\\n      setLoading(false);\\n      return;\\n    }\\n\\n    console.log('Form data:', formData);\\n    console.log('Report ID:', reportId);\\n\\n    try {\\n      // Tentukan type (SP3 atau SP4)\\n      const isSP4 = police_function === 'WABPROF';\\n      const type = isSP4 ? 'SP4' : 'SP3';\\n\\n      const params = {\\n        report_id: reportId,\\n        id: currentData?.id || reportId,\\n        type: type,\\n        consideration: formData.consideration || formData.pertimbangan || '',\\n        legal_basis: formData.legal_basis || formData.dasar || [],\\n        // assigned_to:\\n        //   formData.assigned_to ||\\n        //   formData.diperintahkanKepada?.join(', ') ||\\n        //   '',\\n        issued_at_place:\\n          formData.issued_at_place || formData.dikeluarkanDi || '',\\n        issued_at_date: formData.issued_at_date || formData.tanggal || '',\\n        official_position:\\n          formData.official_position ||\\n          formData.jabatan?.value ||\\n          formData.jabatan ||\\n          '',\\n        official_name: formData.official_name || formData.nama || '',\\n        official_rank:\\n          formData.official_rank ||\\n          formData.pangkat?.value ||\\n          formData.pangkat ||\\n          '',\\n      };\\n\\n      // Tambahan untuk SP3 atau SP4\\n\\n      // if (!isSP4) {\\n      //   params.assigned_action =\\n      //     formData.assigned_action || formData.diperintahkanUntuk || '';\\n      // } else {\\n      //   params.decision =\\n      //     formData.decision ||\\n      //     (formData.menetapkan ? formData.menetapkan.split(', ') : []);\\n      //   params.notes = formData.notes || formData.catatan || '';\\n      // }\\n\\n      if (!isSP4) {\\n        params.assigned_action =\\n          formData.assigned_action || formData.diperintahkanUntuk || '';\\n      } else {\\n        params.decision = formData.decision || formData.menetapkan || [];\\n        params.notes = formData.notes || formData.catatan || '';\\n      }\\n      console.log('Params yang dikirim:', params);\\n\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '6dc296b5128cfa192c1e14d178b62e02',\\n        params: params,\\n        body: {},\\n        headers: {},\\n        additionalPath: 'api/v2/report/rj/create',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id,\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id,\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n        metaData: {\\n          widgetId: '6f2cfeabd19ddafce8fc98f5c9d9ad63',\\n          widgetName: 'Widget Aksi',\\n          menuId: '01f63e60376afe827638ed614e1cea76',\\n          menuName: 'Detail Laporan',\\n          dashboardId: '1769155096865',\\n          dashboardName: 'Propam Aduan',\\n          userId: user?.id,\\n          domain: '',\\n        },\\n      };\\n\\n      console.log('Sending to gateway:', requestPayload);\\n\\n      const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!gatewayResponse.ok) {\\n        const errorText = await gatewayResponse.text();\\n        throw new Error(`Gateway error: ${errorText}`);\\n      }\\n\\n      const gatewayResult = await gatewayResponse.json();\\n      console.log('Gateway success:', gatewayResult);\\n\\n      dispatchNotification('Surat perintah berhasil disimpan!', 'success');\\n\\n      handleSave();\\n    } catch (err) {\\n      console.error('Error submit surat perintah:', err);\\n      dispatchNotification(`Error: ${err.message}`, 'danger');\\n    } finally {\\n      if (setLoading) setLoading(false);\\n    }\\n  };\\n\\n  return (\\n    <>\\n      <CardWrapper>\\n        <HeaderSection>\\n          <div className=\\\"widget-title\\\">{title}</div>\\n          <StyledButton onClick={() => setShow(true)} variant=\\\"secondary\\\">\\n            <i\\n              className=\\\"ph ph-pencil-simple-line\\\"\\n              style={{ fontSize: '1.2rem' }}\\n            ></i>\\n            {buttonText}\\n          </StyledButton>\\n        </HeaderSection>\\n\\n        <WrapperView>\\n          <TitleInput style={{ fontSize: '1rem' }}>\\n            Data Surat Perintah\\n          </TitleInput>\\n\\n          {/* Pertimbangan */}\\n          <SectionGroup>\\n            <TitleView>Pertimbangan</TitleView>\\n            <TextView>\\n              {currentData?.consideration || currentData?.pertimbangan || '-'}\\n            </TextView>\\n          </SectionGroup>\\n\\n          {/* Dasar */}\\n          <SectionGroup>\\n            <TitleView>Dasar</TitleView>\\n            {(currentData?.legal_basis || currentData?.dasar || []).length >\\n            0 ? (\\n              <ListNumbered>\\n                {(currentData?.legal_basis || currentData?.dasar || []).map(\\n                  (item, idx) => (\\n                    <li key={idx}>{item}</li>\\n                  ),\\n                )}\\n              </ListNumbered>\\n            ) : (\\n              <TextView>-</TextView>\\n            )}\\n          </SectionGroup>\\n\\n          {/* Diperintahkan Kepada */}\\n          <SectionGroup>\\n            <TitleView>Diperintahkan Kepada</TitleView>\\n            <TextView>\\n              ANGGOTA BIRO PROVOS DIVPROPAM POLRI YANG NAMA, PANGKAT, NRP DAN\\n              JABATAN TERSEBUT DALAM LAMPIRAN SURAT PERINTAH.\\n            </TextView>\\n          </SectionGroup>\\n\\n          {/* SP4: Menetapkan & Catatan */}\\n          {isSP4 && (\\n            <>\\n              <SectionGroup>\\n                <TitleView>Menetapkan</TitleView>\\n                {(currentData?.decision || currentData?.menetapkan || [])\\n                  .length > 0 ? (\\n                  <ListNumbered>\\n                    {(\\n                      currentData?.decision ||\\n                      currentData?.menetapkan ||\\n                      []\\n                    ).map((item, idx) => (\\n                      <li key={idx}>{item}</li>\\n                    ))}\\n                  </ListNumbered>\\n                ) : (\\n                  <TextView>-</TextView>\\n                )}\\n              </SectionGroup>\\n\\n              <SectionGroup>\\n                <TitleView>Catatan</TitleView>\\n                <TextView>\\n                  {currentData?.notes || currentData?.catatan || '-'}\\n                </TextView>\\n              </SectionGroup>\\n            </>\\n          )}\\n\\n          {/* SP3: Diperintahkan untuk */}\\n          {!isSP4 && (\\n            <SectionGroup>\\n              <TitleView>Diperintahkan untuk</TitleView>\\n              <TextView>\\n                {currentData?.assigned_action ||\\n                  currentData?.diperintahkanUntuk ||\\n                  '-'}\\n              </TextView>\\n            </SectionGroup>\\n          )}\\n\\n          <Divider />\\n\\n          {/* Kolom Tanda Tangan */}\\n          <TitleInput style={{ fontSize: '1rem', marginBottom: '0.5rem' }}>\\n            Kolom Tanda Tangan\\n          </TitleInput>\\n\\n          <SignatureContainer>\\n            <SignatureRow>\\n              <SignatureLabel>Dikeluarkan di</SignatureLabel>\\n              <SignatureValue>\\n                {' '}\\n                {currentData?.issued_at_place ||\\n                  currentData?.dikeluarkanDi ||\\n                  '-'}\\n              </SignatureValue>\\n            </SignatureRow>\\n            <SignatureRow>\\n              <SignatureLabel>Tanggal</SignatureLabel>\\n              <SignatureValue>\\n                {' '}\\n                {currentData?.issued_at_date\\n                  ? dayjs(currentData.issued_at_date).format('DD MMMM YYYY')\\n                  : currentData?.tanggal || '-'}\\n              </SignatureValue>\\n            </SignatureRow>\\n            <SignatureRow>\\n              <SignatureLabel>Nama</SignatureLabel>\\n              <SignatureValue>\\n                {currentData?.official_name || currentData?.nama || '-'}\\n              </SignatureValue>\\n            </SignatureRow>\\n            <SignatureRow>\\n              <SignatureLabel>Jabatan</SignatureLabel>\\n              <SignatureValue>\\n                {' '}\\n                {currentData?.official_position ||\\n                  currentData?.jabatan?.label ||\\n                  currentData?.jabatan ||\\n                  '-'}\\n              </SignatureValue>\\n            </SignatureRow>\\n            <SignatureRow>\\n              <SignatureLabel>Pangkat</SignatureLabel>\\n              <SignatureValue>\\n                {' '}\\n                {currentData?.official_rank ||\\n                  currentData?.pangkat?.label ||\\n                  currentData?.pangkat ||\\n                  '-'}\\n              </SignatureValue>\\n            </SignatureRow>\\n          </SignatureContainer>\\n        </WrapperView>\\n      </CardWrapper>\\n      <StyledModal centered size=\\\"lg\\\" show={show} onHide={handleClose}>\\n        <ModalHeader closeButton>\\n          <WrappIcon>\\n            <i\\n              className=\\\"ph-duotone ph-clipboard-text\\\"\\n              style={{ fontSize: '1.6rem', color: 'var(--primary)' }}\\n            ></i>\\n          </WrappIcon>\\n          <div className=\\\"d-flex flex-column gap-1\\\">\\n            <TitleHeader>{isSP4 ? 'SP4' : 'SP3'}</TitleHeader>\\n            <DescHeader>Sesuaikan isi laporan</DescHeader>\\n          </div>\\n        </ModalHeader>\\n\\n        <ModalBody>\\n          <TitleInput\\n            className=\\\"pb-2\\\"\\n            style={{ color: 'var(--black-500)', fontSize: '1.14286rem' }}\\n          >\\n            {step === 1 && 'Data Surat Perintah'}\\n            {step === 2 && 'Kolom Tanda Tangan'}\\n          </TitleInput>\\n\\n          {/* STEP 1 */}\\n          {step === 1 && (\\n            <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n              <Form.Group className=\\\"w-100\\\">\\n                <TitleInput className=\\\"mb-3\\\">Pertimbangan</TitleInput>\\n                <StyledTextarea\\n                  as=\\\"textarea\\\"\\n                  rows={3}\\n                  placeholder=\\\"Pertimbangan\\\"\\n                  value={formData.pertimbangan}\\n                  onChange={(e) =>\\n                    setFormData((prev) => ({\\n                      ...prev,\\n                      pertimbangan: e.target.value,\\n                    }))\\n                  }\\n                />\\n              </Form.Group>\\n\\n              <Form.Group className=\\\"w-100\\\">\\n                <div className=\\\"d-flex justify-content-between align-items-center mb-3\\\">\\n                  <TitleInput>Dasar</TitleInput>\\n                  <ButtonTambah type=\\\"button\\\" onClick={handleDasarAdd}>\\n                    + Tambah\\n                  </ButtonTambah>\\n                </div>\\n                {(formData.dasar || []).length > 0 ? (\\n                  <div\\n                    style={{\\n                      display: 'flex',\\n                      flexDirection: 'column',\\n                      gap: '0.75rem',\\n                    }}\\n                  >\\n                    {(formData.dasar || []).map((item, index) => (\\n                      <ListItem key={index}>\\n                        <StyledInput\\n                          type=\\\"text\\\"\\n                          placeholder={`Dasar ${index + 1}`}\\n                          value={item}\\n                          onChange={(e) =>\\n                            handleDasarChange(index, e.target.value)\\n                          }\\n                        />\\n                        <HapusButton\\n                          type=\\\"button\\\"\\n                          onClick={() => handleDasarRemove(index)}\\n                        >\\n                          <i className=\\\"ph ph-x\\\"></i>\\n                        </HapusButton>\\n                      </ListItem>\\n                    ))}\\n                  </div>\\n                ) : (\\n                  <EmptyState>\\n                    <i className=\\\"ph ph-file-text\\\"></i>\\n                    <p>Belum ada ada. Klik \\\"Tambah\\\" untuk menambahkan.</p>\\n                  </EmptyState>\\n                )}\\n              </Form.Group>\\n\\n              <Form.Group className=\\\"w-100\\\">\\n                <div className=\\\"d-flex justify-content-between align-items-center mb-3\\\">\\n                  <TitleInput>Diperintahkan Kepada</TitleInput>\\n                </div>\\n                <StyledPerintah>\\n                  ANGGOTA BIRO PROVOS DIVPROPAM POLRI YANG NAMA, PANGKAT, NRP\\n                  DAN JABATAN TERSEBUT DALAM LAMPIRAN SURAT PERINTAH.\\n                </StyledPerintah>\\n              </Form.Group>\\n\\n              {isSP4 ? (\\n                <>\\n                  <hr\\n                    style={{\\n                      borderColor: 'var(--black-100)',\\n                      margin: '0.5rem 0',\\n                    }}\\n                  />\\n                  <Form.Group className=\\\"w-100\\\">\\n                    <div className=\\\"d-flex justify-content-between align-items-center mb-3\\\">\\n                      <TitleInput>Menetapkan</TitleInput>\\n                      <ButtonTambah type=\\\"button\\\" onClick={handleMenetapkanAdd}>\\n                        + Tambah\\n                      </ButtonTambah>\\n                    </div>\\n                    {(formData.menetapkan || []).length > 0 ? (\\n                      <div\\n                        style={{\\n                          display: 'flex',\\n                          flexDirection: 'column',\\n                          gap: '0.75rem',\\n                        }}\\n                      >\\n                        {(formData.menetapkan || []).map((item, index) => (\\n                          <ListItem key={index}>\\n                            <StyledInput\\n                              type=\\\"text\\\"\\n                              placeholder={`Menetapkan ${index + 1}`}\\n                              value={item}\\n                              onChange={(e) =>\\n                                handleMenetapkanChange(index, e.target.value)\\n                              }\\n                            />\\n                            <HapusButton\\n                              type=\\\"button\\\"\\n                              onClick={() => handleMenetapkanRemove(index)}\\n                            >\\n                              <i className=\\\"ph ph-x\\\"></i>\\n                            </HapusButton>\\n                          </ListItem>\\n                        ))}\\n                      </div>\\n                    ) : (\\n                      <EmptyState>\\n                        <i className=\\\"ph ph-file-text\\\"></i>\\n                        <p>Belum ada data. Klik \\\"Tambah\\\" untuk menambahkan.</p>\\n                      </EmptyState>\\n                    )}\\n                  </Form.Group>\\n                  <Form.Group className=\\\"w-100\\\">\\n                    <TitleInput className=\\\"mb-3\\\">Catatan</TitleInput>\\n                    <StyledTextarea\\n                      as=\\\"textarea\\\"\\n                      rows={2}\\n                      placeholder=\\\"Catatan\\\"\\n                      value={formData.catatan}\\n                      onChange={(e) =>\\n                        setFormData((prev) => ({\\n                          ...prev,\\n                          catatan: e.target.value,\\n                        }))\\n                      }\\n                    />\\n                  </Form.Group>\\n                </>\\n              ) : (\\n                <Form.Group className=\\\"w-100\\\">\\n                  <TitleInput className=\\\"mb-3\\\">Diperintahkan untuk</TitleInput>\\n                  <StyledTextarea\\n                    as=\\\"textarea\\\"\\n                    rows={4}\\n                    placeholder=\\\"Diperintahkan untuk...\\\"\\n                    value={formData.diperintahkanUntuk}\\n                    onChange={(e) =>\\n                      setFormData((prev) => ({\\n                        ...prev,\\n                        diperintahkanUntuk: e.target.value,\\n                      }))\\n                    }\\n                  />\\n                </Form.Group>\\n              )}\\n            </div>\\n          )}\\n\\n          {/* STEP 2 */}\\n          {step === 2 && (\\n            <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n              <Row className=\\\"g-3\\\">\\n                <Col md={6}>\\n                  <Form.Group>\\n                    <TitleInput className=\\\"mb-3\\\">Dikeluarkan di</TitleInput>\\n                    <StyledInput\\n                      type=\\\"text\\\"\\n                      placeholder=\\\"Dikeluarkan di\\\"\\n                      value={formData.dikeluarkanDi}\\n                      onChange={(e) =>\\n                        setFormData((prev) => ({\\n                          ...prev,\\n                          dikeluarkanDi: e.target.value,\\n                        }))\\n                      }\\n                    />\\n                  </Form.Group>\\n                </Col>\\n                <Col md={6}>\\n                  <Form.Group>\\n                    <TitleInput className=\\\"mb-3\\\">Tanggal</TitleInput>\\n                    <NativeDateWrapper>\\n                      <DateIconAddon>\\n                        <i className=\\\"ph ph-calendar-blank\\\"></i>\\n                      </DateIconAddon>\\n                      <StyledDatePicker\\n                        format=\\\"YYYY-MM-DD\\\"\\n                        placeholder=\\\"Pilih tanggal\\\"\\n                        value={\\n                          formData.tanggal ? dayjs(formData.tanggal) : null\\n                        }\\n                        onChange={(date) =>\\n                          setFormData((prev) => ({\\n                            ...prev,\\n                            tanggal: date ? date.format('YYYY-MM-DD') : '',\\n                          }))\\n                        }\\n                        suffixIcon={null}\\n                        allowClear={false}\\n                      />\\n                    </NativeDateWrapper>\\n                  </Form.Group>\\n                </Col>\\n              </Row>\\n              <hr\\n                style={{ borderColor: 'var(--black-100)', margin: '0.5rem 0' }}\\n              />\\n              <Form.Group className=\\\"w-100\\\">\\n                <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n                <StyledInput\\n                  type=\\\"text\\\"\\n                  placeholder=\\\"Nama\\\"\\n                  value={formData.nama}\\n                  onChange={(e) =>\\n                    setFormData((prev) => ({ ...prev, nama: e.target.value }))\\n                  }\\n                />\\n              </Form.Group>\\n              <hr\\n                style={{ borderColor: 'var(--black-100)', margin: '0.5rem 0' }}\\n              />\\n              <Row className=\\\"g-3\\\">\\n                <Col md={6}>\\n                  <Form.Group className=\\\"w-100\\\">\\n                    <TitleInput className=\\\"mb-3\\\">Jabatan</TitleInput>\\n                    <StyledInput\\n                      type=\\\"text\\\"\\n                      placeholder=\\\"Jabatan\\\"\\n                      value={formData.jabatan?.label || formData.jabatan || ''}\\n                      onChange={(e) =>\\n                        setFormData((prev) => ({\\n                          ...prev,\\n                          jabatan: e.target.value,\\n                        }))\\n                      }\\n                    />\\n                  </Form.Group>\\n                </Col>\\n                <Col md={6}>\\n                  <Form.Group className=\\\"w-100\\\">\\n                    <TitleInput className=\\\"mb-3\\\">Pilih Pangkat</TitleInput>\\n                    <Select\\n                      options={PangkatOptions}\\n                      styles={ReactSelectStyle}\\n                      placeholder=\\\"Pilih Pangkat\\\"\\n                      value={\\n                        PangkatOptions.find(\\n                          (o) => o.value === formData.pangkat?.value,\\n                        ) || formData.pangkat\\n                      }\\n                      onChange={(val) =>\\n                        setFormData((prev) => ({ ...prev, pangkat: val }))\\n                      }\\n                    />\\n                  </Form.Group>\\n                </Col>\\n              </Row>\\n            </div>\\n          )}\\n        </ModalBody>\\n\\n        <ModalFooter>\\n          <ProgressWrapper>\\n            <ProgressBase>\\n              <ProgressFill step={step} maxStep={maxStep} />\\n            </ProgressBase>\\n          </ProgressWrapper>\\n          <div className=\\\"d-flex gap-3\\\">\\n            {step > 1 && (\\n              <Button variant=\\\"outline-secondary\\\" onClick={handleBack}>\\n                Kembali\\n              </Button>\\n            )}\\n            {step < maxStep ? (\\n              <Button variant=\\\"primary\\\" onClick={handleNext}>\\n                Selanjutnya\\n              </Button>\\n            ) : (\\n              <Button\\n                variant=\\\"primary\\\"\\n                onClick={() => onSubmitSuratPerintah(formData)}\\n              >\\n                Simpan\\n              </Button>\\n            )}\\n          </div>\\n        </ModalFooter>\\n      </StyledModal>\\n    </>\\n  );\\n}\\n\\n// ============ STYLED COMPONENTS ============\\nconst CardWrapper = styled.div`\\n  background: var(--white);\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.8rem;\\n  display: flex;\\n  flex-direction: column;\\n  height: 100%;\\n  max-height:41rem;\\n  overflow-y:auto;\\n`;\\n\\nconst StyledPerintah = styled.div`\\n  background: var(--black-25);\\n  border-radius: 10px;\\nborder: 1px solid var(--black-100);\\npadding:11px 16px;\\nfont-size:1rem;\\ncolor:var(--black-500);\\n\\n`;\\n\\nconst HeaderSection = styled.div`\\n  padding: 12px 16px;;\\n  border-bottom: 1px solid var(--black-100);\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n\\n`;\\n\\nconst StyledButton = styled(Button)`\\n  display: flex;\\n  padding: 6px 12px 6px 8px;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 8px;\\n  border-radius: 8px;\\n  border: 1px solid var(--black-100);\\n  background: var(--white);\\n`;\\n\\nconst WrapperView = styled.div`\\n  padding: 0.85714rem 1.14286rem 1.14286rem 1.14286rem;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 1rem;\\n`;\\n\\nconst TitleView = styled.div`\\n  font-size: 1rem;\\n  color: var(--black-500);\\n  font-weight: 400;\\n  margin-bottom: 0.25rem;\\n`;\\n\\nconst TextView = styled.div`\\n  font-size: 1rem;\\n  color: var(--black);\\n  font-weight: 400;\\n  line-height: 1.5;\\n  white-space: pre-wrap;\\n  word-break: break-word;\\n`;\\n\\nconst SectionGroup = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.25rem;\\n`;\\nconst ListNumbered = styled.ol`\\n  margin: 0;\\n  padding-left: 0; \\n  font-size: 1rem;\\n  color: var(--black);\\n  list-style: none !important;\\n  counter-reset: item;\\n  \\n  li { \\n    counter-increment: item;\\n    margin-bottom: 0.25rem;\\n    display: flex;\\n    align-items: flex-start;\\n    gap: 0.5rem;\\n    padding-left:0.4rem;\\n  }\\n  \\n  li:before {\\n    content: counter(item) \\\".\\\";\\n    font-weight: normal;\\n    flex-shrink: 0;\\n    min-width: 0.8rem;\\n  }\\n`;\\nconst Divider = styled.hr`\\n  border-color: var(--black-100);\\n  margin: 0.5rem 0;\\n`;\\n\\nconst StyledModal = styled(Modal)`\\n  .modal-dialog {\\n    max-width: 670px;\\n  }\\n\\n  .modal-body {\\n    max-height: 60vh;\\n    overflow-y: auto;\\n  }\\n`;\\n\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst ModalBody = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n`;\\n\\nconst ModalFooter = styled(Modal.Footer)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem 1.06667rem 1.33333rem;\\n  justify-content: space-between;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-weight: 600;\\n  margin: 0;\\n`;\\n\\nconst DescHeader = styled.p`\\n  color: var(--black-400);\\n  font-size: 0.93333rem;\\n  margin: 0;\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\\nconst TitleInput = styled.div`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;\\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  border: 1px solid #e1e2e5;\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 0.875rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  font-family: Inter;\\n  box-shadow: none;\\n  background-color:var(--white);\\n\\n  &:focus {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\n\\nconst ListItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  gap: 0.5rem;\\n  width: 100%;\\n`;\\n\\nconst HapusButton = styled.button`\\n  background: none;\\n  border: none;\\n  color: var(--danger);\\n  cursor: pointer;\\n  padding: 0.5rem;\\n  border-radius: 0.375rem;\\n\\n  &:hover {\\n    background: var(--danger-50);\\n  }\\n\\n  i {\\n    font-size: 1.125rem;\\n  }\\n`;\\n\\nconst ButtonTambah = styled.button`\\n  background: none;\\n  border: none;\\n  color: var(--primary);\\n  font-weight: 600;\\n  cursor: pointer;\\n  font-size: 0.875rem;\\n\\n  &:hover {\\n    text-decoration: underline;\\n  }\\n`;\\n\\nconst EmptyState = styled.div`\\n  padding: 1.5rem;\\n  text-align: center;\\n  color: var(--black-400);\\n  background-color: var(--black-25);\\n  border-radius: 0.5rem;\\n  border: 1px dashed var(--black-100);\\n\\n  i {\\n    font-size: 2rem;\\n    margin-bottom: 0.5rem;\\n  }\\n\\n  p {\\n    margin: 0;\\n    font-size: 0.875rem;\\n  }\\n`;\\n\\nconst ProgressWrapper = styled.div`\\n  flex: 1;\\n  display: flex;\\n  align-items: center;\\n`;\\n\\nconst ProgressBase = styled.div`\\n  width: 100%;\\n  max-width: 5.71429rem;\\n  height: 0.57143rem;\\n  background-color: var(--primary-50);\\n  border-radius: 1.71429rem;\\n  position: relative;\\n  overflow: hidden;\\n`;\\n\\nconst ProgressFill = styled.div`\\n  position: absolute;\\n  top: 0;\\n  left: 0;\\n  height: 100%;\\n  width: ${({ step, maxStep }) => {\\n    if (maxStep === 2) {\\n      return step === 1 ? '50%' : step === 2 ? '100%' : '0%';\\n    }\\n\\n    return step === 1 ? '33%' : step === 2 ? '66%' : step === 3 ? '100%' : '0%';\\n  }};\\n  background-color: var(--primary-500);\\n  transition: width 0.4s ease;\\n  border-radius: 1.71429rem;\\n`;\\n\\nconst NativeDateWrapper = styled.div`\\n  display: flex;\\n  align-items: stretch;\\n  width: 100%;\\n  border: 1px solid #e1e2e5;\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  background-color: white;\\n\\n  &:focus-within {\\n    border-color: #0d6efd;\\n    box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.25);\\n  }\\n`;\\n\\nconst DateIconAddon = styled.div`\\n  background-color: var(--black-25);\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  padding: 0 12px;\\n  border-right: 1px solid #e1e2e5;\\n  color: #64748b;\\n`;\\n\\nconst StyledDatePicker = styled(DatePicker)`\\n  flex: 1;\\n  border: none !important;\\n\\n  &.ant-picker {\\n    padding: 0;\\n    height: 36px;\\n  }\\n\\n  .ant-picker-input input {\\n    font-size: 0.875rem;\\n    padding: 0.75rem 1rem;\\n    height: 36px;\\n  }\\n\\n  .ant-picker-suffix,\\n  .ant-picker-clear {\\n    display: none;\\n  }\\n`;\\n\\nconst SignatureContainer = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n`;\\n\\nconst SignatureRow = styled.div`\\n  display: flex;\\n  align-items: center;\\n`;\\n\\nconst SignatureLabel = styled.div`\\n  width: 20rem;\\n  color: var(--black-500);\\n  font-size: 1rem;\\n`;\\n\\nconst SignatureValue = styled.div`\\n  color: var(--black);\\n  font-size: 1rem;\\n  font-weight: 400;\\n`;\\nconst ReactSelectStyle = {\\n  control: (styles) => ({\\n    ...styles,\\n    backgroundColor: 'var(--white)',\\n    borderColor: 'var(--black-150)',\\n    padding: '0rem 0.8rem',\\n    borderRadius: '0.5rem',\\n    minHeight: '1.85rem',\\n  }),\\n  input: (styles) => ({ ...styles, color: 'var(--black-800)', margin: '0' }),\\n  placeholder: (styles) => ({\\n    ...styles,\\n    color: 'var(--black-300)',\\n    fontSize: '0.875rem',\\n  }),\\n  valueContainer: (styles) => ({ ...styles, padding: '0' }),\\n  indicatorSeparator: (styles) => ({\\n    ...styles,\\n    backgroundColor: 'transparent',\\n  }),\\n  singleValue: (styles) => ({\\n    ...styles,\\n    color: 'var(--black)',\\n    fontWeight: '500',\\n    fontSize: '0.875rem',\\n  }),\\n};\\n\\nconst PangkatOptions = [\\n  { label: 'JENDERAL POL', value: 'JENDERAL POL' },\\n  { label: 'KOMJEN POL', value: 'KOMJEN POL' },\\n  { label: 'IRJEN POL', value: 'IRJEN POL' },\\n  { label: 'BRIGJEN POL', value: 'BRIGJEN POL' },\\n  { label: 'KOMBES POL', value: 'KOMBES POL' },\\n  { label: 'AKBP', value: 'AKBP' },\\n  { label: 'KOMPOL', value: 'KOMPOL' },\\n  { label: 'AKP', value: 'AKP' },\\n  { label: 'IPTU', value: 'IPTU' },\\n  { label: 'IPDA', value: 'IPDA' },\\n  { label: 'AIPTU', value: 'AIPTU' },\\n  { label: 'AIPDA', value: 'AIPDA' },\\n  { label: 'BRIPKA', value: 'BRIPKA' },\\n  { label: 'BRIGADIR', value: 'BRIGADIR' },\\n  { label: 'BRIPTU', value: 'BRIPTU' },\\n  { label: 'BRIPDA', value: 'BRIPDA' },\\n];\\n\",\"html\":\"\"}},\"x\":0,\"y\":206,\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\"},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-27 13:39:14.528000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":29,\"id\":\"addbe2829134af0565c9a57e1feea20c\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"edab634693da7219365ea1ed19d4f103\",\"sourceId\":[\"1b383833ce685533ace0f46a61e51e96\"],\"query\":null,\"name\":\"Bukti Pendukung\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Tim Penanganan\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":177,\"w\":8,\"h\":29}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Bukti Pendukung\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"addbe2829134af0565c9a57e1feea20c\":{\"table\":\"aduan_masyarakat_v3.\\\"handling_report\\\"\",\"field\":\"report_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"edab634693da7219365ea1ed19d4f103\",\"sourceId\":[\"1b383833ce685533ace0f46a61e51e96\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"url\",\"alias\":\"url\",\"name\":\"url\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"number\"},{\"field\":\"size\",\"alias\":\"size\",\"name\":\"size\",\"type\":\"string\"},{\"field\":\"detail\",\"alias\":\"detail\",\"name\":\"detail\",\"type\":\"string\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false}},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"report_id\",\"url\",\"updated_at\",\"size\",\"detail\"],[\"2025050511\",\"s3://example22.com/attachment.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"s3://example.com/attachment.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment1234.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment5.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment4.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment3.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment2.jpg\",null,\"2MB\",\"JPG\"],[\"2025050511\",\"s3://example22.com/attachment.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"s3://example.com/attachment.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment1234.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment5.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment4.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment3.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment2.jpg\",1759330425473,\"2MB\",\"JPG\"],[\"2025050511\",\"s3://example22.com/attachment.jpg\",1738547625473,\"2MB\",\"JPG\"],[\"2025050511\",\"s3://example.com/attachment.jpg\",1738547625473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment.jpg\",1738547625473,\"2MB\",\"JPG\"],[\"2025050511\",\"https://example.com/attachment1234.jpg\",1738547625473,\"2MB\",\"JPG\"]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useCallback } from 'react';\\nimport styled from 'styled-components';\\nimport { Card, Modal, Button, Form } from 'react-bootstrap';\\nimport { useForm } from 'react-hook-form';\\nimport { dashboard } from '@store/app';\\nimport axios from 'axios';\\n\\nif (typeof Image !== 'undefined') {\\n  const originalSrc = Object.getOwnPropertyDescriptor(Image.prototype, 'src');\\n  Object.defineProperty(Image.prototype, 'src', {\\n    set(value) {\\n      if (value && value.includes('default-flag.svg')) {\\n        console.warn('Blocked request to:', value);\\n        return;\\n      }\\n      if (originalSrc && originalSrc.set) {\\n        originalSrc.set.call(this, value);\\n      }\\n    },\\n  });\\n}\\n\\nexport default function LaporanCard({ widget, data, pageState }) {\\n  const [showModal, setShowModal] = useState(false);\\n  const [showUploadModal, setShowUploadModal] = useState(false);\\n  const [selectedImage, setSelectedImage] = useState('');\\n  const [selectedItem, setSelectedItem] = useState(null);\\n  const [loading, setLoading] = useState(false);\\n  const [isDragging, setIsDragging] = useState(false);\\n  const [files, setFiles] = useState([]);\\n  const [authUser, setAuthUser] = useState(null);\\n  const [uploadedFiles, setUploadedFiles] = useState([]);\\n  const [isProcessing, setIsProcessing] = useState(false);\\n  const [failedImages, setFailedImages] = useState(new Set());\\n\\n  const dataArray = Array.isArray(data) ? data : [];\\n  const currentItems = dataArray;\\n\\n  const pages = {\\n    informasiDasar: pageState?.['dad5b834f5a7a46b8a119d6e54211dbd'],\\n  };\\n\\n  const informasiDasarData = pages.informasiDasar?.data?.[0] || {};\\n\\n  // === Ambil data user dari localStorage ===\\n  useEffect(() => {\\n    const storedUser = localStorage.getItem('me');\\n    if (storedUser) {\\n      try {\\n        const userData = JSON.parse(storedUser);\\n        setAuthUser(userData);\\n      } catch (error) {\\n        console.error('Error parsing user data from localStorage:', error);\\n      }\\n    }\\n  }, []);\\n\\n  // === Convert URL S3 ===\\n   const convertS3Url = (url) => {\\n    if (!url) return '';\\n\\n    if (url.startsWith('s3://fusion/agent/')) {\\n      const path = url.replace('s3://fusion/agent/', '');\\n      const encodedPath = path\\n        .split('/')\\n        .map((part) => encodeURIComponent(part))\\n        .join('/');\\n      if (\\n        encodedPath.includes('/cdn/media') ||\\n        encodedPath.startsWith('cdn/media')\\n      ) {\\n        return `https://gajamada-propam.polri.go.id/fusion/agent/${encodedPath}`;\\n      } else {\\n        return `https://gajamada-propam.polri.go.id/cdn/media/fusion/agent/${encodedPath}`;\\n      }\\n    }\\n\\n    // Handle s3:// lainnya\\n    if (url.startsWith('s3://')) {\\n      return url.replace('s3://', 'https://asura-s3.stellardata.ai/');\\n    }\\n\\n    if (url.startsWith('http://192.168.180.99:8000')) {\\n      return url.replace(\\n        'http://192.168.180.99:8000',\\n        'https://asura-s3.ebdesk.com',\\n      );\\n    }\\n\\n    if (url.startsWith('https://yanduan-s3.polri.go.id:9000')) {\\n      const path = url.replace('https://yanduan-s3.polri.go.id:9000', '');\\n\\n      if (path.includes('/cdn/media')) {\\n        return `https://gajamada-propam.polri.go.id${path}`;\\n      } else {\\n        return `https://gajamada-propam.polri.go.id/cdn/media${path}`;\\n      }\\n    }\\n\\n    return url;\\n  };\\n\\n  const filterValidFiles = (files) => {\\n    const allowedExtensions = [\\n      '.pdf',\\n      '.jpg',\\n      '.jpeg',\\n      '.png',\\n      '.doc',\\n      '.docx',\\n      '.mp4',\\n      '.mp3',\\n    ];\\n    const MAX_FILE_SIZE = 10 * 1024 * 1024;\\n    const validFiles = [];\\n    const invalidFiles = [];\\n\\n    files.forEach((file) => {\\n      const fileName = file.name.toLowerCase();\\n      const isValidExt = allowedExtensions.some((ext) =>\\n        fileName.endsWith(ext),\\n      );\\n      const isValidSize = file.size <= MAX_FILE_SIZE;\\n\\n      if (isValidExt && isValidSize) {\\n        validFiles.push(file);\\n      } else {\\n        if (!isValidExt) {\\n          invalidFiles.push(`${file.name} (format tidak diizinkan)`);\\n        } else if (!isValidSize) {\\n          invalidFiles.push(`${file.name} (melebihi 10MB)`);\\n        }\\n      }\\n    });\\n\\n    if (invalidFiles.length > 0) {\\n      alert(\\n        `File ditolak:\\\\n${invalidFiles.join('\\\\n')}\\\\n\\\\nFormat yang diizinkan: ${allowedExtensions.join(', ')}`,\\n      );\\n    }\\n\\n    return validFiles;\\n  };\\n\\nconst handleDownloadFile = (item) => {\\n    try {\\n      const fileUrl = convertS3Url(item.url);\\n\\n      if (!fileUrl) {\\n        console.error('URL file tidak valid');\\n        return;\\n      }\\n\\n      // Ambil ekstensi\\n      let fileExtension = item.file_type || '';\\n      if (!fileExtension) {\\n        const ext = fileUrl.split('.').pop()?.toLowerCase() || 'pdf';\\n        fileExtension = ext.split('?')[0];\\n      }\\n\\n      // Bersihkan nama file\\n      let fileName = item.file_name || 'document';\\n      fileName = fileName.replace(/[<>:\\\"/\\\\\\\\|?*]/g, '');\\n      fileName = fileName.replace(/\\\\.[^/.]+$/, '');\\n\\n      console.log('Downloading:', `${fileName}.${fileExtension}`);\\n\\n      // Download dengan link biasa\\n      const link = document.createElement('a');\\n      link.href = fileUrl;\\n      link.download = `${fileName}.${fileExtension}`;\\n      link.target = '_blank';\\n      document.body.appendChild(link);\\n      link.click();\\n      document.body.removeChild(link);\\n    } catch (error) {\\n      console.error('Error:', error);\\n      alert(`Gagal mengunduh file: ${error.message}`);\\n    }\\n  };\\n\\n  const { register, handleSubmit, reset } = useForm();\\n\\n  // === Upload file ===\\n  // const handleFileChange = async (e) => {\\n  //   if (isProcessing) return;\\n  //   const selectedFiles = Array.from(e.target.files || []);\\n  //   if (!selectedFiles.length) return;\\n  //   setIsProcessing(true);\\n\\n  //   try {\\n  //     setFiles((prev) => [...prev, ...selectedFiles]);\\n  //     const uploads = selectedFiles.map((file) => handleFileUpload(file));\\n  //     await Promise.all(uploads);\\n  //   } catch (error) {\\n  //     console.error('Error processing files:', error);\\n  //   } finally {\\n  //     setIsProcessing(false);\\n  //     e.target.value = '';\\n  //   }\\n  // };\\n  const handleFileChange = async (e) => {\\n    if (isProcessing) return;\\n    const selectedFiles = Array.from(e.target.files || []);\\n    if (!selectedFiles.length) return;\\n\\n    // FILTER FILE\\n    const validFiles = filterValidFiles(selectedFiles);\\n    if (validFiles.length === 0) {\\n      e.target.value = '';\\n      return;\\n    }\\n\\n    setIsProcessing(true);\\n\\n    try {\\n      setFiles((prev) => [...prev, ...validFiles]);\\n      const uploads = validFiles.map((file) => handleFileUpload(file));\\n      await Promise.all(uploads);\\n    } catch (error) {\\n      console.error('Error processing files:', error);\\n    } finally {\\n      setIsProcessing(false);\\n      e.target.value = '';\\n    }\\n  };\\n\\n  // const handleDrop = async (e) => {\\n  //   e.preventDefault();\\n  //   if (isProcessing) return;\\n  //   setIsDragging(false);\\n  //   const droppedFiles = Array.from(e.dataTransfer.files || []);\\n  //   setIsProcessing(true);\\n  //   try {\\n  //     setFiles((prev) => [...prev, ...droppedFiles]);\\n  //     const uploads = droppedFiles.map((file) => handleFileUpload(file));\\n  //     await Promise.all(uploads);\\n  //   } finally {\\n  //     setIsProcessing(false);\\n  //   }\\n  // };\\n\\n  const handleDrop = async (e) => {\\n    e.preventDefault();\\n    if (isProcessing) return;\\n    setIsDragging(false);\\n    const droppedFiles = Array.from(e.dataTransfer.files || []);\\n\\n    // FILTER FILE\\n    const validFiles = filterValidFiles(droppedFiles);\\n    if (validFiles.length === 0) return;\\n\\n    setIsProcessing(true);\\n    try {\\n      setFiles((prev) => [...prev, ...validFiles]);\\n      const uploads = validFiles.map((file) => handleFileUpload(file));\\n      await Promise.all(uploads);\\n    } finally {\\n      setIsProcessing(false);\\n    }\\n  };\\n\\n  const handleDragOver = (e) => e.preventDefault();\\n  const handleDragLeave = (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n  };\\n\\n  const removeFile = (file) => {\\n    setFiles((prev) => prev.filter((f) => f !== file));\\n    setUploadedFiles((prev) => prev.filter((f) => f.name !== file.name));\\n  };\\n\\n  const handleFileUpload = async (file) => {\\n    const queryParams = new URLSearchParams({\\n      folder: 'agent',\\n      workspaceId: authUser?.workspaceId || '',\\n      dashboardId: dashboard?.id || '',\\n      createdBy: authUser?.id || '',\\n      extractFile: 'false',\\n    }).toString();\\n\\n    const formData = new FormData();\\n    formData.append('file', file);\\n    formData.append('tags', 'assets');\\n\\n    try {\\n      const res = await fetch(\\n        `/api/v1/apps/upload/upload-file?${queryParams}`,\\n        {\\n          method: 'POST',\\n          body: formData,\\n        },\\n      );\\n      if (!res.ok) throw new Error('Upload gagal');\\n\\n      const result = await res.json();\\n      const uploadedFileInfo = {\\n        id: result?.data?.id || 'unknown_id',\\n        url: result?.data?.path || '',\\n        size: result?.data?.filesize\\n          ? `${(result.data.filesize / (1024 * 1024)).toFixed(1)}MB`\\n          : `${(file.size / (1024 * 1024)).toFixed(1)}MB`,\\n        detail: file.name.split('.').pop(),\\n        name: file.name,\\n      };\\n\\n      setUploadedFiles((prev) => [...prev, uploadedFileInfo]);\\n      return uploadedFileInfo;\\n    } catch (err) {\\n      console.error('Error upload file:', err);\\n      alert(`Error uploading ${file.name}: ${err.message}`);\\n      return null;\\n    }\\n  };\\n\\n  // === Submit ===\\n  const onSubmit = async (formData) => {\\n    if (isProcessing) return;\\n    setLoading(true);\\n    setIsProcessing(true);\\n\\n    try {\\n      const reportId = informasiDasarData?.prepetrator_id;\\n\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '314b80f7ce408ee9911ac3d4723ba0f9',\\n        params: {},\\n        body: {\\n          report_id: reportId,\\n          attachment: uploadedFiles,\\n        },\\n        headers: {},\\n        additionalPath: '',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: authUser?.id,\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id,\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n      };\\n\\n      const res = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!res.ok) throw new Error('Gagal kirim ke gateway');\\n\\n      reset();\\n      setFiles([]);\\n      setUploadedFiles([]);\\n      setShowUploadModal(false);\\n      alert('Laporan berhasil ditambah!');\\n      setTimeout(() => window.location.reload(), 3000);\\n    } catch (err) {\\n      console.error(err);\\n      alert(`Error: ${err.message}`);\\n    } finally {\\n      setLoading(false);\\n      setIsProcessing(false);\\n    }\\n  };\\n\\n  // === Utility ===\\n  // const formatTimeAgo = (timestamp) => {\\n  //   if (!timestamp) return '-';\\n  //   const now = Date.now();\\n  //   const diff = now - Number(timestamp);\\n  //   const seconds = Math.floor(diff / 1000);\\n  //   const minutes = Math.floor(seconds / 60);\\n  //   const hours = Math.floor(minutes / 60);\\n  //   const days = Math.floor(hours / 24);\\n\\n  //   if (seconds < 60) return `${seconds} detik yang lalu`;\\n  //   if (minutes < 60) return `${minutes} menit yang lalu`;\\n  //   if (hours < 24) return `${hours} jam yang lalu`;\\n  //   return `${days} hari yang lalu`;\\n  // };\\n\\n  const formatTimeAgo = (timestamp) => {\\n    if (!timestamp) return '-';\\n    const now = Date.now();\\n    const diff = now - Number(timestamp);\\n    const seconds = Math.floor(diff / 1000);\\n    const minutes = Math.floor(seconds / 60);\\n    const hours = Math.floor(minutes / 60);\\n    const days = Math.floor(hours / 24);\\n\\n    if (seconds < 60) return `${seconds} detik yang lalu`;\\n    if (minutes < 60) return `${minutes} menit yang lalu`;\\n    if (hours < 24) return `${hours} jam yang lalu`;\\n    if (days < 7) return `${days} hari yang lalu`;\\n\\n    const date = new Date(Number(timestamp));\\n    return date.toLocaleDateString('id-ID', {\\n      day: '2-digit',\\n      month: 'short',\\n      year: 'numeric',\\n    });\\n  };\\n\\n  const handleImageClick = (item) => {\\n    setSelectedItem(item);\\n    setSelectedImage(convertS3Url(item.url));\\n    setShowModal(true);\\n  };\\n\\n  const handleClose = () => setShowModal(false);\\n  const triggerFileInput = () =>\\n    !isProcessing && document.getElementById('fileInput').click();\\n\\n  const getFileIconByType = (urlOrName) => {\\n    const ext = urlOrName?.split('.').pop()?.toLowerCase();\\n    switch (ext) {\\n      case 'jpg':\\n      case 'jpeg':\\n      case 'png':\\n      case 'gif':\\n        return 'ph-fill ph-image';\\n      case 'pdf':\\n        return 'ph-fill ph-file-pdf';\\n      case 'doc':\\n      case 'docx':\\n        return 'ph-fill ph-file-doc';\\n      case 'txt':\\n        return 'ph-fill ph-file-text';\\n      case 'mp4':\\n      case 'mov':\\n      case 'avi':\\n        return 'ph ph-video';\\n      case 'mp3':\\n      case 'wav':\\n        return 'ph-fill ph-microphone';\\n      default:\\n        return 'ph-fill ph-file';\\n    }\\n  };\\n\\n  // Check if file is image type\\n  const isImageFile = (url) => {\\n    const ext = url?.split('.').pop()?.toLowerCase();\\n    return ['jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp'].includes(ext);\\n  };\\n\\n  // Handle image error - mark as failed to prevent retry (FIXED VERSION)\\n  const handleImageError = useCallback((index, url) => {\\n    const imageKey = `${index}-${url}`;\\n    setFailedImages((prev) => {\\n      // Only update if the key doesn't exist to prevent unnecessary re-renders\\n      if (prev.has(imageKey)) {\\n        return prev;\\n      }\\n      return new Set([...prev, imageKey]);\\n    });\\n  }, []);\\n\\n  // === RENDER ===\\n  return (\\n    <>\\n      <CardWrapper>\\n        <HeaderSection>\\n          <div className=\\\"widget-title\\\">{widget?.name}</div>\\n          <StyledButton\\n            onClick={() => setShowUploadModal(true)}\\n            disabled={isProcessing}\\n            variant=\\\"secondary\\\"\\n          >\\n            <i className=\\\"ph ph-plus\\\"></i>\\n            {loading ? 'Memproses...' : 'Tambah Bukti'}\\n          </StyledButton>\\n        </HeaderSection>\\n\\n        {currentItems.length === 0 ? (\\n          <div\\n            className=\\\"flex flex-col items-center justify-center py-10 text-muted\\\"\\n            style={{ flex: 1 }}\\n          >\\n            <img\\n              src=\\\"/cdn/media/fusion/assets/1731748832639/Group 1 (4).svg\\\"\\n              alt=\\\"no-data\\\"\\n              style={{ width: '150px', marginBottom: '1rem' }}\\n            />\\n            <p className=\\\"m-0\\\">Belum ada bukti</p>\\n          </div>\\n        ) : (\\n          <ContentGrid>\\n            {currentItems.map((item, index) => {\\n              const imageKey = `${index}-${item.url}`;\\n              const hasFailed = failedImages.has(imageKey);\\n              const shouldShowImage = isImageFile(item.url) && !hasFailed;\\n              const imageUrl = convertS3Url(item.url);\\n\\n              return (\\n                <StyledCard key={index}>\\n                  <div className=\\\"flex items-start gap-4\\\">\\n                    {shouldShowImage ? (\\n                      <ImageWrapper onClick={() => handleImageClick(item)}>\\n                        <img\\n                          src={imageUrl}\\n                          alt=\\\"Preview\\\"\\n                          onError={() => handleImageError(index, item.url)}\\n                          loading=\\\"lazy\\\"\\n                        />\\n                      </ImageWrapper>\\n                    ) : (\\n                      <FallbackIconWrapper>\\n                        <i\\n                          className={`${getFileIconByType(item.url)} fs-20`}\\n                          style={{ color: 'var(--primary)' }}\\n                        ></i>\\n                      </FallbackIconWrapper>\\n                    )}\\n                    <div className=\\\"flex justify-between w-100\\\">\\n                      <div className=\\\"flex flex-col flex-grow-1\\\">\\n                        <FileName className=\\\"fs-14 fw-600\\\">\\n                          {item.file_name}\\n                        </FileName>\\n                        <div className=\\\"text-muted \\\">\\n                          {formatTimeAgo(item.created_at)}\\n                        </div>\\n                      </div>\\n                      {item.url && (\\n                        <DownloadButton\\n                          variant=\\\"secondary\\\"\\n                          onClick={(e) => {\\n                            e.stopPropagation();\\n                            handleDownloadFile(item);\\n                          }}\\n                        >\\n                          <i className=\\\"ph ph-download-simple\\\"></i>\\n                        </DownloadButton>\\n                      )}\\n                    </div>\\n                  </div>\\n                </StyledCard>\\n              );\\n            })}\\n          </ContentGrid>\\n        )}\\n      </CardWrapper>\\n\\n      <Modal\\n        show={showUploadModal}\\n        onHide={() => setShowUploadModal(false)}\\n        centered\\n        size=\\\"md\\\"\\n      >\\n        <ModalHeader closeButton>\\n          <TitleHeader>Tambah Bukti</TitleHeader>\\n        </ModalHeader>\\n        <Modal.Body>\\n          <Form onSubmit={handleSubmit(onSubmit)}>\\n            <input\\n              type=\\\"hidden\\\"\\n              value={data?.[0]?.report_id || ''}\\n              {...register('input_id')}\\n            />\\n            <input\\n              id=\\\"fileInput\\\"\\n              type=\\\"file\\\"\\n              multiple\\n              style={{ display: 'none' }}\\n              onChange={handleFileChange}\\n              accept=\\\".doc,.docx,.png,.jpg,.jpeg,.pdf,.mp4,.mp3\\\"\\n            />\\n\\n            <UploadBox\\n              onDrop={handleDrop}\\n              onDragOver={handleDragOver}\\n              onDragLeave={handleDragLeave}\\n              onClick={triggerFileInput}\\n              isDragging={isDragging}\\n            >\\n              <div style={{ paddingBottom: '0.6rem', pointerEvents: 'none' }}>\\n                <img\\n                  src=\\\"/cdn/media/fusion/assets/1731748832639/upload_file_propam.svg\\\"\\n                  alt=\\\"Upload icon\\\"\\n                />\\n              </div>\\n              <p style={{ fontWeight: '400', fontSize: '0.875rem' }}>\\n                <span style={{ fontWeight: '600', color: 'var(--primary)' }}>\\n                  Choose file\\n                </span>{' '}\\n                or drag and drop\\n              </p>\\n              <small>\\n                doc, docx, png, jpg, jpeg, pdf, mp4, mp3 only. 10MB max.\\n              </small>\\n            </UploadBox>\\n\\n            {files.length > 0 && (\\n              <FileList>\\n                {files.map((file, idx) => (\\n                  <FileItem key={idx} className=\\\"gap-4\\\">\\n                    <WrappIcon>\\n                      <i\\n                        className={`${getFileIconByType(file.url || file.name)} fs-20`}\\n                        style={{ color: 'var(--white)' }}\\n                      ></i>\\n                    </WrappIcon>\\n\\n                    <div className=\\\"flex-grow-1\\\">\\n                      <div>{file.name}</div>\\n                      <small>{(file.size / (1024 * 1024)).toFixed(1)} MB</small>\\n                    </div>\\n                    <button\\n                      type=\\\"button\\\"\\n                      onClick={() => removeFile(file)}\\n                      className=\\\"btn btn-sm btn-link p-1\\\"\\n                      style={{ color: '#dc3545' }}\\n                    >\\n                      ✕\\n                    </button>\\n                  </FileItem>\\n                ))}\\n              </FileList>\\n            )}\\n\\n            <div className=\\\"d-flex justify-content-end mt-3\\\">\\n              <Button\\n                variant=\\\"secondary\\\"\\n                onClick={() => setShowUploadModal(false)}\\n              >\\n                Batal\\n              </Button>\\n              <Button\\n                variant=\\\"primary\\\"\\n                type=\\\"submit\\\"\\n                className=\\\"ms-2\\\"\\n                disabled={loading}\\n              >\\n                {loading ? 'Mengunggah...' : 'Kirim'}\\n              </Button>\\n            </div>\\n          </Form>\\n        </Modal.Body>\\n      </Modal>\\n    </>\\n  );\\n}\\n\\n// styled-components (tetap sama)\\nconst StyledButton = styled(Button)`\\n  border: 1px solid var(--black-100);\\n  display: flex;\\n  padding: 0.4rem 0.8rem 0.4rem 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  color: var(--black);\\n  font-size: 0.8rem !important;\\n  font-weight: 600 !important;\\n  line-height: 1.06667rem;\\n`;\\nconst FileName = styled.div`\\n \\n  white-space: nowrap;\\n  overflow: hidden;\\n  text-overflow: ellipsis;\\n  max-width: 125px;\\n`;\\n\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst DownloadButton = styled(Button)`\\n\\ndisplay: flex;\\npadding: 0.53333rem;\\njustify-content: center;\\nalign-items: center;\\ngap: 0.53333rem;\\n  background-color:none;\\n  border:1px solid var(--black-100);\\n`;\\n\\nconst FallbackIconWrapper = styled.div`\\n  width: 50px;\\n  height: 50px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  flex-shrink: 0;\\n`;\\n\\nconst CardWrapper = styled.div`\\n  background: var(--white);\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.8rem;\\n  display: flex;\\n  flex-direction: column;\\n  height:100%;\\n`;\\n\\nconst HeaderSection = styled.div`\\n  padding: 1rem 1.5rem;\\n  border-bottom: 1px solid var(--black-100);\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n`;\\n\\nconst ContentGrid = styled.div`\\n  padding: 1.5rem;\\n  display: grid;\\n  grid-template-columns: repeat(3, 1fr);\\n  gap: 1rem;\\n`;\\n\\nconst StyledCard = styled(Card)`\\n  padding: 1rem;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n`;\\n\\nconst ImageWrapper = styled.div`\\n  position: relative;\\n  width: 50px;\\n  height: 50px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  cursor: pointer;\\n  transition: all 0.2s ease;\\n  &:hover {\\n    transform: scale(1.05);\\n  }\\n  img {\\n    width: 100%;\\n    height: 100%;\\n    object-fit: cover;\\n  }\\n`;\\n\\nconst FallbackIcon = styled.div`\\n  position: absolute;\\n  inset: 0;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n`;\\n\\nconst LabelInput = styled.label`\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst UploadBox = styled.div`\\n  border: 1px dashed var(--Border-Primary, #E6E9F0);\\n  background: var(--Background-Secondary, #F5F7FA);\\n  border-radius: 0.5rem;\\n  text-align: center;\\n  padding: 3rem 0.75rem;\\n  cursor: pointer;\\n`;\\n\\nconst FileList = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n  padding-top: 1.2rem;\\n`;\\n\\nconst FileItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  border-radius: 0.75rem;\\n  border: 1px solid var(--Border-Primary, #E6E8EB);\\n  background: var(--Background-Secondary, #F7F8FA);\\n  padding: 0.5rem;\\n  font-size: 0.875rem;\\n`;\\n\\nconst FileIcon = styled.div`\\n  font-size: 1.25rem;\\n  margin-right: 0.5rem;\\n`;\\n\\nconst WrappIcon = styled.div`display: flex; padding: 0.66667rem; align-items: center; gap: 0.66667rem; border-radius: 0.53333rem; background: var(--primary-600);`;\\n\",\"html\":\" <div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100);border-radius:0.8rem;\\\">\\r\\n   <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n\\r\\n     <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n\\r\\n   </div>\\r\\n   <div>\\r\\n     tes\\r\\n   </div>\\r\\n </div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":[\"created_at\"],\"useAsFilterConfig\":{\"enable\":false},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":true,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false},\"shareAPI\":\"\"},\"x\":0,\"y\":177},{\"chartConfig\":{},\"createdAt\":\"2026-01-25 14:08:12.097000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Tabset - 2026-01-25 14:08:11\",\"h\":55,\"id\":\"3fad30290c122d517ab20d5eb07e1fbc\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"params\":{\"chart\":\"tabset\"}},\"name\":\"Tabset\",\"responsive\":{\"1024\":{\"x\":0,\"y\":6,\"w\":8,\"h\":55}},\"styleType\":\"tabset\",\"type\":\"tabset\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"2a5e447b396d2070cf65d139c2f124ee\",\"w\":8,\"widgetConfig\":{\"visualizationType\":\"Tabset\",\"showTitle\":false,\"formSchema\":\"\",\"collectionGroup\":\"tabset\",\"styleConfig\":{\"placement\":\"start\",\"tabStyle\":\"b-rounded\",\"tabLocation\":\"body\",\"customColorPalette\":[],\"relationsQueryParams\":{\"3fad30290c122d517ab20d5eb07e1fbc\":false},\"noBorder\":true,\"noPadding\":true,\"limitData\":0,\"axis\":{\"radius\":\"\",\"center\":[]},\"series\":{\"opacity\":0},\"xAxis\":{\"interval\":0},\"yAxis\":{\"interval\":0},\"bgTransparent\":true},\"tabsetConfig\":[{\"tabId\":\"c95e37a2b8aa4152a665b89e5763c1b1\",\"name\":\"Detail Laporan\",\"description\":\"\",\"type\":\"widget\",\"content\":{\"menuId\":\"\",\"widgetId\":\"36584f99010d42c82e9382364e9d32fe\"},\"icon\":\"circles-four\",\"additional\":{\"iconType\":\"phosphor\",\"iconStyle\":\"regular\",\"iconStyleActive\":\"regular\",\"iconCode\":\"E190\",\"bgIcon\":\"\",\"menuBgColorTheme\":\"primary\",\"appBarBgColor\":\"bgPrimaryColor\"},\"tabVisibility\":false,\"visibility\":{\"groups\":[],\"permissions\":[]}},{\"tabId\":\"3fdd53f3507d4006ba8fdab0dc89473f\",\"name\":\"Dokumen Bukti\",\"description\":\"\",\"type\":\"widget\",\"content\":{\"menuId\":\"\",\"widgetId\":\"63efe053dde43be7ee642a476a57c56c\"},\"icon\":\"balloon\",\"additional\":{\"iconType\":\"phosphor\",\"iconStyle\":\"regular\",\"iconStyleActive\":\"regular\",\"iconCode\":\"E76C\",\"bgIcon\":\"\",\"menuBgColorTheme\":\"primary\",\"appBarBgColor\":\"bgPrimaryColor\"},\"tabVisibility\":false,\"visibility\":{}},{\"tabId\":\"87ddb4ce2f60451eb2e7c3841680d73a\",\"name\":\"Rekap Laporan\",\"type\":\"widget\",\"content\":{\"menuId\":\"\",\"widgetId\":\"c142fd1f8dc040e6f5185f4837ce5aac\"},\"icon\":\"circles-four\",\"additional\":{\"iconType\":\"phosphor\",\"iconStyle\":\"regular\",\"iconStyleActive\":\"regular\",\"iconCode\":\"E190\",\"bgIcon\":\"\",\"menuBgColorTheme\":\"primary\",\"appBarBgColor\":\"bgPrimaryColor\"},\"description\":\"\",\"tabVisibility\":false,\"visibility\":{}},{\"tabId\":\"8cacf9871ae44bd39fe932701109ca1d\",\"name\":\"Informasi Terlapor\",\"type\":\"widget\",\"content\":{\"menuId\":\"\",\"widgetId\":\"1b4585af9dd59ba73d7b220c4b1a0a5a\"},\"icon\":\"circles-four\",\"additional\":{\"iconType\":\"none\",\"iconStyle\":\"regular\",\"iconStyleActive\":\"regula