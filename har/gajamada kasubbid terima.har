"fadhil\",\"new_values\":\"priyo adhi\"},{\"field_name\":\"status\",\"old_values\":\"verifikasi\",\"new_values\":\"disposisi\"}]],[\"TAF-20251029-00008\",\"Tidak diketahui\",1761735148746,[{\"field_name\":\"sender_name\",\"old_values\":\"null\",\"new_values\":\"fadhil\"}]],[\"TAF-20251029-00008\",\"Tidak diketahui\",1761733314919,[{\"field_name\":\"status_level\",\"old_values\":\"rendah\",\"new_values\":\"wilayah\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"Low\",\"new_values\":\"rendah\"}]],[\"TAF-20251029-00008\",\"Tidak diketahui\",1761733057564,[{\"field_name\":\"status\",\"old_values\":\"Masuk\",\"new_values\":\"verifikasi\"}]],[\"TAF-20251029-00008\",\"null\",1761731467060,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail_where\",\"old_values\":\"sekitaran bandara halim\",\"new_values\":\"dimana saja\"},{\"field_name\":\"id_address\",\"old_values\":null,\"new_values\":\"ed4795aa5042dd32d7f5dd08958c7e2affe80e30e9b0fc02654a8ae4a8202f63\"},{\"field_name\":\"polda_code\",\"old_values\":\"6012\",\"new_values\":\"6012\"},{\"field_name\":\"polres_code\",\"old_values\":\"60010155642157\",\"new_values\":\"60010155642157\"},{\"field_name\":\"polsek_code\",\"old_values\":\"2102793097\",\"new_values\":\"2102793097\"},{\"field_name\":\"sender_name\",\"old_values\":\"Fadhil Uno\",\"new_values\":\"null\"},{\"field_name\":\"status\",\"old_values\":\"enriched\",\"new_values\":\"Masuk\"},{\"field_name\":\"status_level\",\"old_values\":\"sedang\",\"new_values\":\"rendah\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"Medium\",\"new_values\":\"Low\"}]],[\"TAF-20251029-00008\",\"Tidak diketahui\",1761730412270,[{\"field_name\":\"detail_where\",\"old_values\":\"Lampu merah dekat Pasar Kramat Jati, Jl. Raya Pondok Gede, Jakarta Timur.\",\"new_values\":\"sekitaran bandara halim\"}]],[\"TAF-20251029-00008\",\"null\",1761730048786,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail_where\",\"old_values\":\"Lampu merah dekat Pasar Kramat Jati, Jl. Raya Pondok Gede, Jakarta Timur.\",\"new_values\":\"sekitaran bandara halim\"},{\"field_name\":\"id_address\",\"old_values\":null,\"new_values\":\"ed4795aa5042dd32d7f5dd08958c7e2affe80e30e9b0fc02654a8ae4a8202f63\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda metro jaya\"},{\"field_name\":\"polda_code\",\"old_values\":\"6012\",\"new_values\":\"6012\"},{\"field_name\":\"polres_code\",\"old_values\":\"60010155642157\",\"new_values\":\"60010155642157\"},{\"field_name\":\"polsek\",\"old_values\":\"polsek metro ciracas\",\"new_values\":\"POLSEK METRO MAKASAR\"},{\"field_name\":\"polsek_code\",\"old_values\":\"2102793096\",\"new_values\":\"2102793097\"},{\"field_name\":\"sender_name\",\"old_values\":\"Fadhil Uno\",\"new_values\":\"null\"},{\"field_name\":\"status\",\"old_values\":\"enriched\",\"new_values\":\"Masuk\"},{\"field_name\":\"status_level\",\"old_values\":\"wilayah\",\"new_values\":\"sedang\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"rendah\",\"new_values\":\"Medium\"}]],[\"TAF-20251028-00013\",\"Bripka Andi Setiawan\",1761725537612,[{\"field_name\":\"sender_name\",\"old_values\":\"Annisaaaaaaaaa\",\"new_values\":\"tiwi\"}]],[\"TAF-20251028-00013\",\"Bripka Andi Setiawan\",1761725523468,[{\"field_name\":\"sender_name\",\"old_values\":\"null\",\"new_values\":\"Annisaaaaaaaaa\"}]],[\"82d10699428748989a7e597e019015b1\",\"null\",1761725104476,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"category\",\"old_values\":null,\"new_values\":\"Pengaduan Pribadi\"},{\"field_name\":\"detail\",\"old_values\":\"string\",\"new_values\":\"null\"},{\"field_name\":\"detail_where\",\"old_values\":null,\"new_values\":\"dimana saja\"},{\"field_name\":\"email\",\"old_values\":null,\"new_values\":\"null\"},{\"field_name\":\"information\",\"old_values\":null,\"new_values\":\"null\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"Sumatera Selatan\"},{\"field_name\":\"polda_code\",\"old_values\":\"6008\",\"new_values\":\"6008\"},{\"field_name\":\"polres\",\"old_values\":null,\"new_values\":\"null\"},{\"field_name\":\"polsek\",\"old_values\":null,\"new_values\":\"null\"},{\"field_name\":\"reporter_nik\",\"old_values\":null,\"new_values\":\"null\"},{\"field_name\":\"sender_name\",\"old_values\":\"Anonim\",\"new_values\":\"null\"},{\"field_name\":\"source\",\"old_values\":null,\"new_values\":\"null\"},{\"field_name\":\"status\",\"old_values\":\"Dalam Penanganan\",\"new_values\":\"Masuk\"},{\"field_name\":\"status_level\",\"old_values\":null,\"new_values\":\"rendah\"},{\"field_name\":\"title\",\"old_values\":null,\"new_values\":\"kejahatan\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"Medium\",\"new_values\":\"Low\"}]],[\"TAF-20251028-00013\",\"null\",1761724772539,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail\",\"old_values\":\"Pada hari Selasa, 28 Oktober 2025, sekitar pukul 20.30 WIB, saya sedang melintas di Jl. Margonda Raya, Depok, menggunakan sepeda motor pribadi bernomor polisi B 4321 ZFA. Ketika sampai di depan SPBU Margonda, saya diberhentikan oleh tiga orang anggota polisi berseragam yang mengaku dari Satuan Lalu Lintas Polres Depok.\\n\\nSalah satu anggota yang memeriksa saya memperkenalkan diri sebagai Bripka Deni Ramadhan, sementara dua lainnya dipanggil dengan sebutan Aipda Surya dan Brigadir Rio. Mereka meminta saya menunjukkan surat-surat kendaraan. Saya sudah menyerahkan SIM C dan STNK dalam keadaan lengkap dan masih berlaku.\\n\\nNamun, Bripka Deni menyatakan bahwa saya melanggar aturan karena “lampu depan dianggap terlalu terang” dan mengancam akan menilang dengan denda Rp500.000. Ketika saya mencoba menjelaskan bahwa lampu tersebut standar bawaan pabrikan, Aipda Surya memotong pembicaraan dan mengatakan, “Kalau mau cepat beres, ya bantu aja seikhlasnya.”\\n\\nSaya merasa tidak nyaman dan menanyakan maksudnya. Lalu Brigadir Rio menyarankan agar saya menyerahkan “uang rokok” sebesar Rp100.000 supaya tidak ditilang. Karena situasinya sudah tidak kondusif dan saya merasa tertekan, akhirnya saya menyerahkan uang tersebut agar diperbolehkan melanjutkan perjalanan.\\n\\nSetelah kejadian itu, saya mencatat nama-nama yang tertera di papan nama seragam mereka dan waktu kejadian. Saya juga memiliki rekaman kamera dashboard yang memperlihatkan momen pemberhentian dan sebagian percakapan.\\n\\nSaya merasa tindakan ketiga oknum tersebut mencoreng nama baik institusi Polri dan merupakan bentuk penyalahgunaan wewenang serta pungutan liar. Saya berharap Divisi Propam Polri dapat menindaklanjuti laporan ini secara profesional agar tidak terjadi lagi kepada masyarakat lain.\",\"new_values\":\"null\"},{\"field_name\":\"detail_where\",\"old_values\":\"Depan SPBU Margonda, Jl. Margonda Raya, Depok, Jawa Barat, Indonesia.\",\"new_values\":\"null\"},{\"field_name\":\"id_address\",\"old_values\":\"68018960c20bd16d0404105fc9ff8be6\",\"new_values\":\"8e1ef2b3fb623ed18c2475e3122e1696953ca6ac95b89e933132cc1b5df00722\"},{\"field_name\":\"information\",\"old_values\":\"Aduan dari tiwi:\\nPada hari Selasa, 28 Oktober 2025, sekitar pukul 20.30 WIB, saya sedang melintas di Jl. Margonda Raya, Depok, menggunakan sepeda motor pribadi bernomor polisi B 4321 ZFA. Ketika sampai di depan SPBU Margonda, saya diberhentikan oleh tiga orang anggota polisi berseragam yang mengaku dari Satuan Lalu Lintas Polres Depok.\\nSalah satu anggota yang memeriksa saya memperkenalkan diri sebagai Bripka Deni Ramadhan, sementara dua lainnya dipanggil dengan sebutan Aipda Surya dan Brigadir Rio. Mereka meminta saya menunjukkan surat-surat kendaraan. Saya sudah menyerahkan SIM C dan STNK dalam keadaan lengkap dan masih berlaku.\\nNamun, Bripka Deni menyatakan bahwa saya melanggar aturan karena “lampu depan dianggap terlalu terang” dan mengancam akan menilang dengan denda Rp500.000. Ketika saya mencoba menjelaskan bahwa lampu tersebut standar bawaan pabrikan, Aipda Surya memotong pembicaraan dan mengatakan, “Kalau mau cepat beres, ya bantu aja seikhlasnya.”\\nSaya merasa tidak nyaman dan menanyakan maksudnya. Lalu Brigadir Rio menyarankan agar saya menyerahkan “uang rokok” sebesar Rp100.000 supaya tidak ditilang. Karena situasinya sudah tidak kondusif dan saya merasa tertekan, akhirnya saya menyerahkan uang tersebut agar diperbolehkan melanjutkan perjalanan.\\nSetelah kejadian itu, saya mencatat nama-nama yang tertera di papan nama seragam mereka dan waktu kejadian. Saya juga memiliki rekaman kamera dashboard yang memperlihatkan momen pemberhentian dan sebagian percakapan.\\nSaya merasa tindakan ketiga oknum tersebut mencoreng nama baik institusi Polri dan merupakan bentuk penyalahgunaan wewenang serta pungutan liar. Saya berharap Divisi Propam Polri dapat menindaklanjuti laporan ini secara profesional agar tidak terjadi lagi kepada masyarakat lain.\\n[GAMBAR] None\\n\\n[DOKUMEN] <!-- image -->\",\"new_values\":\"null\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda metro jaya\"},{\"field_name\":\"polda_code\",\"old_values\":\"6012\",\"new_values\":\"6012\"},{\"field_name\":\"polres_code\",\"old_values\":\"60010258641199\",\"new_values\":\"60010258641199\"},{\"field_name\":\"polsek_code\",\"old_values\":\"1001521996\",\"new_values\":\"1001521996\"},{\"field_name\":\"sender_address\",\"old_values\":\"Depok, Jawa Barat\",\"new_values\":\"Kota Depok, Jawa Barat\"},{\"field_name\":\"sender_name\",\"old_values\":\"tiwi\",\"new_values\":\"null\"},{\"field_name\":\"status\",\"old_values\":\"enriched\",\"new_values\":\"Masuk\"},{\"field_name\":\"status_level\",\"old_values\":null,\"new_values\":\"rendah\"},{\"field_name\":\"title\",\"old_values\":\"Pengaduan Penyalahgunaan Wewenang dan Pungutan Liar oleh Anggota Polri di Depok\",\"new_values\":\"null\"},{\"field_name\":\"u