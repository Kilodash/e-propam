          "content": {
            "size": 5795,
            "mimeType": "application/json",
            "compression": 4155,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":144,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"prepetrator_id\",\"report_id\",\"type\",\"group_name\",\"status\",\"status_alias\",\"date_activity\",\"responsible_person_name\",\"officer_report_name\",\"handling_progress\",\"subject\",\"previous_case_position\",\"case_position\",\"polda\",\"polres\",\"police_function\",\"sub_function\",\"sub_status\",\"special_case\",\"attachments\"],[\"260608000047-00001\",\"260608000047\",\"Form Vendor\",null,\"Laporan Diterima Kasubbid Paminal\",\"Laporan Diterima Kasubbid Paminal - POLDA JAWA BARAT\",\"2026-07-13 08:58:12.665000\",null,null,\"LAPORAN DISETUJUI OLEH KABAG YANDUAN (KABAG YANDUAN) UNTUK DILIMPAH KE POLDA JAWA BARAT - SUBBAG YANDUAN\",null,null,\"KASUBBID PAMINAL POLDA JAWA BARAT\",\"POLDA JAWA BARAT\",null,\"PAMINAL\",\"SUBBID PAMINAL\",null,null,[]],[\"260608000047-00001\",\"260608000047\",\"Form Vendor\",null,null,null,\"2026-06-08 22:48:00\",null,null,\"LAPORAN DISETUJUI OLEH KABAG YANDUAN (KABAG YANDUAN) UNTUK DILIMPAH KE POLDA JAWA BARAT - SUBBAG YANDUAN\",null,null,null,null,null,null,null,null,null,[]],[\"260608000047-00001\",\"260608000047\",\"Form Vendor\",null,null,null,\"2026-06-08 22:08:00\",null,null,\"LAPORAN DIVERIFIKASI OLEH KASUBBAG TRIMLAP (Wahyu Indrajaya) DAN DIUSULKAN UNTUK LIMPAH KE POLDA JAWA BARAT\",null,null,null,null,null,null,null,null,null,[]],[\"260608000047-00001\",\"260608000047\",\"Form Vendor\",null,null,null,\"2026-06-08 22:01:00\",null,null,\"LAPORAN DITERIMA OLEH OPERATOR BAGYANDUAN\",null,null,null,null,null,null,null,null,null,[]],[\"260608000047-00001\",\"260608000047\",\"Form Vendor\",null,null,null,\"2026-06-08 21:19:00\",null,null,\"Laporan dibuat dari pengaduan online\",null,null,null,null,null,null,null,null,null,[]]],\"additionalInfo\":{\"query\":\"WITH base_group_name AS (\\n    SELECT DISTINCT ON (d.report_id, d.prepetrator_id)\\n        d.report_id,\\n        d.prepetrator_id,\\n        CASE\\n            WHEN d.group_name IS NULL OR trim(d.group_name) = '' THEN NULL\\n            WHEN trim(d.group_name) LIKE '[%%' THEN (d.group_name::jsonb ->> 0)\\n            ELSE d.group_name\\n        END AS group_name\\n    FROM aduan_masyarakat_v3.report_disposisi d\\n    WHERE d.group_name IS NOT NULL\\n    ORDER BY d.report_id, d.prepetrator_id, d.updated_at ASC NULLS LAST\\n),\\nreport_officer AS (\\n    SELECT\\n        r2.report_id,\\n        r.type,\\n        bg.group_name,\\n        r2.prepetrator_id,\\n    CASE \\n    WHEN r2.status = 'Laporan Diterima'\\n    THEN COALESCE(r2.status,'-') || ' Oleh ' || COALESCE(rd.case_position,'-')\\n    WHEN r2.status IN ('Laporan Dikirim ke Polda','Laporan Diterima Polda','Laporan Diterima Kasubbid Paminal')\\n    THEN COALESCE(r2.status,'-') || ' - ' || COALESCE(rd.polda,'-')\\n    ELSE r2.status\\nEND AS status_alias,r2.status,\\n        r2.updated_at AS activity_at,\\n        (r2.updated_at AT TIME ZONE 'UTC' AT TIME ZONE 'Asia/Jakarta')::text AS date_activity,\\n        r2.responsible_person_name,\\n        r2.officer_report_name,\\n        r2.handling_progress,\\n        r2.subject,\\n        rd.case_position,\\n        rd.polda,\\n        rd.polres,\\n        rd.police_function,\\n        rd.sub_function,\\n        r2.sub_status,\\n        rd.special_case,\\n        COALESCE(\\n            JSON_AGG(\\n                DISTINCT JSONB_BUILD_OBJECT(\\n                    'url', road.url,\\n                    'detail', road.detail,\\n                    'size', road.size,\\n                    'file_name', road.file_name\\n                )\\n            ) FILTER (WHERE road.url IS NOT NULL),\\n            '[]'::json\\n        ) AS attachments\\n    FROM aduan_masyarakat_v3.report_officer_detail r2\\n    JOIN gold.report r\\n        ON r.id::text = r2.report_id::text\\n    LEFT JOIN base_group_name bg\\n        ON bg.report_id::text = r2.report_id::text\\n       AND bg.prepetrator_id::text = r2.prepetrator_id::text\\n    LEFT JOIN aduan_masyarakat_v3.report_disposisi rd \\n        ON r2.report_id::text = rd.report_id::text\\n       AND r2.prepetrator_id::text = rd.prepetrator_id::text\\n       AND r2.updated_at = rd.updated_at \\n    LEFT JOIN aduan_masyarakat_v3.report_officer_attachments roa\\n        ON roa.report_id::text = r2.report_id::text\\n       AND roa.prepetrator_id::text = r2.prepetrator_id::text\\n       AND roa.updated_at = r2.updated_at\\n    LEFT JOIN aduan_masyarakat_v3.report_officer_attachments_detail road\\n        ON road.id::text = roa.attachment_status_id::text\\n    WHERE COALESCE(lower(r.status_label), '') <> 'spam'\\n      AND r2.prepetrator_id = %(prepetrator_id_0)s\\n    GROUP BY \\n        r2.report_id,\\n        r.type,\\n        bg.group_name,\\n        r2.prepetrator_id,\\n        r2.status,\\n        r2.responsible_person_name,\\n        r2.officer_report_name,\\n        r2.handling_progress,\\n        r2.subject,\\n        rd.case_position,\\n        rd.polda,\\n        rd.polres,\\n        rd.police_function,\\n        rd.sub_function,\\n        r2.updated_at,\\n        r2.sub_status,\\n        rd.special_case\\n),\\nwith_previous AS (\\n    SELECT\\n        *,\\n        LAG(case_position) OVER (\\n            PARTITION BY report_id, prepetrator_id\\n            ORDER BY activity_at ASC NULLS LAST\\n        ) AS previous_case_position\\n    FROM report_officer\\n)\\nSELECT\\n    prepetrator_id,\\n    report_id,\\n    type,\\n    group_name,\\n    status,status_alias,\\n    date_activity,\\n    responsible_person_name,\\n    officer_report_name,\\n    handling_progress,\\n    subject,\\n    previous_case_position,\\n    case_position,\\n    polda,\\n    polres,\\n    police_function,\\n    sub_function,\\n    sub_status,\\n    special_case,\\n    attachments\\nFROM with_previous\\nORDER BY prepetrator_id, activity_at DESC\\nLIMIT 35;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
          },
