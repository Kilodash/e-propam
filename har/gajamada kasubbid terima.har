\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"hideWidget\":false},\"x\":0,\"y\":6},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-25 11:56:17.068000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":18,\"id\":\"b7b630239fb7ad396f2a432f47e876b2\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"63a0a4b198f6c6e4d931a7f71d3deaf0\",\"sourceId\":[\"19624557c4b9723e26811e2fe66de07a\",\"f18355f59f66004075a27e71061a4df5\"],\"query\":null,\"name\":\"Informasi Terlapor\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Informasi Terlapor\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":8,\"y\":60,\"w\":4,\"h\":18}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"36b62f09924da44ef55dffc0f67b7531\",\"w\":4,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"b7b630239fb7ad396f2a432f47e876b2\":{\"table\":\"aduan_masyarakat_v3.\\\"report\\\"\",\"field\":\"id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"63a0a4b198f6c6e4d931a7f71d3deaf0\",\"sourceId\":[\"19624557c4b9723e26811e2fe66de07a\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":true,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"63a0a4b198f6c6e4d931a7f71d3deaf0\",\"sourceId\":[\"19624557c4b9723e26811e2fe66de07a\",\"f18355f59f66004075a27e71061a4df5\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultipleField\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableCustomField\":false,\"customFieldName\":\"\"}]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"id\",\"alias\":\"report_id\",\"name\":\"id\",\"type\":\"string\"},{\"field\":\"prepetrator_data\",\"alias\":\"name\",\"name\":\"prepetrator_data\",\"type\":\"string\"},{\"field\":\"description\",\"alias\":\"description\",\"name\":\"description\",\"type\":\"string\"},{\"field\":\"division\",\"alias\":\"division\",\"name\":\"division\",\"type\":\"string\"},{\"field\":\"rank\",\"alias\":\"rank\",\"name\":\"rank\",\"type\":\"string\"},{\"field\":\"position\",\"alias\":\"position\",\"name\":\"position\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"date\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customColorPalette\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"prepetrator_id\",\"report_id\",\"source\",\"created_date\",\"prepetrator_data\",\"police_reports\",\"officer_details\"],[\"260227000012-00004\",\"260227000012\",\"Landing Page\",1772160900000,[{\"prepetrator_id\":\"260227000012-00004\",\"name\":\"La Ode Retno Sukur Abdullah, S.H.\",\"rank\":\"BRIGPOL\",\"position\":\"Banit 1 Satreskrim Polres Baubau\",\"identity_number\":null,\"functional_assignment\":null,\"articles\":null,\"type_perpetrator\":null}],[{\"report_number\":null,\"datetime\":null,\"criminal_lp_number\":null,\"hearing_decision_date\":null,\"report_detail\":null,\"criminal_offense\":null,\"criminal_article\":null,\"criminal_process_status\":null,\"decision_number\":null,\"short_description\":null,\"criminal_article_description\":null,\"criminal_notes\":null}],{\"document_number\":null,\"document_date\":null,\"hearing_date\":null,\"hearing_place\":null,\"hearing_decision_number\":null,\"hearing_decision_date\":null,\"offense_description\":null}]],\"useAsFilterConfig\":{\"enable\":false},\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\".information {\\n  width: 10rem;\\n  font-weight: 500;\\n  color: var(--black);\\n}\\n\\n.flex.items-start.gap-2>div:last-child {\\n  flex: 1;\\n  word-break: break-word;\\n}\\n\\n\\n.report-body-container {\\n  scrollbar-gutter: stable;\\n\\n  overflow-y: hidden;\\n}\\n\\n.report-body-container:hover {\\n  overflow-y: overlay;\\n}\\n\\n\\n.report-body-container::-webkit-scrollbar {\\n  width: 6px;\\n}\\n\\n\\n.report-body-container::-webkit-scrollbar-track {\\n  background: transparent;\\n}\\n\\n.report-body-container::-webkit-scrollbar-thumb {\\n  background-color: transparent;\\n  border-radius: 10px;\\n}\\n\\n.report-body-container:hover::-webkit-scrollbar-thumb {\\n  background-color: rgba(0, 0, 0, 0.2);\\n}\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport styled from 'styled-components';\\n\\nexport default function WidgetInfo({\\n  widget,\\n  handleCallbackOnClick,\\n  data = [],\\n}) {\\n  const hasData = Array.isArray(data) && data.length > 0;\\n  const report = hasData ? data[0] : null;\\n  const terlaporList = report?.prepetrator_data || [];\\n  const totalTerlapor = terlaporList.length;\\n\\n  const currentReportId = report?.report_id;\\n  console.log(currentReportId, 'ini current');\\n\\n  const handleOtherReportClick = () => {\\n    if (handleCallbackOnClick) {\\n      handleCallbackOnClick({\\n        name: 'Terlapor Lainnya',\\n        key: currentReportId,\\n      });\\n    }\\n    if (currentReportId) {\\n      localStorage.setItem('currentReportId', currentReportId);\\n    }\\n  };\\n  const startCase = (str) => {\\n    if (!str) return '-';\\n    return str\\n      .toString()\\n      .replace(/[_-]+/g, ' ')\\n      .replace(/([a-z])([A-Z])/g, '$1 $2')\\n      .split(' ')\\n      .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())\\n      .join(' ');\\n  };\\n\\n  return (\\n    <Container>\\n      <Header>\\n        <div className=\\\"flex items-center justify-between gap-2 px-6 \\\">\\n          <div className=\\\"py-4 widget-title\\\">\\n            {widget?.name || 'Informasi Terlapor'}\\n          </div>\\n          <OtherReportsLink onClick={handleOtherReportClick}>\\n            Terlapor Lainnya\\n          </OtherReportsLink>\\n        </div>\\n      </Header>\\n      <ScrollableContent>\\n        {terlaporList.length > 0 ? (\\n          terlaporList.map((terlapor, index) => (\\n            <div key={index}>\\n              <InfoGroup>\\n                {terlaporList.length > 1 && (\\n                  <div className=\\\"fw-600 mb-2 text-primary fs-12\\\">\\n                    Terlapor {index + 1}\\n                  </div>\\n                )}\\n                <InfoRow>\\n                  <Information>Nama</Information>\\n                  <Value>{terlapor?.name || '-'}</Value>\\n                </InfoRow>\\n                <InfoRow>\\n                  <Information>Pangkat</Information>\\n                  <Value>{startCase(terlapor?.rank)}</Value>\\n                </InfoRow>\\n                <InfoRow>\\n                  <Information>Jabatan</Information>\\n                  <Value>{startCase(terlapor?.position)}</Value>\\n                </InfoRow>\\n                <InfoRow>\\n                  <Information>Fungsi</Information>\\n                  <Value style={{ wordBreak: 'break-all' }}>\\n                    {startCase(terlapor?.functional_assignment)}\\n                  </Value>\\n                </InfoRow>\\n                <InfoRow>\\n                  <Information>NRP</Information>\\n                  <Value style={{ wordBreak: 'break-all' }}>\\n                    {startCase(terlapor?.identity_number)}\\n                  </Value>\\n                </InfoRow>\\n              </InfoGroup>\\n              {index < terlaporList.length - 1 && <Divider />}\\n            </div>\\n          ))\\n        ) : (\\n          <div className=\\\"text-center text-muted py-4 fs-14\\\">\\n            Data terlapor tidak tersedia\\n          </div>\\n        )}\\n      </ScrollableContent>\\n    </Container>\\n  );\\n}\\nconst Container = styled.div`\\n  background: var(--white);\\n  height: 100%;\\n  border: 1px solid var(--black-100, #e6e9f0);\\n  border-radius: 0.8rem;\\n  display: flex;         /* Penting untuk layout scroll */\\n  flex-direction: column; /* Susun Header dan Body secara vertikal */\\n  overflow: hidden;      /* Agar border radius tidak tertutup anak elemen */\\n`;\\nconst Header = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  border-bottom: 1px solid var(--black-100, #e6e9f0);\\n  background: var(--white);\\n  flex-shrink: 0; /* Header tidak boleh mengecil */\\n  .widget-title {\\n    font-weight: 600;\\n    font-size: 1rem;\\n    color: var(--black);\\n  }\\n`;\\nconst ScrollableContent = styled.div`\\n  flex: 1;             \\n  overflow-y: auto;  \\n  padding: 16px;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 1rem;\\n  &::-webkit-scrollbar {\\n    width: 6px;\\n  }\\n  &::-webkit-scrollbar-track {\\n    background: #f1f1f1;\\n  }\\n  &::-webkit-scrollbar-thumb {\\n    background: #ccc;\\n    border-radius: 3px;\\n  }\\n  &::-webkit-scrollbar-thumb:hover {\\n    background: #aaa;\\n  }\\n`;\\nconst InfoGroup = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.8rem;\\n`;\\nconst InfoRow = styled.div`\\n  display: flex;\\n  align-items: flex-start;\\n  gap: 0.5rem;\\n`;\\nconst Information = styled.div`\\n  width: 8rem; /* Sedikit dikecilkan agar Value lebih lega */\\n  flex-shrink: 0;\\n  font-weight: 400;\\n  color: var(--black-500);\\n  font-size: 14px;\\n`;\\nconst Value = styled.div`\\n  flex: 1;\\n  font-size: 14px;\\n  font-weight: 400;\\n  color: var(--black);\\n  word-break: break-word; /* Mencegah teks keluar container */\\n`;\\nconst Divider = styled.div`\\n  height: 1px;\\n  background-color: var(--black-100, #e6e9f0);\\n  margin: 1rem 0;\\n  width: 100%;\\n`;\\n\\nconst OtherReportsLink = styled.div`\\n  cursor: pointer;\\n  color: var(--primary); \\n  font-size: 14px;\\n  font-weight: 500;\\n\\n  &:hover {\\n    text-decoration: underline;\\n    opacity: 0.8;\\n  }\\n`;\\n\",\"html\":\"<div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100); border-radius: 0.8rem;\\\">\\r\\n  <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n    <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n  </div>\\r\\n\\r\\n  <div class=\\\"px-6 py-4\\\">\\r\\n    {{#if data.length}}\\r\\n      <div class=\\\"flex flex-col\\\" style=\\\"gap: 0.53333rem;\\\">\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Nama</div>\\r\\n          <div>{{data.0.name}}</div>\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Pangkat</div>\\r\\n          {{#if data.0.rank}}\\r\\n            <div>{{_ 'startCase' data.0.rank}}</div>\\r\\n          {{else}}\\r\\n            <div>-</div>\\r\\n          {{/if}}\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Jabatan</div>\\r\\n          {{#if data.0.position}}\\r\\n            <div>{{_ 'startCase' data.0.position}}</div>\\r\\n          {{else}}\\r\\n            <div>-</div>\\r\\n          {{/if}}\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Fungsi</div>\\r\\n          {{#if data.0.sender_address}}\\r\\n            <div style=\\\"word-break: break-all;\\\">{{data.0.sender_address}}</div>\\r\\n          {{else}}\\r\\n            <div>-</div>\\r\\n          {{/if}}\\r\\n        </div>\\r\\n      </div>\\r\\n    {{else}}\\r\\n      <div class=\\\"flex flex-col items-center justify-center py-10 text-muted\\\">\\r\\n        <p class=\\\"m-0\\\">Belum ada data laporan</p>\\r\\n      </div>\\r\\n    {{/if}}\\r\\n  </div>\\r\\n</div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"hideWidget\":false,\"dateFields\":\"\",\"fullscreen\":false,\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":false,\"cache\":{\"status\":false},\"pageState\":true,\"customLimit\":{\"status\":false},\"orderColumn\":false,\"shareAPI\":\"\",\"childrenConfig\":{\"enable\":true,\"pageBykey\":[{\"key\":\"report_id\",\"menuId\":\"1fc94cf2aba6f0f557dc7fb2127f0f9c\",\"widgetFilterId\":\"\",\"openTarget\":\"modal\"}],\"type\":\"widget\",\"enablePageBykey\":true,\"menuId\":\"1fc94cf2aba6f0f557dc7fb2127f0f9c\",\"widgetFilterId\":\"\",\"buttonStyle\":{\"label\":\"\",\"additional\":{}},\"modal\":{\"enablePaddingBody\":false},\"fullscreen\":false,\"customSize\":{\"enable\":false},\"minusStartDate\":{\"enable\":false},\"disableTitle\":false,\"prefixTitle\":{\"enable\":false},\"prefixSubtitle\":{\"enable\":false},\"titleSeries\":false,\"autoFillSubtitle\":false,\"widgetId\":\"2899aa517c3f3c381a7593a9d532550b\",\"dashboardId\":\"1769155096865\",\"field\":{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"report_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"06a20639dfc4c51abaab7dae05a7e42e\",\"sourceId\":[\"19624557c4b9723e26811e2fe66de07a\",\"f18355f59f66004075a27e71061a4df5\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"valueFromCatalog\":false,\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"alias\":[]},\"filterModalChildren\":false},\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false,\"splitTime\":false,\"filtersGeneral\":{\"type\":\"\"},\"downloadConfig\":{\"enable\":false,\"viewData\":false,\"customColumnOrder\":{\"enable\":false,\"columns\":[]}}},\"x\":8,\"y\":60},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-25 11:15:21.178000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":6,\"id\":\"5cea803380b931d14df231453c466448\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"946f2222e45a9c2e4571bf97ed8bf89e\",\"sourceId\":[\"e3dd3c5e53fa4350bb2d65e687708e7c\",\"fec19eb5093c8901cf58d41eefb87872\"],\"query\":null,\"name\":\"Riwayat Log\",\"chart\":\"Table\",\"database_type\":\"postgresql\"}},\"name\":\"History Edit\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":0,\"w\":11,\"h\":6}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":11,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Riwayat Log\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"5cea803380b931d14df231453c466448\":false},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"status\",\"alias\":\"status\",\"name\":\"status\",\"type\":\"string\"},{\"field\":\"created_date\",\"alias\":\"created_date\",\"name\":\"created_date\",\"type\":\"date\"},{\"field\":\"polda\",\"alias\":\"polda\",\"name\":\"polda\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"string\"},{\"field\":\"subject\",\"alias\":\"subject\",\"name\":\"subject\",\"type\":\"string\"},{\"field\":\"handling_progress\",\"alias\":\"handling_progress\",\"name\":\"handling_progress\",\"type\":\"string\"},{\"field\":\"responsible_person_name\",\"alias\":\"responsible_person_name\",\"name\":\"responsible_person_name\",\"type\":\"string\"},{\"field\":\"detail\",\"alias\":\"detail\",\"name\":\"detail\",\"type\":\"string\"},{\"field\":\"method\",\"alias\":\"method\",\"name\":\"method\",\"type\":\"string\"},{\"field\":\"sender_name\",\"alias\":\"sender_name\",\"name\":\"sender_name\",\"type\":\"string\"},{\"field\":\"complaint_name\",\"alias\":\"complaint_name\",\"name\":\"complaint_name\",\"type\":\"string\"}]},\"customColorKey\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"report_id\",\"status\",\"created_date\",\"polda\",\"updated_at\",\"subject\",\"handling_progress\",\"responsible_person_name\",\"detail\",\"method\",\"sender_name\",\"complaint_name\"],[\"2025100633\",\"Laporan Masuk\",1759729366406,\"polda sumatera utara\",null,null,null,null,\"Mengalami kekerasan saat melaporkan kasus di kantor polisi Medan\\n\\n[GAMBAR] Gambar menunjukkan luka berwarna gelap pada lutut seseorang, yang mungkin merupakan bekas pukulan atau benturan. Hal ini dapat menjadi bukti fisik dari kekerasan yang dilaporkan oleh individu tersebut saat melaporkan kasus di kantor polisi Medan.\\n\",null,\"Dewi\",\"Dewi\"],[\"202506202\",\"Laporan Masuk\",1750941300000,\"polda metro jaya\",null,null,null,null,\"Perusahaan konstruksi PT. Jaya Abadi Perkasa Giat gagal membayar gaji karyawan untuk bulan Maret, April, dan Mei 2025 meski kontrak kerja telah dipenuhi.\",null,\"Sri Lestari\",\"Sri Lestari\"],[\"TAFA-20251011-00003\",\"Laporan Masuk\",1760168835100,null,null,null,null,null,\"Kronologi kejadian...\",\"form_anonymous\",\"Anonim\",\"Anonim\"],[\"TAF-20251013-00002\",\"Laporan Masuk\",1760326227055,\"polda metro jaya\",null,null,null,null,\"Saya mengalami pemerasan dari salah satu pihak polres metro bekasi saat saya ingin meminta surat kehilangan kendaraan. saya diminta kasih uang 10 juta untuk mempercepat proses pengeluaran surat dan lain-lainnya\",\"form_internal\",\"Anonim\",\"Anonim\"],[\"2025091913\",\"Laporan Masuk\",1758252183316,\"polda metro jaya\",null,null,null,null,\"Dugaan pelanggaran dan penyalahgunaan wewenang oleh oknum anggota kepolisian dalam proses perpanjangan SIM, termasuk pungutan liar dan perlakuan tidak adil\",null,\"Ahmad Fauzi\",\"Ahmad Fauzi\"],[\"TAFA-20251013-00001\",\"Laporan Masuk\",1760326042999,\"polda metro jaya\",null,null,null,null,\"Saya pertama kali bertugas bersama Aiptu Rosikin, rekan sesama anggota di Polres Tangerang Selatan, sekitar bulan Mei 2024. Pada awalnya, hubungan kerja kami berjalan normal dan profesional. Kami sering berkoordinasi terkait kegiatan administrasi dan patroli di wilayah Bintaro, Tangerang Selatan. Namun, setelah beberapa waktu, sikapnya mulai berubah dan cenderung merendahkan saya di depan rekan kerja lainnya.\\n\\nSejak bulan Juli, tindakan tidak menyenangkan itu semakin sering terjadi. Ia kerap melontarkan komentar bernada ejekan saat rapat, menyindir kinerja saya, bahkan menyebarkan candaan yang menjatuhkan nama baik saya di lingkungan kerja. Awalnya saya mencoba menanggapinya dengan tenang dan menganggapnya sebagai bentuk gurauan, tetapi perilaku tersebut justru semakin intens dan membuat saya tertekan secara mental.\\n\\nSaya sempat mencoba menyelesaikan masalah ini secara pribadi dengan menegurnya secara baik-baik, namun tanggapan yang saya dapatkan malah berupa sindiran balik dan penambahan tekanan sosial di lingkungan kerja. Situasi ini berdampak pada kinerja saya dan menciptakan suasana tidak nyaman di unit tempat saya bertugas.\",\"form_anonymous\",\"Anonim\",\"Anonim\"],[\"202509189\",\"Laporan Masuk\",1758154442746,\"polda riau\",null,null,null,null,\"Dugaan penipuan dan penyalahgunaan wewenang oleh oknum anggota kepolisian Aiptu Rudi Saputra terkait janji pengamanan jalur khusus untuk seleksi Bintara Polri yang tidak terpenuhi\",null,\"Budi Santoso\",\"Budi Santoso\"],[\"20486e743ce04ec1bf66fa6b4eebdada\",\"Laporan Masuk\",1760438816000,\"polda jambi\",null,null,null,null,\"Sebelumnya saya dan pelaku berpacaran. pada hari Sabtu pagi pukul 08.00 tanggal 04 Oktober 2025, pelaku menghubungi saya untuk meminjam uang sebesar Rp 2.500.000, namun tidak saya berikan. Awalnya pelaku menerima bahwa saya tidak bisa memberikan bantuan, sebelumnya saya memang sudah berencana untuk pergi ke jakarta menemui teman saya perempuan atas nama afifah, yang mana suaminya sedang dinas luar di jakarta, saya sudah pesan tiket dari hari Rabu tanggal 01 Oktober 2025, saat di bandara saya masih berkomunikasi dengan pelaku, masih telfon, setelah itu telfon mati, dari pukul 18.33 sampai 20.00 pelaku tidak ada kabar, tapi bisa liat Story Instagram saya, saya menghubungi pelaku sebagai bentuk protes tindakan pelaku, tapi yang saya dapat adalah maki-makian “tidak punya otak, empati, orang paling jahat di dunia, saya ke jakarta mau ngentot”pelaku memaki saya, tapi tidak saya balas semua makian tersebut. Lalu berakhir last chat di WhatsApp itu di nomor 085378477700 di saya, lalu pelaku menghubungi saya via wa di pukul 12.30 siang tanggal 5 Oktober 2025, saya tidak balas karena handphone saya mode jangan ganggu, lalu saya mengupload Story di Instagram berupa video tiktok, pelaku mengomentari, menuduh tanpa dasar dan merendahkan saya secara verbal mengatakan jika saya menjual diri, karena saya takut ini merusak mood saya, akhirnya saya putuskan untuk block semua sosial media pelaku terhadap saya. Pelaku langsung menyindir saya di catatan Instagram nya @ko.ptr “kedoknya aja main saham, padahal orang tau gawe dio apo” saya pemain saham & pelaku selalu bilang itu ke temen-temennya, pasti semua orang tau itu sindiran untuk saya, saya membantah sindiran tersebut dengan inti bantahan bahwa “pelaku bersikap seperti itu karena tidak saya berikan pinjaman” saya ada bukti voice note pelaku marah karena tidak dipinjami uang, lalu besoknya pelaku live di tiktok @ko.ptr4 mencemari serta menggiring opini yang tidak baik tentang saya, tidak hanya itu bahkan pelaku membawa bawa keluarga saya. Bahkan pelaku menginstruksikan followers nya, untuk menyerang saya di sosial media.\",\"form_vendor\",\"Anonim\",\"Anonim\"],[\"2025100634\",\"Laporan Masuk\",1759729381665,null,null,null,null,null,\"kemarin, saya datang ke polsek pesanggrahan polres jaksel untuk mengurusi surat kehilangan kendaraan bermotor, tapi polisi yang ada di sana tidak serius, meminta saya menunggu lama, lalu setelah di proses, saya disuruh pulang lagi nunggu satu minggu. saya merasa ini tindakan tidak profesional untuk menerima surat aja harus satu minggu.\\n\\n[GAMBAR] Dalam gambar ini, terlihat seorang petugas kepolisian sedang berinteraksi dengan dua orang lainnya di sebuah ruangan yang tampak seperti kantor polisi. Petugas tersebut tampak fokus pada dokumen yang diperiksa, sementara dua orang lainnya tampak sedang berbicara atau menunggu. Gambar ini mungkin menggambarkan situasi di mana petugas kepolisian sedang melakukan pemeriksaan administratif atau proses pengurusan surat. Konteks dari keluhan yang diberikan dalam teks tersebut menunjukkan bahwa pengalaman pengurusan surat kehilangan kendaraan bermotor di tempat tersebut tidak memuaskan, dengan petugas yang tidak serius dan menuntut waktu tunggu yang lama.\\n\",null,\"Bayu Hermanto\",\"Bayu Hermanto\"],[\"TAFA-20251013-00004\",\"Laporan Masuk\",1760328925090,\"polda metro jaya\",null,null,null,null,\"duit saya diambil sama atasan saya, katanya di MOU pas bertugas saya mau dikasi 2 juta tp saya cuma nerima 1.5 jt aja, 500 ribunya kemana? kejadian di puri.. kami sabhara.. mohon ditindaklanjuti\",\"form_anonymous\",\"Anonim\",\"Anonim\"],[\"4a8a64a42c89439a8f16f5b34169e43f\",\"Laporan Masuk\",1760449030000,\"polda maluku\",null,null,null,null,\"IPDA sulaiman fattah membeli mobil saya (aries manuhutu) dengan jenis/type avanza  tahun 2016 warna silver dengan harga 135 juta, namun baru dibayarkan 126 juta, dan sisanya 9 juta rupiah belum dibayarkan hingga saat ini, saya sudah mencoba berkoordinasi secara kekeluargaan namun belum juga di lunasi, mohon bantuannya bapak/ibu komandan\",\"form_internal\",\"Anonim\",\"Anonim\"],[\"TAF-20251011-00001\",\"Laporan Masuk\",1760154309998,null,null,null,null,null,\"Kronologi kejadian...\",\"form_internal\",\"Anonim\",\"Anonim\"],[\"2025100636\",\"Laporan Masuk\",1759733228122,\"polda nusa tenggara barat\",null,null,null,null,\"Pada malam tanggal 3 Oktober 2025, diri pelapor dihentikan oleh anggota kepolisian di Jalan Veteran saat berkendara pulang dari tempat kerja. Oknum tersebut menuduh pelapor melanggar aturan lalu lintas karena tidak menyalakan lampu utama, meskipun kondisi kendaraan pelapor normal. Oknum kemudian meminta uang sebesar Rp300.000 agar pelapor tidak dikenai tilang. Pelapor menolak namun setelah didesak, ia menyerahkan uang tersebut secara tunai. Pelapor merasa dirugikan dan melapor melalui kanal pengaduan Propam.\",null,\"Rizky Ananta Putra\",\"Rizky Ananta Putra\"],[\"TAF-20251011-00002\",\"Laporan Masuk\",1760169575081,\"polda jawa tengah\",null,null,null,null,\"Saya, Andi Pratama (28 tahun), bekerja sebagai pegawai administrasi di sebuah instansi pemerintahan di Kota Mandala. Kejadian ini terjadi pada Selasa, 23 Juli 2024, sekitar pukul 20.30 WIB di area parkir belakang kantor.\\n\\nSaat itu saya baru saja menyelesaikan pekerjaan lembur dan bersiap untuk pulang. Di lokasi tersebut hanya ada beberapa rekan kerja lain, dan suasana sudah cukup sepi. Tiba-tiba, seorang pria berpakaian dinas lengkap menghampiri saya dan memperkenalkan diri sebagai anggota Polsek Metro Jakarta Barat. Ia mengaku sedang melakukan patroli malam dan ingin memeriksa kendaraan saya.\\n\\nAwalnya saya tidak curiga. Namun, saat pemeriksaan berlangsung, perilaku pria tersebut mulai tidak profesional. Ia menanyakan hal-hal pribadi dan berusaha mendekat terlalu dekat secara fisik. Saya merasa tidak nyaman, namun mencoba tetap sopan. Ketika saya menolak ajakan untuk berbicara di tempat yang lebih sepi, ia mulai bersikap kasar dan melakukan tindakan yang saya anggap sebagai pelecehan fisik.\\n\\nSaya segera berlari ke arah pos keamanan kantor dan meminta bantuan petugas jaga. Petugas keamanan langsung menghubungi piket Polsek Metro Jakarta Barat\\n, dan beberapa menit kemudian dua anggota kepolisian datang ke lokasi untuk menindaklanjuti laporan saya. Setelah mendengar kronologi awal, saya diarahkan untuk membuat laporan resmi ke Polsek Metro Jakarta Barat\\n malam itu juga.\\n\\nKeesokan harinya, saya diminta memberikan keterangan tambahan di ruang Unit Reserse Kriminal (Reskrim). Pihak kepolisian kemudian mengonfirmasi bahwa pelaku benar merupakan anggota kepolisian aktif, namun saat kejadian sedang tidak bertugas. Berdasarkan arahan dari pimpinan kepolisian wilayah, kasus ini langsung diteruskan ke Bidang Profesi dan Pengamanan (Propam) Kepolisian Daerah Jakbar untuk pemeriksaan internal.\\n\\nPihak Polda Tambora kemudian melakukan penyelidikan internal, memeriksa saksi-saksi termasuk petugas keamanan kantor, dan menahan sementara pelaku di ruang tahanan Propam. Saya juga mendapat pendampingan dari Unit Pelayanan Perempuan dan Anak (PPA) selama proses pemeriksaan.\\n\\nProses pemeriksaan internal berlangsung sekitar dua minggu, dan hasilnya disampaikan bahwa pelaku terbukti melanggar kode etik kepolisian serta dikenai sanksi disiplin berat. Kasus pidana juga dilanjutkan ke kejaksaan setempat setelah berkas dinyatakan lengkap.\\n\\nSaya merasa lega karena laporan saya ditangani dengan serius dan profesional. Saya juga mendapat perlindungan serta pendampingan hukum hingga kasus selesai. Meskipun peristiwa ini meninggalkan trauma, saya bersyukur penanganannya cepat dan transparan\",\"form_internal\",\"Anonim\",\"Anonim\"],[\"2025100635\",\"Laporan Masuk\",1759733384573,null,null,null,null,null,null,null,null,null],[\"d8987acdf61e4322a6f33f0b9f59e662\",\"Laporan Masuk\",1760438816000,\"polda metro jaya\",null,null,null,null,\"Pada hari ini teman saya bernama Deybi silvia menghubungi saya melalui whatsapp, beliau adalah calon istri dari Bripda Bastian yang berdinas di Yon A Batalyon Pelopor resimen. Deybi melakukan perselingkuhan dengan Briptu Iryantho Simbolayuk yg berdinas di mabes polri kebayoran lama jakarta selatan sebagai yanma. Saya hanyalah sebatas teman dengan deybi, namun sih iryantho kerap menghubungi saya dan melakukan sweet text ke wa saya yg tidak pernah saya gubris secara serius. Iryantho dan saya bisa berkomunikasi karna selama deybi melakukan perselingkuhan dengan ian dia selalu menjadikan saya tameng ke calon suami/ke ian jika ingin diam diam bertemu atau setiap kali mereka ketahuan main belakang jd nomor saya di suka dihubungi oleh mereka bertiga ketika terjadi crash. Kemudian secara tbtb sih deybi menyampaikan saya telah minum dan tidur bareng dengan iryantho simbolayuk dan ngomel2in saya. Ketika saya tegur iryantho hany minta maaf saja tanpa melakukan pembelaan namun sih deybi masih keras kepala bahwa saya telah tidur bareng dan minum dengan iryantho dmn sy tidak pernah dan saya adalah Bhayangkari juga yg sudah tidak pernah bertemu dengan terlapor selama ini!!!!!. Saya tidak setuju pelecehan dan pencemaran nama baik yg dilakukan oleh iryantho sumbolayuk kepada Deybi sehingga saya di cap wanita tidak benar! Saya punya suami dan keluarga yg bahagia. Hal ini sngt mencemari citra polri dan mengganggu Bhayangkari! Mohon untuk di berikan teguran dan tindakan sebagaimana mestinya nilai nilai anggota polri.\",\"form_vendor\",\"Anonim\",\"Anonim\"],[\"TAF-20251013-00006\",\"Laporan Masuk\",1760349903528,\"polda jawa tengah\",null,null,null,null,\"Saya, Andi Pratama (28 tahun), bekerja sebagai pegawai administrasi di sebuah instansi pemerintahan di Kota Mandala. Kejadian ini terjadi pada Selasa, 23 Juli 2024, sekitar pukul 20.30 WIB di area parkir belakang kantor.\\n\\nSaat itu saya baru saja menyelesaikan pekerjaan lembur dan bersiap untuk pulang. Di lokasi tersebut hanya ada beberapa rekan kerja lain, dan suasana sudah cukup sepi. Tiba-tiba, seorang pria berpakaian dinas lengkap menghampiri saya dan memperkenalkan diri sebagai anggota Polsek Metro Jakarta Barat. Ia mengaku sedang melakukan patroli malam dan ingin memeriksa kendaraan saya.\\n\\nAwalnya saya tidak curiga. Namun, saat pemeriksaan berlangsung, perilaku pria tersebut mulai tidak profesional. Ia menanyakan hal-hal pribadi dan berusaha mendekat terlalu dekat secara fisik. Saya merasa tidak nyaman, namun mencoba tetap sopan. Ketika saya menolak ajakan untuk berbicara di tempat yang lebih sepi, ia mulai bersikap kasar dan melakukan tindakan yang saya anggap sebagai pelecehan fisik.\\n\\nSaya segera berlari ke arah pos keamanan kantor dan meminta bantuan petugas jaga. Petugas keamanan langsung menghubungi piket Polsek Metro Jakarta Barat\\n, dan beberapa menit kemudian dua anggota kepolisian datang ke lokasi untuk menindaklanjuti laporan saya. Setelah mendengar kronologi awal, saya diarahkan untuk membuat laporan resmi ke Polsek Metro Jakarta Barat\\n malam itu juga.\\n\\nKeesokan harinya, saya diminta memberikan keterangan tambahan di ruang Unit Reserse Kriminal (Reskrim). Pihak kepolisian kemudian mengonfirmasi bahwa pelaku benar merupakan anggota kepolisian aktif, namun saat kejadian sedang tidak bertugas. Berdasarkan arahan dari pimpinan kepolisian wilayah, kasus ini langsung diteruskan ke Bidang Profesi dan Pengamanan (Propam) Kepolisian Daerah Jakbar untuk pemeriksaan internal.\\n\\nPihak Polda Tambora kemudian melakukan penyelidikan internal, memeriksa saksi-saksi termasuk petugas keamanan kantor, dan menahan sementara pelaku di ruang tahanan Propam. Saya juga mendapat pendampingan dari Unit Pelayanan Perempuan dan Anak (PPA) selama proses pemeriksaan.\\n\\nProses pemeriksaan internal berlangsung sekitar dua minggu, dan hasilnya disampaikan bahwa pelaku terbukti melanggar kode etik kepolisian serta dikenai sanksi disiplin berat. Kasus pidana juga dilanjutkan ke kejaksaan setempat setelah berkas dinyatakan lengkap.\\n\\nSaya merasa lega karena laporan saya ditangani dengan serius dan profesional. Saya juga mendapat perlindungan serta pendampingan hukum hingga kasus selesai. Meskipun peristiwa ini meninggalkan trauma, saya bersyukur penanganannya cepat dan transparan.\",\"form_internal\",\"Anonim\",\"Anonim\"],[\"bf305323-0034-4ccb-ad25-1f9655fefb5f\",\"Laporan Masuk\",1760413580867,\"polda metro jaya\",null,null,null,null,\"Saya pertama kali bertugas bersama Aiptu Rosikin, rekan sesama anggota di Polres Metro Jakarta Barat, sekitar bulan Mei 2024. Pada awalnya, hubungan kerja kami berjalan profesional. Kami sering berkoordinasi terkait kegiatan administrasi dan patroli di wilayah Kebon Jeruk, Jakarta Barat. Namun, seiring waktu, sikapnya mulai berubah dan menunjukkan perilaku yang tidak pantas.\\n\\nAwalnya, ia sering melontarkan komentar bernada menggoda dan membuat saya merasa tidak nyaman, terutama saat kami sedang bertugas di lapangan maupun di kantor Polsek Metro Kebon Jeruk. Saya mencoba mengabaikannya, menganggap hal itu hanya candaan sesaat. Namun, perilaku tersebut semakin menjadi-jadi — ia mulai melakukan tindakan yang mengarah pada pelecehan secara verbal, seperti mengucapkan kalimat bernuansa seksual dan berusaha mendekati saya dengan cara yang tidak profesional.\\n\\nPada bulan Juli 2024, intensitas tindakan tersebut meningkat. Ia beberapa kali berusaha menyentuh tanpa izin saat berada di ruang administrasi, serta mengirim pesan pribadi bernada tidak pantas di luar jam dinas. Perilaku ini tidak hanya membuat saya merasa tidak aman, tetapi juga menimbulkan tekanan mental yang berat.\\n\\nSaya sempat mencoba menyelesaikan masalah ini secara pribadi dengan menegurnya secara baik-baik, namun tanggapan yang saya dapatkan justru berupa ejekan dan ancaman terselubung agar saya tidak melaporkan kejadian tersebut. Situasi ini menciptakan suasana kerja yang sangat tidak nyaman dan mengganggu fokus saya dalam menjalankan tugas di lingkungan Polsek Metro Kebon Jeruk.\",\"web_chat\",\"Anonim\",\"Anonim\"],[\"2025100637\",\"Laporan Masuk\",1759734930520,\"polda sumatera utara\",null,null,null,null,\"Pelapor datang ke Polsek untuk melaporkan kasus penganiayaan ringan terhadap anaknya. Namun, setelah pertemuan dengan penyidik, pelapor diminta “menghapus laporan” dengan alasan “masalah keluarga bisa diselesaikan damai.” Beberapa hari kemudian, pelapor mengetahui bahwa pihak terlapor (pelaku penganiayaan) masih bebas dan ternyata merupakan kerabat dari anggota polisi tersebut.\",null,\"Yupi Nasution\",\"Yupi Nasution\"],[\"2025100638\",\"Laporan Masuk\",1759736700662,\"polda metro jaya\",null,null,null,null,\"Saya mendapatkan kelakuan tidak baik oleh salah satu anggota kepolisian ketika saya melapor di Polda Metro Jaya.\\n\\n[GAMBAR] Gambar menunjukkan luka berwarna gelap pada kulit yang tampak seperti bekas pukulan atau luka bakar. Hal ini mungkin berkaitan dengan keluhan tentang perlakuan tidak baik dari anggota kepolisian saat melapor di Polda Metro Jaya.\\n\",null,\"Priyo\",\"Priyo\"]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\".ascfitur {\\n  border-radius: 0.625rem;\\n  border: 1px solid var(--black-100);\\n  cursor: pointer;\\n  display: flex;\\n  padding: 0.66667rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  background-color: var(--white);\\n}\\n\\n.ascfitur:hover {\\n  background: var(--primary);\\n  color: var(--white);\\n\\n}\\n\\n.ascfitur.active {\\n  background: var(--primary-50);\\n  color: var(--white);\\n\\n}\",\"js\":\"\",\"react\":\"import React, { useState, useCallback } from 'react';\\nimport { Button, Modal, Table, Row, Col } from 'react-bootstrap';\\nimport styled from 'styled-components';\\nimport { useLocation, useNavigate } from 'react-router-dom';\\n\\nexport default function MyCode({ widget, data, G }) {\\n  const dataArray = Array.isArray(data) ? data : [];\\n  const [showModal, setShowModal] = useState<boolean>(false);\\n  const [showModalDetail, setShowModalDetail] = useState<boolean>(false);\\n  const [showModalInfo, setShowModalInfo] = useState<boolean>(false);\\n  const [currentPage, setCurrentPage] = useState<number>(1);\\n  const [itemsPerPage] = useState<number>(5);\\n  const [detailSelected, setDetailSelected] = useState(null);\\n  const [infoSelected, setInfoSelected] = useState(null);\\n  const navigate = useNavigate();\\n  const location = useLocation();\\n  // Pagination logic\\n  const indexOfLastItem = currentPage * itemsPerPage;\\n  const indexOfFirstItem = indexOfLastItem - itemsPerPage;\\n  const currentItems =\\n    dataArray?.slice(indexOfFirstItem, indexOfLastItem) || [];\\n  const totalPages = Math.ceil((data?.length || 0) / itemsPerPage);\\n\\n  const shouldHideActions = (() => {\\n    const urlParams = new URLSearchParams(window.location.search);\\n    const source = urlParams.get('source');\\n    return source === 'cari-laporan';\\n  })();\\n\\n  const toggleRefresh = useCallback(() => {\\n    const widgetIds = [\\n      'dad5b834f5a7a46b8a119d6e54211dbd',\\n      '295a451dd09f9f90b84e651c4c65e98f',\\n      'b7b630239fb7ad396f2a432f47e876b2',\\n      '1d05ba6d572d5d65307ffd83ca1399d4',\\n      '36584f99010d42c82e9382364e9d32fe',\\n      'c142fd1f8dc040e6f5185f4837ce5aac',\\n      '63efe053dde43be7ee642a476a57c56c',\\n      'addbe2829134af0565c9a57e1feea20c',\\n      '1b4585af9dd59ba73d7b220c4b1a0a5a',\\n      '276335c580fea2d34dc22fb24038fb3e',\\n      'b3f9b775e59d281525035ad11b5028cf',\\n      '3478e4a441eb264e8c19d839a5218d8a',\\n      '45afafbd616d5ec96bb4b27b915da3de',\\n    ];\\n\\n    document.body.setAttribute('refresh-data', 'true');\\n\\n    widgetIds.forEach((widgetId) => {\\n      document.body.setAttribute('widget-id', widgetId);\\n\\n      document.body.dispatchEvent(\\n        new CustomEvent('refreshData', {\\n          detail: {\\n            refresh: true,\\n            widgetId,\\n          },\\n        }),\\n      );\\n    });\\n  }, []);\\n\\n  const getPerubahanValue = (item: any, key: string) => {\\n    switch (key) {\\n      case 'location':\\n        return (\\n          item?.location_change ||\\n          `${item?.old_location} -> ${item?.new_location}`\\n        );\\n      case 'case_position':\\n        return `${item?.old_values} -> ${item?.new_values}` || 'N/A';\\n      case 'rank_category':\\n        return `${item?.old_values} -> ${item?.new_values}` || 'N/A';\\n      case 'nik':\\n        return item?.nik || '3218884888392929 -> 3288383842231';\\n      case 'name':\\n        return item?.name || 'Jirayut -> Otten Kamali';\\n      case 'platform':\\n        return item?.platform || 'Telegram -> Website';\\n      case 'chronology':\\n        return item?.kronologi || '';\\n      default:\\n        return item?.[`${key}_change`] || 'Perubahan tidak tersedia';\\n    }\\n  };\\n\\n  const handleDetailClick = (item: any) => {\\n    setShowModalDetail(true);\\n    setDetailSelected(item);\\n  };\\n\\n  const handleCloseDetail = () => {\\n    setShowModalDetail(false);\\n    setDetailSelected(null);\\n  };\\n\\n  const handleInfoClick = (item: any) => {\\n    setShowModalInfo(true);\\n    setInfoSelected(item);\\n  };\\n\\n  const handleCloseInfo = () => {\\n    setShowModalInfo(false);\\n    setInfoSelected(null);\\n  };\\n\\n  const renderPagination = () => {\\n    if (totalPages <= 1) return null;\\n\\n    const pages = [];\\n    const maxVisiblePages = 5;\\n\\n    let startPage = Math.max(1, currentPage - Math.floor(maxVisiblePages / 2));\\n    let endPage = Math.min(totalPages, startPage + maxVisiblePages - 1);\\n\\n    if (endPage - startPage + 1 < maxVisiblePages) {\\n      startPage = Math.max(1, endPage - maxVisiblePages + 1);\\n    }\\n\\n    pages.push(\\n      <PaginationItem\\n        key=\\\"prev\\\"\\n        disabled={currentPage === 1}\\n        onClick={() => currentPage > 1 && setCurrentPage(currentPage - 1)}\\n      >\\n        &laquo;\\n      </PaginationItem>,\\n    );\\n\\n    if (startPage > 1) {\\n      pages.push(\\n        <PaginationItem\\n          key={1}\\n          active={1 === currentPage}\\n          onClick={() => setCurrentPage(1)}\\n        >\\n          1\\n        </PaginationItem>,\\n      );\\n      if (startPage > 2) {\\n        pages.push(\\n          <PaginationEllipsis key=\\\"start-ellipsis\\\">...</PaginationEllipsis>,\\n        );\\n      }\\n    }\\n\\n    for (let page = startPage; page <= endPage; page++) {\\n      pages.push(\\n        <PaginationItem\\n          key={page}\\n          active={page === currentPage}\\n          onClick={() => setCurrentPage(page)}\\n        >\\n          {page}\\n        </PaginationItem>,\\n      );\\n    }\\n\\n    if (endPage < totalPages) {\\n      if (endPage < totalPages - 1) {\\n        pages.push(\\n          <PaginationEllipsis key=\\\"end-ellipsis\\\">...</PaginationEllipsis>,\\n        );\\n      }\\n      pages.push(\\n        <PaginationItem\\n          key={totalPages}\\n          active={totalPages === currentPage}\\n          onClick={() => setCurrentPage(totalPages)}\\n        >\\n          {totalPages}\\n        </PaginationItem>,\\n      );\\n    }\\n\\n    pages.push(\\n      <PaginationItem\\n        key=\\\"next\\\"\\n        disabled={currentPage === totalPages}\\n        onClick={() =>\\n          currentPage < totalPages && setCurrentPage(currentPage + 1)\\n        }\\n      >\\n        &raquo;\\n      </PaginationItem>,\\n    );\\n\\n    return pages;\\n  };\\n\\n  const formatDateID = (dateString) => {\\n    if (!dateString) return 'NA';\\n\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return 'NA';\\n\\n    const hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n    const tahun = date.getFullYear().toString().slice(-2);\\n    const jam = date.getHours().toString().padStart(2, '0');\\n    const menit = date.getMinutes().toString().padStart(2, '0');\\n\\n    return `${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n  };\\n  // const goToDetail = () => {\\n  //   const basePath = location.pathname.split('/report')[0];\\n\\n  //   navigate(`${basePath}/report/laporan-pengaduan`);\\n  // };\\n\\n  // const goToDetail = () => {\\n  //   const queryParams = new URLSearchParams(window.location.search);\\n\\n  //   const source = queryParams.get('source');\\n\\n  //   const basePath = location.pathname.split('/report')[0];\\n\\n  //   const targetPage = source ? source : 'cari-laporan';\\n\\n  //   navigate(`${basePath}/report/${targetPage}`);\\n  // };\\n\\n  const goToDetail = () => {\\n    const queryParams = new URLSearchParams(window.location.search);\\n    const source = queryParams.get('source');\\n\\n    const basePath = location.pathname.split('/report')[0];\\n\\n    if (source === 'trimlap' || source === 'bagyanduan') {\\n      navigate(`${basePath}/internal-bidpropam/${source}`);\\n    } else {\\n      const targetPage = source ? source : 'cari-laporan';\\n      navigate(`${basePath}/report/${targetPage}`);\\n    }\\n  };\\n\\n  return (\\n    <>\\n      <div className=\\\"d-flex justify-space-between  py-4\\\">\\n        <Button\\n          variant=\\\"secondary\\\"\\n          className=\\\"d-flex gap-2 align-items-center\\\"\\n          style={{ height: '2.9rem' }}\\n          onClick={() => goToDetail()}\\n        >\\n          <i class=\\\"ph ph-caret-left\\\"></i> Kembali\\n        </Button>\\n\\n        {!shouldHideActions && (\\n          <div className=\\\"d-flex justify-content-end w-100\\\">\\n            <div className=\\\"d-flex gap-2\\\">\\n              <div\\n                className=\\\"ascfitur cursor-pointer\\\"\\n                onClick={(e) => {\\n                  e.stopPropagation();\\n                  toggleRefresh();\\n                }}\\n              >\\n                <div className=\\\"flex items-center gap-2 fs-14 fw-400\\\">\\n                  <i\\n                    className=\\\"ph ph-arrows-clockwise\\\"\\n                    style={{ fontSize: '1.2rem' }}\\n                  />\\n                </div>\\n              </div>\\n              <Button\\n                variant=\\\"secondary\\\"\\n                className=\\\"d-flex gap-2 align-items-center\\\"\\n                onClick={() => setShowModal(true)}\\n                style={{ height: '2.9rem' }}\\n              >\\n                <i class=\\\"ph ph-clock\\\"></i> Riwayat Edit\\n              </Button>\\n            </div>\\n          </div>\\n        )}\\n      </div>\\n      <ModalStyled\\n        centered\\n        size=\\\"lg\\\"\\n        show={showModal}\\n        onHide={() => setShowModal(false)}\\n        className={`${showModalDetail ? 'd-none' : 'd-block'}`}\\n      >\\n        <ModalHeader closeButton>\\n          <WrappIcon>\\n            <i\\n              className=\\\"ph-duotone ph-clock\\\"\\n              style={{ fontSize: '1.6rem', color: 'var(--primary)' }}\\n            ></i>\\n          </WrappIcon>\\n          <div className=\\\"d-flex flex-column gap-1\\\">\\n            <TitleHeader>Riwayat Edit</TitleHeader>\\n            <DescHeader>Berisi riwayat edit yang dilakukan petugas</DescHeader>\\n          </div>\\n        </ModalHeader>\\n        <ModalBody>\\n          <Table>\\n            <thead>\\n              <tr>\\n                <th style={{ width: '5%' }}>No</th>\\n                <th style={{ width: '45%' }}>Perubahan</th>\\n                <th style={{ width: '25%' }}>Petugas</th>\\n                <th style={{ width: '25%' }}>Tanggal</th>\\n              </tr>\\n            </thead>\\n            <tbody>\\n              {currentItems?.length === 0 ? (\\n                <tr>\\n                  <td colSpan={4}>\\n                    <WrappError>\\n                      <div className=\\\"flex flex-col items-center justify-center gap-4\\\">\\n                        <img\\n                          src=\\\"/cdn/media/fusion/assets/1731748832639/Group 1 (4).svg\\\"\\n                          alt=\\\"image-error\\\"\\n                        />\\n                        <p className=\\\"m-0\\\">Belum ada riwayat</p>\\n                      </div>\\n                    </WrappError>\\n                  </td>\\n                </tr>\\n              ) : (\\n                <>\\n                  {currentItems.map((item: any, index: number) => (\\n                    <tr key={indexOfFirstItem + index}>\\n                      <td>{indexOfFirstItem + index + 1}</td>\\n                      <td>\\n                        <WrappColumn>\\n                          {item.perubahan?.map((itemPer: any, idx: number) => (\\n                            <WrappPerubahan key={idx}>\\n                              <LabelPerubahan>\\n                                {itemPer.field_name}\\n                              </LabelPerubahan>\\n                              <svg\\n                                xmlns=\\\"http://www.w3.org/2000/svg\\\"\\n                                width=\\\"4\\\"\\n                                height=\\\"4\\\"\\n                                viewBox=\\\"0 0 4 4\\\"\\n                                fill=\\\"none\\\"\\n                              >\\n                                <circle cx=\\\"2\\\" cy=\\\"2\\\" r=\\\"2\\\" fill=\\\"#D9D9D9\\\" />\\n                              </svg>\\n                              {itemPer.field_name === 'detail' ? (\\n                                <Button\\n                                  variant=\\\"\\\"\\n                                  className=\\\"border-0 bg-transparent p-0 m-0 text-primary\\\"\\n                                  onClick={() => handleDetailClick(itemPer)}\\n                                >\\n                                  Lihat Detail Perubahan\\n                                </Button>\\n                              ) : itemPer.field_name === 'information' ? (\\n                                <Button\\n                                  variant=\\\"\\\"\\n                                  className=\\\"border-0 bg-transparent p-0 m-0 text-primary\\\"\\n                                  onClick={() => handleInfoClick(itemPer)}\\n                                >\\n                                  Lihat Information\\n                                </Button>\\n                              ) : (\\n                                <ValuePerubahan>\\n                                  {`${itemPer.old_values || 'N/A'} -> ${itemPer.new_values || 'N/A'}`}\\n                                </ValuePerubahan>\\n                              )}\\n                            </WrappPerubahan>\\n                          ))}\\n                        </WrappColumn>\\n                      </td>\\n                      <td>{item?.officer_name || 'N/A'}</td>\\n                      <td>{formatDateID(item?.updated_at)}</td>\\n                    </tr>\\n                  ))}\\n                </>\\n              )}\\n            </tbody>\\n          </Table>\\n\\n          {(data?.length || 0) > itemsPerPage && (\\n            <PaginationWrapper>\\n              <PaginationInfo>\\n                Menampilkan {indexOfFirstItem + 1}-\\n                {Math.min(indexOfLastItem, data?.length || 0)} dari{' '}\\n                {data?.length || 0} data\\n              </PaginationInfo>\\n              <PaginationContainer>{renderPagination()}</PaginationContainer>\\n            </PaginationWrapper>\\n          )}\\n        </ModalBody>\\n      </ModalStyled>\\n      <ModalStyled\\n        centered\\n        size=\\\"lg\\\"\\n        show={showModalDetail}\\n        onHide={handleCloseDetail}\\n      >\\n        <ModalHeader closeButton>\\n          <TitleHeader>Detail Perubahan Teknologi</TitleHeader>\\n        </ModalHeader>\\n        <ModalBody>\\n          <Row className=\\\"align-items-start\\\">\\n            <Col md={6}>\\n              <LeftDetail style={{ overflowY: 'auto', maxHeight: '45rem' }}>\\n                <ContentDetail>\\n                  {detailSelected?.old_values === 'null'\\n                    ? '-'\\n                    : detailSelected?.old_values}\\n                </ContentDetail>\\n              </LeftDetail>\\n            </Col>\\n            <Col md={6}>\\n              <RightDetail style={{ overflowY: 'auto', maxHeight: '45rem' }}>\\n                <ContentDetail>\\n                  {detailSelected?.new_values === 'null'\\n                    ? '-'\\n                    : detailSelected?.new_values}\\n                </ContentDetail>\\n              </RightDetail>\\n            </Col>\\n          </Row>\\n        </ModalBody>\\n      </ModalStyled>\\n      <ModalStyled\\n        centered\\n        size=\\\"lg\\\"\\n        show={showModalInfo}\\n        onHide={handleCloseInfo}\\n      >\\n        <ModalHeader closeButton>\\n          <TitleHeader>Detail Information</TitleHeader>\\n        </ModalHeader>\\n        <ModalBody>\\n          <Row className=\\\"align-items-start\\\">\\n            <Col md={6}>\\n              <LeftDetail style={{ overflowY: 'auto', maxHeight: '45rem' }}>\\n                <ContentDetail>\\n                  {infoSelected?.old_values === 'null'\\n                    ? '-'\\n                    : infoSelected?.old_values}\\n                </ContentDetail>\\n              </LeftDetail>\\n            </Col>\\n            <Col md={6}>\\n              <RightDetail style={{ overflowY: 'auto', maxHeight: '45rem' }}>\\n                <ContentDetail>\\n                  {infoSelected?.new_values === 'null'\\n                    ? '-'\\n                    : infoSelected?.new_values}\\n                </ContentDetail>\\n              </RightDetail>\\n            </Col>\\n          </Row>\\n        </ModalBody>\\n      </ModalStyled>\\n    </>\\n  );\\n}\\n\\nconst ModalStyled = styled(Modal)``;\\n\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst ModalBody = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n`;\\n\\nconst ModalFooter = styled(Modal.Footer)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem 1.06667rem 1.33333rem;\\n  justify-content: flex-end;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst DescHeader = styled.p`\\n  color: var(--black-400);\\n  font-size: 0.93333rem;\\n  font-style: normal;\\n  font-weight: 400;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst WrappColumn = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  justify-content: center;\\n  align-items: flex-start;\\n  gap: 0.26667rem;\\n`;\\n\\nconst WrappPerubahan = styled.div`\\n  display: flex;\\n  align-items: start;\\n  gap:0.53333rem;\\n`;\\n\\nconst LabelPerubahan = styled.p`\\n  color: var(--black);\\n  font-size: 0.8rem;\\n  font-style: normal;\\n  font-weight: 400;\\n  line-height: 140%;\\n  margin:0;\\n`;\\n\\nconst ValuePerubahan = styled.p`\\n  color: var(--black-400);\\n  font-size: 0.8rem;\\n  font-style: normal;\\n  font-weight: 400;\\n  line-height: 140%;\\n  margin:0;\\n`;\\n\\nconst PaginationWrapper = styled.div`\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n  width: 100%;\\n  margin-top: 1rem;\\n`;\\n\\nconst PaginationContainer = styled.div`\\n  display: flex;\\n  gap: 0.25rem;\\n`;\\n\\nconst PaginationItem = styled.div<{ active?: boolean; disabled?: boolean }>`\\n  display: flex;\\n  padding: 0.375rem 0.75rem;\\n  justify-content: center;\\n  align-items: center;\\n  border-radius: 0.25rem;\\n  border: 1px solid var(--black-100);\\n  background: ${(props) => (props.active ? 'var(--primary)' : 'white')};\\n  color: ${(props) => (props.active ? 'white' : 'var(--black)')};\\n  cursor: ${(props) => (props.disabled ? 'not-allowed' : 'pointer')};\\n  opacity: ${(props) => (props.disabled ? 0.5 : 1)};\\n  \\n  &:hover {\\n    background: ${(props) => (!props.disabled && !props.active ? 'var(--black-50)' : '')};\\n  }\\n`;\\n\\nconst PaginationEllipsis = styled.div`\\n  display: flex;\\n  padding: 0.375rem 0.75rem;\\n  justify-content: center;\\n  align-items: center;\\n  color: var(--black-400);\\n`;\\n\\nconst PaginationInfo = styled.span`\\n  color: var(--black-400);\\n  font-size: 0.8rem;\\n  font-style: normal;\\n  font-weight: 400;\\n`;\\n\\nconst LeftDetail = styled.div`\\n  display: flex;\\n  padding: 1.06667rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 0.53333rem;\\n  align-self: stretch;\\n  border-radius: 0.8rem;\\n  border: 1px solid var(--black-100);\\n  background: var(--black-50);\\n`;\\n\\nconst RightDetail = styled(LeftDetail)`\\n  background: var(--white);\\n`;\\n\\nconst ContentDetail = styled.p`\\n  color: var(--black);\\n  font-size: 0.93333rem;\\n  font-style: normal;\\n  font-weight: 400;\\n  line-height: 150%;\\n  margin:0;\\n`;\\n\\nconst WrappError = styled.div`\\n  display: flex;\\n  align-items:center;\\n  justify-content: center;\\n  height: 30rem;\\n  width:100%;\\n`;\\n\",\"html\":\" <div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100);border-radius:0.8rem;\\\">\\r\\n   <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n\\r\\n     <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n\\r\\n   </div>\\r\\n   <div class=\\\"px-2 py-4 \\\">\\r\\n     <div class=\\\"eui scroll\\\" style=\\\"height:16.8rem;\\\">\\r\\n       <div class=\\\"scroll-body\\\">\\r\\n         {{#each data as |item index| }}\\r\\n\\r\\n           <div class=\\\"flex items-start gap-2\\\">\\r\\n             <i class=\\\"ph ph-dot-outline\\\" style=\\\"color:var(--primary); font-size:2rem;\\\"></i>\\r\\n             <div class=\\\"flex flex-col\\\">\\r\\n               {{#if (eq item.status \\\"Masuk\\\")}}\\r\\n                 <div class=\\\"fs-16 fw-500\\\">{{item.status}}</div>\\r\\n                 <p class=\\\"fs-12 text-muted fw-400\\\" style=\\\"margin:0;\\\">\\r\\n                   {{dateFormat item.created_date \\\"DD MMM YYYY, HH:mm\\\"}} WIB\\r\\n                 </p>\\r\\n                 <p>{{item.responsible_person_name}}</p>\\r\\n               {{else if (eq item.status \\\"Dalam Penanganan\\\")}}\\r\\n                 <div class=\\\"fs-16 fw-500\\\">{{item.status}}</div>\\r\\n                 <p class=\\\"fs-12 text-muted fw-400\\\" style=\\\"margin:0;\\\">\\r\\n                   {{dateFormat item.updated_at \\\"DD MMM YYYY, HH:mm\\\"}} WIB\\r\\n                 </p>\\r\\n\\r\\n               {{else}}\\r\\n                 <div class=\\\"fs-16 fw-500\\\">{{item.status}}</div>\\r\\n                 <p class=\\\"fs-12 text-muted fw-400\\\" style=\\\"margin:0;\\\">\\r\\n                   {{dateFormat item.updated_at \\\"DD MMM YYYY, HH:mm\\\"}} WIB\\r\\n                 </p>\\r\\n               {{/if}}\\r\\n\\r\\n             </div>\\r\\n           </div>\\r\\n\\r\\n         {{/each}}\\r\\n       </div>\\r\\n     </div>\\r\\n   </div>\\r\\n </div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":false,\"dateFields\":\"\",\"childrenConfig\":{\"enable\":false},\"useAsFilterConfig\":{\"enable\":false}},\"x\":0,\"y\":0},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-23 23:12:19.835000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":23,\"id\":\"295a451dd09f9f90b84e651c4c65e98f\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"51b2f4333042aa434e00108d2d2a907f\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"query\":null,\"name\":\"Informasi Terlapor\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Informasi Pelapor\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":8,\"y\":37,\"w\":4,\"h\":23}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":4,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"295a451dd09f9f90b84e651c4c65e98f\":{\"table\":\"aduan_masyarakat_v3.\\\"prepetrator\\\"\",\"field\":\"id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"51b2f4333042aa434e00108d2d2a907f\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"name\",\"alias\":\"name\",\"name\":\"name\",\"type\":\"string\"},{\"field\":\"description\",\"alias\":\"description\",\"name\":\"description\",\"type\":\"string\"},{\"field\":\"division\",\"alias\":\"division\",\"name\":\"division\",\"type\":\"string\"},{\"field\":\"rank\",\"alias\":\"rank\",\"name\":\"rank\",\"type\":\"string\"},{\"field\":\"position\",\"alias\":\"position\",\"name\":\"position\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"date\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false}},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"prepetrator_id\",\"id\",\"sender_name\",\"reporter_nik\",\"phone_no\",\"email\",\"sender_address\",\"created_date\",\"source\",\"updated_at\"],[\"2026061400011-00001\",\"2026061400011\",\"TEST - Budi Santoso 2\",\"3273126709050005\",\"6281234567890\",null,\"Jl. Melati No. 12, RT 05 RW 03, Kel. Cipinang, Kec. Pulogadung, Jakarta Timur\",1781422516000,\"Surat dari Masyarakat\",1781420400000]],\"useAsFilterConfig\":{\"enable\":false},\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\".information {\\n  width: 10rem;\\n  font-weight: 500;\\n  color: var(--black);\\n}\\n\\n.flex.items-start.gap-2>div:last-child {\\n  flex: 1;\\n  word-break: break-word;\\n}\\n\\n\\n.report-body-container {\\n  scrollbar-gutter: stable;\\n\\n  overflow-y: hidden;\\n}\\n\\n.report-body-container:hover {\\n  overflow-y: overlay;\\n}\\n\\n\\n.report-body-container::-webkit-scrollbar {\\n  width: 6px;\\n}\\n\\n\\n.report-body-container::-webkit-scrollbar-track {\\n  background: transparent;\\n}\\n\\n.report-body-container::-webkit-scrollbar-thumb {\\n  background-color: transparent;\\n  border-radius: 10px;\\n}\\n\\n.report-body-container:hover::-webkit-scrollbar-thumb {\\n  background-color: rgba(0, 0, 0, 0.2);\\n}\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport styled from 'styled-components';\\n\\nconst DUMMY_DATA = [\\n  {\\n    name: '-',\\n    nik: '-',\\n    phone: '-',\\n    email: '-',\\n    category: '-',\\n    address: '-',\\n  },\\n];\\n\\nexport default function WidgetInfo({ widget, data = [] }) {\\n  const hasData = Array.isArray(data) && data.length > 0;\\n  const activeData = hasData ? data : DUMMY_DATA;\\n  const item = activeData[0];\\n\\n  const startCase = (str) => {\\n    if (!str) return '';\\n    return str\\n      .toString()\\n      .replace(/[_-]+/g, ' ')\\n      .replace(/([a-z])([A-Z])/g, '$1 $2')\\n      .split(' ')\\n      .map((word) => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())\\n      .join(' ');\\n  };\\n\\n  return (\\n    <Container>\\n      <Header>\\n        <div className=\\\"px-6 py-4 widget-title\\\">\\n          {widget?.name || 'Informasi Pelapor'}\\n        </div>\\n      </Header>\\n\\n      <div\\n        className=\\\"flex flex-col report-body-container\\\"\\n        style={{\\n          gap: '0.53333rem',\\n          padding: '16px',\\n          height: '78%',\\n        }}\\n      >\\n        <InfoGroup>\\n          <InfoRow>\\n            <Information>Nama</Information>\\n            <Value>{item?.sender_name || '-'}</Value>\\n          </InfoRow>\\n\\n          <InfoRow>\\n            <Information>NIK</Information>\\n            <Value>{item?.reporter_nik || '-'}</Value>\\n          </InfoRow>\\n\\n          <InfoRow>\\n            <Information>Nomor Telepon</Information>\\n            <Value>{item?.phone_no || '-'}</Value>\\n          </InfoRow>\\n\\n          {/* <InfoRow>\\n            <Information>Email</Information>\\n            <Value style={{ wordBreak: 'break-all' }}>\\n              {item?.email || '-'}\\n            </Value>\\n          </InfoRow> */}\\n\\n          <InfoRow>\\n            <Information>Sumber Aduan</Information>\\n            <Value style={{ wordBreak: 'break-all' }}>\\n              {item?.source ? startCase(item.source) : '-'}\\n            </Value>\\n          </InfoRow>\\n\\n          <InfoRow>\\n            <Information>Alamat</Information>\\n            <Value className=\\\"value\\\">{item?.sender_address || '-'}</Value>\\n          </InfoRow>\\n\\n          <InfoRow>\\n            <Information>Domisili</Information>\\n            <Value className=\\\"value\\\">{item?.sender_address || '-'}</Value>\\n          </InfoRow>\\n        </InfoGroup>\\n      </div>\\n    </Container>\\n  );\\n}\\n\\nconst Container = styled.div`\\n  background: var(--white);\\n  height: 100%;\\n  border: 1px solid var(--black-100, #e6e9f0);\\n  border-radius: 0.8rem;\\n`;\\n\\nconst Header = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  border-bottom: 1px solid var(--black-100, #e6e9f0);\\n  .widget-title {\\n    font-weight: 600;\\n    font-size: 1rem;\\n    color: var(--black);\\n  }\\n`;\\n\\nconst InfoGroup = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.8rem;\\n`;\\n\\nconst InfoRow = styled.div`\\n  display: flex;\\n  align-items: flex-start;\\n  gap: 0.5rem;\\n`;\\n\\nconst Information = styled.div`\\n  width: 10rem;\\n  font-weight: 400;\\n  color: var(--black-500);\\n  font-size: 14px;\\n`;\\n\\nconst Value = styled.div`\\n  flex: 1;\\n  font-size: 14px;\\n  font-weight: 400;\\n  color: var(--black);\\n`;\\n\",\"html\":\"<div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100); border-radius: 0.8rem;\\\">\\r\\n  <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n    <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n  </div>\\r\\n\\r\\n  <div class=\\\"px-6 py-4\\\">\\r\\n    {{#if data.length}}\\r\\n      <div class=\\\"flex flex-col\\\" style=\\\"gap: 0.53333rem;\\\">\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Nama</div>\\r\\n          <div>{{data.0.name}}</div>\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Pangkat</div>\\r\\n          {{#if data.0.rank}}\\r\\n            <div>{{_ 'startCase' data.0.rank}}</div>\\r\\n          {{else}}\\r\\n            <div>-</div>\\r\\n          {{/if}}\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Jabatan</div>\\r\\n          {{#if data.0.position}}\\r\\n            <div>{{_ 'startCase' data.0.position}}</div>\\r\\n          {{else}}\\r\\n            <div>-</div>\\r\\n          {{/if}}\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"flex items-start gap-2\\\">\\r\\n          <div class=\\\"information\\\">Fungsi</div>\\r\\n          {{#if data.0.sender_address}}\\r\\n            <div style=\\\"word-break: break-all;\\\">{{data.0.sender_address}}</div>\\r\\n          {{else}}\\r\\n            <div>-</div>\\r\\n          {{/if}}\\r\\n        </div>\\r\\n      </div>\\r\\n    {{else}}\\r\\n      <div class=\\\"flex flex-col items-center justify-center py-10 text-muted\\\">\\r\\n        <p class=\\\"m-0\\\">Belum ada data laporan</p>\\r\\n      </div>\\r\\n    {{/if}}\\r\\n  </div>\\r\\n</div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"hideWidget\":false,\"dateFields\":\"\",\"fullscreen\":false,\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":false,\"cache\":{\"status\":false},\"pageState\":true,\"customLimit\":{\"status\":false},\"orderColumn\":false,\"shareAPI\":\"\",\"childrenConfig\":{\"enable\":false,\"pageBykey\":[]},\"filterdByWorkspace\":false},\"x\":8,\"y\":37},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-23 23:12:19.835000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":31,\"id\":\"dad5b834f5a7a46b8a119d6e54211dbd\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"c732cb91b25e6df722edd4d551f174b0\",\"sourceId\":[\"e3dd3c5e53fa4350bb2d65e687708e7c\"],\"query\":null,\"name\":\"Informasi Dasar Laporan\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Informasi Dasar Laporan\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":8,\"y\":6,\"w\":4,\"h\":31}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"4d4a38a86d160d1b5d45ce4ebce39168\",\"w\":4,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"dad5b834f5a7a46b8a119d6e54211dbd\":{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"c732cb91b25e6df722edd4d551f174b0\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":true,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"c732cb91b25e6df722edd4d551f174b0\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\"}]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"id\",\"alias\":\"id\",\"name\":\"id\",\"type\":\"string\"},{\"field\":\"source\",\"alias\":\"title\",\"name\":\"source\",\"type\":\"string\"},{\"field\":\"created_date\",\"alias\":\"status\",\"name\":\"created_date\",\"type\":\"date\"},{\"field\":\"updated_at\",\"alias\":\"urgency_score_category\",\"name\":\"updated_at\",\"type\":\"number\"},{\"field\":\"phone_no\",\"alias\":\"type\",\"name\":\"phone_no\",\"type\":\"string\"},{\"field\":\"organization_unit\",\"alias\":\"method\",\"name\":\"organization_unit\",\"type\":\"string\"},{\"field\":\"type_of_violation\",\"alias\":\"created_date\",\"name\":\"type_of_violation\",\"type\":\"string\"},{\"field\":\"category\",\"alias\":\"phone_no\",\"name\":\"category\",\"type\":\"string\"},{\"field\":\"sub_category\",\"alias\":\"polda\",\"name\":\"sub_category\",\"type\":\"string\"},{\"field\":\"detail_where\",\"alias\":\"polres\",\"name\":\"detail_where\",\"type\":\"string\"},{\"field\":\"polda\",\"alias\":\"polsek\",\"name\":\"polda\",\"type\":\"string\"},{\"field\":\"polres\",\"alias\":\"category\",\"name\":\"polres\",\"type\":\"string\"},{\"field\":\"polsek\",\"alias\":\"type_of_violation\",\"name\":\"polsek\",\"type\":\"string\"},{\"field\":\"sub_status\",\"alias\":\"detail_where\",\"name\":\"sub_status\",\"type\":\"string\"},{\"field\":\"case_position\",\"alias\":\"updated_at\",\"name\":\"case_position\",\"type\":\"string\"},{\"field\":\"status\",\"alias\":\"status\",\"name\":\"status\",\"type\":\"string\"},{\"field\":\"latest_updated_at\",\"alias\":\"latest_updated_at\",\"name\":\"latest_updated_at\",\"type\":\"date\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customColorPalette\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"id\",\"prepetrator_id\",\"source\",\"created_date\",\"updated_at\",\"phone_no\",\"form_of_action\",\"organization_unit\",\"type_of_violation\",\"category\",\"sub_category\",\"detail_where\",\"ds_updated_at\",\"polda_disposisi\",\"polres\",\"sub_function\",\"police_level\",\"polsek\",\"sub_status\",\"police_function\",\"case_position\",\"polda\",\"unit_name\",\"document_number\",\"document_date\",\"hearing_decision_number\",\"hearing_decision_date\",\"hearing_date\",\"hearing_place\",\"case_handover\",\"status\",\"latest_updated_at\"],[\"2026071300180\",\"2026071300180-00001\",\"Surat dari Masyarakat\",\"2026-07-12 23:16:17\",\"2026-07-12 23:16:17\",\"6285262222103\",\"KOORDINASI DILAKUKAN LEBIH DARI SATU KALI UNTUK TUJUAN PENYIMPANGAN\",null,null,\"PENANGANAN PERKARA PIDANA\",\"PELANGGARAN PADA TAHAP PENYIDIKAN\",\"SPKT POLDA SUMUT TGL 10-3-2023\",1783898177000,null,null,null,null,null,null,null,\"DIV PROPAM MABES POLRI\",null,null,null,null,null,null,null,null,null,\"Laporan Masuk\",\"2026-07-12 23:16:17\"]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\".information {\\n  min-width: 10.66667rem;\\n  font-size: 14px;\\n  font-weight: 400;\\n  line-height: 140%;\\n  color: var(--black-500);\\n\\n}\\n\\n.value {\\n  font-size: 14px;\\n  font-weight: 400;\\n  line-height: 140%;\\n  color: var(--black);\\n  word-break: normal;\\n}\\n\\n.badge {\\n\\n\\n\\n  gap: 0.4rem;\\n\\n\\n  display: inline-block;\\n  padding: 0.26667rem 0.53333rem;\\n  font-size: 12px;\\n  font-weight: 600;\\n  border-radius: 0.4rem;\\n\\n\\n  white-space: normal;\\n\\n  word-break: break-word;\\n\\n  line-height: 1.4;\\n\\n  max-width: 100%;\\n  text-align: left;\\n}\\n\\n\\n.badge-bagyanduan {\\n  color: var(--success);\\n\\n  background: var(--success-25);\\n}\\n\\n\\n.badge-masuk {\\n  background: var(--black-50);\\n  color: var(--black);\\n}\\n\\n\\n\\n.badge-selesai {\\n  background: var(--success-50);\\n  color: var(--success);\\n}\\n\\n.badge-dikembalikan {\\n  color: var(--Secondary-Base, #FF6F00);\\n  background: var(--Secondary-Light, #FFF1E6);\\n}\\n\\n.badge-disposisi {\\n  background: var(--warning-50);\\n  color: var(--warning);\\n}\\n\\n.badge-verifikasi {\\n  background: var(--primary-50);\\n  color: var(--primary);\\n}\\n\\n.badge-high {\\n  background: var(--danger-50);\\n  color: var(--danger);\\n}\\n\\n.badge-medium {\\n  background: var(--warning-50);\\n  color: var(--warning);\\n\\n}\\n\\n.badge-low {\\n  background: var(--success-50);\\n  color: var(--success);\\n\\n}\\n\\n.badge-laporan {\\n  background: var(--white);\\n  border: 1px solid var(--primary-50);\\n  color: var(--primary);\\n}\\n\\n\\n.report-body-container {\\n  scrollbar-gutter: stable;\\n\\n  overflow-y: hidden;\\n}\\n\\n.report-body-container:hover {\\n  overflow-y: overlay;\\n}\\n\\n\\n.report-body-container::-webkit-scrollbar {\\n  width: 6px;\\n}\\n\\n\\n.report-body-container::-webkit-scrollbar-track {\\n  background: transparent;\\n}\\n\\n.report-body-container::-webkit-scrollbar-thumb {\\n  background-color: transparent;\\n  border-radius: 10px;\\n}\\n\\n.report-body-container:hover::-webkit-scrollbar-thumb {\\n  background-color: rgba(0, 0, 0, 0.2);\\n}\",\"js\":\"\",\"react\":\"import React from 'react';\\nconst dummyData = [\\n  {\\n    id: '-',\\n    status: '-',\\n    posisi: '-',\\n    urgency_score_category: '-',\\n    created_date: '-',\\n    detail_where: '-',\\n    type_of_violation: '-',\\n    category: '-',\\n    polda: '-',\\n    polres: '-',\\n    polsek: '-',\\n  },\\n  {\\n    id: '-',\\n    status: '-',\\n    posisi: '-',\\n    urgency_score_category: '-',\\n    created_date: '-',\\n    detail_where: '-',\\n    type_of_violation: '-',\\n    category: '-',\\n    polda: '-',\\n    polres: '-',\\n    polsek: '-',\\n  },\\n];\\n\\nexport default function MyCode({ widget, data, G }) {\\n  const activeData = data && data.length > 0 ? data : dummyData;\\n  const report = activeData[0];\\n\\n  const getStatusBadgeClass = (status) => {\\n    const s = status?.toLowerCase();\\n    if (s.includes('bagyanduan')) return 'badge-bagyanduan';\\n    if (s === 'Masuk') return 'badge-masuk';\\n    if (s === 'selesai' || s === 'disetujui') return 'badge-selesai';\\n    if (s === 'dikembalikan') return 'badge-dikembalikan';\\n    if (s === 'verifikasi') return 'badge-verifikasi';\\n    if (s === 'disposisi') return 'badge-disposisi';\\n    if (s === 'penanganan') return 'badge-penanganan';\\n    return '';\\n  };\\n\\n  const getUrgencyClass = (urgency) => {\\n    const u = urgency?.toLowerCase();\\n    if (u === 'tinggi') return 'badge-high';\\n    if (u === 'sedang') return 'badge-medium';\\n    if (u === 'rendah') return 'badge-low';\\n    return '';\\n  };\\n\\n  const formatText = (text) => {\\n    return text\\n      ? text.charAt(0).toUpperCase() + text.slice(1).toLowerCase()\\n      : '-';\\n  };\\n\\n  const formatDateID = (dateString) => {\\n    if (!dateString) return '-';\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return '-';\\n    const hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n    const tahun = date.getFullYear().toString().slice(-2);\\n    const jam = date.getHours().toString().padStart(2, '0');\\n    const menit = date.getMinutes().toString().padStart(2, '0');\\n    return `${hari}, ${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n  };\\n\\n  const statusStyle = {\\n    backgroundColor: 'var(--primary-25)',\\n    color: 'var(--primary)',\\n    display: 'flex',\\n    padding: '0.25rem 0.5rem',\\n    justifyContent: 'center',\\n    alignItems: 'center',\\n    borderRadius: '0.375rem',\\n    gap: '0.375rem',\\n    fontSize: '0.875rem',\\n    fontWeight: '500',\\n    display: 'inline-block',\\n  };\\n\\n  const subStatusStyle = {\\n    backgroundColor: 'var(--success-25)',\\n    color: 'var(--success)',\\n    display: 'flex',\\n    padding: '0.25rem 0.5rem',\\n    justifyContent: 'center',\\n    alignItems: 'center',\\n    borderRadius: '0.375rem',\\n    gap: '0.375rem',\\n    fontSize: '0.875rem',\\n    fontWeight: '500',\\n    display: 'inline-block',\\n  };\\n\\n  const statusOfSub = {\\n    backgroundColor: 'var(--warning-25)',\\n    color: '#FF6F00',\\n    display: 'flex',\\n    padding: '0.25rem 0.5rem',\\n    justifyContent: 'center',\\n    alignItems: 'center',\\n    borderRadius: '0.375rem',\\n    gap: '0.375rem',\\n    fontSize: '0.875rem',\\n    fontWeight: '500',\\n    display: 'inline-block',\\n  };\\n  return (\\n    <div\\n      className=\\\"bg-white h-100\\\"\\n      style={{ border: '1px solid var(--black-100)', borderRadius: '0.8rem' }}\\n    >\\n      <div\\n        className=\\\"flex flex-col\\\"\\n        style={{ borderBottom: '1px solid var(--black-100)', padding: '16px' }}\\n      >\\n        <div className=\\\"widget-title\\\">{widget?.name || 'Detail Laporan'}</div>\\n      </div>\\n\\n      {/* Body */}\\n\\n      <div\\n        className=\\\"flex flex-col report-body-container\\\"\\n        style={{\\n          gap: '0.53333rem',\\n          padding: '16px',\\n          height: '85%',\\n        }}\\n      >\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Nomor Laporan</div>\\n          <div className=\\\"value\\\">{report?.id}</div>\\n        </div>\\n        {/* Status Utama */}\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Status</div>\\n          <div style={statusStyle}>{report?.status}</div>\\n        </div>\\n\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Posisi Laporan</div>\\n          <div style={subStatusStyle}>{report?.case_position}</div>\\n        </div>\\n\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Sub Status</div>\\n          <div style={statusOfSub}>{report?.sub_status}</div>\\n        </div>\\n\\n        {/* Waktu Lapor */}\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Waktu Lapor</div>\\n          <div className=\\\"value\\\">\\n            {report?.created_date ? formatDateID(report.created_date) : '-'}\\n          </div>\\n        </div>\\n\\n        <div className=\\\"flex items-start\\\">\\n          <div className=\\\"information\\\">Lokasi Kejadian</div>\\n          <div\\n            className=\\\"value\\\"\\n            // style={{\\n            //   flex: 1,\\n            //   maxHeight: '4.2em',\\n            //   overflowY: 'auto',\\n            //   paddingRight: '8px',\\n            //   wordBreak: 'break-word',\\n            // }}\\n          >\\n            {report?.detail_where || '-'}\\n          </div>\\n        </div>\\n\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Kategori</div>\\n          <div className=\\\"value\\\">{formatText(report?.category)}</div>\\n        </div>\\n\\n        <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Sub Kategori</div>\\n          <div className=\\\"value\\\">{formatText(report?.sub_category)}</div>\\n        </div>\\n\\n          <div className=\\\"flex items-center\\\">\\n          <div className=\\\"information\\\">Wujud Perbuatan</div>\\n          <div className=\\\"value\\\">{formatText(report?.form_of_action)}</div>\\n        </div>\\n\\n        <div className=\\\"flex items-start\\\">\\n          <div className=\\\"information\\\">Satuan</div>\\n          <div className=\\\"flex flex-col\\\">\\n            <div className=\\\"value\\\">{formatText(report?.polda)}</div>\\n            <div className=\\\"value\\\">{formatText(report?.polres)}</div>\\n            {/* <div className=\\\"value\\\">{formatText(report?.polsek)}</div> */}\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  );\\n}\\n\",\"html\":\" <div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100);border-radius:0.8rem;\\\">\\r\\n   <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n\\r\\n     <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n\\r\\n   </div>\\r\\n   <div class=\\\"py-4 px-6\\\">\\r\\n     <div class=\\\"flex flex-col gap-2\\\">\\r\\n       <div class=\\\"fs-16 fw-400 flex items-center gap-2\\\">Nomor Tiket: <span class=\\\"fw-600\\\">{{data.0.id}}</span> </div>\\r\\n       <p class=\\\"fs-14 fw-400 text-muted\\\">{{data.0.title}}</[div]>\\r\\n\\r\\n     </div>\\r\\n     <div style=\\\"border-bottom: 1px solid var(--Border-Primary, #E6E9F0);margin-top:1.33333rem;\\\"></div>\\r\\n\\r\\n     <div class=\\\"flex flex-col\\\" style=\\\"gap:0.53333rem;margin-top:1.33333rem;\\\">\\r\\n\\r\\n\\r\\n       <div class=\\\"flex items-center\\\">\\r\\n         <div class=\\\"information\\\"> Status</div>\\r\\n         {{#if (eq data.0.status \\\"Masuk\\\")}}\\r\\n           <div class=\\\"badge badge-masuk fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else if (eq data.0.status \\\"selesai\\\")}}\\r\\n           <div class=\\\"badge badge-selesai fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else if (eq data.0.status \\\"dikembalikan\\\")}}\\r\\n           <div class=\\\"badge badge-dikembalikan fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else if (eq data.0.status \\\"disetujui\\\")}}\\r\\n           <div class=\\\"badge badge-selesai fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else if (eq data.0.status \\\"verifikasi\\\")}}\\r\\n           <div class=\\\"badge badge-verifikasi fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else if (eq data.0.status \\\"disposisi\\\")}}\\r\\n           <div class=\\\"badge badge-disposisi fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else if (eq data.0.status \\\"penanganan\\\")}}\\r\\n           <div class=\\\"badge badge-penanganan fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{else}}\\r\\n           <div class=\\\"badge fs-12 fw-600\\\">{{_ 'startCase' data.0.status}}</div>\\r\\n         {{/if}}\\r\\n       </div>\\r\\n\\r\\n       <!-- <div class=\\\"flex items-center\\\">\\r\\n         <div class=\\\"information\\\"> Status Penanganan</div>\\r\\n\\r\\n         <div class=\\\"badge fs-12 fw-600\\\">{{_ 'startCase' data.0.sub_status}}</div>\\r\\n\\r\\n       </div> -->\\r\\n\\r\\n\\r\\n       {{#if data.0.sub_status}}\\r\\n         <div class=\\\"flex items-center\\\">\\r\\n           <div class=\\\"information\\\">Status Penanganan</div>\\r\\n           <div class=\\\"badge fs-12 fw-600\\\">{{_ 'startCase' data.0.sub_status}}</div>\\r\\n         </div>\\r\\n       {{/if}}\\r\\n       <div class=\\\"flex items-center\\\">\\r\\n         <div class=\\\"information\\\"> Prioritas</div>\\r\\n         {{#if (eq data.0.urgency_score_category \\\"tinggi\\\")}}\\r\\n           <div class=\\\"badge badge-high fs-12 fw-600\\\">{{_ 'startCase' data.0.urgency_score_category}}</div>\\r\\n         {{else if (eq data.0.urgency_score_category \\\"sedang\\\")}}\\r\\n           <div class=\\\"badge badge-medium fs-12 fw-600\\\">{{_ 'startCase' data.0.urgency_score_category}}</div>\\r\\n         {{else if (eq data.0.urgency_score_category \\\"rendah\\\")}}\\r\\n           <div class=\\\"badge badge-low fs-12 fw-600\\\">{{_ 'startCase' data.0.urgency_score_category}}</div>\\r\\n         {{else}}\\r\\n           <div class=\\\"badge fs-12 fw-600\\\">{{_ 'startCase' data.0.urgency_score_category}}</div>\\r\\n         {{/if}}\\r\\n       </div>\\r\\n\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\"> Tipe Laporan</div>\\r\\n         <div class=\\\"badge badge-laporan fs-12 fw-600\\\"> {{_ 'startCase' data.0.type}}</div>\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\"> Platform</div>\\r\\n         <div class=\\\"badge badge-verifikasi fs-12 fw-600\\\">{{_ 'startCase' data.0.method}}</div>\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\"> Waktu Lapor</div>\\r\\n         {{#if data.0.created_date}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{dateFormat data.0.created_date \\\"DD MMMM YYYY,HH:mm\\\" }}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\"> Terakhir Update</div>\\r\\n         {{#if data.0.updated_at}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{dateFormat data.0.updated_at \\\"DD MMMM YYYY,HH:mm\\\"}}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\"> Nomor Telepon</div>\\r\\n         {{#if data.0.phone_no}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{data.0.phone_no}}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\">Level Kasus</div>\\r\\n         {{#if data.0.status_level}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.status_level}}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-start \\\">\\r\\n         <div class=\\\"information\\\"> Satuan</div>\\r\\n         <div class=\\\"flex flex-col\\\">\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.polda}}</div>\\r\\n           <div class=\\\"information\\\"></div>\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.polres}}</div>\\r\\n           <div class=\\\"information\\\"></div>\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.polsek}}</div>\\r\\n         </div>\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\">Posisi Kasus</div>\\r\\n         {{#if data.0.case_position}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.case_position}}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\">Satker / Satwil</div>\\r\\n         {{#if data.0.organization_unit}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.organization_unit}}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\">Kategori</div>\\r\\n         {{#if data.0.type_of_violation}}\\r\\n           <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.type_of_violation}}</div>\\r\\n         {{else}}\\r\\n           -\\r\\n         {{/if}}\\r\\n\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\">Sub Kategori</div>\\r\\n         <div class=\\\"fs-14 fw-400\\\"> {{_ 'startCase' data.0.category}}</div>\\r\\n       </div>\\r\\n\\r\\n       <div class=\\\"flex items-center \\\">\\r\\n         <div class=\\\"information\\\">Lokasi</div>\\r\\n         {{#if data.0.detail_where}}\\r\\n           <div class=\\\"fs-14 fw-400\\\">{{data.0.detail_where}}</div>\\r\\n         {{else}}\\r\\n           <div>-</div>\\r\\n         {{/if}}\\r\\n\\r\\n       </div>\\r\\n     </div>\\r\\n   </div>\\r\\n </div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":false,\"dateFields\":[],\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":false,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false},\"shareAPI\":\"\",\"useAsFilterConfig\":{\"enable\":false},\"pageState\":true,\"orderColumn\":false,\"childrenConfig\":{\"enable\":false,\"pageBykey\":[]},\"filtersGeneral\":{\"type\":\"\"},\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false},\"x\":8,\"y\":6},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-23 23:12:19.835000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":49,\"id\":\"36584f99010d42c82e9382364e9d32fe\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"96d2527795a0b17ff4e890d36ad660fe\",\"sourceId\":[\"e3dd3c5e53fa4350bb2d65e687708e7c\"],\"query\":null,\"name\":\"Detail laporan\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Detail laporan\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":61,\"w\":8,\"h\":49}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"4d4a38a86d160d1b5d45ce4ebce39168\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Detail laporan\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"36584f99010d42c82e9382364e9d32fe\":{\"table\":\"aduan_masyarakat_v3.\\\"report_comment\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"96d2527795a0b17ff4e890d36ad660fe\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":true,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[{\"table\":\"aduan_masyarakat_v3.\\\"prepetrator\\\"\",\"field\":\"id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"96d2527795a0b17ff4e890d36ad660fe\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\"}]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"prepetrator_id\",\"alias\":\"prepetrator_id\",\"name\":\"prepetrator_id\",\"type\":\"string\"},{\"field\":\"id\",\"alias\":\"id\",\"name\":\"id\",\"type\":\"string\"},{\"field\":\"summary\",\"alias\":\"summary\",\"name\":\"summary\",\"type\":\"string\"},{\"field\":\"detail\",\"alias\":\"detail\",\"name\":\"detail\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"date\"},{\"field\":\"comment\",\"alias\":\"comment\",\"name\":\"comment\",\"type\":\"string\"},{\"field\":\"comment_date\",\"alias\":\"comment_date\",\"name\":\"comment_date\",\"type\":\"date\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false}},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"prepetrator_id\",\"id\",\"summary\",\"detail\",\"updated_at\",\"comment\",\"comment_date\"],[\"2026070901002-00001\",\"2026070901002\",\"Pada Rabu, 17 Juni 2026 pukul 10.20 WIB, masyarakat melaporkan bahwa beberapa anggota Polri di Polsek Cendana diduga meninggalkan tugas tanpa izin selama jam dinas. Sejak pukul 08.00 WIB, anggota-anggota tersebut tidak hadir di kantor dan tidak memberi pemberitahuan kepada atasan maupun rekan piket. Mereka kemudian terlihat berada di warung kopi di luar wilayah tugas, sebagaimana terlihat dalam foto dan video yang dikumpulkan. Anggota yang teridentifikasi adalah Briptu FH, Bripda AR, Brigpol DS, dan Aipda RK, yang masing-masing bertugas di pelayanan masyarakat dan patroli. Kejadian ini menimbulkan dugaan pelanggaran disiplin berupa ketidakhadiran tanpa izin, kelalaian dalam pelaksanaan tugas, dan pengabaian tanggung jawab kedinasan.\",\"Pada hari Rabu, 17 Juni 2026 sekitar pukul 10.20 WIB, diperoleh informasi dari masyarakat mengenai dugaan pelanggaran disiplin oleh beberapa anggota Polri yang diduga meninggalkan tugas tanpa izin pada saat jam dinas berlangsung. Kejadian tersebut diketahui terjadi di lingkungan kantor Polsek Cendana, saat para anggota yang bersangkutan seharusnya melaksanakan piket pelayanan dan pengamanan wilayah. Berdasarkan keterangan rekan kerja, sejak pukul 08.00 WIB beberapa anggota tidak berada di tempat tanpa pemberitahuan kepada atasan maupun personel piket lainnya, sehingga menyebabkan pelayanan kepada masyarakat mengalami keterlambatan. Setelah dilakukan penelusuran, diketahui bahwa anggota-anggota tersebut berada di sebuah warung kopi di luar wilayah tugas bersama-sama dalam keadaan tidak menjalankan tugas kedinasan. Informasi tersebut diperkuat dengan dokumentasi foto dan video yang menunjukkan keberadaan mereka di lokasi pada saat jam dinas masih berlangsung. Berdasarkan identifikasi awal, anggota yang diduga terlibat diketahui berinisial Briptu FH, Bripda AR, Brigpol DS, dan Aipda RK, yang masing-masing bertugas pada fungsi pelayanan masyarakat dan patroli. Atas kejadian tersebut, terdapat dugaan pelanggaran disiplin berupa ketidakhadiran tanpa izin, kelalaian dalam pelaksanaan tugas, serta pengabaian tanggung jawab kedinasan, sehingga diperlukan pemeriksaan lebih lanjut untuk memastikan motif, peran masing-masing, dan tingkat pelanggaran yang dilakukan.\",1783633453326,\"masukan lah\",\"2026-07-10 06:37:57\"],[\"2026070901002-00001\",\"2026070901002\",\"Pada Rabu, 17 Juni 2026 pukul 10.20 WIB, masyarakat melaporkan bahwa beberapa anggota Polri di Polsek Cendana diduga meninggalkan tugas tanpa izin selama jam dinas. Sejak pukul 08.00 WIB, anggota-anggota tersebut tidak hadir di kantor dan tidak memberi pemberitahuan kepada atasan maupun rekan piket. Mereka kemudian terlihat berada di warung kopi di luar wilayah tugas, sebagaimana terlihat dalam foto dan video yang dikumpulkan. Anggota yang teridentifikasi adalah Briptu FH, Bripda AR, Brigpol DS, dan Aipda RK, yang masing-masing bertugas di pelayanan masyarakat dan patroli. Kejadian ini menimbulkan dugaan pelanggaran disiplin berupa ketidakhadiran tanpa izin, kelalaian dalam pelaksanaan tugas, dan pengabaian tanggung jawab kedinasan.\",\"Pada hari Rabu, 17 Juni 2026 sekitar pukul 10.20 WIB, diperoleh informasi dari masyarakat mengenai dugaan pelanggaran disiplin oleh beberapa anggota Polri yang diduga meninggalkan tugas tanpa izin pada saat jam dinas berlangsung. Kejadian tersebut diketahui terjadi di lingkungan kantor Polsek Cendana, saat para anggota yang bersangkutan seharusnya melaksanakan piket pelayanan dan pengamanan wilayah. Berdasarkan keterangan rekan kerja, sejak pukul 08.00 WIB beberapa anggota tidak berada di tempat tanpa pemberitahuan kepada atasan maupun personel piket lainnya, sehingga menyebabkan pelayanan kepada masyarakat mengalami keterlambatan. Setelah dilakukan penelusuran, diketahui bahwa anggota-anggota tersebut berada di sebuah warung kopi di luar wilayah tugas bersama-sama dalam keadaan tidak menjalankan tugas kedinasan. Informasi tersebut diperkuat dengan dokumentasi foto dan video yang menunjukkan keberadaan mereka di lokasi pada saat jam dinas masih berlangsung. Berdasarkan identifikasi awal, anggota yang diduga terlibat diketahui berinisial Briptu FH, Bripda AR, Brigpol DS, dan Aipda RK, yang masing-masing bertugas pada fungsi pelayanan masyarakat dan patroli. Atas kejadian tersebut, terdapat dugaan pelanggaran disiplin berupa ketidakhadiran tanpa izin, kelalaian dalam pelaksanaan tugas, serta pengabaian tanggung jawab kedinasan, sehingga diperlukan pemeriksaan lebih lanjut untuk memastikan motif, peran masing-masing, dan tingkat pelanggaran yang dilakukan.\",1783633453326,\"Laporan ini jelas mencakup dugaan pelanggaran disiplin oleh anggota Polri yang berpotensi menimbulkan dampak negatif terhadap pelayanan publik dan reputasi institusi. Karena laporan menyertakan kronologi terperinci, bukti foto dan video, serta identifikasi nama-nama anggota, maka laporan ini memenuhi kriteria validitas bukti dan relevansi. Sebagai langkah awal, Divpropam harus memulai penyelidikan internal dengan memanggil saksi, memverifikasi rekaman video, dan meninjau catatan kehadiran anggota terkait. Jika bukti konfirmasi ditemukan, maka dapat dilanjutkan dengan rekomendasi sanksi sesuai kebijakan disiplin. Jika tidak ada bukti yang cukup, maka laporan dapat ditolak. Namun, pada tahap ini, laporan harus diproses lebih lanjut.\",\"2026-07-09 05:14:35\"]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"let isSubmittingMasukan = false;\\r\\nlet masukanSubmitHandler = null;\\r\\n\\r\\nfunction setupMasukanListener() {\\r\\n    const form = document.getElementById(\\\"generateForm\\\");\\r\\n    if (!form) return false;\\r\\n\\r\\n    if (masukanSubmitHandler) {\\r\\n        form.removeEventListener(\\\"submit\\\", masukanSubmitHandler);\\r\\n    }\\r\\n\\r\\n    masukanSubmitHandler = async function(event) {\\r\\n        event.preventDefault();\\r\\n        event.stopImmediatePropagation();\\r\\n\\r\\n        if (isSubmittingMasukan) {\\r\\n            console.log(\\\"Submit masukan diabaikan (duplikat)\\\");\\r\\n            return;\\r\\n        }\\r\\n\\r\\n        isSubmittingMasukan = true;\\r\\n        console.log(\\\"Submit masukan dipanggil\\\");\\r\\n\\r\\n        const submitButton = document.getElementById(\\\"generateButton\\\");\\r\\n        const commentInput = document.getElementById(\\\"inputComment\\\");\\r\\n        const reportId = document.getElementById(\\\"idReport\\\");\\r\\n\\r\\n        if (!commentInput || !reportId) {\\r\\n            alert(\\\"Form masukan tidak lengkap.\\\");\\r\\n            isSubmittingMasukan = false;\\r\\n            return;\\r\\n        }\\r\\n\\r\\n        const comment = commentInput.value.trim();\\r\\n        if (!comment) {\\r\\n            alert(\\\"Masukan tidak boleh kosong.\\\");\\r\\n            isSubmittingMasukan = false;\\r\\n            return;\\r\\n        }\\r\\n\\r\\n        if (submitButton) {\\r\\n            submitButton.disabled = true;\\r\\n            submitButton.innerHTML = \\\"Mengirim...\\\";\\r\\n        }\\r\\n\\r\\n\\r\\n        const payload = {\\r\\n            client: \\\"Propam Polri\\\",\\r\\n            gatewayId: \\\"db03aa6e4d166c5682c766441f49a53b\\\",\\r\\n            params: {\\r\\n                id: reportId.value,\\r\\n                comment: comment,\\r\\n            },\\r\\n            body: {},\\r\\n            headers: {},\\r\\n            additionalPath: \\\"\\\",\\r\\n            additionalParams: {},\\r\\n            tags: [\\\"aduan_propam\\\"],\\r\\n            createdBy: \\\"Aduan Propam\\\",\\r\\n            startDate: \\\"\\\",\\r\\n            endDate: \\\"\\\",\\r\\n            dashboardId: \\\"\\\",\\r\\n            sessionId: \\\"\\\",\\r\\n            logging: true,\\r\\n            appendedLog: true,\\r\\n        };\\r\\n\\r\\n        try {\\r\\n            console.log(\\\" Eksekusi fetch masukan...\\\", payload);\\r\\n\\r\\n            const response = await fetch(\\\"/api/v1/apps/api/gateway/execute\\\", {\\r\\n                method: \\\"POST\\\",\\r\\n                headers: {\\r\\n                    \\\"Content-Type\\\": \\\"application/json\\\",\\r\\n                },\\r\\n                body: JSON.stringify(payload),\\r\\n            });\\r\\n\\r\\n            if (response.ok) {\\r\\n                const result = await response.json();\\r\\n                console.log(\\\" Masukan berhasil:\\\", result);\\r\\n                alert(\\\"Masukan berhasil dikirim!\\\");\\r\\n                setTimeout(() => window.location.reload(), 2000);\\r\\n            } else {\\r\\n                const text = await response.text();\\r\\n                console.error(\\\" Gagal:\\\", text);\\r\\n                alert(\\\"Gagal mengirim masukan: \\\" + text);\\r\\n            }\\r\\n        } catch (err) {\\r\\n            console.error(\\\"Error:\\\", err);\\r\\n            alert(\\\"Terjadi kesalahan: \\\" + err.message);\\r\\n        } finally {\\r\\n            if (submitButton) {\\r\\n                submitButton.disabled = false;\\r\\n                submitButton.innerHTML = \\\"Kirim\\\";\\r\\n            }\\r\\n            isSubmittingMasukan = false;\\r\\n        }\\r\\n    };\\r\\n\\r\\n\\r\\n    form.addEventListener(\\\"submit\\\", masukanSubmitHandler);\\r\\n    console.log(\\\"✅ Listener masukan terpasang\\\");\\r\\n    return true;\\r\\n}\\r\\n\\r\\n\\r\\nif (document.readyState === \\\"loading\\\") {\\r\\n    document.addEventListener(\\\"DOMContentLoaded\\\", setupMasukanListener);\\r\\n} else {\\r\\n    setupMasukanListener();\\r\\n}\",\"react\":\"import React, { useState } from 'react';\\nimport styled from 'styled-components';\\n\\nconst WidgetWrapper = styled.div`\\n  background: var(--white);\\n  height: 100%;\\n  border: 1px solid var(--black-100, #e6e9f0);\\n  border-radius: 0.8rem;\\n  display: flex;\\n  flex-direction: column;\\n  overflow: hidden;\\n`;\\n\\nconst HeaderSection = styled.div`\\n  padding: 1rem 1.5rem;\\n  border-bottom: 1px solid var(--black-100);\\n  .widget-title { font-weight: 600; font-size: 1rem; color: var(--black); }\\n`;\\n\\nconst ContentSection = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  flex: 1;\\n  min-height: 0;\\n  overflow: hidden; \\n`;\\n\\nconst SectionGap = styled.div`\\n  display: flex; flex-direction: column; gap: 1.5rem; padding: 1rem 1.5rem;\\n`;\\n\\nconst InfoCard = styled.div`\\n  display: flex; padding: 1rem; flex-direction: column; gap: 0.5rem;\\n  border-radius: 0.5rem; background: var(--primary-25);\\n`;\\n\\nconst Label = styled.div`\\n  font-size: 0.875rem; font-weight: 600; margin-bottom: 0.25rem;\\n`;\\n\\nconst ScrollBox = styled.div`\\n  font-size: 0.875rem; line-height: 1.5; max-height: ${(props) => props.maxHeight || '7.5rem'};\\n  overflow-y: auto; padding-right: 0.5rem;\\n  &::-webkit-scrollbar { width: 4px; }\\n  &::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }\\n`;\\n\\nconst CommentSection = styled.div`\\n  border-top: 1px solid var(--black-100);\\n  display: flex;\\n  flex-direction: column;\\n  flex: 1; \\n  min-height: 200px; \\n  overflow: hidden; \\n`;\\n\\nconst CommentCard = styled.div`\\n  padding: 1rem; background: var(--black-25); \\n  border-bottom: 1px solid var(--black-100);\\n  display: flex; flex-direction: column; gap: 0.5rem;\\n`;\\n\\nconst CommentHeader = styled.div`\\n  display: flex; \\n  justify-content: space-between; \\n  align-items: center;\\n  color: var(--black-500); \\n\\n  font-size: 0.875rem;\\n`;\\n\\nconst InputFooter = styled.div`\\n  padding: 1rem 1.5rem; \\n  border-top: 1px solid var(--black-100); \\n  background: var(--white);\\n`;\\n\\nconst StyledInput = styled.input`\\n  flex: 1; \\n  padding: 0.6rem 1rem; \\n  border: 1px solid var(--black-100); \\n  border-radius: 0.5rem;\\n  font-size: 0.875rem; \\n  outline: none;\\n  background-color:var(--white);\\n  &:focus { border-color: #2374AB; }\\n`;\\n\\nconst SendButton = styled.button`\\n  background: var(--primary); \\n  color: #ffff; \\n  padding: 0.6rem 1.25rem; \\n  border-radius: 0.5rem;\\n  border: none; \\n  font-size: 0.875rem; \\n  font-weight: 500; \\n  cursor: pointer;\\n  &:disabled { opacity: 0.6; cursor: not-allowed; }\\n`;\\n\\nconst CommentListWrapper = styled.div`\\n  flex: 1;\\n  overflow-y: auto;\\n  min-height: 0; \\n  background: var(--white);\\n  &::-webkit-scrollbar { width: 4px; }\\n  &::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }\\n`;\\n\\nexport default function MyCode({ widget, data }) {\\n  const [comment, setComment] = useState('');\\n  const [isSubmitting, setIsSubmitting] = useState(false);\\n\\n  const reportData = data?.[0] ?? {};\\n  // const displayComments = reportData?.comments ?? {};\\n   const displayComments = data\\n    ?.filter(item => item?.comment && item.comment.trim() !== '')\\n    ?.map(item => ({\\n      comment: item.comment,\\n      comment_date: item.comment_date\\n    }))\\n    ?.reverse() ?? []; \\n\\n  const formatDateID = (dateString) => {\\n    if (!dateString) return '-';\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return '-';\\n    const hari = date.toLocaleDateString('id-ID', { weekday: 'long' });\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = date.toLocaleDateString('id-ID', { month: 'short' });\\n    const tahun = date.getFullYear().toString().slice(-2);\\n    const jam = date.getHours().toString().padStart(2, '0');\\n    const menit = date.getMinutes().toString().padStart(2, '0');\\n    return `${hari}, ${tanggal} ${bulan} ${tahun}, ${jam}:${menit}`;\\n  };\\n\\n  const handleSubmit = async (e) => {\\n    e.preventDefault();\\n    const cleanComment = comment.trim();\\n    if (!cleanComment || isSubmitting) return;\\n\\n    setIsSubmitting(true);\\n    const payload = {\\n      client: 'Propam Polri',\\n      gatewayId: 'db03aa6e4d166c5682c766441f49a53b',\\n      params: {\\n        id: reportData?.id,\\n        prepetrator_id: reportData?.prepetrator_id,\\n        comment: cleanComment,\\n      },\\n      tags: ['aduan_propam'],\\n      createdBy: 'Aduan Propam',\\n      logging: true,\\n      appendedLog: true,\\n    };\\n\\n    try {\\n      const response = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(payload),\\n      });\\n\\n      if (response.ok) {\\n        alert('Masukan berhasil dikirim!');\\n        setComment('');\\n        // window.location.reload();\\n      }\\n    } catch (err) {\\n      console.error(err);\\n    } finally {\\n      setIsSubmitting(false);\\n    }\\n  };\\n\\n  return (\\n    <WidgetWrapper>\\n      <HeaderSection>\\n        <div className=\\\"widget-title\\\">{widget?.name}</div>\\n      </HeaderSection>\\n\\n      <ContentSection>\\n        <SectionGap>\\n          <InfoCard>\\n            <Label>Ringkasan Laporan</Label>\\n            <ScrollBox maxHeight=\\\"6rem\\\">{reportData.summary || '-'}</ScrollBox>\\n          </InfoCard>\\n          <div>\\n            <Label>Kronologi</Label>\\n            <ScrollBox maxHeight=\\\"14.6rem\\\">\\n              {reportData.detail || '-'}\\n            </ScrollBox>\\n          </div>\\n        </SectionGap>\\n\\n        <CommentSection>\\n          <div style={{ padding: '0.8rem 1.5rem' }}>\\n            <Label style={{ margin: 0 }}>Catatan</Label>\\n          </div>\\n\\n          <CommentListWrapper>\\n            {displayComments.length > 0 ? (\\n              displayComments.map(\\n                (item, index) =>\\n                  item.comment && (\\n                    <CommentCard key={index}>\\n                      <CommentHeader>\\n                        <div\\n                          style={{\\n                            display: 'flex',\\n                            alignItems: 'center',\\n                            gap: '8px',\\n                          }}\\n                        >\\n                          <i className=\\\"ph ph-user\\\"></i>\\n                          <div>Propam Polri</div>\\n                        </div>\\n                        <span>{formatDateID(item.comment_date)}</span>\\n                      </CommentHeader>\\n                      <div style={{ fontSize: '0.875rem' }}>{item.comment}</div>\\n                    </CommentCard>\\n                  ),\\n              )\\n            ) : (\\n              <div\\n                style={{\\n                  textAlign: 'center',\\n                  color: '#64748b',\\n                  padding: '1rem',\\n                  fontSize: '14px',\\n                }}\\n              >\\n                Belum ada masukan\\n              </div>\\n            )}\\n          </CommentListWrapper>\\n\\n          <InputFooter>\\n            <form\\n              onSubmit={handleSubmit}\\n              style={{ display: 'flex', gap: '0.5rem' }}\\n            >\\n              <StyledInput\\n                type=\\\"text\\\"\\n                placeholder=\\\"Tulis masukan...\\\"\\n                value={comment}\\n                onChange={(e) => setComment(e.target.value)}\\n                disabled={isSubmitting}\\n              />\\n              <SendButton type=\\\"submit\\\" disabled={isSubmitting}>\\n                {isSubmitting ? '...' : 'Kirim'}\\n              </SendButton>\\n            </form>\\n          </InputFooter>\\n        </CommentSection>\\n      </ContentSection>\\n    </WidgetWrapper>\\n  );\\n}\\n\",\"html\":\"<div class=\\\"h-100\\\">\\r\\n  <div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100); border-radius: 0.8rem; display: flex; flex-direction: column;\\\">\\r\\n\\r\\n    <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n      <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n    </div>\\r\\n\\r\\n    <div class=\\\"flex flex-col flex-1\\\">\\r\\n\\r\\n      <div class=\\\"flex flex-col gap-6 py-4 px-6 w-100\\\">\\r\\n\\r\\n        <div class=\\\"flex flex-col gap-2\\\">\\r\\n          <div class=\\\"fs-14 fw-600\\\">Kronologi</div>\\r\\n          <div class=\\\"eui scroll\\\" style=\\\"height:7.5rem\\\">\\r\\n            <div class=\\\"scroll-body\\\">\\r\\n              <div class=\\\"fs-14 fw-400 w-100\\\">{{data.0.detail}}</div>\\r\\n            </div>\\r\\n          </div>\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"style-card-laporan p-4 w-100\\\">\\r\\n          <div class=\\\"fs-14 fw-600\\\">Ringkasan Laporan</div>\\r\\n          <div class=\\\"eui scroll\\\" style=\\\"height:6rem\\\">\\r\\n            <div class=\\\"scroll-body\\\">\\r\\n              <div class=\\\"fs-14 fw-400 w-100\\\">{{data.0.summary}}</div>\\r\\n            </div>\\r\\n          </div>\\r\\n        </div>\\r\\n      </div>\\r\\n\\r\\n\\r\\n      <div class=\\\"flex flex-col h-full\\\" style=\\\"border-top: 1px solid var(--black-100);\\\">\\r\\n\\r\\n        <div class=\\\"py-4 px-6\\\" style=\\\"border-bottom: 1px solid var(--black-100);\\\">\\r\\n          <div class=\\\"widget-title\\\">Catatan</div>\\r\\n        </div>\\r\\n\\r\\n        <div class=\\\"eui scroll\\\" style=\\\"max-height: 14rem;\\\">\\r\\n          <div class=\\\"scroll-body flex flex-col gap-3\\\">\\r\\n            {{#if data.length}}\\r\\n              {{#each data as |item index|}}\\r\\n                {{#unless (eq item.comment null)}}\\r\\n                  <div class=\\\"style-card-masukan\\\">\\r\\n                    <div class=\\\"flex justify-between items-center\\\">\\r\\n                      <div class=\\\"flex items-center gap-2\\\">\\r\\n                        <i class=\\\"ph ph-user\\\"></i>\\r\\n                        <div class=\\\"fs-14 fw-400 text-muted\\\">Propam Polri</div>\\r\\n                      </div>\\r\\n                      <div class=\\\"fs-14 fw-400 text-muted\\\">\\r\\n                        {{dateFormatId item.comment_date \\\"dddd, DD MMMM YYYY\\\"}}\\r\\n                      </div>\\r\\n                    </div>\\r\\n                    <div class=\\\"fs-14 fw-400\\\">\\r\\n                      {{{marked item.comment}}}\\r\\n                    </div>\\r\\n                  </div>\\r\\n                {{/unless}}\\r\\n              {{/each}}\\r\\n            {{else}}\\r\\n              <div class=\\\"fs-14 text-muted text-center py-4\\\">\\r\\n                Belum ada masukan\\r\\n              </div>\\r\\n            {{/if}}\\r\\n          </div>\\r\\n        </div>\\r\\n\\r\\n\\r\\n        <div class=\\\"border-t px-6 py-4\\\">\\r\\n          <form id=\\\"generateForm\\\" onsubmit=\\\"generateContent(event)\\\" class=\\\"flex items-center gap-2\\\">\\r\\n            <div class=\\\"form-group\\\" hidden>\\r\\n              <input type=\\\"text\\\" id=\\\"idReport\\\" value=\\\"{{data.0.id}}\\\" />\\r\\n            </div>\\r\\n            <input type=\\\"text\\\" placeholder=\\\"Tulis masukan...\\\" id=\\\"inputComment\\\" class=\\\"fs-14 fw-400 flex-1\\\" style=\\\"padding: 0.6rem 1rem; border: 1px solid var(--black-100); border-radius: 0.5rem;\\\" />\\r\\n            <button type=\\\"submit\\\" id=\\\"generateButton\\\" class=\\\"fs-14 fw-500\\\" style=\\\"background: var(--primary); color: white; padding: 0.6rem 1rem; border-radius: 0.5rem; border: none;\\\">\\r\\n              Kirim\\r\\n            </button>\\r\\n          </form>\\r\\n        </div>\\r\\n\\r\\n      </div>\\r\\n\\r\\n\\r\\n    </div>\\r\\n  </div>\\r\\n</div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":[\"comment_date\"],\"useAsFilterConfig\":{\"enable\":false,\"buttonStyle\":{\"label\":\"\",\"filterMultiSelect\":false,\"additional\":{}}},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":true,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false},\"shareAPI\":\"\",\"childrenConfig\":{\"enable\":false},\"pageState\":true,\"orderColumn\":false,\"manageOrderColumn\":{\"orderColumn\":{\"enable\":false,\"columns\":[]}}},\"x\":0,\"y\":61},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-23 23:12:19.835000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":29,\"id\":\"63efe053dde43be7ee642a476a57c56c\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"4f602f42d1b2b8a6d387b6026c5efba5\",\"sourceId\":[\"d386b521c3fd0a11a2284f283fbc4aab\"],\"query\":null,\"name\":\"Bukti Pendukung\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Bukti Pendukung\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":148,\"w\":8,\"h\":29}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"4d4a38a86d160d1b5d45ce4ebce39168\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Bukti Pendukung\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"63efe053dde43be7ee642a476a57c56c\":{\"table\":\"aduan_masyarakat_v3.\\\"report_attachments\\\"\",\"field\":\"id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"4f602f42d1b2b8a6d387b6026c5efba5\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":true,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"4f602f42d1b2b8a6d387b6026c5efba5\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\"}]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"url\",\"alias\":\"url\",\"name\":\"url\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"number\"},{\"field\":\"size\",\"alias\":\"size\",\"name\":\"size\",\"type\":\"string\"},{\"field\":\"detail\",\"alias\":\"detail\",\"name\":\"detail\",\"type\":\"string\"}]},\"customColorKey\":[],\"customColorPalette\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"id\",\"prepetrator_id\",\"url\",\"file_type\",\"file_name\",\"created_at\"],[\"2026071001002\",\"2026071001002-00001\",\"s3://fusion/agent/0000007900000f080001d26600387abe_1783667026124_d9axec.png\",\"png\",\"yanduan-propam.png\",\"2026-07-10 07:03:52\"]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useCallback } from 'react';\\nimport styled from 'styled-components';\\nimport { Card, Modal, Button, Form } from 'react-bootstrap';\\nimport { useForm } from 'react-hook-form';\\nimport { dashboard } from '@store/app';\\nimport axios from 'axios';\\n\\nif (typeof Image !== 'undefined') {\\n  const originalSrc = Object.getOwnPropertyDescriptor(Image.prototype, 'src');\\n  Object.defineProperty(Image.prototype, 'src', {\\n    set(value) {\\n      if (value && value.includes('default-flag.svg')) {\\n        console.warn('Blocked request to:', value);\\n        return;\\n      }\\n      if (originalSrc && originalSrc.set) {\\n        originalSrc.set.call(this, value);\\n      }\\n    },\\n  });\\n}\\n\\nexport default function LaporanCard({ widget, data, user, pageState }) {\\n  const [showModal, setShowModal] = useState(false);\\n  const [showUploadModal, setShowUploadModal] = useState(false);\\n  const [selectedImage, setSelectedImage] = useState('');\\n  const [selectedItem, setSelectedItem] = useState(null);\\n  const [loading, setLoading] = useState(false);\\n  const [isDragging, setIsDragging] = useState(false);\\n  const [files, setFiles] = useState([]);\\n  const [authUser, setAuthUser] = useState(null);\\n  const [uploadedFiles, setUploadedFiles] = useState([]);\\n  const [isProcessing, setIsProcessing] = useState(false);\\n  const [failedImages, setFailedImages] = useState(new Set());\\n\\n  const dataArray = Array.isArray(data) ? data : [];\\n  const currentItems = dataArray;\\n\\n  const pages = {\\n    informasiDasar: pageState?.['dad5b834f5a7a46b8a119d6e54211dbd'],\\n  };\\n\\n  const informasiDasarData = pages.informasiDasar?.data?.[0] || {};\\n\\n  // === Ambil data user dari localStorage ===\\n  useEffect(() => {\\n    const storedUser = localStorage.getItem('me');\\n    if (storedUser) {\\n      try {\\n        const userData = JSON.parse(storedUser);\\n        setAuthUser(userData);\\n      } catch (error) {\\n        console.error('Error parsing user data from localStorage:', error);\\n      }\\n    }\\n  }, []);\\n\\n  const filterValidFiles = (files) => {\\n    const allowedExtensions = [\\n      '.pdf',\\n      '.jpg',\\n      '.jpeg',\\n      '.png',\\n      '.doc',\\n      '.docx',\\n      '.mp4',\\n      '.mp3',\\n    ];\\n    const MAX_FILE_SIZE = 10 * 1024 * 1024;\\n    const validFiles = [];\\n    const invalidFiles = [];\\n\\n    files.forEach((file) => {\\n      const fileName = file.name.toLowerCase();\\n      const isValidExt = allowedExtensions.some((ext) =>\\n        fileName.endsWith(ext),\\n      );\\n      const isValidSize = file.size <= MAX_FILE_SIZE;\\n\\n      if (isValidExt && isValidSize) {\\n        validFiles.push(file);\\n      } else {\\n        if (!isValidExt) {\\n          invalidFiles.push(`${file.name} (format tidak diizinkan)`);\\n        } else if (!isValidSize) {\\n          invalidFiles.push(`${file.name} (melebihi 10MB)`);\\n        }\\n      }\\n    });\\n\\n    if (invalidFiles.length > 0) {\\n      alert(\\n        `File ditolak:\\\\n${invalidFiles.join('\\\\n')}\\\\n\\\\nFormat yang diizinkan: ${allowedExtensions.join(', ')}`,\\n      );\\n    }\\n\\n    return validFiles;\\n  };\\n  // === Convert URL S3 ===\\n  const convertS3Url = (url) => {\\n    if (!url) return '';\\n\\n    if (url.startsWith('s3://fusion/agent/')) {\\n      const path = url.replace('s3://fusion/agent/', '');\\n      const encodedPath = path\\n        .split('/')\\n        .map((part) => encodeURIComponent(part))\\n        .join('/');\\n      if (\\n        encodedPath.includes('/cdn/media') ||\\n        encodedPath.startsWith('cdn/media')\\n      ) {\\n        return `https://gajamada-propam.polri.go.id/fusion/agent/${encodedPath}`;\\n      } else {\\n        return `https://gajamada-propam.polri.go.id/cdn/media/fusion/agent/${encodedPath}`;\\n      }\\n    }\\n\\n    // Handle s3:// lainnya\\n    if (url.startsWith('s3://')) {\\n      return url.replace('s3://', 'https://asura-s3.stellardata.ai/');\\n    }\\n\\n    if (url.startsWith('http://192.168.180.99:8000')) {\\n      return url.replace(\\n        'http://192.168.180.99:8000',\\n        'https://asura-s3.ebdesk.com',\\n      );\\n    }\\n\\n    if (url.startsWith('https://yanduan-s3.polri.go.id:9000')) {\\n      const path = url.replace('https://yanduan-s3.polri.go.id:9000', '');\\n\\n      if (path.includes('/cdn/media')) {\\n        return `https://gajamada-propam.polri.go.id${path}`;\\n      } else {\\n        return `https://gajamada-propam.polri.go.id/cdn/media${path}`;\\n      }\\n    }\\n\\n    return url;\\n  };\\n\\n  const handleDownloadFile = (item) => {\\n    try {\\n      const fileUrl = convertS3Url(item.url);\\n\\n      if (!fileUrl) {\\n        console.error('URL file tidak valid');\\n        return;\\n      }\\n\\n      // Ambil ekstensi\\n      let fileExtension = item.file_type || '';\\n      if (!fileExtension) {\\n        const ext = fileUrl.split('.').pop()?.toLowerCase() || 'pdf';\\n        fileExtension = ext.split('?')[0];\\n      }\\n\\n      // Bersihkan nama file\\n      let fileName = item.file_name || 'document';\\n      fileName = fileName.replace(/[<>:\\\"/\\\\\\\\|?*]/g, '');\\n      fileName = fileName.replace(/\\\\.[^/.]+$/, '');\\n\\n      console.log('Downloading:', `${fileName}.${fileExtension}`);\\n\\n      // Download dengan link biasa\\n      const link = document.createElement('a');\\n      link.href = fileUrl;\\n      link.download = `${fileName}.${fileExtension}`;\\n      link.target = '_blank';\\n      document.body.appendChild(link);\\n      link.click();\\n      document.body.removeChild(link);\\n    } catch (error) {\\n      console.error('Error:', error);\\n      alert(`Gagal mengunduh file: ${error.message}`);\\n    }\\n  };\\n\\n  const { register, handleSubmit, reset } = useForm();\\n\\n  // === Upload file ===\\n  // const handleFileChange = async (e) => {\\n  //   if (isProcessing) return;\\n  //   const selectedFiles = Array.from(e.target.files || []);\\n  //   if (!selectedFiles.length) return;\\n  //   setIsProcessing(true);\\n\\n  //   try {\\n  //     setFiles((prev) => [...prev, ...selectedFiles]);\\n  //     const uploads = selectedFiles.map((file) => handleFileUpload(file));\\n  //     await Promise.all(uploads);\\n  //   } catch (error) {\\n  //     console.error('Error processing files:', error);\\n  //   } finally {\\n  //     setIsProcessing(false);\\n  //     e.target.value = '';\\n  //   }\\n  // };\\n\\n  // Tambahkan setelah import, sebelum export default\\n\\n  const simpleHash32 = (str) => {\\n    let hash = 0;\\n    let result = '';\\n\\n    for (let i = 0; i < str.length; i++) {\\n      const char = str.charCodeAt(i);\\n      hash = (hash << 5) - hash + char;\\n      hash = hash & hash;\\n\\n      const hex = Math.abs(hash).toString(16).padStart(8, '0');\\n      result += hex;\\n\\n      if (result.length >= 32) break;\\n    }\\n\\n    while (result.length < 32) {\\n      result += '0';\\n    }\\n\\n    return result.substring(0, 32);\\n  };\\n\\n  const getFileExtension = (filename) => {\\n    return filename.split('.').pop() || '';\\n  };\\n\\n  const generateHashedPath = (originalFilename) => {\\n    const hash = simpleHash32(originalFilename);\\n    const extension = getFileExtension(originalFilename);\\n    const timestamp = Date.now();\\n    const random = Math.random().toString(36).substring(2, 8);\\n\\n    return `${hash}_${timestamp}_${random}.${extension}`;\\n  };\\n  const handleFileChange = async (e) => {\\n    if (isProcessing) return;\\n    const selectedFiles = Array.from(e.target.files || []);\\n    if (!selectedFiles.length) return;\\n\\n    // FILTER FILE TERLEBIH DAHULU\\n    const validFiles = filterValidFiles(selectedFiles);\\n\\n    if (validFiles.length === 0) {\\n      e.target.value = '';\\n      return;\\n    }\\n\\n    setIsProcessing(true);\\n\\n    try {\\n      setFiles((prev) => [...prev, ...validFiles]);\\n      const uploads = validFiles.map((file) => handleFileUpload(file));\\n      await Promise.all(uploads);\\n    } catch (error) {\\n      console.error('Error processing files:', error);\\n    } finally {\\n      setIsProcessing(false);\\n      e.target.value = '';\\n    }\\n  };\\n\\n  const handleDrop = async (e) => {\\n    e.preventDefault();\\n    if (isProcessing) return;\\n    setIsDragging(false);\\n    const droppedFiles = Array.from(e.dataTransfer.files || []);\\n\\n    const validFiles = filterValidFiles(droppedFiles);\\n\\n    if (validFiles.length === 0) return;\\n\\n    setIsProcessing(true);\\n    try {\\n      setFiles((prev) => [...prev, ...validFiles]);\\n      const uploads = validFiles.map((file) => handleFileUpload(file));\\n      await Promise.all(uploads);\\n    } finally {\\n      setIsProcessing(false);\\n    }\\n  };\\n  // const handleDrop = async (e) => {\\n  //   e.preventDefault();\\n  //   if (isProcessing) return;\\n  //   setIsDragging(false);\\n  //   const droppedFiles = Array.from(e.dataTransfer.files || []);\\n  //   setIsProcessing(true);\\n  //   try {\\n  //     setFiles((prev) => [...prev, ...droppedFiles]);\\n  //     const uploads = droppedFiles.map((file) => handleFileUpload(file));\\n  //     await Promise.all(uploads);\\n  //   } finally {\\n  //     setIsProcessing(false);\\n  //   }\\n  // };\\n\\n  const handleDragOver = (e) => e.preventDefault();\\n  const handleDragLeave = (e) => {\\n    e.preventDefault();\\n    setIsDragging(false);\\n  };\\n\\n  const removeFile = (file) => {\\n    setFiles((prev) => prev.filter((f) => f !== file));\\n    setUploadedFiles((prev) => prev.filter((f) => f.name !== file.name));\\n  };\\n\\n  // const handleFileUpload = async (file) => {\\n  //   const queryParams = new URLSearchParams({\\n  //     folder: 'agent',\\n  //     workspaceId: user?.workspaceId || '',\\n  //     dashboardId: dashboard?.id || '',\\n  //     createdBy: user?.id || '',\\n  //     extractFile: 'false',\\n  //   }).toString();\\n\\n  //   const formData = new FormData();\\n  //   formData.append('file', file);\\n  //   formData.append('tags', 'assets');\\n\\n  //   try {\\n  //     const res = await fetch(\\n  //       `/api/v1/apps/upload/upload-file?${queryParams}`,\\n  //       {\\n  //         method: 'POST',\\n  //         body: formData,\\n  //       },\\n  //     );\\n  //     if (!res.ok) throw new Error('Upload gagal');\\n\\n  //     const result = await res.json();\\n  //     const uploadedFileInfo = {\\n  //       id: result?.data?.id || 'unknown_id',\\n  //       url: result?.data?.path || '',\\n  //       size: result?.data?.filesize\\n  //         ? `${(result.data.filesize / (1024 * 1024)).toFixed(1)}MB`\\n  //         : `${(file.size / (1024 * 1024)).toFixed(1)}MB`,\\n  //       detail: file.name.split('.').pop(),\\n  //       name: file.name,\\n  //     };\\n\\n  //     setUploadedFiles((prev) => [...prev, uploadedFileInfo]);\\n  //     return uploadedFileInfo;\\n  //   } catch (err) {\\n  //     console.error('Error upload file:', err);\\n  //     alert(`Error uploading ${file.name}: ${err.message}`);\\n  //     return null;\\n  //   }\\n  // };\\n\\n  const handleFileUpload = async (file) => {\\n    const hashedPath = generateHashedPath(file.name);\\n    const fileHash = simpleHash32(file.name);\\n    const createdByValue = `agent_${fileHash.substring(0, 8)}`;\\n\\n    const queryParams = new URLSearchParams({\\n      folder: 'agent',\\n      workspaceId: user?.workspaceId || '',\\n      dashboardId: dashboard?.id || '',\\n      createdBy: createdByValue,\\n      extractFile: 'false',\\n      filename: hashedPath,\\n    }).toString();\\n\\n    const formData = new FormData();\\n    formData.append('file', file);\\n    formData.append('tags', 'assets');\\n\\n    try {\\n      const res = await fetch(\\n        `/api/v1/apps/upload/upload-file?${queryParams}`,\\n        {\\n          method: 'POST',\\n          body: formData,\\n        },\\n      );\\n      if (!res.ok) throw new Error('Upload gagal');\\n\\n      const result = await res.json();\\n      const uploadedFileInfo = {\\n        id: result?.data?.id || 'unknown_id',\\n        url: result?.data?.path || '',\\n        size: result?.data?.filesize\\n          ? `${(result.data.filesize / (1024 * 1024)).toFixed(1)}MB`\\n          : `${(file.size / (1024 * 1024)).toFixed(1)}MB`,\\n        detail: file.name.split('.').pop(),\\n        name: file.name,\\n      };\\n\\n      setUploadedFiles((prev) => [...prev, uploadedFileInfo]);\\n      return uploadedFileInfo;\\n    } catch (err) {\\n      console.error('Error upload file:', err);\\n      alert(`Error uploading ${file.name}: ${err.message}`);\\n      return null;\\n    }\\n  };\\n\\n  // === Submit ===\\n  const onSubmit = async (formData) => {\\n    if (isProcessing) return;\\n    setLoading(true);\\n    setIsProcessing(true);\\n\\n    try {\\n      const reportId = informasiDasarData?.prepetrator_id;\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '314b80f7ce408ee9911ac3d4723ba0f9',\\n        params: {},\\n        body: {\\n          report_id: reportId,\\n          attachment: uploadedFiles,\\n          report_type: \\\"barbuk\\\"\\n        },\\n        headers: {},\\n        additionalPath: '',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id,\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id,\\n        sessionId: '',\\n        metaData: {\\n          widgetId: '63efe053dde43be7ee642a476a57c56c',\\n          widgetName: 'Bukti Pendukung',\\n          menuId: '01f63e60376afe827638ed614e1cea76',\\n          menuName: 'Detail Laporan',\\n          dashboardId: '1769155096865',\\n          dashboardName: 'Propam Aduan',\\n          userId: user?.id,\\n          domain: '',\\n        },\\n        logging: false,\\n        appendedLog: false,\\n      };\\n\\n      const res = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!res.ok) throw new Error('Gagal kirim ke gateway');\\n\\n      reset();\\n      setFiles([]);\\n      setUploadedFiles([]);\\n      setShowUploadModal(false);\\n      alert('Laporan berhasil ditambah!');\\n      // setTimeout(() => window.location.reload(), 3000);\\n    } catch (err) {\\n      console.error(err);\\n      alert(`Error: ${err.message}`);\\n    } finally {\\n      setLoading(false);\\n      setIsProcessing(false);\\n    }\\n  };\\n\\n  // === Utility ===\\n  // const formatTimeAgo = (timestamp) => {\\n  //   if (!timestamp) return '-';\\n  //   const now = Date.now();\\n  //   const diff = now - Number(timestamp);\\n  //   const seconds = Math.floor(diff / 1000);\\n  //   const minutes = Math.floor(seconds / 60);\\n  //   const hours = Math.floor(minutes / 60);\\n  //   const days = Math.floor(hours / 24);\\n\\n  //   if (seconds < 60) return `${seconds} detik yang lalu`;\\n  //   if (minutes < 60) return `${minutes} menit yang lalu`;\\n  //   if (hours < 24) return `${hours} jam yang lalu`;\\n  //   return `${days} hari yang lalu`;\\n  // };\\n\\n  const formatTimeAgo = (timestamp) => {\\n    if (!timestamp) return '-';\\n\\n    try {\\n      let date;\\n\\n      if (typeof timestamp === 'string') {\\n        const cleanTimestamp = timestamp.replace(' ', 'T');\\n        date = new Date(cleanTimestamp);\\n\\n        if (isNaN(date.getTime()) && /^\\\\d+$/.test(timestamp)) {\\n          const num = parseInt(timestamp);\\n\\n          date = new Date(num.toString().length === 10 ? num * 1000 : num);\\n        }\\n      } else if (typeof timestamp === 'number') {\\n        date = new Date(\\n          timestamp.toString().length === 10 ? timestamp * 1000 : timestamp,\\n        );\\n      } else {\\n        date = new Date(timestamp);\\n      }\\n\\n      // Validasi\\n      if (isNaN(date.getTime())) return '-';\\n\\n      const diff = Date.now() - date.getTime();\\n      const seconds = Math.floor(diff / 1000);\\n      const minutes = Math.floor(seconds / 60);\\n      const hours = Math.floor(minutes / 60);\\n      const days = Math.floor(hours / 24);\\n\\n      if (seconds < 60) return `${seconds} detik yang lalu`;\\n      if (minutes < 60) return `${minutes} menit yang lalu`;\\n      if (hours < 24) return `${hours} jam yang lalu`;\\n      if (days < 7) return `${days} hari yang lalu`;\\n\\n      return date.toLocaleDateString('id-ID', {\\n        day: '2-digit',\\n        month: 'short',\\n        year: 'numeric',\\n      });\\n    } catch {\\n      return '-';\\n    }\\n  };\\n\\n  const handleImageClick = (item) => {\\n    setSelectedItem(item);\\n    setSelectedImage(convertS3Url(item.url));\\n    setShowModal(true);\\n  };\\n\\n  const handleClose = () => setShowModal(false);\\n  const triggerFileInput = () =>\\n    !isProcessing && document.getElementById('fileInput').click();\\n\\n  const getFileIconByType = (urlOrName) => {\\n    const ext = urlOrName?.split('.').pop()?.toLowerCase();\\n    switch (ext) {\\n      case 'jpg':\\n      case 'jpeg':\\n      case 'png':\\n      case 'gif':\\n        return 'ph-fill ph-image';\\n      case 'pdf':\\n        return 'ph-fill ph-file-pdf';\\n      case 'doc':\\n      case 'docx':\\n        return 'ph-fill ph-file-doc';\\n      case 'txt':\\n        return 'ph-fill ph-file-text';\\n      case 'mp4':\\n      case 'mov':\\n      case 'avi':\\n        return 'ph ph-video';\\n      case 'mp3':\\n      case 'wav':\\n        return 'ph-fill ph-microphone';\\n      default:\\n        return 'ph-fill ph-file';\\n    }\\n  };\\n\\n  // Check if file is image type\\n  const isImageFile = (url) => {\\n    const ext = url?.split('.').pop()?.toLowerCase();\\n    return ['jpg', 'jpeg', 'png', 'gif', 'webp', 'bmp'].includes(ext);\\n  };\\n\\n  // Handle image error - mark as failed to prevent retry (FIXED VERSION)\\n  const handleImageError = useCallback((index, url) => {\\n    const imageKey = `${index}-${url}`;\\n    setFailedImages((prev) => {\\n      // Only update if the key doesn't exist to prevent unnecessary re-renders\\n      if (prev.has(imageKey)) {\\n        return prev;\\n      }\\n      return new Set([...prev, imageKey]);\\n    });\\n  }, []);\\n\\n  // === RENDER ===\\n  return (\\n    <>\\n      <CardWrapper>\\n        <HeaderSection>\\n          <div className=\\\"widget-title\\\">{widget?.name}</div>\\n          <StyledButton\\n            onClick={() => setShowUploadModal(true)}\\n            disabled={isProcessing}\\n            variant=\\\"secondary\\\"\\n          >\\n            <i className=\\\"ph ph-plus\\\"></i>\\n            {loading ? 'Memproses...' : 'Tambah Bukti'}\\n          </StyledButton>\\n        </HeaderSection>\\n\\n        {currentItems.length === 0 ? (\\n          <div\\n            className=\\\"flex flex-col items-center justify-center py-10 text-muted\\\"\\n            style={{ flex: 1 }}\\n          >\\n            <img\\n              src=\\\"/cdn/media/fusion/assets/1731748832639/Group 1 (4).svg\\\"\\n              alt=\\\"no-data\\\"\\n              style={{ width: '150px', marginBottom: '1rem' }}\\n            />\\n            <p className=\\\"m-0\\\">Belum ada bukti</p>\\n          </div>\\n        ) : (\\n          <ContentGrid>\\n            {currentItems.map((item, index) => {\\n              const imageKey = `${index}-${item.url}`;\\n              const hasFailed = failedImages.has(imageKey);\\n              const imageUrl = convertS3Url(item.url);\\n              const shouldShowImage = isImageFile(item.url) && !hasFailed;\\n\\n              return (\\n                <StyledCard key={index}>\\n                  <div className=\\\"flex items-start gap-4\\\">\\n                    {shouldShowImage ? (\\n                      <ImageWrapper onClick={() => handleImageClick(item)}>\\n                        <img\\n                          src={imageUrl}\\n                          alt=\\\"Preview\\\"\\n                          onError={() => handleImageError(index, item.url)}\\n                          loading=\\\"lazy\\\"\\n                        />\\n                      </ImageWrapper>\\n                    ) : (\\n                      <FallbackIconWrapper>\\n                        <i\\n                          className={`${getFileIconByType(item.url)} fs-20`}\\n                          style={{ color: 'var(--primary)' }}\\n                        ></i>\\n                      </FallbackIconWrapper>\\n                    )}\\n                    <div className=\\\"flex justify-between w-100\\\">\\n                      <div className=\\\"flex flex-col flex-grow-1\\\">\\n                        <FileName className=\\\"fs-14 fw-600\\\">\\n                          {item.file_name}\\n                        </FileName>\\n                        <div className=\\\"text-muted \\\">\\n                          {formatTimeAgo(item.created_at)}\\n                        </div>\\n                      </div>\\n                      {item.url && (\\n                        <DownloadButton\\n                          variant=\\\"secondary\\\"\\n                          onClick={(e) => {\\n                            e.stopPropagation();\\n                            handleDownloadFile(item);\\n                          }}\\n                        >\\n                          <i className=\\\"ph ph-download-simple\\\"></i>\\n                        </DownloadButton>\\n                      )}\\n                    </div>\\n                  </div>\\n                </StyledCard>\\n              );\\n            })}\\n          </ContentGrid>\\n        )}\\n      </CardWrapper>\\n\\n      <Modal\\n        show={showUploadModal}\\n        onHide={() => setShowUploadModal(false)}\\n        centered\\n        size=\\\"md\\\"\\n      >\\n        <ModalHeader closeButton>\\n          <TitleHeader>Tambah Bukti</TitleHeader>\\n        </ModalHeader>\\n        <Modal.Body>\\n          <Form onSubmit={handleSubmit(onSubmit)}>\\n            <input\\n              type=\\\"hidden\\\"\\n              value={data?.[0]?.id || ''}\\n              {...register('input_id')}\\n            />\\n            <input\\n              id=\\\"fileInput\\\"\\n              type=\\\"file\\\"\\n              multiple\\n              style={{ display: 'none' }}\\n              onChange={handleFileChange}\\n              accept=\\\".doc,.docx,.png,.jpg,.jpeg,.pdf,.mp4,.mp3\\\"\\n            />\\n\\n            <UploadBox\\n              onDrop={handleDrop}\\n              onDragOver={handleDragOver}\\n              onDragLeave={handleDragLeave}\\n              onClick={triggerFileInput}\\n              isDragging={isDragging}\\n            >\\n              <div style={{ paddingBottom: '0.6rem', pointerEvents: 'none' }}>\\n                <img\\n                  src=\\\"/cdn/media/fusion/assets/1731748832639/upload_file_propam.svg\\\"\\n                  alt=\\\"Upload icon\\\"\\n                />\\n              </div>\\n              <p style={{ fontWeight: '400', fontSize: '0.875rem' }}>\\n                <span style={{ fontWeight: '600', color: 'var(--primary)' }}>\\n                  Choose file\\n                </span>{' '}\\n                or drag and drop\\n              </p>\\n              <small>\\n                doc, docx, png, jpg, jpeg, pdf, mp4, mp3 only. 10MB max.\\n              </small>\\n            </UploadBox>\\n\\n            {files.length > 0 && (\\n              <FileList>\\n                {files.map((file, idx) => (\\n                  <FileItem key={idx} className=\\\"gap-4\\\">\\n                    <WrappIcon>\\n                      <i\\n                        className={`${getFileIconByType(file.url || file.name)} fs-20`}\\n                        style={{ color: 'var(--white)' }}\\n                      ></i>\\n                    </WrappIcon>\\n\\n                    <div className=\\\"flex-grow-1\\\">\\n                      <div>{file.name}</div>\\n                      <small>{(file.size / (1024 * 1024)).toFixed(1)} MB</small>\\n                    </div>\\n                    <button\\n                      type=\\\"button\\\"\\n                      onClick={() => removeFile(file)}\\n                      className=\\\"btn btn-sm btn-link p-1\\\"\\n                      style={{ color: '#dc3545' }}\\n                    >\\n                      ✕\\n                    </button>\\n                  </FileItem>\\n                ))}\\n              </FileList>\\n            )}\\n\\n            <div className=\\\"d-flex justify-content-end mt-3\\\">\\n              <Button\\n                variant=\\\"secondary\\\"\\n                onClick={() => setShowUploadModal(false)}\\n              >\\n                Batal\\n              </Button>\\n              <Button\\n                variant=\\\"primary\\\"\\n                type=\\\"submit\\\"\\n                className=\\\"ms-2\\\"\\n                disabled={loading}\\n              >\\n                {loading ? 'Mengunggah...' : 'Kirim'}\\n              </Button>\\n            </div>\\n          </Form>\\n        </Modal.Body>\\n      </Modal>\\n    </>\\n  );\\n}\\n\\n// styled-components (tetap sama)\\nconst StyledButton = styled(Button)`\\n  border: 1px solid var(--black-100);\\n  display: flex;\\n  padding: 0.4rem 0.8rem 0.4rem 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  color: var(--black);\\n  font-size: 0.8rem !important;\\n  font-weight: 600 !important;\\n  line-height: 1.06667rem;\\n`;\\nconst FileName = styled.div`\\n \\n  white-space: nowrap;\\n  overflow: hidden;\\n  text-overflow: ellipsis;\\n  max-width: 125px;\\n`;\\n\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst DownloadButton = styled(Button)`\\n\\ndisplay: flex;\\npadding: 0.53333rem;\\njustify-content: center;\\nalign-items: center;\\ngap: 0.53333rem;\\n  background-color:none;\\n  border:1px solid var(--black-100);\\n`;\\n\\nconst FallbackIconWrapper = styled.div`\\n  width: 50px;\\n  height: 50px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  flex-shrink: 0;\\n`;\\n\\nconst CardWrapper = styled.div`\\n  background: var(--white);\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.8rem;\\n  display: flex;\\n  flex-direction: column;\\n  height:100%;\\n`;\\n\\nconst HeaderSection = styled.div`\\n  padding: 1rem 1.5rem;\\n  border-bottom: 1px solid var(--black-100);\\n  display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n`;\\n\\nconst ContentGrid = styled.div`\\n  padding: 1.5rem;\\n  display: grid;\\n  grid-template-columns: repeat(3, 1fr);\\n  gap: 1rem;\\n\\n  overflow-y:auto;\\n  max-height:28rem;\\n`;\\n\\nconst StyledCard = styled(Card)`\\n  padding: 1rem;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n`;\\n\\nconst ImageWrapper = styled.div`\\n  position: relative;\\n  width: 50px;\\n  height: 50px;\\n  background: var(--primary-50);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  cursor: pointer;\\n  transition: all 0.2s ease;\\n  &:hover {\\n    transform: scale(1.05);\\n  }\\n  img {\\n    width: 100%;\\n    height: 100%;\\n    object-fit: cover;\\n  }\\n`;\\n\\nconst FallbackIcon = styled.div`\\n  position: absolute;\\n  inset: 0;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n`;\\n\\nconst LabelInput = styled.label`\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst UploadBox = styled.div`\\n  border: 1px dashed var(--Border-Primary, #E6E9F0);\\n  background: var(--Background-Secondary, #F5F7FA);\\n  border-radius: 0.5rem;\\n  text-align: center;\\n  padding: 3rem 0.75rem;\\n  cursor: pointer;\\n`;\\n\\nconst FileList = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n  padding-top: 1.2rem;\\n`;\\n\\nconst FileItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  border-radius: 0.75rem;\\n  border: 1px solid var(--Border-Primary, #E6E8EB);\\n  background: var(--Background-Secondary, #F7F8FA);\\n  padding: 0.5rem;\\n  font-size: 0.875rem;\\n`;\\n\\nconst FileIcon = styled.div`\\n  font-size: 1.25rem;\\n  margin-right: 0.5rem;\\n`;\\n\\nconst WrappIcon = styled.div`display: flex; padding: 0.66667rem; align-items: center; gap: 0.66667rem; border-radius: 0.53333rem; background: var(--primary-600);`;\\n\",\"html\":\" <div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100);border-radius:0.8rem;\\\">\\r\\n   <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n\\r\\n     <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n\\r\\n   </div>\\r\\n   <div>\\r\\n     tes\\r\\n   </div>\\r\\n </div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":[],\"useAsFilterConfig\":{\"enable\":false},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":true,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false},\"shareAPI\":\"\"},\"x\":0,\"y\":148},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-23 23:12:19.835000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":26,\"id\":\"1d05ba6d572d5d65307ffd83ca1399d4\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"7761377d7802b8a2f07e200d8cde526b\",\"sourceId\":[\"43aaa37a892e73ccdab7ecc581bf97a4\",\"fec19eb5093c8901cf58d41eefb87872\"],\"query\":null,\"name\":\"Riwayat Log\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Timeline\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":8,\"y\":78,\"w\":4,\"h\":26}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"4d4a38a86d160d1b5d45ce4ebce39168\",\"w\":4,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Riwayat Log\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"1d05ba6d572d5d65307ffd83ca1399d4\":{\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operator\":\"is\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"field\":\"prepetrator_id\",\"table\":\"aduan_masyarakat_v3.\\\"report_officer_detail\\\"\",\"queryParams\":[{\"table\":\"aduan_masyarakat_v3.\\\"report_officer_detail\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"7761377d7802b8a2f07e200d8cde526b\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\"},{\"table\":\"aduan_masyarakat_v3.\\\"report_officer_attachments\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"7761377d7802b8a2f07e200d8cde526b\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\"}]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"status\",\"alias\":\"status\",\"name\":\"status\",\"type\":\"string\"},{\"field\":\"created_date\",\"alias\":\"created_date\",\"name\":\"created_date\",\"type\":\"date\"},{\"field\":\"polda\",\"alias\":\"polda\",\"name\":\"polda\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"string\"},{\"field\":\"subject\",\"alias\":\"subject\",\"name\":\"subject\",\"type\":\"string\"},{\"field\":\"handling_progress\",\"alias\":\"handling_progress\",\"name\":\"handling_progress\",\"type\":\"string\"},{\"field\":\"responsible_person_name\",\"alias\":\"responsible_person_name\",\"name\":\"responsible_person_name\",\"type\":\"string\"},{\"field\":\"detail\",\"alias\":\"detail\",\"name\":\"detail\",\"type\":\"string\"},{\"field\":\"method\",\"alias\":\"method\",\"name\":\"method\",\"type\":\"string\"},{\"field\":\"sender_name\",\"alias\":\"sender_name\",\"name\":\"sender_name\",\"type\":\"string\"},{\"field\":\"complaint_name\",\"alias\":\"complaint_name\",\"name\":\"complaint_name\",\"type\":\"string\"}]},\"customColorKey\":[],\"customColorPalette\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\".card-detail {\\n  display: flex;\\n  padding: 1rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1rem;\\n  align-self: stretch;\\n  border-radius: 0.5rem;\\n  border: 1px solid var(--black-100);\\n  background: var(--white);\\n}\\n\\n.information {\\n  width: 10.75rem;\\n  font-size: 0.93333rem;\\n  font-weight: 400;\\n  line-height: 140%;\\n  color: var(--black-600);\\n}\\n\\n/* Styles untuk attachment */\\n.attachment-item {\\n  margin-bottom: 1rem;\\n}\\n\\n.file-attachment {\\n  display: flex;\\n  align-items: center;\\n  gap: 0.75rem;\\n  padding: 0.75rem;\\n  border: 1px solid #E6E9F0;\\n  border-radius: 0.5rem;\\n  background: white;\\n}\\n\\n.file-icon-wrapper {\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  width: 2.5rem;\\n  height: 2.5rem;\\n  background: var(--primary-50);\\n  border-radius: 0.375rem;\\n}\\n\\n.file-info {\\n  flex: 1;\\n}\\n\\n.file-name {\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  color: var(--black);\\n}\\n\\n.file-size {\\n  font-size: 0.75rem;\\n  color: var(--text-muted);\\n}\\n\\n.download-btn {\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  background-color: transparent;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.375rem;\\n  cursor: pointer;\\n  color: var(--black);\\n  text-decoration: none;\\n}\\n\\n.download-btn:hover {\\n  background-color: var(--primary-50);\\n  color: var(--primary);\\n}\",\"js\":\"function openModal(modalId) {\\r\\n    const modal = document.getElementById(modalId);\\r\\n    if (modal) {\\r\\n        modal.classList.remove('hidden');\\r\\n    }\\r\\n}\\r\\n\\r\\nfunction closeModal(modalId) {\\r\\n    const modal = document.getElementById(modalId);\\r\\n    if (modal) {\\r\\n        modal.classList.add('hidden');\\r\\n    }\\r\\n}\",\"react\":\"import React, { useState, useCallback } from 'react';\\nimport { Timeline } from 'antd';\\nimport styled from 'styled-components';\\n\\nexport default function TimelineWidget({ widget, data }) {\\n  const [showModalPenanganan, setShowModalPenanganan] = useState(false);\\n  const [showModalDisposisi, setShowModalDisposisi] = useState(false);\\n  const [showModalVerif, setShowModalVerif] = useState(false);\\n  const [showModalSelesai, setShowModalSelesai] = useState(false);\\n  const [showModalTolak, setShowModalTolak] = useState(false);\\n  const [selectedItem, setSelectedItem] = useState(null);\\n  const [tooltipVisible, setTooltipVisible] = useState(false);\\n  const [tooltipText, setTooltipText] = useState('');\\n\\n  const dataArray = Array.isArray(data) ? data : [];\\n\\n  const startCase = (str) => {\\n    if (!str) return '';\\n    return str.charAt(0).toUpperCase() + str.slice(1).toLowerCase();\\n  };\\n\\n  const formatDateID = (dateString) => {\\n    if (!dateString) return '-';\\n    const date = new Date(dateString);\\n    if (isNaN(date)) return '-';\\n\\n    const listBulan = [\\n      'Jan',\\n      'Feb',\\n      'Mar',\\n      'Apr',\\n      'Mei',\\n      'Jun',\\n      'Jul',\\n      'Agu',\\n      'Sep',\\n      'Okt',\\n      'Nov',\\n      'Des',\\n    ];\\n\\n    const tanggal = date.getDate().toString().padStart(2, '0');\\n    const bulan = listBulan[date.getMonth()];\\n    const tahun = date.getFullYear();\\n    const jam = date.getHours().toString().padStart(2, '0');\\n    const menit = date.getMinutes().toString().padStart(2, '0');\\n\\n    return `${tanggal} ${bulan} ${tahun}, ${jam}:${menit} WIB`;\\n  };\\n\\n  // Handler Utama untuk membuka modal berdasarkan status\\n  const handleDetailClick = (item) => {\\n    setSelectedItem(item);\\n    const status = item.status;\\n\\n    if (status === 'Tolak') {\\n      setShowModalTolak(true);\\n    } else if (\\n      status === 'Laporan Dikirim/Diterima Polda' ||\\n      status === 'disposisi' ||\\n      status?.toLowerCase().includes('limpah')\\n    ) {\\n      setShowModalDisposisi(true);\\n    } else {\\n      setShowModalVerif(true);\\n    }\\n  };\\n\\n  return (\\n    <>\\n      <WidgetWrapper>\\n        <HeaderSection>\\n          <div className=\\\"widget-title px-6 py-4\\\">{widget?.name}</div>\\n        </HeaderSection>\\n\\n        <ContentSection>\\n          <ScrollContainer>\\n            <ScrollBody style={{ padding: '12px 16px 16px 16px' }}>\\n              <StyledTimeline>\\n                {dataArray.map((item, index) => {\\n                  const statusLower = item.status?.toLowerCase();\\n\\n                  return (\\n                    <Timeline.Item\\n                      key={index}\\n                      color={\\n                        statusLower === 'selesai'\\n                          ? 'green'\\n                          : statusLower === 'tolak'\\n                            ? 'red'\\n                            : 'blue'\\n                      }\\n                    >\\n                      <div className=\\\"flex justify-between items-start w-full\\\">\\n                        <div className=\\\"flex flex-col\\\">\\n                          <StatusTitle>\\n                            {item.status === 'Laporan Masuk' && 'Laporan Masuk'}\\n                            {item.status === 'Verifikasi' &&\\n                              `Laporan Diverifikasi Oleh ${item.officer_report_name || ''}`}\\n                            {item.status ===\\n                              'Laporan diterima Bagyanduan & Di Review Kassubag Trimlap' &&\\n                              'Laporan diterima Bagyanduan & Di Review Kassubag Trimlap'}\\n\\n                            {item.status === 'Laporan Dinomori Administrasi' &&\\n                              'Laporan Dinomori Administrasi'}\\n                            {item.status ===\\n                              'Laporan Dikirim Ke Polda / Diterima Polda' &&\\n                              'Laporan Dikirim Ke Polda / Diterima Polda'}\\n\\n                            {item.status === 'Verifikasi Kabid Propam' &&\\n                              'Verifikasi Kabid Propam'}\\n                            {statusLower === 'tolak' && 'Laporan Ditolak'}\\n\\n                            {!['Laporan Masuk', 'Verifikasi', 'Tolak'].includes(\\n                              item.status,\\n                            ) && startCase(item.status)}\\n                          </StatusTitle>\\n                          <div\\n                            onMouseEnter={(e) => {\\n                              setTooltipText(item.case_position);\\n                              setTooltipVisible(true);\\n                            }}\\n                            onMouseLeave={() => setTooltipVisible(false)}\\n                            style={{\\n                              position: 'relative',\\n                              display: 'inline-block',\\n                            }}\\n                          >\\n                            {/* <CasePosition>{item.case_position}</CasePosition>\\n                            {tooltipVisible && (\\n                              <div\\n                                style={{\\n                                  position: 'absolute',\\n                                  bottom: '100%',\\n                                  left: '50%',\\n                                  transform: 'translateX(-50%)',\\n                                  backgroundColor: 'rgba(0,0,0,0.75)',\\n                                  color: 'white',\\n                                  padding: '4px 8px',\\n                                  borderRadius: '4px',\\n                                  fontSize: '12px',\\n                                  whiteSpace: 'nowrap',\\n                                  zIndex: 1000,\\n                                  pointerEvents: 'none',\\n                                }}\\n                              >\\n                                {tooltipText}\\n                              </div>\\n                            )} */}\\n                            <CasePosition>{item.case_position}</CasePosition>\\n                          </div>\\n\\n                          <TimelineDate>\\n                            {formatDateID(item.date_activity)}\\n                          </TimelineDate>\\n                        </div>\\n\\n                        {statusLower !== 'laporan masuk' && (\\n                          <DetailButton onClick={() => handleDetailClick(item)}>\\n                            Detail\\n                          </DetailButton>\\n                        )}\\n                      </div>\\n                    </Timeline.Item>\\n                  );\\n                })}\\n              </StyledTimeline>\\n            </ScrollBody>\\n          </ScrollContainer>\\n        </ContentSection>\\n      </WidgetWrapper>\\n\\n      {/* MODAL VERIFIKASI (Untuk Umum/Default) */}\\n      {showModalVerif && selectedItem && (\\n        <ModalOverlay onClick={() => setShowModalVerif(false)}>\\n          <ModalContent onClick={(e) => e.stopPropagation()}>\\n            <ModalHeader className=\\\"w-100\\\">\\n              <ModalTitle>Detail Progress</ModalTitle>\\n              <CloseButton onClick={() => setShowModalVerif(false)}>\\n                <i className=\\\"ph ph-x\\\"></i>\\n              </CloseButton>\\n            </ModalHeader>\\n            <div style={{ padding: '1rem 1.25rem' }}>\\n              <Title>Catatan</Title>\\n              <ModalDesc style={{ color: 'var(--black)' }}>\\n                {selectedItem.handling_progress || 'Sedang dalam proses.'}\\n              </ModalDesc>\\n            </div>\\n            <ModalFooter>\\n              <SecondaryButton onClick={() => setShowModalVerif(false)}>\\n                Tutup\\n              </SecondaryButton>\\n            </ModalFooter>\\n          </ModalContent>\\n        </ModalOverlay>\\n      )}\\n\\n      {/* MODAL DISPOSISI / LIMPAH */}\\n      {showModalDisposisi && selectedItem && (\\n        <ModalOverlay onClick={() => setShowModalDisposisi(false)}>\\n          <ModalContent onClick={(e) => e.stopPropagation()}>\\n            <ModalHeader className=\\\"w-100\\\">\\n              <div className=\\\"flex items-center gap-4\\\">\\n                <IconWrap>\\n                  <i\\n                    className=\\\"ph ph-arrows-left-right\\\"\\n                    style={{ color: 'var(--primary)', fontSize: '24px' }}\\n                  ></i>\\n                </IconWrap>\\n                <div>\\n                  <ModalTitle>Detail Disposisi</ModalTitle>\\n                  <ModalDesc>Detail limpahan laporan</ModalDesc>\\n                </div>\\n              </div>\\n              <CloseButton onClick={() => setShowModalDisposisi(false)}>\\n                <i className=\\\"ph ph-x\\\"></i>\\n              </CloseButton>\\n            </ModalHeader>\\n            <ModalBody>\\n              <div className=\\\"flex flex-col gap-4\\\">\\n                <Title>Dilimpahkan ke</Title>\\n                <CardDetail>\\n                  <DetailItem>\\n                    <Information>Satuan</Information>\\n                    <Desc>\\n                      {selectedItem.polda_disposisi || selectedItem.biro || '-'}\\n                    </Desc>\\n                  </DetailItem>\\n                </CardDetail>\\n                <Title>Catatan Disposisi</Title>\\n                <Desc>{selectedItem.handling_progress}</Desc>\\n              </div>\\n            </ModalBody>\\n            <ModalFooter>\\n              <SecondaryButton onClick={() => setShowModalDisposisi(false)}>\\n                Tutup\\n              </SecondaryButton>\\n            </ModalFooter>\\n          </ModalContent>\\n        </ModalOverlay>\\n      )}\\n\\n      {/* MODAL TOLAK */}\\n      {showModalTolak && selectedItem && (\\n        <ModalOverlay onClick={() => setShowModalTolak(false)}>\\n          <ModalContent onClick={(e) => e.stopPropagation()}>\\n            <ModalHeader className=\\\"w-100\\\">\\n              <div className=\\\"flex items-center gap-4\\\">\\n                <IconWrap style={{ background: '#FEE2E2' }}>\\n                  <i\\n                    className=\\\"ph ph-x-circle\\\"\\n                    style={{ color: '#DC2626', fontSize: '24px' }}\\n                  ></i>\\n                </IconWrap>\\n                <ModalTitle>Laporan Ditolak</ModalTitle>\\n              </div>\\n              <CloseButton onClick={() => setShowModalTolak(false)}>\\n                <i className=\\\"ph ph-x\\\"></i>\\n              </CloseButton>\\n            </ModalHeader>\\n            <ModalBody>\\n              <Title>Alasan Penolakan</Title>\\n              <ModalDesc style={{ color: 'var(--black)', marginTop: '8px' }}>\\n                {selectedItem.handling_progress || 'Tidak ada alasan spesifik.'}\\n              </ModalDesc>\\n            </ModalBody>\\n            <ModalFooter>\\n              <SecondaryButton onClick={() => setShowModalTolak(false)}>\\n                Tutup\\n              </SecondaryButton>\\n            </ModalFooter>\\n          </ModalContent>\\n        </ModalOverlay>\\n      )}\\n    </>\\n  );\\n}\\n\\nconst Desc = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-style: normal;\\nfont-weight: 400;\\n\\n\\n`;\\n\\nconst WidgetWrapper = styled.div`\\n  background: var(--white);\\n  height: 100%;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.8rem;\\n  display: flex;\\n  flex-direction: column;\\n  overflow:hidden\\n`;\\n\\nconst ModalFooter = styled.div`\\n  display: flex;\\n  justify-content: flex-end;\\n  padding: 1rem 2rem;\\n  border-top: 1px solid var(--black-100);\\n  gap: 0.5rem;\\n`;\\n\\nconst Title = styled.div`\\ncolor: var(--black);\\n\\nfont-size: 0.875rem;\\nfont-style: normal;\\nfont-weight: 600;\\nline-height: 150%; \\n`;\\nconst SecondaryButton = styled.button`\\n\\nborder-radius: 0.625rem;\\nbackground: var(--Primary-Base, #2374AB);\\npadding: 0.5rem 0.875rem;\\n  background: var(--primary-600);\\n  color: var(--white);\\n  border: none;\\n  border-radius: 0.625rem;\\n  font-weight:600;\\n  cursor: pointer;\\n  font-size: 0.875rem;\\n  \\n  &:hover {\\n    background: var(--primary-400);\\n  }\\n`;\\n\\nconst HeaderSection = styled.div`\\n  display: flex;\\n  flex-direction: column;\\n  border-bottom: 1px solid var(--black-100);\\n    flex-shrink: 0;\\n  \\n`;\\n\\nconst ContentSection = styled.div`\\n  // padding: 0.5rem 1rem 1rem;\\n  flex: 1;\\n  display: flex;\\n  flex-direction: column;\\n    min-height: 0;\\n`;\\n\\n// Scroll container mengambil semua ruang yang tersisa\\nconst ScrollContainer = styled.div`\\n  flex: 1;\\n  overflow: hidden;\\n  display: flex;\\n  flex-direction: column;\\n`;\\nconst ScrollBody = styled.div`\\n  flex: 1;\\n  overflow-y: auto;\\n\\n  max-height: 300px;\\n  position: relative;   \\n  &::-webkit-scrollbar { width: 6px; }\\n  &::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 3px; }\\n  &::-webkit-scrollbar-thumb { background: #c1c1c1; border-radius: 3px; }\\n`;\\n\\nconst TimelineItem = styled.div`\\n  display: flex; \\n  gap: 1rem;\\n  padding: 0.75rem 0;\\n  position: relative;\\n  width: 100%; \\n`;\\n\\nconst TimelineDot = styled.div`\\n  width: 8px;\\n  height: 8px;\\n  background-color: white;\\n  border: 2px solid var(--primary); \\n  border-radius: 50%;\\n  flex-shrink: 0;\\n  margin-top: 0.25rem;\\n  position: relative;\\n  z-index: 2;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n\\n  i, svg { display: none; } \\n`;\\nconst TimelineContent = styled.div`\\n  flex: 1;\\n  display: flex;\\n  flex-direction: column;\\n`;\\nconst StatusTitle = styled.div`\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  color: var(--black);\\n  margin-bottom: 0.25rem;\\n  display:flex;\\n  align-items:center;\\n  gap:0.2rem;\\n\\n  line-height: 1.4;\\n  word-break: break-word; \\n  width: 21rem;\\n  overflow-wrap: break-word;\\n`;\\n\\nconst TimelineDate = styled.p`\\n  font-size: 0.75rem;\\n  color: var(--text-muted);\\n  font-weight: 400;\\n  margin: 0;\\n  margin-bottom: 0.5rem;\\n`;\\n\\nconst ResponsiblePerson = styled.p`\\n  font-size: 0.875rem;\\n  color: var(--black);\\n  margin: 0;\\n`;\\n\\nconst DetailButton = styled.div`\\n  font-size: 0.875rem;\\n  font-weight: 600;\\n  color: var(--primary);\\n  cursor: pointer;\\n  \\n  &:hover {\\n    text-decoration: underline;\\n  }\\n`;\\n\\n// Modal Styles\\nconst ModalOverlay = styled.div`\\n  position: fixed;\\n  top: 0;\\n  left: 0;\\n  right: 0;\\n  bottom: 0;\\n  background: rgba(0, 0, 0, 0.75);\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  z-index: 20;\\n  padding: 1rem;\\n`;\\n\\nconst ModalContent = styled.div`\\n  background: white;\\n  border-radius: 0.75rem;\\n  width: 42rem;\\n  max-width: 100%;\\n  max-height: 90vh;\\n  overflow-y: auto;\\n  border: 2px solid #e2e8f0;\\n`;\\n\\nconst ModalHeader = styled.div`\\n   display: flex;\\n  justify-content: space-between;\\n  align-items: center;\\n padding: 0.8rem 1.33333rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\nconst ModalTitle = styled.p`\\n  color: var(--black);\\n  font-size: 1.06667rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\nconst ModalDesc = styled.p`\\ncolor: var(--Font-Secondary, #5B5D63);\\n\\nfont-size: 0.875rem;\\nfont-style: normal;\\nfont-weight: 400;\\nline-height: 150%; \\n`;\\n\\nconst CloseButton = styled.button`\\n  background: none;\\n  border: none;\\n  font-size: 1.5rem;\\n  font-weight: bold;\\n  cursor: pointer;\\n  padding: 0;\\n  margin: 0;\\n`;\\n\\nconst IconWrap = styled.div`\\n  display: flex;\\n  padding: 8px;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 8px;\\n  border-radius: 8px;\\n  background: var(--white);\\n  border:1px solid var(--black-100);\\n  border-radius:0.5rem;\\n`;\\nconst StyledTimeline = styled(Timeline)`\\n\\n  .ant-timeline-item-tail {\\n    border-inline-start: 1px solid var(--primary);\\n  }\\n\\n\\n  .ant-timeline-item-head {\\n    background-color: transparent;\\n    border-color: var(--primary); \\n  }\\n\\n \\n  .ant-timeline-item-head-blue {\\n    color: var(--primary);\\n    border-color: var(--primary);\\n  }\\n\\n  /* Mengatur jarak konten agar tidak terlalu mepet ke titik */\\n  .ant-timeline-item-content {\\n    margin-inline-start: 20px; \\n    bottom: 10px; /* Sesuaikan posisi vertikal konten */\\n  }\\n`;\\n\\nconst ModalBody = styled.div`\\n  padding: 2rem;\\n`;\\n\\n// Card Detail Styles\\nconst CardDetail = styled.div`\\n  display: flex;\\n  padding: 1rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1rem;\\n  align-self: stretch;\\n  border-radius: 0.5rem;\\n  border: 1px solid var(--Border-Primary, #E6E9F0);\\n  background: var(--Background-Secondary, #F5F7FA);\\n`;\\n\\nconst DetailItem = styled.div`\\n  display: flex;\\n  align-items: center;\\n  width: 100%;\\n`;\\n\\nconst Information = styled.div`\\n  width: 13.75rem;\\n  font-size: 0.93333rem;\\n  font-weight: 400;\\n  line-height: 140%;\\n  color: var(--black-600);\\n`;\\n\\n// Attachment Styles\\nconst AttachmentsSection = styled.div`\\n  margin-top: 1rem;\\n`;\\n\\nconst AttachmentsLabel = styled.label`\\n  display: block;\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  color: #374151;\\n  margin-bottom: 0.25rem;\\n`;\\n\\nconst AttachmentsContent = styled.div`\\n  color: #111827;\\n  padding\\n`;\\n\\nconst AttachmentItem = styled.div`\\n  margin-bottom: 1rem;\\n`;\\n\\nconst FileAttachment = styled.div`\\n  display: flex;\\n  align-items: center;\\n  gap: 0.75rem;\\n  padding: 0.75rem;\\n  border: 1px solid #E6E9F0;\\n  border-radius: 0.5rem;\\n  background: var(--white);\\n    margin-bottom: 0.5rem; \\n`;\\n\\nconst FileIconWrapper = styled.div`\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  width: 2.5rem;\\n  height: 2.5rem;\\n  background: var(--primary-50);\\n  border-radius: 0.375rem;\\n`;\\n\\nconst FileInfo = styled.div`\\n  flex: 1;\\n`;\\n\\nconst FileName = styled.div`\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  color: var(--black);\\n`;\\n\\nconst FileSize = styled.div`\\n  font-size: 0.75rem;\\n  color: var(--text-muted);\\n`;\\n\\nconst DownloadLink = styled.a`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  background-color: transparent;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.375rem;\\n  cursor: pointer;\\n  color: var(--black);\\n  text-decoration: none;\\n\\n  &:hover {\\n    background-color: var(--primary-50);\\n    color: var(--primary);\\n  }\\n`;\\n\\nconst AttachmentDetail = styled.p` \\n  font-size: 0.75rem;\\n  color: var(--text-muted);\\n  margin: 0.5rem 0 0 0;\\n`;\\n\\nconst NoAttachments = styled.span`\\n  font-size: 0.875rem;\\n  color: var(--text-muted);\\n`;\\nconst CasePosition = styled.div`\\n  max-width: 20rem;\\n  white-space: normal;\\n  overflow-wrap: break-word;\\n  font-size: 0.86rem;\\n`;\\n\",\"html\":\"<div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100);border-radius:0.8rem;\\\">\\r\\n  <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n    <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n  </div>\\r\\n  <div class=\\\"px-2 py-4 \\\">\\r\\n    <div class=\\\"eui scroll\\\" style=\\\"height:16.8rem;\\\">\\r\\n      <div class=\\\"scroll-body\\\">\\r\\n        {{#each data as |item index| }}\\r\\n\\r\\n          <div class=\\\"flex items-start gap-2\\\">\\r\\n            <i class=\\\"ph ph-dot-outline\\\" style=\\\"color:var(--primary); font-size:2rem;\\\"></i>\\r\\n            <div class=\\\"flex flex-col w-full\\\">\\r\\n              {{#if (eq item.status \\\"Masuk\\\")}}\\r\\n                <div class=\\\"fs-16 fw-500\\\">{{_ 'startCase' item.status}}</div>\\r\\n                <p class=\\\"fs-12 text-muted fw-400\\\" style=\\\"margin:0;\\\">\\r\\n                  {{dateFormat item.date_activity \\\"DD MMM YYYY, HH:mm\\\"}} WIB\\r\\n                </p>\\r\\n                <p>{{item.responsible_person_name}}</p>\\r\\n              {{else if (eq item.status \\\"penanganan\\\")}}\\r\\n                <div class=\\\"flex justify-between w-100\\\">\\r\\n                  <div class=\\\"flex flex-col\\\">\\r\\n                    <div class=\\\"fs-16 fw-500\\\">{{_ 'startCase' item.status}}</div>\\r\\n                    <p class=\\\"fs-12 text-muted fw-400\\\" style=\\\"margin:0;\\\">\\r\\n                      {{dateFormat item.date_activity \\\"DD MMM YYYY, HH:mm\\\"}} WIB\\r\\n                    </p>\\r\\n                  </div>\\r\\n\\r\\n                  <div class=\\\"fs-12 fw-600\\\" onclick=\\\"openModal('penanganan-{{index}}')\\\" style=\\\"color:var(--primary); cursor:pointer;\\\">\\r\\n                    Detail\\r\\n                  </div>\\r\\n                </div>\\r\\n              {{else}}\\r\\n                <div class=\\\"fs-16 fw-500\\\">{{_ 'startCase' item.status}}</div>\\r\\n                <p class=\\\"fs-12 text-muted fw-400\\\" style=\\\"margin:0;\\\">\\r\\n                  {{dateFormat item.date_activity \\\"DD MMM YYYY, HH:mm\\\"}} WIB\\r\\n                </p>\\r\\n              {{/if}}\\r\\n            </div>\\r\\n          </div>\\r\\n\\r\\n\\r\\n          {{#if (eq item.status \\\"penanganan\\\")}}\\r\\n            <div class=\\\"z-20 fixed overflow-y-auto top-0 w-full left-0 hidden\\\" id=\\\"penanganan-{{index}}\\\">\\r\\n              <div class=\\\"flex items-center justify-center min-height-100vh pt-4 px-4 pb-20 text-center sm:block sm:p-0\\\">\\r\\n                <div class=\\\"fixed inset-0 transition-opacity overflow-y-auto\\\">\\r\\n                  <div class=\\\"fixed inset-0 bg-gray-900 opacity-75 h-full\\\" onclick=\\\"closeModal('penanganan-{{index}}')\\\"></div>\\r\\n                  <span class=\\\"hidden sm:inline-block sm:align-middle sm:h-screen\\\"></span>\\r\\n                  <div class=\\\"inline-block align-center bg-white overflow-hidden rounded-xl text-left shadow-xl transform transition-all sm:my-24 sm:align-middle sm:max-w-2xl sm:w-full\\\" role=\\\"dialog\\\" style=\\\"width:60rem;\\\" aria-modal=\\\"true\\\" aria-labelledby=\\\"modal-headline\\\">\\r\\n                    <div class=\\\"rounded-xl bg-white border-2 p-8\\\">\\r\\n                      <div class=\\\"flex justify-between items-center mb-5\\\">\\r\\n                        <div class=\\\"fs-16 fw-600\\\">Detail Penanganan - {{item.report_id}}</div>\\r\\n                        <button onclick=\\\"closeModal('penanganan-{{index}}')\\\" class=\\\"m-0 font-bold text-xl\\\" type=\\\"button\\\">\\r\\n                          <svg xmlns=\\\"http://www.w3.org/2000/svg\\\" width=\\\"24\\\" height=\\\"24\\\" viewBox=\\\"0 0 24 24\\\" fill=\\\"none\\\">\\r\\n                            <path d=\\\"M19.281 18.2194C19.3507 18.289 19.406 18.3718 19.4437 18.4628C19.4814 18.5539 19.5008 18.6514 19.5008 18.75C19.5008 18.8485 19.4814 18.9461 19.4437 19.0372C19.406 19.1282 19.3507 19.2109 19.281 19.2806C19.2114 19.3503 19.1286 19.4056 19.0376 19.4433C18.9465 19.481 18.849 19.5004 18.7504 19.5004C18.6519 19.5004 18.5543 19.481 18.4632 19.4433C18.3722 19.4056 18.2895 19.3503 18.2198 19.2806L12.0004 13.0603L5.78104 19.2806C5.64031 19.4213 5.44944 19.5004 5.25042 19.5004C5.05139 19.5004 4.86052 19.4213 4.71979 19.2806C4.57906 19.1399 4.5 18.949 4.5 18.75C4.5 18.551 4.57906 18.3601 4.71979 18.2194L10.9401 12L4.71979 5.78061C4.57906 5.63988 4.5 5.44901 4.5 5.24999C4.5 5.05097 4.57906 4.8601 4.71979 4.71936C4.86052 4.57863 4.86052 4.57863 4.86052 4.57863C4.86052 4.57863 5.05139 4.49957 5.25042 4.49957C5.44944 4.49957 5.64031 4.57863 5.78104 4.71936L12.0004 10.9397L18.2198 4.71936C18.3605 4.57863 18.5514 4.49957 18.7504 4.49957C18.9494 4.49957 19.1403 4.57863 19.281 4.71936C19.4218 4.8601 19.5008 5.05097 19.5008 5.24999C19.5008 5.44901 19.4218 5.63988 19.281 5.78061L13.0607 12L19.281 18.2194Z\\\" fill=\\\"#333333\\\" />\\r\\n                          </svg>\\r\\n                        </button>\\r\\n                      </div>\\r\\n\\r\\n                      <div class=\\\"card-detail\\\">\\r\\n                        <div class=\\\"flex items-center w-100 \\\">\\r\\n                          <div class=\\\"information\\\">Nama Penanggung Jawab</div>\\r\\n                          <div>{{item.responsible_person_name}}</div>\\r\\n                        </div>\\r\\n                        <div class=\\\"flex items-center w-100 \\\">\\r\\n                          <div class=\\\"information\\\">Nama Penyidik</div>\\r\\n                          <div>{{item.officer_report_name}}</div>\\r\\n                        </div>\\r\\n                        <div class=\\\"flex items-center w-100 \\\">\\r\\n                          <div class=\\\"information\\\">Perihal</div>\\r\\n                          <div>{{item.subject}}</div>\\r\\n                        </div>\\r\\n                        <div class=\\\"flex items-center w-100 \\\">\\r\\n                          <div class=\\\"information\\\">Tanggal Penanganan</div>\\r\\n                          <div>{{dateFormat item.date_activity \\\"DD MMM YYYY, HH:mm\\\"}} WIB</div>\\r\\n                        </div>\\r\\n                        <div class=\\\"flex items-center w-100 \\\">\\r\\n                          <div class=\\\"information\\\">Penanganan Laporan</div>\\r\\n                          <div>{{item.handling_progress}}</div>\\r\\n                        </div>\\r\\n                      </div>\\r\\n                      <div class=\\\"space-y-4\\\">\\r\\n\\r\\n                        <div>\\r\\n                          <label class=\\\"block text-sm font-medium text-gray-700 mb-1\\\">Lampiran</label>\\r\\n                          <div class=\\\"text-gray-900\\\">\\r\\n                            {{#if item.attachments}}\\r\\n                              {{#each item.attachments}}\\r\\n                                {{#if url}}\\r\\n                                  <div class=\\\"attachment-item\\\">\\r\\n                                    {{#if (isImageFile url)}}\\r\\n                                      <img src=\\\"{{cdnAsuraToCurrentDomain url}}\\\" alt=\\\"Lampiran\\\" class=\\\"max-w-full h-auto rounded-lg cursor-pointer\\\" onclick=\\\"window.open('{{cdnAsuraToCurrentDomain url}}', '_blank')\\\">\\r\\n                                    {{else}}\\r\\n                                      <div class=\\\"file-attachment\\\">\\r\\n                                        <div class=\\\"file-icon-wrapper\\\">\\r\\n                                          <i class=\\\"{{getFileIconByType url}} fs-20\\\" style=\\\"color:var(--primary)\\\"></i>\\r\\n                                        </div>\\r\\n                                        <div class=\\\"file-info\\\">\\r\\n                                          <div class=\\\"file-name\\\">{{file_name}}</div>\\r\\n                                          {{#if size}}\\r\\n                                            <div class=\\\"file-size\\\">{{size}}</div>\\r\\n                                          {{/if}}\\r\\n                                        </div>\\r\\n                                        <a href=\\\"{{cdnAsuraToCurrentDomain url}}\\\" download=\\\"{{file_name}}\\\" class=\\\"download-btn\\\">\\r\\n                                          <i class=\\\"ph ph-download-simple\\\"></i>\\r\\n                                        </a>\\r\\n                                      </div>\\r\\n                                    {{/if}}\\r\\n                                    {{#if detail}}\\r\\n                                      <p class=\\\"mt-2 text-sm\\\">{{detail}}</p>\\r\\n                                    {{/if}}\\r\\n                                  </div>\\r\\n                                {{/if}}\\r\\n                              {{/each}}\\r\\n                            {{else}}\\r\\n                              <span>Tidak ada lampiran</span>\\r\\n                            {{/if}}\\r\\n                          </div>\\r\\n                        </div>\\r\\n                      </div>\\r\\n                    </div>\\r\\n                  </div>\\r\\n                </div>\\r\\n              </div>\\r\\n            </div>\\r\\n          {{/if}}\\r\\n\\r\\n        {{/each}}\\r\\n      </div>\\r\\n    </div>\\r\\n  </div>\\r\\n</div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":false,\"dateFields\":[\"date_activity\"],\"childrenConfig\":{\"enable\":false},\"useAsFilterConfig\":{\"enable\":false},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"cache\":{\"status\":false},\"pageState\":true,\"orderColumn\":false,\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false,\"shareAPI\":\"\",\"manageOrderColumn\":{\"orderColumn\":{\"enable\":false,\"columns\":[]}},\"filtersGeneral\":{\"type\":\"\"}},\"x\":8,\"y\":78},{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-01-23 23:12:19.835000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":38,\"id\":\"c142fd1f8dc040e6f5185f4837ce5aac\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"db23b1acf5ab6564f0393a3040c2db2d\",\"sourceId\":[\"0e2671c991e778604feb386c8564c848\",\"2487ed7ae5e0525fa5e62a87d1ff6fc5\",\"4d556d20cb857c9432a232b830b3a278\"],\"query\":null,\"name\":\"Bukti Pendukung\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Rekap Laporan\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":110,\"w\":8,\"h\":38}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Bukti Pendukung\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"c142fd1f8dc040e6f5185f4837ce5aac\":{\"table\":\"aduan_masyarakat_v3.\\\"report_officer_attachments\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"db23b1acf5ab6564f0393a3040c2db2d\",\"sourceId\":[\"0e2671c991e778604feb386c8564c848\",\"2487ed7ae5e0525fa5e62a87d1ff6fc5\",\"4d556d20cb857c9432a232b830b3a278\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"prepetrator_id\",\"alias\":\"url\",\"name\":\"prepetrator_id\",\"type\":\"string\"},{\"field\":\"created_at\",\"alias\":\"updated_at\",\"name\":\"created_at\",\"type\":\"number\"},{\"field\":\"file_name\",\"alias\":\"size\",\"name\":\"file_name\",\"type\":\"string\"},{\"field\":\"file_type\",\"alias\":\"detail\",\"name\":\"file_type\",\"type\":\"string\"},{\"field\":\"url\",\"alias\":\"url\",\"name\":\"url\",\"type\":\"url\"},{\"field\":\"source_table\",\"alias\":\"source_table\",\"name\":\"source_table\",\"type\":\"string\"}]},\"customColorKey\":[],\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false}},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"id\",\"created_at\",\"file_name\",\"file_type\",\"report_type\",\"url\",\"prepetrator_id\",\"source_table\"],[\"2026070901002\",1783644774337,\"SP2HP2 CONTOH.docx\",\"vnd.openxmlformats-officedocument.wordprocessingml.document\",\"SP2HP2\",\"s3://fusion/agent/0000005300000a5d000141750026ed73_1783669973596_i9lovl.docx\",\"2026070901002-00001\",\"generate_report\"],[\"2026070901002\",1783644758997,\"SP2HP2 CONTOH.docx\",\"vnd.openxmlformats-officedocument.wordprocessingml.document\",\"SP2HP2\",\"s3://fusion/agent/0000005300000a5d000141750026ed73_1783669958363_lj7bch.docx\",\"2026070901002-00001\",\"generate_report\"],[\"2026070901002\",1783643112478,\"LP /2026070901002-A/VII/2026/Roprovos\",\"docx\",\"LP DISIPLIN\",\"http://192.168.180.99:8000/nextcloud-regen-pusat/propam/provos/lp_provos_20260710072512_2026070901002.docx\",\"2026070901002-00001\",\"generate_report\"],[\"2026070901002\",1783642895829,\"merged_comparison.png\",\"png\",\"SP2HP2\",\"s3://fusion/agent/0000006d00000d980001a5da003315cd_1783668095410_mkrnm3.png\",\"2026070901002-00001\",\"generate_report\"],[\"2026070901002\",1783642601964,\"USULAN EMP.pdf\",\"pdf\",\"SP2HP2\",\"s3://fusion/agent/0000005500000a9e000149770027e5b5_1783667801152_r95exr.pdf\",\"2026070901002-00001\",\"generate_report\"],[\"2026070901002\",1783640457114,\"Analisis E-Tilang.pdf\",\"pdf\",null,\"s3://fusion/agent/000000410000084d000101b4001f3538_1783665655892_t1ho7e.pdf\",\"2026070901002-00001\",\"report_attachments\"],[\"2026070901002\",1783640457114,\"Analisis E-Tilang.pdf\",\"pdf\",null,\"s3://fusion/agent/000000410000084d000101b4001f3538_1783665655892_t1ho7e.pdf\",\"2026070901002-00001\",\"report_attachments\"],[\"2026070901002\",1783640457114,\"Analisis E-Tilang.pdf\",\"pdf\",null,\"s3://fusion/agent/000000410000084d000101b4001f3538_1783665655892_t1ho7e.pdf\",\"2026070901002-00001\",\"report_attachments\"],[\"2026070901002\",1783640457114,\"Analisis E-Tilang.pdf\",\"pdf\",null,\"s3://fusion/agent/000000410000084d000101b4001f3538_1783665655892_t1ho7e.pdf\",\"2026070901002-00001\",\"report_attachments\"],[\"2026070901002\",1783640457114,\"Analisis E-Tilang.pdf\",\"pdf\",null,\"s3://fusion/agent/000000410000084d000101b4001f3538_1783665655892_t1ho7e.pdf\",\"2026070901002-00001\",\"report_attachments\"]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useRef } from 'react';\\nimport { useForm } from 'react-hook-form';\\nimport styled from 'styled-components';\\nimport { Card, Button, Spinner } from 'react-bootstrap';\\nimport { dashboard } from '@store/app';\\nimport { useSearchParams } from 'react-router-dom';\\nimport { useNotification } from 'notification.hooks';\\n\\nexport default function LaporanCard({ widget, data, user, pageState }) {\\n  const { dispatchNotification } = useNotification();\\n  const [showModal, setShowModal] = useState(false);\\n  const [selectedImage, setSelectedImage] = useState('');\\n  const [selectedItem, setSelectedItem] = useState(null);\\n\\n  const [loading, setLoading] = useState(false);\\n  const [sp2hp2Loading, setSp2hp2Loading] = useState(false);\\n  const sp2hp2InputRef = useRef(null);\\n  const [isImageLoaded, setIsImageLoaded] = useState(false);\\n  const [uploadLoading, setUploadLoading] = useState(false);\\n  const fileInputRef = useRef(null);\\n\\n  const [searchParams] = useSearchParams();\\n  const idDetailFromUrl = searchParams.get('id-detail');\\n\\n  // const dataArray = Array.isArray(data) ? data : [];\\n  // const currentItems = dataArray;\\n\\n  const dataArray = Array.isArray(data) ? data : [];\\n\\n  const sp2hp2Files = dataArray.filter((item) => item.report_type === 'SP2HP2');\\n  const otherFiles = dataArray.filter((item) => item.report_type !== 'SP2HP2');\\n\\n  const currentItems = otherFiles;\\n\\n  const pages = {\\n    informasiDasar: pageState?.['dad5b834f5a7a46b8a119d6e54211dbd'],\\n  };\\n\\n  const informasiDasarData = pages?.informasiDasar?.data?.[0] || {};\\n  // console.log(informasiDasarData, 'te');\\n\\n  const formatTimeAgo = (timestamp) => {\\n    if (!timestamp) return '-';\\n\\n    const date =\\n      typeof timestamp === 'number' ? new Date(timestamp) : new Date(timestamp);\\n\\n    const time = date.getTime();\\n\\n    if (!Number.isFinite(time)) {\\n      return '-';\\n    }\\n\\n    const diff = Date.now() - time;\\n\\n    const rtf = new Intl.RelativeTimeFormat('id', {\\n      numeric: 'auto',\\n    });\\n\\n    const seconds = Math.floor(diff / 1000);\\n    const minutes = Math.floor(seconds / 60);\\n    const hours = Math.floor(minutes / 60);\\n    const days = Math.floor(hours / 24);\\n    const months = Math.floor(days / 30);\\n    const years = Math.floor(days / 365);\\n\\n    if (seconds < 60) return rtf.format(-seconds, 'second');\\n    if (minutes < 60) return rtf.format(-minutes, 'minute');\\n    if (hours < 24) return rtf.format(-hours, 'hour');\\n    if (days < 30) return rtf.format(-days, 'day');\\n    if (months < 12) return rtf.format(-months, 'month');\\n\\n    return rtf.format(-years, 'year');\\n  };\\n\\n  // const convertS3Url = (url) => {\\n  //   if (!url) return '';\\n\\n  //   if (url.startsWith('http://192.168.180.99:8000')) {\\n  //     return url.replace(\\n  //       'http://192.168.180.99:8000',\\n  //       'https://asura-s3.ebdesk.com',\\n  //     );\\n  //   }\\n\\n  //   if (url.startsWith('https://')) return url;\\n\\n  //   if (url.startsWith('s3://')) {\\n  //     return url.replace('s3://', 'https://asura-s3.stellardata.ai/');\\n  //   }\\n\\n  //   return url;\\n  // };\\n\\n  const convertS3Url = (url) => {\\n    if (!url) return '';\\n\\n    if (url.startsWith('s3://fusion/agent/')) {\\n      const path = url.replace('s3://fusion/agent/', '');\\n      const encodedPath = path\\n        .split('/')\\n        .map((part) => encodeURIComponent(part))\\n        .join('/');\\n      if (\\n        encodedPath.includes('/cdn/media') ||\\n        encodedPath.startsWith('cdn/media')\\n      ) {\\n        return `https://gajamada-propam.polri.go.id/fusion/agent/${encodedPath}`;\\n      } else {\\n        return `https://gajamada-propam.polri.go.id/cdn/media/fusion/agent/${encodedPath}`;\\n      }\\n    }\\n\\n    // Handle s3:// lainnya\\n    if (url.startsWith('s3://')) {\\n      return url.replace('s3://', 'https://asura-s3.stellardata.ai/');\\n    }\\n\\n    if (url.startsWith('http://192.168.180.99:8000')) {\\n      return url.replace(\\n        'http://192.168.180.99:8000',\\n        'https://asura-s3.ebdesk.com',\\n      );\\n    }\\n\\n    if (url.startsWith('https://yanduan-s3.polri.go.id:9000')) {\\n      const path = url.replace('https://yanduan-s3.polri.go.id:9000', '');\\n\\n      if (path.includes('/cdn/media')) {\\n        return `https://gajamada-propam.polri.go.id${path}`;\\n      } else {\\n        return `https://gajamada-propam.polri.go.id/cdn/media${path}`;\\n      }\\n    }\\n\\n    return url;\\n  };\\n\\n  const handleDownloadFile = (item) => {\\n    try {\\n      const fileUrl = convertS3Url(item.url);\\n\\n      if (!fileUrl) {\\n        console.error('URL file tidak valid');\\n        return;\\n      }\\n\\n      // Ambil ekstensi\\n      let fileExtension = item.file_type || '';\\n      if (!fileExtension) {\\n        const ext = fileUrl.split('.').pop()?.toLowerCase() || 'pdf';\\n        fileExtension = ext.split('?')[0];\\n      }\\n\\n      // Bersihkan nama file\\n      let fileName = item.file_name || 'document';\\n      fileName = fileName.replace(/[<>:\\\"/\\\\\\\\|?*]/g, '');\\n      fileName = fileName.replace(/\\\\.[^/.]+$/, '');\\n\\n      console.log('Downloading:', `${fileName}.${fileExtension}`);\\n\\n      // Download dengan link biasa\\n      const link = document.createElement('a');\\n      link.href = fileUrl;\\n      link.download = `${fileName}.${fileExtension}`;\\n      link.target = '_blank';\\n      document.body.appendChild(link);\\n      link.click();\\n      document.body.removeChild(link);\\n    } catch (error) {\\n      console.error('Error:', error);\\n      alert(`Gagal mengunduh file: ${error.message}`);\\n    }\\n  };\\n\\n  const getFileExtensionFromUrl = (url) => {\\n    if (!url) return 'pdf';\\n\\n    const urlParts = url.split('.');\\n    if (urlParts.length > 1) {\\n      return urlParts[urlParts.length - 1].toLowerCase();\\n    }\\n    return 'pdf';\\n  };\\n\\n  // Fungsi untuk membuka file di tab baru (preview)\\n  // const handlePreviewFile = (item) => {\\n  //   try {\\n  //     const fileUrl = convertS3Url(item.url);\\n  //     if (fileUrl) {\\n  //       window.open(fileUrl, '_blank');\\n  //     }\\n  //   } catch (error) {\\n  //     console.error('Error previewing file:', error);\\n  //   }\\n  // };\\n\\n  const filterValidFiles = (\\n    files,\\n    allowedExtensions = ['.pdf', '.jpg', '.png', '.doc', '.docx'],\\n  ) => {\\n    const MAX_FILE_SIZE = 50 * 1024 * 1024;\\n    const invalidFiles = [];\\n    const validFiles = [];\\n\\n    files.forEach((file) => {\\n      const fileName = file.name.toLowerCase();\\n      const isValidExt = allowedExtensions.some((ext) =>\\n        fileName.endsWith(ext),\\n      );\\n      const isValidSize = file.size <= MAX_FILE_SIZE;\\n\\n      if (isValidExt && isValidSize) {\\n        validFiles.push(file);\\n      } else {\\n        if (!isValidExt) {\\n          invalidFiles.push(`${file.name} (format tidak diizinkan)`);\\n        } else if (!isValidSize) {\\n          invalidFiles.push(`${file.name} (melebihi 50MB)`);\\n        }\\n      }\\n    });\\n\\n    if (invalidFiles.length > 0) {\\n      dispatchNotification(\\n        `File ditolak: ${invalidFiles.join(', ')}. Format yang diizinkan: ${allowedExtensions.join(', ')}`,\\n        'danger',\\n      );\\n    }\\n\\n    return validFiles;\\n  };\\n\\n  const simpleHash32 = (str) => {\\n    let hash = 0;\\n    let result = '';\\n\\n    for (let i = 0; i < str.length; i++) {\\n      const char = str.charCodeAt(i);\\n      hash = (hash << 5) - hash + char;\\n      hash = hash & hash;\\n\\n      const hex = Math.abs(hash).toString(16).padStart(8, '0');\\n      result += hex;\\n\\n      if (result.length >= 32) break;\\n    }\\n\\n    while (result.length < 32) {\\n      result += '0';\\n    }\\n\\n    return result.substring(0, 32);\\n  };\\n\\n  const getFileExtension = (filename) => {\\n    return filename.split('.').pop() || '';\\n  };\\n\\n  const generateHashedPath = (originalFilename) => {\\n    const hash = simpleHash32(originalFilename);\\n    const extension = getFileExtension(originalFilename);\\n    const timestamp = Date.now();\\n    const random = Math.random().toString(36).substring(2, 8);\\n\\n    return `${hash}_${timestamp}_${random}.${extension}`;\\n  };\\n  const onSubmitGenerate = async () => {\\n    setLoading(true);\\n    console.log('Starting submit process...');\\n\\n    try {\\n      const reportId = informasiDasarData?.prepetrator_id;\\n\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '2b78f35564f497044109d1d647f98cf8',\\n        params: {},\\n        body: { report_id: reportId },\\n        headers: {},\\n        additionalPath: '',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id,\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id,\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n      };\\n\\n      console.log('Sending to gateway:', requestPayload);\\n\\n      const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!gatewayResponse.ok) {\\n        const errorText = await gatewayResponse.text();\\n        throw new Error(`Gateway error: ${errorText}`);\\n      }\\n\\n      const gatewayResult = await gatewayResponse.json();\\n      dispatchNotification('Upload dokumen berhasil!', 'success');\\n      // console.log('Gateway success:', gatewayResult);\\n    } catch (err) {\\n      console.error('Error submit ke gateway:', err);\\n      // dispatchNotification(`Error: ${err.message}`, 'danger');\\n    } finally {\\n      setLoading(false);\\n    }\\n  };\\n\\n  // const handleUploadAndExecute = async (files) => {\\n  //   const validFiles = filterValidFiles(Array.from(files));\\n\\n  //   if (validFiles.length === 0) {\\n  //     dispatchNotification(\\n  //       'Tidak ada file yang valid untuk diupload',\\n  //       'warning',\\n  //     );\\n  //     setUploadLoading(false);\\n  //     if (fileInputRef.current) fileInputRef.current.value = '';\\n  //     return;\\n  //   }\\n  //   setUploadLoading(true);\\n\\n  //   try {\\n  //     const attachments = [];\\n\\n  //     for (const file of validFiles) {\\n  //       const queryParams = new URLSearchParams({\\n  //         folder: 'agent',\\n  //         workspaceId: user?.workspaceId || '',\\n  //         dashboardId: dashboard?.id,\\n  //         createdBy: user?.id,\\n  //         extractFile: 'false',\\n  //       }).toString();\\n\\n  //       const formData = new FormData();\\n  //       formData.append('file', file);\\n  //       formData.append('tags', 'assets');\\n\\n  //       const res = await fetch(\\n  //         `/api/v1/apps/upload/upload-file?${queryParams}`,\\n  //         {\\n  //           method: 'POST',\\n  //           body: formData,\\n  //         },\\n  //       );\\n\\n  //       if (!res.ok) throw new Error(`Upload ${file.name} gagal`);\\n\\n  //       const result = await res.json();\\n  //       attachments.push({\\n  //         name: file.name,\\n  //         url: result?.data?.path || '',\\n  //         type: file.type,\\n  //       });\\n  //     }\\n\\n  //     console.log('All files uploaded:', attachments);\\n\\n  //     const reportId = informasiDasarData?.prepetrator_id;\\n\\n  //     const requestPayload = {\\n  //       client: 'Propam Polri',\\n  //       gatewayId: '314b80f7ce408ee9911ac3d4723ba0f9',\\n  //       params: {},\\n  //       body: {\\n  //         report_id: reportId,\\n  //         attachment: attachments,\\n  //         report_type: 'barbuk',\\n  //       },\\n  //       headers: {},\\n  //       additionalPath: '',\\n  //       additionalParams: {},\\n  //       additionalFileParams: {},\\n  //       tags: ['Propam Polri'],\\n  //       createdBy: user?.id,\\n  //       startDate: '',\\n  //       endDate: '',\\n  //       dashboardId: dashboard?.id,\\n  //       sessionId: '',\\n  //       logging: false,\\n  //       appendedLog: false,\\n  //     };\\n\\n  //     const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n  //       method: 'POST',\\n  //       headers: { 'Content-Type': 'application/json' },\\n  //       body: JSON.stringify(requestPayload),\\n  //     });\\n\\n  //     if (!gatewayResponse.ok) throw new Error('Execute gagal');\\n  //     dispatchNotification('Upload dokumen berhasil!', 'success');\\n\\n  //     // setTimeout(() => window.location.reload(), 3000);\\n  //   } catch (err) {\\n  //     console.error('Error:', err);\\n  //     alert(`Gagal: ${err.message}`);\\n  //   } finally {\\n  //     setUploadLoading(false);\\n  //     if (fileInputRef.current) fileInputRef.current.value = '';\\n  //   }\\n  // };\\n  const handleUploadAndExecute = async (files) => {\\n    const validFiles = filterValidFiles(Array.from(files));\\n\\n    if (validFiles.length === 0) {\\n      dispatchNotification(\\n        'Tidak ada file yang valid untuk diupload',\\n        'warning',\\n      );\\n      setUploadLoading(false);\\n      if (fileInputRef.current) fileInputRef.current.value = '';\\n      return;\\n    }\\n    setUploadLoading(true);\\n\\n    try {\\n      const attachments = [];\\n\\n      for (const file of validFiles) {\\n        const hashedPath = generateHashedPath(file.name);\\n        const fileHash = simpleHash32(file.name);\\n        const createdByValue = `agent_${fileHash.substring(0, 8)}`;\\n\\n        const queryParams = new URLSearchParams({\\n          folder: 'agent',\\n          workspaceId: user?.workspaceId || '',\\n          dashboardId: dashboard?.id,\\n          createdBy: createdByValue,\\n          extractFile: 'false',\\n          filename: hashedPath,\\n        }).toString();\\n\\n        const formData = new FormData();\\n        formData.append('file', file);\\n        formData.append('tags', 'assets');\\n\\n        const res = await fetch(\\n          `/api/v1/apps/upload/upload-file?${queryParams}`,\\n          {\\n            method: 'POST',\\n            body: formData,\\n          },\\n        );\\n\\n        if (!res.ok) throw new Error(`Upload ${file.name} gagal`);\\n\\n        const result = await res.json();\\n        attachments.push({\\n          name: file.name,\\n          url: result?.data?.path || '',\\n          type: file.type,\\n        });\\n      }\\n\\n      console.log('All files uploaded:', attachments);\\n\\n      const reportId = informasiDasarData?.prepetrator_id;\\n\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '314b80f7ce408ee9911ac3d4723ba0f9',\\n        params: {},\\n        body: {\\n          report_id: reportId,\\n          attachment: attachments,\\n          // report_type: 'barbuk',\\n        },\\n        headers: {},\\n        additionalPath: '',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id,\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id,\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n      };\\n\\n      const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!gatewayResponse.ok) throw new Error('Execute gagal');\\n      dispatchNotification('Upload dokumen berhasil!', 'success');\\n    } catch (err) {\\n      console.error('Error:', err);\\n      alert(`Gagal: ${err.message}`);\\n    } finally {\\n      setUploadLoading(false);\\n      if (fileInputRef.current) fileInputRef.current.value = '';\\n    }\\n  };\\n\\n  // const handleUploadSP = async (files) => {\\n  //   const validFiles = filterValidFiles(Array.from(files));\\n\\n  //   if (validFiles.length === 0) {\\n  //     dispatchNotification(\\n  //       'Tidak ada file yang valid untuk diupload',\\n  //       'warning',\\n  //     );\\n  //     setSp2hp2Loading(false);\\n  //     if (sp2hp2InputRef.current) sp2hp2InputRef.current.value = '';\\n  //     return;\\n  //   }\\n  //   setSp2hp2Loading(true);\\n\\n  //   try {\\n  //     const attachments = [];\\n\\n  //     for (const file of validFiles) {\\n  //       const queryParams = new URLSearchParams({\\n  //         folder: 'agent',\\n  //         workspaceId: user?.workspaceId || '',\\n  //         dashboardId: dashboard?.id,\\n  //         createdBy: user?.id,\\n  //         extractFile: 'false',\\n  //       }).toString();\\n\\n  //       const formData = new FormData();\\n  //       formData.append('file', file);\\n  //       formData.append('tags', 'assets');\\n\\n  //       const res = await fetch(\\n  //         `/api/v1/apps/upload/upload-file?${queryParams}`,\\n  //         {\\n  //           method: 'POST',\\n  //           body: formData,\\n  //         },\\n  //       );\\n\\n  //       if (!res.ok) throw new Error(`Upload ${file.name} gagal`);\\n\\n  //       const result = await res.json();\\n  //       attachments.push({\\n  //         name: file.name,\\n  //         url: result?.data?.path || '',\\n  //         type: file.type,\\n  //       });\\n  //     }\\n\\n  //     console.log('SP2HP2 files uploaded:', attachments);\\n\\n  //     const reportId = informasiDasarData?.prepetrator_id;\\n\\n  //     const requestPayload = {\\n  //       client: 'Propam Polri',\\n  //       gatewayId: '314b80f7ce408ee9911ac3d4723ba0f9',\\n  //       params: {},\\n  //       body: {\\n  //         report_id: reportId,\\n  //         attachment: attachments,\\n  //         report_type: 'SP2HP2',\\n  //       },\\n  //       headers: {},\\n  //       additionalPath: '',\\n  //       additionalParams: {},\\n  //       additionalFileParams: {},\\n  //       tags: ['Propam Polri'],\\n  //       createdBy: user?.id,\\n  //       startDate: '',\\n  //       endDate: '',\\n  //       dashboardId: dashboard?.id,\\n  //       sessionId: '',\\n  //       logging: false,\\n  //       appendedLog: false,\\n  //     };\\n\\n  //     const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n  //       method: 'POST',\\n  //       headers: { 'Content-Type': 'application/json' },\\n  //       body: JSON.stringify(requestPayload),\\n  //     });\\n\\n  //     if (!gatewayResponse.ok) throw new Error('Execute gagal');\\n\\n  //     dispatchNotification('Upload dokumen berhasil!', 'success');\\n  //   } catch (err) {\\n  //     console.error('Error:', err);\\n  //     alert(`Gagal: ${err.message}`);\\n  //   } finally {\\n  //     setSp2hp2Loading(false);\\n  //     if (sp2hp2InputRef.current) sp2hp2InputRef.current.value = '';\\n  //   }\\n  // };\\n  const handleUploadSP = async (files) => {\\n    const validFiles = filterValidFiles(Array.from(files));\\n\\n    if (validFiles.length === 0) {\\n      dispatchNotification(\\n        'Tidak ada file yang valid untuk diupload',\\n        'warning',\\n      );\\n      setSp2hp2Loading(false);\\n      if (sp2hp2InputRef.current) sp2hp2InputRef.current.value = '';\\n      return;\\n    }\\n    setSp2hp2Loading(true);\\n\\n    try {\\n      const attachments = [];\\n\\n      for (const file of validFiles) {\\n        const hashedPath = generateHashedPath(file.name);\\n        const fileHash = simpleHash32(file.name);\\n        const createdByValue = `agent_${fileHash.substring(0, 8)}`;\\n\\n        const queryParams = new URLSearchParams({\\n          folder: 'agent',\\n          workspaceId: user?.workspaceId || '',\\n          dashboardId: dashboard?.id,\\n          createdBy: createdByValue,\\n          extractFile: 'false',\\n          filename: hashedPath,\\n        }).toString();\\n\\n        const formData = new FormData();\\n        formData.append('file', file);\\n        formData.append('tags', 'assets');\\n\\n        const res = await fetch(\\n          `/api/v1/apps/upload/upload-file?${queryParams}`,\\n          {\\n            method: 'POST',\\n            body: formData,\\n          },\\n        );\\n\\n        if (!res.ok) throw new Error(`Upload ${file.name} gagal`);\\n\\n        const result = await res.json();\\n        attachments.push({\\n          name: file.name,\\n          url: result?.data?.path || '',\\n          type: file.type,\\n        });\\n      }\\n\\n      console.log('SP2HP2 files uploaded:', attachments);\\n\\n      const reportId = informasiDasarData?.prepetrator_id;\\n\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '314b80f7ce408ee9911ac3d4723ba0f9',\\n        params: {},\\n        body: {\\n          report_id: reportId,\\n          attachment: attachments,\\n          report_type: 'SP2HP2',\\n        },\\n        headers: {},\\n        additionalPath: '',\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id,\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id,\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n      };\\n\\n      const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!gatewayResponse.ok) throw new Error('Execute gagal');\\n\\n      dispatchNotification('Upload dokumen berhasil!', 'success');\\n    } catch (err) {\\n      console.error('Error:', err);\\n      alert(`Gagal: ${err.message}`);\\n    } finally {\\n      setSp2hp2Loading(false);\\n      if (sp2hp2InputRef.current) sp2hp2InputRef.current.value = '';\\n    }\\n  };\\n\\n  const triggerFileInput = () => {\\n    fileInputRef.current?.click();\\n  };\\n  const triggerSP2HP2Input = () => {\\n    sp2hp2InputRef.current?.click();\\n  };\\n\\n  return (\\n    <>\\n      <CardWrapper>\\n        <HeaderSection>\\n          <div className=\\\"flex justify-between\\\">\\n            <div className=\\\"widget-title\\\">{widget?.name}</div>\\n\\n            <div className=\\\"flex items-center gap-2\\\">\\n              <StyledButton\\n                variant=\\\"secondary\\\"\\n                onClick={onSubmitGenerate}\\n                disabled={loading}\\n              >\\n                <i\\n                  className=\\\"ph ph-file-arrow-down\\\"\\n                  style={{ fontWeight: '600', fontSize: '1rem' }}\\n                ></i>\\n                {loading ? 'Memproses...' : 'Generate laporan'}\\n              </StyledButton>\\n\\n              <input\\n                type=\\\"file\\\"\\n                ref={fileInputRef}\\n                onChange={(e) =>\\n                  handleUploadAndExecute(Array.from(e.target.files))\\n                }\\n                style={{ display: 'none' }}\\n                accept=\\\".pdf,.jpg,.png,.doc,.docx\\\"\\n                multiple\\n              />\\n\\n              <StyledButton\\n                variant=\\\"secondary\\\"\\n                onClick={triggerFileInput}\\n                disabled={uploadLoading}\\n              >\\n                <i\\n                  className=\\\"ph ph-upload-simple\\\"\\n                  style={{ fontWeight: '600', fontSize: '1rem' }}\\n                ></i>\\n                {uploadLoading ? 'Processing...' : 'Upload Document'}\\n              </StyledButton>\\n            </div>\\n          </div>\\n        </HeaderSection>\\n        <ContentGrid>\\n          {/* <div className=\\\"flex flex-col gap-2 w-100\\\">\\n            <TitleInput className=\\\"pb-2\\\">SP2HP2</TitleInput>\\n            <input\\n              type=\\\"file\\\"\\n              ref={sp2hp2InputRef}\\n              onChange={(e) => handleUploadSP(Array.from(e.target.files))}\\n              style={{ display: 'none' }}\\n              accept=\\\".pdf,.jpg,.png,.doc,.docx\\\"\\n              multiple\\n            />\\n            <StyledCard style={{ borderRadius: '0.85714rem' }}>\\n              <div className=\\\"flex justify-between\\\">\\n                <div className=\\\"flex items-center gap-4\\\">\\n                  <WrappIcon>\\n                    <i class=\\\"ph ph-clipboard-text\\\" />\\n                  </WrappIcon>\\n\\n                  <TitleInput style={{ fontWeight: '400' }}>\\n                    Upload SP2HP2 disini\\n                  </TitleInput>\\n                </div>\\n                <Button\\n                  variant=\\\"secondary\\\"\\n                  style={{ border: 'none' }}\\n                  onClick={triggerSP2HP2Input}\\n                  disabled={sp2hp2Loading}\\n                >\\n                  {sp2hp2Loading ? (\\n                    <Spinner animation=\\\"border\\\" size=\\\"sm\\\" />\\n                  ) : (\\n                    <i\\n                      className=\\\"ph ph-upload-simple\\\"\\n                      style={{ fontSize: '1.2rem' }}\\n                    ></i>\\n                  )}\\n                </Button>\\n              </div>\\n            </StyledCard>\\n          </div> */}\\n          <TitleInput className=\\\"pb-2\\\">SP2HP2</TitleInput>\\n          <input\\n            type=\\\"file\\\"\\n            ref={sp2hp2InputRef}\\n            onChange={(e) => handleUploadSP(Array.from(e.target.files))}\\n            style={{ display: 'none' }}\\n            accept=\\\".pdf,.jpg,.png,.doc,.docx\\\"\\n            multiple\\n          />\\n\\n          {sp2hp2Files.length > 0 ? (\\n            sp2hp2Files.map((item, index) => (\\n              <StyledCard key={index}>\\n                <div className=\\\"d-flex justify-content-between align-items-center w-100\\\">\\n                  <div className=\\\"d-flex align-items-center gap-4\\\">\\n                    <WrappIcon style={{ backgroundColor: 'var(--primary-25)' }}>\\n                      <i\\n                        className=\\\"ph ph-clipboard-text\\\"\\n                        style={{ color: 'var(--primary)' }}\\n                      />\\n                    </WrappIcon>\\n                    <div>\\n                      <div className=\\\"fs-14 fw-600\\\">{item.file_name}</div>\\n                      <div className=\\\"text-muted\\\">\\n                        {formatTimeAgo(item.created_at)}\\n                      </div>\\n                    </div>\\n                  </div>\\n                  <div className=\\\"d-flex align-items-center gap-4 flex-shrink-0\\\">\\n                    <Button\\n                      variant=\\\"secondary\\\"\\n                      style={{ border: 'none', padding: '0' }}\\n                      onClick={triggerSP2HP2Input}\\n                      disabled={sp2hp2Loading}\\n                    >\\n                      {sp2hp2Loading ? (\\n                        <Spinner animation=\\\"border\\\" size=\\\"sm\\\" />\\n                      ) : (\\n                        <i\\n                          className=\\\"ph ph-upload-simple\\\"\\n                          style={{ fontSize: '1.2rem' }}\\n                        ></i>\\n                      )}\\n                    </Button>\\n                    <Button\\n                      variant=\\\"secondary\\\"\\n                      style={{ border: 'none', padding: '0' }}\\n                      onClick={() => handleDownloadFile(item)}\\n                    >\\n                      <i\\n                        className=\\\"ph ph-download-simple\\\"\\n                        style={{ fontSize: '1.2rem' }}\\n                      ></i>\\n                    </Button>\\n                  </div>\\n                </div>\\n              </StyledCard>\\n            ))\\n          ) : (\\n            <StyledCard style={{ borderRadius: '0.85714rem' }}>\\n              <div className=\\\"d-flex justify-content-between align-items-center\\\">\\n                <div className=\\\"d-flex align-items-center gap-4\\\">\\n                  <WrappIcon>\\n                    <i className=\\\"ph ph-clipboard-text\\\" />\\n                  </WrappIcon>\\n                  <TitleInput style={{ fontWeight: '400' }}>\\n                    Upload SP2HP2 disini\\n                  </TitleInput>\\n                </div>\\n                <Button\\n                  variant=\\\"secondary\\\"\\n                  style={{ border: 'none' }}\\n                  onClick={triggerSP2HP2Input}\\n                  disabled={sp2hp2Loading}\\n                >\\n                  {sp2hp2Loading ? (\\n                    <Spinner animation=\\\"border\\\" size=\\\"sm\\\" />\\n                  ) : (\\n                    <i\\n                      className=\\\"ph ph-upload-simple\\\"\\n                      style={{ fontSize: '1.2rem' }}\\n                    ></i>\\n                  )}\\n                </Button>\\n              </div>\\n            </StyledCard>\\n          )}\\n\\n          <hr style={{ border: '1px solid var(--black-100)' }} />\\n\\n          <TitleInput>Dokumen Lainnya</TitleInput>\\n\\n          {currentItems.length === 0 ? (\\n            <div className=\\\"flex flex-col items-center justify-center py-10 text-muted\\\">\\n              <img\\n                src=\\\"/cdn/media/fusion/assets/1731748832639/Group 1 (4).svg\\\"\\n                alt=\\\"no-data\\\"\\n                style={{ width: '150px', marginBottom: '1rem' }}\\n              />\\n              <p className=\\\"m-0\\\">Belum ada dokumen lainnya</p>\\n            </div>\\n          ) : (\\n            currentItems.map((item, index) => (\\n              <StyledCard key={index}>\\n                <div className=\\\"flex items-center gap-4\\\">\\n                  <ImageWrapper\\n                    style={{\\n                      backgroundColor: getFileBgColor(item),\\n                      border: `1px solid ${getFileIconColor(item)}20`,\\n                    }}\\n                  >\\n                    {item.url &&\\n                    (item.url.endsWith('.jpg') ||\\n                      item.url.endsWith('.png') ||\\n                      item.url.endsWith('.jpeg')) ? (\\n                      <img\\n                        src={convertS3Url(item.url)}\\n                        alt=\\\"Preview\\\"\\n                        onLoad={() => setIsImageLoaded(true)}\\n                        onError={(e) => {\\n                          e.target.style.display = 'none';\\n                          setIsImageLoaded(false);\\n                        }}\\n                      />\\n                    ) : null}\\n\\n                    {!isImageLoaded && (\\n                      <FallbackIcon>\\n                        <i\\n                          className={getFileIcon(item)}\\n                          style={{\\n                            color: getFileIconColor(item),\\n                            fontSize: '2rem',\\n                          }}\\n                        ></i>\\n                      </FallbackIcon>\\n                    )}\\n                  </ImageWrapper>\\n\\n                  <div className=\\\"flex justify-between w-100\\\">\\n                    <div className=\\\"flex flex-col flex-1\\\">\\n                      <div className=\\\"fs-14 fw-600\\\">{item.file_name}</div>\\n                      <div className=\\\"text-muted\\\">\\n                        {formatTimeAgo(item.created_at)}\\n                      </div>\\n                    </div>\\n\\n                    <DownloadButton\\n                      variant=\\\"secondary\\\"\\n                      style={{ border: 'none' }}\\n                      onClick={() => handleDownloadFile(item)}\\n                    >\\n                      <i\\n                        className=\\\"ph ph-download-simple\\\"\\n                        style={{ fontSize: '1.2rem' }}\\n                      ></i>\\n                    </DownloadButton>\\n                  </div>\\n                </div>\\n              </StyledCard>\\n            ))\\n          )}\\n        </ContentGrid>\\n      </CardWrapper>\\n    </>\\n  );\\n}\\n\\n// styled-components\\nconst TitleInput = styled.div`\\ncolor:var(--black);\\nfont-size: 0.85714rem;\\nfont-style: normal;\\nfont-weight: 600;\\nline-height: 140%;\\n`;\\n\\nconst CardWrapper = styled.div`\\n  background: var(--white);\\n  height: 100%;\\n  width: 100%;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.8rem;\\n  display: flex;\\n  flex-direction: column;\\n`;\\n\\nconst HeaderSection = styled.div`\\n  padding: 1rem 1.5rem;\\n  border-bottom: 1px solid var(--black-100);\\n`;\\n\\n// const ContentGrid = styled.div`\\n//   padding: 1.5rem;\\n// `;\\n\\nconst ContentGrid = styled.div`\\npadding: 1.5rem;\\n  display: flex;\\n  flex-direction: column;\\n  gap: 1rem;\\n  max-height: 28rem; /* ubah sesuai kebutuhan */\\n  overflow-y: auto;\\n  padding-right: 0.4rem; /* agar scroll tidak nempel ke konten */\\n  scrollbar-width: thin;\\n  scrollbar-color: var(--black-200) transparent;\\n\\n  /* styling scrollbar untuk Chrome/Safari */\\n  &::-webkit-scrollbar {\\n    width: 6px;\\n  }\\n\\n  &::-webkit-scrollbar-track {\\n    background: transparent;\\n  }\\n\\n  &::-webkit-scrollbar-thumb {\\n    background-color: var(--black-300);\\n    border-radius: 4px;\\n  }\\n`;\\n\\nconst StyledCard = styled(Card)`\\n  padding: 1rem;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem;\\n  margin-bottom: 1rem;\\n`;\\n\\nconst ImageWrapper = styled.div`\\n  position: relative;\\n  width: 50px;\\n  height: 50px;\\n  background: var(--danger-50);\\n  border-radius: 0.5rem;\\n  overflow: hidden;\\n  cursor: pointer;\\n  transition: all 0.2s ease;\\n\\n  &:hover {\\n    transform: scale(1.05);\\n  }\\n\\n  img {\\n    width: 100%;\\n    height: 100%;\\n    object-fit: cover;\\n    display: block;\\n  }\\n`;\\n\\nconst FallbackIcon = styled.div`\\n  position: absolute;\\n  inset: 0;\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  background-color:var(--black-25);\\n  border: 1px solid var(--black-100);\\n  i {\\n    font-size: 1.6rem;\\n    font-weight:600;\\n    color: var(--black-500)\\n  }\\n`;\\n\\nconst StyledButton = styled(Button)`\\n  border: 1px solid var(--black-100);\\n  display: flex;\\n  padding: 0.4rem 0.8rem 0.4rem 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  color: var(--black);\\n  font-size: 0.8rem !important;\\n  font-style: normal;\\n  font-weight: 600 !important;\\n  line-height: 1.06667rem;\\n`;\\n// Perbaiki fungsi getFileIcon untuk lebih mengutamakan file_type\\nconst getFileIcon = (item) => {\\n  const fileType = item.file_type?.toLowerCase() || '';\\n  const fileName = item.file_name?.toLowerCase() || '';\\n\\n  // Prioritaskan pengecekan berdasarkan file_type terlebih dahulu\\n  if (fileType === 'pdf' || fileType.includes('pdf')) {\\n    return 'ph-fill ph-file-pdf';\\n  }\\n  if (\\n    fileType === 'docx' ||\\n    fileType === 'doc' ||\\n    fileType.includes('word') ||\\n    fileType.includes('document')\\n  ) {\\n    return 'ph-fill ph-file-doc';\\n  }\\n  if (\\n    fileType === 'xlsx' ||\\n    fileType === 'xls' ||\\n    fileType.includes('excel') ||\\n    fileType.includes('spreadsheet')\\n  ) {\\n    return 'ph-fill ph-file-spreadsheet';\\n  }\\n  if (\\n    fileType === 'jpg' ||\\n    fileType === 'jpeg' ||\\n    fileType === 'png' ||\\n    fileType === 'gif' ||\\n    fileType === 'webp'\\n  ) {\\n    return 'ph-fill ph-file-image';\\n  }\\n  if (\\n    fileType === 'mp4' ||\\n    fileType === 'avi' ||\\n    fileType === 'mov' ||\\n    fileType === 'mkv'\\n  ) {\\n    return 'ph-fill ph-file-video';\\n  }\\n  if (fileType === 'mp3' || fileType === 'wav' || fileType === 'flac') {\\n    return 'ph-fill ph-file-audio';\\n  }\\n  if (fileType === 'zip' || fileType === 'rar' || fileType === '7z') {\\n    return 'ph-fill ph-file-archive';\\n  }\\n  if (fileType === 'txt' || fileType === 'log') {\\n    return 'ph-fill ph-file-text';\\n  }\\n\\n  // Fallback ke pengecekan dari file_name\\n  if (fileName.endsWith('.pdf')) return 'ph-fill ph-file-pdf';\\n  if (fileName.endsWith('.docx') || fileName.endsWith('.doc'))\\n    return 'ph-fill ph-file-doc';\\n  if (\\n    fileName.endsWith('.jpg') ||\\n    fileName.endsWith('.jpeg') ||\\n    fileName.endsWith('.png')\\n  )\\n    return 'ph-fill ph-file-image';\\n\\n  // Default icon\\n  return 'ph-fill ph-file';\\n};\\n\\n// Perbaiki fungsi getFileIconColor\\nconst getFileIconColor = (item) => {\\n  const fileType = item.file_type?.toLowerCase() || '';\\n  const fileName = item.file_name?.toLowerCase() || '';\\n\\n  if (\\n    fileType === 'pdf' ||\\n    fileType.includes('pdf') ||\\n    fileName.endsWith('.pdf')\\n  ) {\\n    return 'var(--danger-600)';\\n  }\\n  if (\\n    fileType === 'docx' ||\\n    fileType === 'doc' ||\\n    fileType.includes('word') ||\\n    fileName.endsWith('.docx') ||\\n    fileName.endsWith('.doc')\\n  ) {\\n    return 'var(--primary-600)';\\n  }\\n  if (\\n    fileType === 'xlsx' ||\\n    fileType === 'xls' ||\\n    fileType.includes('excel') ||\\n    fileName.endsWith('.xlsx') ||\\n    fileName.endsWith('.xls')\\n  ) {\\n    return 'var(--success-600)';\\n  }\\n  if (\\n    fileType === 'jpg' ||\\n    fileType === 'jpeg' ||\\n    fileType === 'png' ||\\n    fileName.endsWith('.jpg') ||\\n    fileName.endsWith('.jpeg') ||\\n    fileName.endsWith('.png')\\n  ) {\\n    return 'var(--warning-600)';\\n  }\\n  if (\\n    fileType === 'mp4' ||\\n    fileType === 'avi' ||\\n    fileName.endsWith('.mp4') ||\\n    fileName.endsWith('.avi')\\n  ) {\\n    return 'var(--purple-600)';\\n  }\\n\\n  return 'var(--black-500)';\\n};\\n\\n// Perbaiki fungsi getFileBgColor\\nconst getFileBgColor = (item) => {\\n  const fileType = item.file_type?.toLowerCase() || '';\\n  const fileName = item.file_name?.toLowerCase() || '';\\n\\n  if (\\n    fileType === 'pdf' ||\\n    fileType.includes('pdf') ||\\n    fileName.endsWith('.pdf')\\n  ) {\\n    return 'var(--danger-50)';\\n  }\\n  if (\\n    fileType === 'docx' ||\\n    fileType === 'doc' ||\\n    fileType.includes('word') ||\\n    fileName.endsWith('.docx') ||\\n    fileName.endsWith('.doc')\\n  ) {\\n    return 'var(--primary-50)';\\n  }\\n  if (\\n    fileType === 'xlsx' ||\\n    fileType === 'xls' ||\\n    fileType.includes('excel') ||\\n    fileName.endsWith('.xlsx') ||\\n    fileName.endsWith('.xls')\\n  ) {\\n    return 'var(--success-50)';\\n  }\\n  if (\\n    fileType === 'jpg' ||\\n    fileType === 'jpeg' ||\\n    fileType === 'png' ||\\n    fileName.endsWith('.jpg') ||\\n    fileName.endsWith('.jpeg') ||\\n    fileName.endsWith('.png')\\n  ) {\\n    return 'var(--warning-50)';\\n  }\\n  if (\\n    fileType === 'mp4' ||\\n    fileType === 'avi' ||\\n    fileName.endsWith('.mp4') ||\\n    fileName.endsWith('.avi')\\n  ) {\\n    return 'var(--purple-50)';\\n  }\\n\\n  return 'var(--black-25)';\\n};\\nconst DownloadButton = styled(Button)`\\n  display: flex;\\n  align-items: center;\\n  gap: 0.5rem;\\n \\n  background-color:none;\\n  border:1px solid var(--black-100);\\n`;\\n\",\"html\":\" <div class=\\\"bg-white h-100\\\" style=\\\"border: 1px solid var(--black-100);border-radius:0.8rem;\\\">\\r\\n   <div class=\\\"flex flex-col px-6 py-4\\\" style=\\\"border-bottom: 1px solid var(--black-100)\\\">\\r\\n\\r\\n     <div class=\\\"widget-title\\\">{{widget.name}}</div>\\r\\n\\r\\n   </div>\\r\\n   <div>\\r\\n     tes\\r\\n   </div>\\r\\n </div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":[],\"useAsFilterConfig\":{\"enable\":false},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":false,\"mapInsight\":false,\"actionCopy\":false,\"hiddenWidget\":true,\"cache\":{\"status\":false},\"customLimit\":{\"status\":false}