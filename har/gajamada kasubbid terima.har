            "text": "{\"metaData\":{\"pagination\":{\"size\":10000,\"totalElements\":15,\"totalPages\":1,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":31},\"data\":[{\"chartConfig\":{\"description\":\"\",\"visualizationType\":\"TableDisplay\"},\"createdAt\":\"2026-05-11 10:00:14.120000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"\",\"fieldMapping\":null,\"filtersConfig\":[],\"group\":null,\"h\":47,\"id\":\"45afafbd616d5ec96bb4b27b915da3de\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"metaData\":{\"skill\":\"fusion_chart_generator\",\"params\":{\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"70406e51b88cf3d4c44c472be98af72d\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"query\":null,\"name\":\"Detail Laporan Informasi\",\"chart\":\"table\",\"database_type\":\"postgresql\"}},\"name\":\"Laporan Informasi atau Infosus\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":0,\"y\":348,\"w\":8,\"h\":47}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"table\",\"updatedAt\":\"2026-07-13 15:58:26.006000\",\"updatedBy\":\"73b1b5e7e68d4557c98d84fde4efe696\",\"w\":8,\"widgetConfig\":{\"showTitle\":false,\"handler\":true,\"styleType\":\"table\",\"visualizationType\":\"TableDisplay\",\"showSummary\":false,\"name\":\"Detail Laporan Informasi\",\"styleConfig\":{\"allowSorting\":true,\"allowTruncate\":true,\"dateFormatter\":\"default\",\"inverse\":false,\"itemsPerPage\":6,\"modelTableView\":\"pagination\",\"numberConverter\":false,\"paginationPosition\":\"end\",\"titleBold\":\"bold\",\"titleTransform\":\"normal\",\"truncateLength\":150,\"relationsQueryParams\":{\"45afafbd616d5ec96bb4b27b915da3de\":{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"70406e51b88cf3d4c44c472be98af72d\",\"sourceId\":[\"092330451af086bc6f27edb14693e741\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"enableMultiQueryParams\":false,\"enableDataFromStorage\":false,\"queryParamsName\":\"detail-laporan\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\",\"queryParams\":[]}},\"showPagination\":false,\"customNoData\":false,\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"report_id\",\"alias\":\"report_id\",\"name\":\"report_id\",\"type\":\"string\"},{\"field\":\"report_type\",\"alias\":\"report_type\",\"name\":\"report_type\",\"type\":\"string\"},{\"field\":\"about\",\"alias\":\"about\",\"name\":\"about\",\"type\":\"string\"},{\"field\":\"name\",\"alias\":\"name\",\"name\":\"name\",\"type\":\"string\"},{\"field\":\"occupation\",\"alias\":\"occupation\",\"name\":\"occupation\",\"type\":\"string\"},{\"field\":\"relation_to_target\",\"alias\":\"relation_to_target\",\"name\":\"relation_to_target\",\"type\":\"string\"},{\"field\":\"information_source\",\"alias\":\"information_source\",\"name\":\"information_source\",\"type\":\"string\"},{\"field\":\"information_place_time\",\"alias\":\"information_place_time\",\"name\":\"information_place_time\",\"type\":\"string\"},{\"field\":\"reporter_code\",\"alias\":\"reporter_code\",\"name\":\"reporter_code\",\"type\":\"string\"},{\"field\":\"facts\",\"alias\":\"facts\",\"name\":\"facts\",\"type\":\"string\"},{\"field\":\"reporter_opinion\",\"alias\":\"reporter_opinion\",\"name\":\"reporter_opinion\",\"type\":\"string\"},{\"field\":\"signature\",\"alias\":\"signature\",\"name\":\"signature\",\"type\":\"string\"},{\"field\":\"notes\",\"alias\":\"notes\",\"name\":\"notes\",\"type\":\"string\"},{\"field\":\"updated_at\",\"alias\":\"updated_at\",\"name\":\"updated_at\",\"type\":\"date\"},{\"field\":\"number\",\"alias\":\"number\",\"name\":\"number\",\"type\":\"string\"},{\"field\":\"prepetrator_id\",\"alias\":\"prepetrator_id\",\"name\":\"prepetrator_id\",\"type\":\"string\"},{\"field\":\"signature_place_time\",\"alias\":\"signature_place_time\",\"name\":\"signature_place_time\",\"type\":\"string\"},{\"field\":\"sub_function\",\"alias\":\"sub_function\",\"name\":\"sub_function\",\"type\":\"string\"},{\"field\":\"police_level\",\"alias\":\"police_level\",\"name\":\"police_level\",\"type\":\"string\"},{\"field\":\"polda\",\"alias\":\"polda\",\"name\":\"polda\",\"type\":\"string\"},{\"field\":\"polres\",\"alias\":\"polres\",\"name\":\"polres\",\"type\":\"string\"}]},\"customColorKey\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"report_id\",\"report_type\",\"about\",\"name\",\"occupation\",\"relation_to_target\",\"information_source\",\"information_place_time\",\"reporter_code\",\"facts\",\"reporter_opinion\",\"signature\",\"notes\",\"updated_at\",\"number\",\"prepetrator_id\",\"signature_place_time\",\"sub_function\",\"police_level\",\"polda\",\"polres\"],[\"2026042300013\",null,null,null,null,null,null,null,null,null,null,null,null,1776934210376,\"R/LI-2026042300013-00002/IV/2026/Ropaminal\",\"2026042300013-00002\",\"23 April 2026\",null,null,\"\",\"\"],[\"2026042300013\",null,null,null,null,null,null,null,null,null,null,null,null,1776934262993,\"R/LI-2026042300013-00002/IV/2026/Ropaminal\",\"2026042300013-00002\",\"23 April 2026\",null,null,\"\",\"\"],[\"2026042300013\",null,null,null,null,null,null,null,null,null,null,null,null,1776937384712,null,\"2026042300013-00002\",\"23 April 2026\",null,null,\"\",\"\"],[\"2026042300013\",\"LI\",\"Siti Rahmawati melaporkan dugaan pungutan liar oleh Briptu Arif Nugroho dan Briptu Norman caiya caiya di Polres Metro Kota Bekasi pada 10 September 2025, di mana petugas meminta biaya tambahan Rp300.000 tunai.\",null,null,null,null,null,null,[\"Pelapor datang ke Polres Metro Kota Bekasi untuk mengurus administrasi pada 10 September 2025 sekitar pukul 10.30 WIB.\",\"Pelapor diarahkan oleh oknum petugas ke ruangan tertentu tanpa melalui prosedur antrean resmi.\",\"Dalam proses tersebut, oknum petugas meminta sejumlah uang tambahan sebesar Rp300.000 secara tunai.\",\"Permintaan uang tidak disertai dengan bukti pembayaran resmi atau kwitansi.\",\"Pelapor merasa keberatan namun tetap melakukan pembayaran karena khawatir proses administrasi akan dipersulit.\"],[\"Menurut pelapor, tindakan yang dilakukan oleh oknum petugas tersebut mengindikasikan adanya praktik pungutan liar yang tidak sesuai dengan prosedur resmi.\",\"Pelapor menilai bahwa permintaan uang tambahan tanpa bukti resmi merupakan pelanggaran terhadap aturan pelayanan publik.\",\"Pelapor merasa bahwa situasi tersebut dimanfaatkan oleh oknum karena kurangnya pengawasan di area pelayanan.\",\"Pelapor berpendapat bahwa kejadian ini dapat terjadi juga kepada masyarakat lain apabila tidak ada tindakan tegas dari pihak berwenang.\",\"Pelapor berharap adanya transparansi dan peningkatan pengawasan agar kejadian serupa tidak terulang di kemudian hari.\"],[\"Tanda Tangan 1\",\"Tanda Tangan 2\"],[\"Pelapor berharap adanya tindak lanjut dan pemeriksaan terhadap oknum petugas yang bersangkutan.\",\"Perlu dilakukan pengecekan CCTV di area pelayanan pada tanggal dan waktu kejadian.\",\"Disarankan untuk melakukan klarifikasi terhadap petugas lain yang bertugas pada hari tersebut.\",\"Kasus ini berpotensi merugikan masyarakat dan mencoreng citra institusi jika tidak ditindaklanjuti.\",\"Diperlukan sosialisasi ulang terkait prosedur resmi dan larangan pungutan liar kepada seluruh petugas.\"],1776908152217,\"R/LI-2026042300013/III/2026/Ropaminal\",\"2026042300013-0001\",\"23 April 2026\",null,null,\"\",\"\"],[\"2026042300014\",\"LI\",\"Siti Rahmawati melaporkan dugaan pungutan liar oleh Briptu Arif Nugroho dan Briptu Norman caiya caiya Briptu Adi Nugroho di Polres Metro Kota Bekasi pada 10 September 2025, di mana petugas meminta biaya tambahan Rp300.000 tunai.\",null,null,null,null,null,null,[\"Pelapor datang ke Polres Metro Kota Bekasi untuk mengurus administrasi pada 10 September 2025 sekitar pukul 10.30 WIB.\",\"Pelapor diarahkan oleh oknum petugas ke ruangan tertentu tanpa melalui prosedur antrean resmi.\",\"Dalam proses tersebut, oknum petugas meminta sejumlah uang tambahan sebesar Rp300.000 secara tunai.\",\"Permintaan uang tidak disertai dengan bukti pembayaran resmi atau kwitansi.\",\"Pelapor merasa keberatan namun tetap melakukan pembayaran karena khawatir proses administrasi akan dipersulit.\"],[\"Menurut pelapor, tindakan yang dilakukan oleh oknum petugas tersebut mengindikasikan adanya praktik pungutan liar yang tidak sesuai dengan prosedur resmi.\",\"Pelapor menilai bahwa permintaan uang tambahan tanpa bukti resmi merupakan pelanggaran terhadap aturan pelayanan publik.\",\"Pelapor merasa bahwa situasi tersebut dimanfaatkan oleh oknum karena kurangnya pengawasan di area pelayanan.\",\"Pelapor berpendapat bahwa kejadian ini dapat terjadi juga kepada masyarakat lain apabila tidak ada tindakan tegas dari pihak berwenang.\",\"Pelapor berharap adanya transparansi dan peningkatan pengawasan agar kejadian serupa tidak terulang di kemudian hari.\"],[\"Tanda Tangan 1\",\"Tanda Tangan 2\"],[\"Pelapor berharap adanya tindak lanjut dan pemeriksaan terhadap oknum petugas yang bersangkutan.\",\"Perlu dilakukan pengecekan CCTV di area pelayanan pada tanggal dan waktu kejadian.\",\"Disarankan untuk melakukan klarifikasi terhadap petugas lain yang bertugas pada hari tersebut.\",\"Kasus ini berpotensi merugikan masyarakat dan mencoreng citra institusi jika tidak ditindaklanjuti.\",\"Diperlukan sosialisasi ulang terkait prosedur resmi dan larangan pungutan liar kepada seluruh petugas.\"],1776909764346,\"R/LI-2026042300014/III/2026/Ropaminal\",\"2026042300014-00001\",\"23 April 2026\",null,null,\"\",\"\"],[\"2026042300015\",\"LI\",\"Siti Rahmawati melaporkan dugaan pungutan liar oleh Briptu Arif Nugroho , Briptu Norman caiya caiya dan Briptu Adi Nugroho di Polres Metro Kota Bekasi pada 10 September 2025, di mana petugas meminta biaya tambahan Rp300.000 tunai.\",null,null,null,null,null,null,[\"Pelapor datang ke Polres Metro Kota Bekasi untuk mengurus administrasi pada 10 September 2025 sekitar pukul 10.30 WIB.\",\"Pelapor diarahkan oleh oknum petugas ke ruangan tertentu tanpa melalui prosedur antrean resmi.\",\"Dalam proses tersebut, oknum petugas meminta sejumlah uang tambahan sebesar Rp300.000 secara tunai.\",\"Permintaan uang tidak disertai dengan bukti pembayaran resmi atau kwitansi.\",\"Pelapor merasa keberatan namun tetap melakukan pembayaran karena khawatir proses administrasi akan dipersulit.\"],[\"Menurut pelapor, tindakan yang dilakukan oleh oknum petugas tersebut mengindikasikan adanya praktik pungutan liar yang tidak sesuai dengan prosedur resmi.\",\"Pelapor menilai bahwa permintaan uang tambahan tanpa bukti resmi merupakan pelanggaran terhadap aturan pelayanan publik.\",\"Pelapor merasa bahwa situasi tersebut dimanfaatkan oleh oknum karena kurangnya pengawasan di area pelayanan.\",\"Pelapor berpendapat bahwa kejadian ini dapat terjadi juga kepada masyarakat lain apabila tidak ada tindakan tegas dari pihak berwenang.\",\"Pelapor berharap adanya transparansi dan peningkatan pengawasan agar kejadian serupa tidak terulang di kemudian hari.\"],[\"Tanda Tangan 1\",\"Tanda Tangan 2\"],[\"Pelapor berharap adanya tindak lanjut dan pemeriksaan terhadap oknum petugas yang bersangkutan.\",\"Perlu dilakukan pengecekan CCTV di area pelayanan pada tanggal dan waktu kejadian.\",\"Disarankan untuk melakukan klarifikasi terhadap petugas lain yang bertugas pada hari tersebut.\",\"Kasus ini berpotensi merugikan masyarakat dan mencoreng citra institusi jika tidak ditindaklanjuti.\",\"Diperlukan sosialisasi ulang terkait prosedur resmi dan larangan pungutan liar kepada seluruh petugas.\"],1776910419301,\"R/LI-20260