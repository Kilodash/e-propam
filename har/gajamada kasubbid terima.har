            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":69,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"prepetrator_id\",\"id\",\"sender_name\",\"reporter_nik\",\"phone_no\",\"email\",\"sender_address\",\"created_date\",\"source\",\"updated_at\"],[\"260608000047-00001\",\"260608000047\",\"WALAZAN BIMA MUKASYAFA\",\"3674061207990007\",\"+6283135194856\",null,\"Cijantra girang no 77 RT 05/03 desa Jatake kecamatan Pagedangan kabupaten Tangerang\",1780903140000,\"SUMBER QR CODE\",1783882692665]],\"additionalInfo\":{\"query\":\"select distinct on (p.id)\\n  p.id as prepetrator_id,\\n  r.id, \\n    r.sender_name,\\n    r.reporter_nik,\\n    r.phone_no,\\n    r.email,\\n    r.sender_address,\\n    r.created_date,\\n    gr.source_alias as source,\\n    r.updated_at\\nFROM aduan_masyarakat_v3.report r\\nleft JOIN aduan_masyarakat_v3.report_prepetrators rp \\n    ON r.id = rp.report_id \\nleft JOIN aduan_masyarakat_v3.prepetrator p \\n    ON rp.prepetrator_id = p.id\\nleft join gold.report gr on p.id=gr.prepetrator_id\\nWHERE p.id = %(id_0)s\\nORDER BY p.id, r.updated_at DESC;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
