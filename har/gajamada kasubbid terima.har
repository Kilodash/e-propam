            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":41,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"report_id\",\"officer_name\",\"updated_at\",\"perubahan\"],[\"TAF-20251105-00003\",\"Tidak diketahui\",1765841909561,[{\"field_name\":\"email\",\"old_values\":\"taswiyah@gmail.com\",\"new_values\":null},{\"field_name\":\"phone_no\",\"old_values\":\"6282936665473\",\"new_values\":null},{\"field_name\":\"sender_name\",\"old_values\":\"Taswiyah Marsyah Noor\",\"new_values\":null},{\"field_name\":\"source\",\"old_values\":\"Surat dari Masyarakat\",\"new_values\":null}]],[\"TWEB-20251117-00001\",\"Tidak diketahui\",1763685058260,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"mabes\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"POLDA JAWA TIMUR\"},{\"field_name\":\"polda\",\"old_values\":null,\"new_values\":\"POLDA JAWA TIMUR\"},{\"field_name\":\"polres\",\"old_values\":null,\"new_values\":\"POLRES PONOROGO\"},{\"field_name\":\"polsek\",\"old_values\":null,\"new_values\":\"POLSEK BALONG\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"sedang\",\"new_values\":\"tinggi\"}]],[\"TWEB-20251117-00002\",\"Tidak diketahui\",1763608344215,[{\"field_name\":\"division\",\"old_values\":null,\"new_values\":\"ipda\"},{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"sule\"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"brigadir polisi 2\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"brimob\"}]],[\"TWEB-20251117-00002\",\"Tidak diketahui\",1763606388396,[{\"field_name\":\"division\",\"old_values\":null,\"new_values\":\"ipda\"},{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"sule\"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"brigadir polisi 2\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"brimob\"}]],[\"TWEB-20251117-00002\",\"Tidak diketahui\",1763606360540,[{\"field_name\":\"division\",\"old_values\":null,\"new_values\":\"ipda\"},{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"sule\"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"brigadir polisi 2\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"brimob\"}]],[\"TAF-20251111-00002\",\"Tidak diketahui\",1763091996964,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda jawa timur\"}]],[\"TAF-20251113-00001\",\"Tidak diketahui\",1762979860557,[{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"Andi\"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"Briptu\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"Sersan Satu\"}]],[\"TAF-20251106-00007\",\"Tidak diketahui\",1762917595916,[{\"field_name\":\"detail\",\"old_values\":\"Saya ditelpon oleh oknum polisi bernama akbp rosikin , saya diminta untuk menyerahkan uang sebesar 1 juta atau dia akan menangkap saya atas tuduhan kepemilikan narkoba padahal saya tidak ada sama sekali\",\"new_values\":\"Saya ditelpon oleh oknum polisi bernama akbp rosikin , saya diminta untuk menyerahkan uang sebesar 1 juta atau dia akan menangkap saya atas tuduhan kepemilikan narkoba padahal saya tidak ada sama sekali.\"}]],[\"TAF-20251106-00010\",\"Tidak diketahui\",1762914505473,[{\"field_name\":\"detail\",\"old_values\":\"Saya Sasya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu.\",\"new_values\":\"Saya Sasya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu..\"}]],[\"TAF-20251106-00010\",\"Tidak diketahui\",1762913445314,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail\",\"old_values\":\"Saya Sasya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu\",\"new_values\":\"Saya Sasya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu.\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda jawa barat\"}]],[\"TAF-20251106-00015\",\"Tidak diketahui\",1762913401245,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail\",\"old_values\":\"Saya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu\",\"new_values\":\"Saya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu..\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda jawa barat\"}]],[\"TAF-20251106-00020\",\"Tidak diketahui\",1762912966887,[{\"field_name\":\"detail\",\"old_values\":\"Saya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu\",\"new_values\":\"Saya mengalami tindakan pemerasan dilakukan oknum polisi saat saya membuat skck dipolda padalarang , saya diminta uang sebesar 500 ribu rupiah\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda jawa barat\"}]],[\"TAF-20251111-00003\",\"Tidak diketahui\",1762912653976,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail\",\"old_values\":\"Saya, Briptu Nadia Permata, anggota Unit Reskrim Polres Sleman, melaporkan dugaan pelanggaran disiplin dan penyalahgunaan wewenang yang dilakukan oleh rekan satuan saya, Aipda Feri Pranata, yang menjabat sebagai Kanit Opsnal Reskrim.\\n\\nPada hari Rabu, tanggal 30 Oktober 2025 sekitar pukul 22.00 WIB, saya sedang bertugas dalam giat penangkapan terhadap tersangka kasus pencurian kendaraan bermotor di wilayah Gamping bersama tim. Seusai kegiatan tersebut, barang bukti berupa satu unit sepeda motor Honda Beat warna merah dengan nomor polisi AB 4563 QH diamankan di halaman belakang kantor Reskrim. Keesokan harinya, saat saya melakukan pencatatan administrasi barang bukti, saya mendapati bahwa motor tersebut tidak lagi berada di tempat penyimpanan.\\n\\nSaya kemudian menanyakan kepada petugas piket dan rekan satu tim, namun tidak ada yang mengetahui ke mana barang bukti tersebut dipindahkan. Setelah beberapa hari mencari informasi, saya memperoleh keterangan dari seorang warga bernama Bayu yang bekerja di bengkel sekitar Pogung. Ia menyampaikan bahwa sempat melihat kendaraan dengan ciri yang sama digunakan oleh seseorang yang mengenakan jaket bertuliskan “Reskrim Sleman”. Berdasarkan informasi tersebut, saya mencoba melakukan pengecekan internal dan menemukan bahwa kendaraan itu sempat digunakan oleh Aipda Feri Pranata untuk keperluan pribadi tanpa izin resmi dari pimpinan.\\n\\nSaya sempat menanyakan langsung kepada yang bersangkutan, namun ia menjawab dengan nada tinggi dan menyebut bahwa dirinya memiliki “hak” untuk menggunakan barang bukti karena masih dalam proses pengembangan perkara. Saya menilai pernyataan tersebut tidak sesuai dengan prosedur penanganan barang bukti sebagaimana diatur dalam peraturan internal, di mana setiap pemindahan atau penggunaan barang bukti harus disertai surat perintah dan berita acara.\\n\\nUntuk memastikan keabsahan temuan saya, saya memeriksa kembali dokumen administrasi dan menemukan bahwa berita acara penyitaan belum ditandatangani oleh penyidik pembantu, namun sudah dicap “diserahkan untuk pengembangan” atas nama Aipda Feri Pranata. Berdasarkan hal itu, saya menyimpulkan telah terjadi penyalahgunaan wewenang dan pelanggaran terhadap tata kelola barang bukti.\\n\\nSaya kemudian menyusun laporan pengaduan resmi kepada Seksi Propam Polres Sleman pada tanggal 4 November 2025, dengan melampirkan bukti berupa salinan dokumen BAPB, foto kendaraan saat diamankan pertama kali, serta keterangan saksi masyarakat. Saya berharap laporan ini dapat ditindaklanjuti secara profesional, karena tindakan semacam ini berpotensi mencoreng kepercayaan publik terhadap institusi dan melemahkan moral anggota yang bekerja sesuai aturan.\",\"new_values\":\"Saya, Briptu Nadia Permata, anggota Unit Reskrim Polres Sleman, melaporkan dugaan pelanggaran disiplin dan penyalahgunaan wewenang yang dilakukan oleh rekan satuan saya, Aipda Feri Pranata, yang menjabat sebagai Kanit Opsnal Reskrim.\\n\\nPada hari Rabu, tanggal 30 Oktober 2025 sekitar pukul 22.00 WIB, saya sedang bertugas dalam giat penangkapan terhadap tersangka kasus pencurian kendaraan bermotor di wilayah Gamping bersama tim. Seusai kegiatan tersebut, barang bukti berupa satu unit sepeda motor Honda Beat warna merah dengan nomor polisi AB 4563 QH diamankan di halaman belakang kantor Reskrim. Keesokan harinya, saat saya melakukan pencatatan administrasi barang bukti, saya mendapati bahwa motor tersebut tidak lagi berada di tempat penyimpanan.\\n\\nSaya kemudian menanyakan kepada petugas piket dan rekan satu tim, namun tidak ada yang mengetahui ke mana barang bukti tersebut dipindahkan. Setelah beberapa hari mencari informasi, saya memperoleh keterangan dari seorang warga bernama Bayu yang bekerja di bengkel sekitar Pogung. Ia menyampaikan bahwa sempat melihat kendaraan dengan ciri yang sama digunakan oleh seseorang yang mengenakan jaket bertuliskan “Reskrim Sleman”. Berdasarkan informasi tersebut, saya mencoba melakukan pengecekan internal dan menemukan bahwa kendaraan itu sempat digunakan oleh Aipda Feri Pranata untuk keperluan pribadi tanpa izin resmi dari pimpinan.\\n\\nSaya sempat menanyakan langsung kepada yang bersangkutan, namun ia menjawab dengan nada tinggi dan menyebut bahwa dirinya memiliki “hak” untuk menggunakan barang bukti karena masih dalam proses pengembangan perkara. Saya menilai pernyataan tersebut tidak sesuai dengan prosedur penanganan barang bukti sebagaimana diatur dalam peraturan internal, di mana setiap pemindahan atau penggunaan barang bukti harus disertai surat perintah dan berita acara.\\n\\nUntuk memastikan keabsahan temuan saya, saya memeriksa kembali dokumen administrasi dan menemukan bahwa berita acara penyitaan belum ditandatangani oleh penyidik pembantu, namun sudah dicap “diserahkan untuk pengembangan” atas nama Aipda Feri Pranata. Berdasarkan hal itu, saya menyimpulkan telah terjadi penyalahgunaan wewenang dan pelanggaran terhadap tata kelola barang bukti.\\n\\nSaya kemudian menyusun laporan pengaduan resmi kepada Seksi Propam Polres Sleman pada tanggal 4 November 2025, dengan melampirkan bukti berupa salinan dokumen BAPB, foto kendaraan saat diamankan pertama kali, serta keterangan saksi masyarakat. Saya berharap laporan ini dapat ditindaklanjuti secara profesional, karena tindakan semacam ini berpotensi mencoreng kepercayaan publik terhadap institusi dan melemahkan moral anggota yang bekerja sesuai aturan...\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda daerah istimewa yogyakarta\"}]],[\"TAF-20251028-00013\",\"Tidak diketahui\",1762912343800,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"rendah\"},{\"field_name\":\"detail\",\"old_values\":\"Pada hari Selasa, 28 Oktober 2025, sekitar pukul 20.30 WIB, saya sedang melintas di Jl. Margonda Raya, Depok, menggunakan sepeda motor pribadi bernomor polisi B 4321 ZFA. Ketika sampai di depan SPBU Margonda, saya diberhentikan oleh tiga orang anggota polisi berseragam yang mengaku dari Satuan Lalu Lintas Polres Depok.\\n\\nSalah satu anggota yang memeriksa saya memperkenalkan diri sebagai Bripka Deni Ramadhan, sementara dua lainnya dipanggil dengan sebutan Aipda Surya dan Brigadir Rio. Mereka meminta saya menunjukkan surat-surat kendaraan. Saya sudah menyerahkan SIM C dan STNK dalam keadaan lengkap dan masih berlaku.\\n\\nNamun, Bripka Deni menyatakan bahwa saya melanggar aturan karena “lampu depan dianggap terlalu terang” dan mengancam akan menilang dengan denda Rp500.000. Ketika saya mencoba menjelaskan bahwa lampu tersebut standar bawaan pabrikan, Aipda Surya memotong pembicaraan dan mengatakan, “Kalau mau cepat beres, ya bantu aja seikhlasnya.”\\n\\nSaya merasa tidak nyaman dan menanyakan maksudnya. Lalu Brigadir Rio menyarankan agar saya menyerahkan “uang rokok” sebesar Rp100.000 supaya tidak ditilang. Karena situasinya sudah tidak kondusif dan saya merasa tertekan, akhirnya saya menyerahkan uang tersebut agar diperbolehkan melanjutkan perjalanan.\\n\\nSetelah kejadian itu, saya mencatat nama-nama yang tertera di papan nama seragam mereka dan waktu kejadian. Saya juga memiliki rekaman kamera dashboard yang memperlihatkan momen pemberhentian dan sebagian percakapan.\\n\\nSaya merasa tindakan ketiga oknum tersebut mencoreng nama baik institusi Polri dan merupakan bentuk penyalahgunaan wewenang serta pungutan liar. Saya berharap Divisi Propam Polri dapat menindaklanjuti laporan ini secara profesional agar tidak terjadi lagi kepada masyarakat lain.\",\"new_values\":\"Pada hari Selasa, 28 Oktober 2025, sekitar pukul 20.30 WIB, saya sedang melintas di Jl. Margonda Raya, Depok, menggunakan sepeda motor pribadi bernomor polisi B 4321 ZFA. Ketika sampai di depan SPBU Margonda, saya diberhentikan oleh tiga orang anggota polisi berseragam yang mengaku dari Satuan Lalu Lintas Polres Depok.\\n\\nSalah satu anggota yang memeriksa saya memperkenalkan diri sebagai Bripka Deni Ramadhan, sementara dua lainnya dipanggil dengan sebutan Aipda Surya dan Brigadir Rio. Mereka meminta saya menunjukkan surat-surat kendaraan. Saya sudah menyerahkan SIM C dan STNK dalam keadaan lengkap dan masih berlaku.\\n\\nNamun, Bripka Deni menyatakan bahwa saya melanggar aturan karena “lampu depan dianggap terlalu terang” dan mengancam akan menilang dengan denda Rp500.000. Ketika saya mencoba menjelaskan bahwa lampu tersebut standar bawaan pabrikan, Aipda Surya memotong pembicaraan dan mengatakan, “Kalau mau cepat beres, ya bantu aja seikhlasnya.”\\n\\nSaya merasa tidak nyaman dan menanyakan maksudnya. Lalu Brigadir Rio menyarankan agar saya menyerahkan “uang rokok” sebesar Rp100.000 supaya tidak ditilang. Karena situasinya sudah tidak kondusif dan saya merasa tertekan, akhirnya saya menyerahkan uang tersebut agar diperbolehkan melanjutkan perjalanan.\\n\\nSetelah kejadian itu, saya mencatat nama-nama yang tertera di papan nama seragam mereka dan waktu kejadian. Saya juga memiliki rekaman kamera dashboard yang memperlihatkan momen pemberhentian dan sebagian percakapan.\\n\\nSaya merasa tindakan ketiga oknum tersebut mencoreng nama baik institusi Polri dan merupakan bentuk penyalahgunaan wewenang serta pungutan liar. Saya berharap Divisi Propam Polri dapat menindaklanjuti laporan ini secara profesional agar tidak terjadi lagi kepada masyarakat lain..\"}]],[\"TAF-20251105-00007\",\"Tidak diketahui\",1762912273947,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":null}]],[\"TAF-20251112-00002\",\"Tidak diketahui\",1762912253291,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"Andi \"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"Briptu\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"Sersan Satu\"}]],[\"TAF-20251105-00007\",\"Tidak diketahui\",1762911708292,[{\"field_name\":\"detail\",\"old_values\":\"Lokasi: Jl. Pangeran Antasari, Jakarta Selatan\\n\\nSekitar pukul 21.15 WIB, saya diberhentikan dalam razia kendaraan. Meskipun surat-surat saya lengkap, petugas menuduh lampu motor redup dan mengancam menilang. Petugas meminta Rp100.000 agar “tidak diproses tilang resmi.” Karena situasi gelap dan tidak nyaman, saya menyerahkan uang tersebut tanpa bukti.\\nSaya melaporkan tindakan pemerasan dan penyalahgunaan wewenang oleh anggota tersebut.\",\"new_values\":\"Lokasi: Jl. Pangeran Antasari, Jakarta Selatan\\n\\nSekitar pukul 21.15 WIB, saya diberhentikan dalam razia kendaraan. Meskipun surat-surat saya lengkap, petugas menuduh lampu motor redup dan mengancam menilang. Petugas meminta Rp100.000 agar “tidak diproses tilang resmi.” Karena situasi gelap dan tidak nyaman, saya menyerahkan uang tersebut tanpa bukti.\\nSaya melaporkan tindakan pemerasan dan penyalahgunaan wewenang oleh anggota tersebut..\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda metro jaya\"}]],[\"TAF-20251111-00001\",\"Tidak diketahui\",1762910890843,[{\"field_name\":\"detail\",\"old_values\":\"Saya sedang melintas di lampu merah Jalan TB Simatupang sekitar pukul sepuluh pagi. Saat itu saya mengakui telah menerobos lampu merah karena tergesa-gesa menuju kantor. Tidak lama kemudian, seorang petugas kepolisian bernama Ipda Paldo menghentikan saya.\\nSaya sudah menjelaskan dengan sopan bahwa saya bersedia untuk ditilang dan mengikuti proses sidang sesuai aturan. Namun, petugas tersebut justru meminta saya untuk memberikan sejumlah uang di tempat agar “urusan cepat selesai”. Saya menolak dengan alasan ingin menjalani prosedur yang benar, tetapi beliau tetap memaksa dengan nada yang tidak menyenangkan.\\nSaya merasa tindakan tersebut tidak pantas dan merugikan masyarakat, sehingga saya membuat laporan ini agar ada tindak lanjut sesuai ketentuan yang berlaku..\",\"new_values\":\"Saya sedang melintas di lampu merah Jalan TB Simatupang sekitar pukul sepuluh pagi. Saat itu saya mengakui telah menerobos lampu merah karena tergesa-gesa menuju kantor. Tidak lama kemudian, seorang petugas kepolisian bernama Ipda Paldo menghentikan saya.\\nSaya sudah menjelaskan dengan sopan bahwa saya bersedia untuk ditilang dan mengikuti proses sidang sesuai aturan. Namun, petugas tersebut justru meminta saya untuk memberikan sejumlah uang di tempat agar “urusan cepat selesai”. Saya menolak dengan alasan ingin menjalani prosedur yang benar, tetapi beliau tetap memaksa dengan nada yang tidak menyenangkan.\\nSaya merasa tindakan tersebut tidak pantas dan merugikan masyarakat, sehingga saya membuat laporan ini agar ada tindak lanjut sesuai ketentuan yang berlaku.\"}]],[\"TAF-20251111-00001\",\"Tidak diketahui\",1762910675244,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail\",\"old_values\":\"Saya sedang melintas di lampu merah Jalan TB Simatupang sekitar pukul sepuluh pagi. Saat itu saya mengakui telah menerobos lampu merah karena tergesa-gesa menuju kantor. Tidak lama kemudian, seorang petugas kepolisian bernama Ipda Paldo menghentikan saya.\\nSaya sudah menjelaskan dengan sopan bahwa saya bersedia untuk ditilang dan mengikuti proses sidang sesuai aturan. Namun, petugas tersebut justru meminta saya untuk memberikan sejumlah uang di tempat agar “urusan cepat selesai”. Saya menolak dengan alasan ingin menjalani prosedur yang benar, tetapi beliau tetap memaksa dengan nada yang tidak menyenangkan.\\nSaya merasa tindakan tersebut tidak pantas dan merugikan masyarakat, sehingga saya membuat laporan ini agar ada tindak lanjut sesuai ketentuan yang berlaku.\",\"new_values\":\"Saya sedang melintas di lampu merah Jalan TB Simatupang sekitar pukul sepuluh pagi. Saat itu saya mengakui telah menerobos lampu merah karena tergesa-gesa menuju kantor. Tidak lama kemudian, seorang petugas kepolisian bernama Ipda Paldo menghentikan saya.\\nSaya sudah menjelaskan dengan sopan bahwa saya bersedia untuk ditilang dan mengikuti proses sidang sesuai aturan. Namun, petugas tersebut justru meminta saya untuk memberikan sejumlah uang di tempat agar “urusan cepat selesai”. Saya menolak dengan alasan ingin menjalani prosedur yang benar, tetapi beliau tetap memaksa dengan nada yang tidak menyenangkan.\\nSaya merasa tindakan tersebut tidak pantas dan merugikan masyarakat, sehingga saya membuat laporan ini agar ada tindak lanjut sesuai ketentuan yang berlaku..\"}]],[\"TAF-20251106-00002\",\"Tidak diketahui\",1762910374915,[{\"field_name\":\"detail\",\"old_values\":\"Nama saya Musdalifah, saya ingin melaporkan tindakan yang dilakukan oleh salah satu anggota kepolisian bernama Ipda Yoga yang bertugas di Divisi Lantas Polsek Palembang. Kejadian ini terjadi sekitar satu minggu yang lalu di Simpang 5 DPRD Palembang.\\n\\nPada saat itu, saya sedang berkendara melintasi kawasan tersebut. Semua perlengkapan berkendara sudah lengkap saya memakai helm, membawa surat-surat kendaraan lengkap, dan tidak menerobos lampu merah. Namun, saya diberhentikan oleh Ipda Yoga dengan alasan bahwa saya melaju dengan kecepatan di atas rata-rata. Padahal, saat itu situasi lalu lintas sedang padat merayap, sehingga tidak mungkin bagi saya untuk mengebut.\\n\\nSetelah memberhentikan saya, Ipda Yoga meminta sejumlah uang dan mengatakan bahwa jika saya tidak memberikan uang tersebut, maka saya akan ditilang. Karena merasa takut dan tidak ingin memperpanjang masalah, saya akhirnya memberikan uang seperti yang diminta. Setelah kejadian itu, saya merasa sangat dirugikan, karena saya yakin tidak melakukan pelanggaran lalu lintas apa pun.\",\"new_values\":\"Nama saya Musdalifah, saya ingin melaporkan tindakan yang dilakukan oleh salah satu anggota kepolisian bernama Ipda Yoga yang bertugas di Divisi Lantas Polsek Palembang. Kejadian ini terjadi sekitar satu minggu yang lalu diSimpang 5 DPRD Palembang.\\n\\nPada saat itu, saya sedang berkendara melintasi kawasan tersebut. Semua perlengkapan berkendara sudah lengkap saya memakai helm, membawa surat-surat kendaraan lengkap, dan tidak menerobos lampu merah. Namun, saya diberhentikan oleh Ipda Yoga dengan alasan bahwa saya melaju dengan kecepatan di atas rata-rata. Padahal, saat itu situasi lalu lintas sedang padat merayap, sehingga tidak mungkin bagi saya untuk mengebut.\\n\\nSetelah memberhentikan saya, Ipda Yoga meminta sejumlah uang dan mengatakan bahwa jika saya tidak memberikan uang tersebut, maka saya akan ditilang. Karena merasa takut dan tidak ingin memperpanjang masalah, saya akhirnya memberikan uang seperti yang diminta. Setelah kejadian itu, saya merasa sangat dirugikan, karena saya yakin tidak melakukan pelanggaran lalu lintas apa pun.\"}]],[\"TAF-20251112-00001\",\"Tidak diketahui\",1762907410373,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"Andi \"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"Briptu\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"Sersan Satu\"}]],[\"TAF-20251106-00002\",\"Tidak diketahui\",1762906396496,[{\"field_name\":\"created_at\",\"old_values\":null,\"new_values\":\"Wed Nov 12 2025 07:13:16 GMT+0000 (Coordinated Universal Time)\"},{\"field_name\":\"id\",\"old_values\":null,\"new_values\":\"TAF-20251106-00002-00001\"},{\"field_name\":\"name\",\"old_values\":null,\"new_values\":\"Andi \"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda sumatera selatan\"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"Briptu\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"Sersan Satu\"}]],[\"TAF-20251112-00001\",\"Tidak diketahui\",1762904757689,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"}]],[\"TAF-20251111-00001\",\"Tidak diketahui\",1762894335346,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"}]],[\"TAF-20251111-00001\",\"Tidak diketahui\",1762894288500,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"detail_where\",\"old_values\":\"Lampu merah Jalan TB Simatupang\",\"new_values\":\"Lampu merah, Jalan TB Simatupang \"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda metro jaya\"}]],[\"4768d4a9-6324-4c1f-a024-bcc388f74007\",\"Bripka Andi Setiawan\",1762722873519,[{\"field_name\":\"division\",\"old_values\":null,\"new_values\":\"Samapta\"},{\"field_name\":\"name\",\"old_values\":\"Petugas berseragam Satlantas\",\"new_values\":\"Bripka Andi Setiawan\"},{\"field_name\":\"position\",\"old_values\":null,\"new_values\":\"Kanit Patroli\"},{\"field_name\":\"rank\",\"old_values\":null,\"new_values\":\"Bripka\"}]],[\"TAF-20251106-00003\",\"Tidak diketahui\",1762395456218,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda sumatera selatan\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"rendah\",\"new_values\":\"tinggi\"}]],[\"TAF-20251105-00003\",\"Tidak diketahui\",1762334825445,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"wilayah\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda sumatera selatan\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"rendah\",\"new_values\":\"tinggi\"}]],[\"TAF-20251030-00006\",\"Tidak diketahui\",1761820299345,[{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"POLDA D. I. YOGYAKARTA\"},{\"field_name\":\"polda\",\"old_values\":null,\"new_values\":\"POLDA D. I. YOGYAKARTA\"},{\"field_name\":\"polda_code\",\"old_values\":null,\"new_values\":\"6015\"},{\"field_name\":\"polres\",\"old_values\":null,\"new_values\":\"POLRES BANTUL\"},{\"field_name\":\"polres_code\",\"old_values\":null,\"new_values\":\"60010401643848\"},{\"field_name\":\"polsek\",\"old_values\":null,\"new_values\":\"POLSEK BANTUL\"},{\"field_name\":\"polsek_code\",\"old_values\":null,\"new_values\":\"500500445\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"rendah\",\"new_values\":\"sedang\"}]],[\"TAFA-20251013-00007\",\"Tidak diketahui\",1761820136194,[{\"field_name\":\"detail_where\",\"old_values\":null,\"new_values\":\"Pantai Kuta\"},{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"POLDA BALI\"},{\"field_name\":\"polda\",\"old_values\":null,\"new_values\":\"POLDA BALI\"},{\"field_name\":\"polda_code\",\"old_values\":null,\"new_values\":\"6018\"},{\"field_name\":\"polres\",\"old_values\":null,\"new_values\":\"POLRES JEMBRANA\"},{\"field_name\":\"polres_code\",\"old_values\":null,\"new_values\":\"60012202644747\"},{\"field_name\":\"polsek\",\"old_values\":null,\"new_values\":\"POLSEK MENDOYO\"},{\"field_name\":\"polsek_code\",\"old_values\":null,\"new_values\":\"200290257\"},{\"field_name\":\"urgency_score_category\",\"old_values\":\"rendah\",\"new_values\":\"sedang\"}]],[\"TAF-20251030-00004\",\"Tidak diketahui\",1761814425055,[{\"field_name\":\"sender_name\",\"old_values\":\"Anisa Dewi\",\"new_values\":\"Anisa Dewi Pertiwi\"}]],[\"TAF-20251028-00013\",\"Tidak diketahui\",1761813679281,[{\"field_name\":\"case_position\",\"old_values\":null,\"new_values\":\"rendah\"},{\"field_name\":\"detail\",\"old_values\":\"null\",\"new_values\":\"Pada hari Selasa, 28 Oktober 2025, sekitar pukul 20.30 WIB, saya sedang melintas di Jl. Margonda Raya, Depok, menggunakan sepeda motor pribadi bernomor polisi B 4321 ZFA. Ketika sampai di depan SPBU Margonda, saya diberhentikan oleh tiga orang anggota polisi berseragam yang mengaku dari Satuan Lalu Lintas Polres Depok. Salah satu anggota yang memeriksa saya memperkenalkan diri sebagai Bripka Deni Ramadhan, sementara dua lainnya dipanggil dengan sebutan Aipda Surya dan Brigadir Rio. Mereka meminta saya menunjukkan surat-surat kendaraan. Saya sudah menyerahkan SIM C dan STNK dalam keadaan lengkap dan masih berlaku. Namun, Bripka Deni menyatakan bahwa saya melanggar aturan karena “lampu depan dianggap terlalu terang” dan mengancam akan menilang dengan denda Rp500.000. Ketika saya mencoba menjelaskan bahwa lampu tersebut standar bawaan pabrikan, Aipda Surya memotong pembicaraan dan mengatakan, “Kalau mau cepat beres, ya bantu aja seikhlasnya.” Saya merasa tidak nyaman dan menanyakan maksudnya. Lalu Brigadir Rio menyarankan agar saya menyerahkan “uang rokok” sebesar Rp100.000 supaya tidak ditilang. Karena situasinya sudah tidak kondusif dan saya merasa tertekan, akhirnya saya menyerahkan uang tersebut agar diperbolehkan melanjutkan perjalanan. Setelah kejadian itu, saya mencatat nama-nama yang tertera di papan nama seragam mereka dan waktu kejadian. Saya juga memiliki rekaman kamera dashboard yang memperlihatkan momen pemberhentian dan sebagian percakapan. Saya merasa tindakan ketiga oknum tersebut mencoreng nama baik institusi Polri dan merupakan bentuk penyalahgunaan wewenang serta pungutan liar. Saya berharap Divisi Propam Polri dapat menindaklanjuti laporan ini secara profesional agar tidak terjadi lagi kepada masyarakat lain.\"}]],[\"TAF-20251028-00005\",\"Tidak diketahui\",1761806929586,[{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"polda sumatera selatan\"},{\"field_name\":\"polda_code\",\"old_values\":\"6008\",\"new_values\":\"6008\"},{\"field_name\":\"polres_code\",\"old_values\":\"60011151641635\",\"new_values\":\"60011151641635\"},{\"field_name\":\"polsek\",\"old_values\":\"polsek kalidoni\",\"new_values\":\"POLSEK GANDUS\"},{\"field_name\":\"polsek_code\",\"old_values\":\"3304784516\",\"new_values\":\"3304784511\"}]],[\"TAF-20251030-00005\",\"Tidak diketahui\",1761805908109,[{\"field_name\":\"sender_name\",\"old_values\":\"Rizaldi\",\"new_values\":\"Rizaldi aja\"}]],[\"TAF-20251030-00005\",\"Tidak diketahui\",1761805776051,[{\"field_name\":\"organization_unit\",\"old_values\":null,\"new_values\":\"POLDA BANTEN\"},{\"field_name\":\"polda\",\"old_values\":null,\"new_values\":\"POLDA BANTEN\"},{\"field_name\":\"polda_code\",\"old_values\":null,\"new_values\":\"6017\"},{\"field_name\":\"polres\",\"old_values\":null,\"new_values\":\"POLRESTA TANGERANG\"},{\"field_name\":\"polres_code\",\"old_values\":null,\"new_values\":\"60012904665360\"},{\"field_name\":\"polsek\",\"old_values\":null,\"new_values\":\"POLSEK BALARAJA\"},{\"field_nam