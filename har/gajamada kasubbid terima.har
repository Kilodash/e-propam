          "cookies": [],
          "content": {
            "size": 3740,
            "mimeType": "application/json",
            "compression": 2473,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":266,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"id\",\"prepetrator_id\",\"source\",\"created_date\",\"updated_at\",\"phone_no\",\"form_of_action\",\"organization_unit\",\"type_of_violation\",\"category\",\"sub_category\",\"detail_where\",\"ds_updated_at\",\"polda_disposisi\",\"polres\",\"sub_function\",\"police_level\",\"polsek\",\"sub_status\",\"police_function\",\"case_position\",\"polda\",\"unit_name\",\"document_number\",\"document_date\",\"hearing_decision_number\",\"hearing_decision_date\",\"hearing_date\",\"hearing_place\",\"case_handover\",\"status\",\"latest_updated_at\"],[\"260608000047\",\"260608000047-00001\",\"SUMBER QR CODE\",1780928340000,1783907892665,\"+6283135194856\",null,null,null,\"MENOLAK MEMBUAT LAPORAN ATAU MELAYANI PEMOHON TANPA ALASAN SAH\",null,\"Wilayah hukum Polres Cianjur\",1783882692665,\"POLDA JAWA BARAT\",null,\"SUBBID PAMINAL\",\"POLDA\",null,null,\"PAMINAL\",\"KASUBBID PAMINAL POLDA JAWA BARAT\",null,null,null,null,null,null,null,null,null,\"Laporan Diterima Kasubbid Paminal\",1783882692665]],\"additionalInfo\":{\"query\":\"WITH latest_report AS (\\n    SELECT DISTINCT ON (id) *\\n    FROM aduan_masyarakat_v3.report r\\n    WHERE r.status <> 'spam'\\n    ORDER BY id, updated_at DESC\\n),\\nlatest_report_info AS (\\n    SELECT DISTINCT ON (id) *\\n    FROM aduan_masyarakat_v3.report_info\\n    ORDER BY id, updated_at DESC\\n),\\nlatest_report_disposisi AS (\\n    SELECT DISTINCT ON (prepetrator_id) *\\n    FROM aduan_masyarakat_v3.report_disposisi\\n    ORDER BY prepetrator_id, updated_at DESC \\n),\\nlatest_report_officer_detail AS (\\n    SELECT DISTINCT ON (prepetrator_id) *\\n    FROM aduan_masyarakat_v3.report_officer_detail\\n    ORDER BY prepetrator_id, updated_at DESC\\n),\\njoined AS (\\n    SELECT\\n        r.id,\\n        rp.prepetrator_id,\\n        r.source,\\n        ((r.created_date AT TIME ZONE 'UTC') AT TIME ZONE 'Asia/Jakarta') as created_date,\\n        ((r.updated_at AT TIME ZONE 'UTC') AT TIME ZONE 'Asia/Jakarta') as updated_at,\\n        r.phone_no,\\n        r.form_of_action,\\n        r2.organization_unit,\\n        r2.type_of_violation,\\n        r.category,\\n        r.sub_category,\\n        r.detail_where,\\n        ds.updated_at AS ds_updated_at,\\n        ds.polda AS polda_disposisi,\\n        ds.polres,\\n        ds.sub_function,\\n        ds.police_level,\\n        r2.polsek,\\n        r4.sub_status,\\n        ds.police_function,\\n        ds.case_position,\\n        r2.polda,\\n        r2.polsek,\\n        r4.unit_name,\\n        r4.document_number,\\n        r4.document_date,\\n        r4.hearing_decision_number,\\n        r4.hearing_decision_date,\\n        r4.hearing_date,\\n        r4.hearing_place,\\n        r4.case_handover,\\n        CASE \\n            WHEN COALESCE(r4.status, r.status) = 'enriched' THEN 'Laporan Masuk'\\n            ELSE COALESCE(r4.status, r.status)\\n        END AS status,\\n        GREATEST(\\n            r.updated_at,\\n            COALESCE(r2.updated_at, r.updated_at),\\n            COALESCE(ds.updated_at, r.updated_at),\\n            COALESCE(r4.updated_at, r.updated_at)\\n        ) AS latest_updated_at\\n    FROM latest_report r\\n    JOIN aduan_masyarakat_v3.report_prepetrators rp \\n        ON r.id = rp.report_id\\n    LEFT JOIN latest_report_info r2 \\n        ON r.id = r2.id\\n    LEFT JOIN latest_report_disposisi ds \\n        ON rp.prepetrator_id = ds.prepetrator_id\\n    LEFT JOIN latest_report_officer_detail r4 \\n        ON rp.prepetrator_id = r4.prepetrator_id\\n)\\nSELECT DISTINCT ON (prepetrator_id)\\n    *\\nFROM joined\\nWHERE prepetrator_id = %(prepetrator_id_0)s\\nORDER BY prepetrator_id, latest_updated_at DESC\\nlimit 1\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
          },
