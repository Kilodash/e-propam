            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":500,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"prepetrator_id\",\"report_id\",\"source\",\"created_date\",\"prepetrator_data\",\"police_reports\",\"officer_details\"],[\"260608000047-00001\",\"260608000047\",\"Landing Page\",1780903140000,[{\"prepetrator_id\":\"260608000047-00001\",\"name\":null,\"rank\":null,\"position\":null,\"identity_number\":null,\"functional_assignment\":null,\"articles\":null,\"type_perpetrator\":null}],[{\"report_number\":null,\"datetime\":null,\"criminal_lp_number\":null,\"hearing_decision_date\":null,\"report_detail\":null,\"criminal_offense\":null,\"criminal_article\":null,\"criminal_process_status\":null,\"decision_number\":null,\"short_description\":null,\"criminal_article_description\":null,\"criminal_notes\":null}],{\"document_number\":null,\"document_date\":null,\"hearing_date\":null,\"hearing_place\":null,\"hearing_decision_number\":null,\"hearing_decision_date\":null,\"offense_description\":null}]],\"additionalInfo\":{\"query\":\"WITH ArticlesData AS (\\n    SELECT\\n        prepetrator_id,\\n        json_agg(\\n            json_build_object(\\n                'article_id', article_id,\\n                'type', cp_type,\\n                'kode_pasal', kode_pasal,\\n                'description', description\\n            )\\n        ) AS articles_list\\n    FROM (\\n        SELECT \\n            inner_pa.prepetrator_id,\\n            inner_pa.article_id,\\n            cp.type AS cp_type,\\n            cp.kode_pasal,\\n            cp.description,\\n            DENSE_RANK() OVER (\\n                PARTITION BY inner_pa.prepetrator_id \\n                ORDER BY inner_pa.updated_at DESC\\n            ) as session_rank\\n        FROM aduan_masyarakat_v3.prepetrator_article inner_pa\\n        LEFT JOIN dimension.catalog_pasal cp \\n            ON inner_pa.article_id = cp.id\\n        WHERE (inner_pa.\\\"type\\\" <> 'juncto' OR inner_pa.\\\"type\\\" IS NULL)\\n    ) final_articles\\n    WHERE session_rank = 1\\n    GROUP BY prepetrator_id\\n),\\nreport_clean AS (\\n    SELECT DISTINCT ON (id) *\\n    FROM aduan_masyarakat_v3.report\\n    ORDER BY id, created_date DESC\\n),\\nlatest_combined_docs AS (\\n    SELECT\\n        prepetrator_id,\\n        report_id,\\n        (ARRAY_AGG(document_number ORDER BY updated_at DESC)\\n            FILTER (WHERE document_number IS NOT NULL))[1] AS document_number,\\n        (ARRAY_AGG(document_date ORDER BY updated_at DESC)\\n            FILTER (WHERE document_date IS NOT NULL))[1] AS document_date,\\n        (ARRAY_AGG(hearing_date ORDER BY updated_at DESC)\\n            FILTER (WHERE hearing_date IS NOT NULL))[1] AS hearing_date,\\n        (ARRAY_AGG(hearing_place ORDER BY updated_at DESC)\\n            FILTER (WHERE hearing_place IS NOT NULL))[1] AS hearing_place,\\n        (ARRAY_AGG(hearing_decision_number ORDER BY updated_at DESC)\\n            FILTER (WHERE hearing_decision_number IS NOT NULL))[1] AS hearing_decision_number,\\n        (ARRAY_AGG(hearing_decision_date ORDER BY updated_at DESC)\\n            FILTER (WHERE hearing_decision_date IS NOT NULL))[1] AS hearing_decision_date,\\n        (ARRAY_AGG(offense_description ORDER BY updated_at DESC)\\n            FILTER (WHERE offense_description IS NOT NULL))[1] AS offense_description\\n    FROM aduan_masyarakat_v3.report_officer_detail\\n    GROUP BY prepetrator_id, report_id\\n),\\nprepetrator_flattened AS (\\n    SELECT DISTINCT ON (rp.report_id, rp.prepetrator_id)\\n        rp.report_id,\\n        rp.prepetrator_id,\\n        p.name,\\n        p.rank,\\n        p.position,\\n        p.identity_number,\\n        p.functional_assignment,\\n        ad.articles_list AS articles,\\n        p.updated_at AS prep_updated_at,\\n        p.type as type_perpetrator\\n    FROM aduan_masyarakat_v3.report_prepetrators rp\\n    LEFT JOIN aduan_masyarakat_v3.prepetrator p \\n        ON rp.prepetrator_id = p.id\\n    LEFT JOIN ArticlesData ad \\n        ON rp.prepetrator_id = ad.prepetrator_id\\n    WHERE rp.prepetrator_id = %(prepetrator_id_0)s\\n    ORDER BY rp.report_id, rp.prepetrator_id, p.updated_at DESC\\n),\\nlatest_police_report_array AS (\\n    SELECT \\n        report_id,\\n        prepetrator_id,\\n        JSON_AGG(\\n            JSON_BUILD_OBJECT(\\n                'report_number', report_number,\\n                'datetime', datetime,\\n                'criminal_lp_number', criminal_lp_number,\\n                'hearing_decision_date', hearing_decision_date,\\n                'report_detail', report_detail,\\n                'criminal_offense', criminal_offense,\\n                'criminal_article', criminal_article,\\n                'criminal_process_status', criminal_process_status,\\n                'decision_number', decision_number,\\n                'short_description', short_description,\\n                'criminal_article_description', criminal_article_description,\\n                'criminal_notes', criminal_notes\\n            )\\n            ORDER BY updated_at DESC\\n        ) AS list_police_reports\\n    FROM aduan_masyarakat_v3.police_report\\n    GROUP BY report_id, prepetrator_id\\n),\\njoined AS (\\n    SELECT\\n        r.id AS report_id,\\n        r.source,\\n        r.created_date,\\n        r.updated_at,\\n        pf.prepetrator_id,\\n        pf.name,\\n        pf.rank,\\n        pf.position,\\n        pf.identity_number,\\n        pf.functional_assignment,\\n        pf.articles,\\n        pf.type_perpetrator,\\n        pra.list_police_reports,\\n        cd.document_number,\\n        cd.document_date,\\n        cd.hearing_date,\\n        cd.hearing_place,\\n        cd.hearing_decision_number,\\n        cd.hearing_decision_date,\\n        cd.offense_description,\\n        GREATEST(\\n            r.updated_at,\\n            COALESCE(pf.prep_updated_at, r.updated_at)\\n        ) AS latest_updated_at\\n    FROM report_clean r\\n    JOIN prepetrator_flattened pf \\n        ON r.id = pf.report_id\\n    LEFT JOIN latest_police_report_array pra \\n        ON pf.prepetrator_id = pra.prepetrator_id\\n        AND pf.report_id = pra.report_id\\n    LEFT JOIN latest_combined_docs cd \\n        ON pf.prepetrator_id = cd.prepetrator_id\\n        AND pf.report_id = cd.report_id\\n)\\nSELECT DISTINCT ON (prepetrator_id)\\n    prepetrator_id, \\n    report_id,\\n    source,\\n    created_date,\\n    json_build_array(\\n        json_build_object(\\n            'prepetrator_id', prepetrator_id,\\n            'name', name,\\n            'rank', rank,\\n            'position', position,\\n            'identity_number', identity_number,\\n            'functional_assignment', functional_assignment,\\n            'articles', articles,\\n            'type_perpetrator', type_perpetrator\\n        )\\n    ) AS prepetrator_data,\\n    CASE \\n        WHEN list_police_reports IS NULL \\n             OR json_array_length(list_police_reports) = 0\\n        THEN json_build_array(\\n            json_build_object(\\n                'report_number', NULL,\\n                'datetime', NULL,\\n                'criminal_lp_number', NULL,\\n                'hearing_decision_date', NULL,\\n                'report_detail', NULL,\\n                'criminal_offense', NULL,\\n                'criminal_article', NULL,\\n                'criminal_process_status', NULL,\\n                'decision_number', NULL,\\n                'short_description', null,\\n                'criminal_article_description', null,\\n                'criminal_notes', null\\n            )\\n        )\\n        ELSE list_police_reports\\n    END AS police_reports,\\n    json_build_object(\\n        'document_number', document_number,\\n        'document_date', document_date,\\n        'hearing_date', hearing_date,\\n        'hearing_place', hearing_place,\\n        'hearing_decision_number', hearing_decision_number,\\n        'hearing_decision_date', hearing_decision_date,\\n        'offense_description', offense_description\\n    ) AS officer_details\\nFROM joined\\nORDER BY prepetrator_id, latest_updated_at DESC, report_id DESC\\nLIMIT 15;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
          },
