        "response": {
          "status": 200,
          "statusText": "OK",
          "httpVersion": "HTTP/1.1",
          "headers": [
            {
              "name": "access-control-allow-origin",
              "value": "https://gajamada-propam.polri.go.id"
            },
            {
              "name": "content-encoding",
