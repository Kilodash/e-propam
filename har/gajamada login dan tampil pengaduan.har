ieldName\":\"\"},{\"table\":\"aduan_masyarakat_v3.\\\"report_view\\\"\",\"field\":\"status_label\",\"field_type_origin\":\"character varying\",\"enable\":true,\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"queryId\":\"07540eba57b58ad266d16b90d36b9930\",\"sourceId\":[\"898801d5dceb3fe4d10c13d25d4f5b88\"],\"fieldType\":\"character varying\",\"operator\":\"is\",\"queryParamsName\":\"status_label\",\"operatorField\":\"AND\",\"enableMultipleField\":false,\"enableCustomField\":false,\"customFieldName\":\"\"}]}},\"showPagination\":false,\"customNoData\":true,\"customConfigTable\":{\"tableCategoryCustom\":[],\"tableColumnAlias\":[{\"field\":\"total_penanganan\",\"alias\":\"total_penanganan\",\"name\":\"total_penanganan\",\"type\":\"number\"},{\"field\":\"total_masuk\",\"alias\":\"total_masuk\",\"name\":\"total_masuk\",\"type\":\"number\"},{\"field\":\"total_selesai\",\"alias\":\"total_selesai\",\"name\":\"total_selesai\",\"type\":\"number\"},{\"field\":\"total_rendah\",\"alias\":\"total_rendah\",\"name\":\"total_rendah\",\"type\":\"number\"},{\"field\":\"total_sedang\",\"alias\":\"total_sedang\",\"name\":\"total_sedang\",\"type\":\"number\"},{\"field\":\"total_tinggi\",\"alias\":\"total_tinggi\",\"name\":\"total_tinggi\",\"type\":\"number\"}]},\"customColorKey\":[],\"dataLabel\":{},\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customColorPalette\":[]},\"formSchema\":\"postgresql\",\"collectionGroup\":\"table\",\"values\":[[\"total_penanganan\",\"total_masuk\",\"total_selesai\",\"total_rendah\",\"total_sedang\",\"total_tinggi\"],[0,110,6,0,0,0]],\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"/* Base Card Icon */\\n.card-icon {\\n  display: flex;\\n  padding: 8px;\\n  justify-content: center;\\n  align-items: center;\\n  border-radius: 8px;\\n  background-color: var(--black-50);\\n  color: var(--black);\\n  font-size: 20px;\\n}\\n\\n.kpi-card {\\n  display: flex;\\n  padding: 8px 12px;\\n  align-items: center;\\n  gap: 12px;\\n\\n  border-radius: 12px;\\n  border: 1px solid var(--black-100);\\n  background: var(--white);\\n}\\n\\n\\n\\n\\n.card-icon.selesai {\\n  background: var(--success-50);\\n  /* hijau muda */\\n  color: var(--success);\\n  /* hijau tua */\\n}\\n\\n.card-icon.disposisi {\\n  background: var(--warning-50);\\n\\n  color: var(--warning);\\n\\n}\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport styled from 'styled-components';\\nexport default function MyCode({ widget, data, G }) {\\n  const hasData = Array.isArray(data) && data.length > 0;\\n  const item = hasData ? data[0] : {};\\n\\n  function formatThousand(value: any, maxAfterComma: number = 2) {\\n    return `${(parseFloat(value) || 0).toLocaleString('id-ID', {\\n      maximumFractionDigits: maxAfterComma,\\n    })}`;\\n  }\\n\\n  return (\\n    <div className=\\\"h-100 py-2\\\">\\n      <div className=\\\"row\\\">\\n        <div className=\\\"col-4\\\">\\n          <div className=\\\"kpi-card\\\">\\n            <div className=\\\"card-icon\\\">\\n              <i className=\\\"ph-fill ph-file-arrow-down\\\"></i>\\n            </div>\\n            <div className=\\\"flex flex-col gap-2\\\">\\n              <p className=\\\"text-muted fw-500\\\" style={{ fontSize: '14px' }}>\\n                Laporan Belum Diproses\\n              </p>\\n              <p style={{ fontSize: '20px' }} className=\\\"fw-600\\\">\\n                {item?.total_masuk ? formatThousand(item.total_masuk) : '0'}\\n              </p>\\n            </div>\\n          </div>\\n        </div>\\n\\n        <div className=\\\"col-4\\\">\\n          <div className=\\\"kpi-card\\\">\\n            <div className=\\\"card-icon disposisi\\\">\\n              <i className=\\\"ph-fill ph-arrows-clockwise\\\"></i>\\n            </div>\\n            <div className=\\\"flex flex-col gap-2\\\">\\n              <p style={{ fontSize: '14px' }} className=\\\"text-muted fw-500\\\">\\n                Laporan Diproses\\n              </p>\\n              <p style={{ fontSize: '20px' }} className=\\\"fw-600\\\">\\n                {item?.total_penanganan ? formatThousand(item.total_penanganan) : '0'}\\n          \\n              </p>\\n            </div>\\n          </div>\\n        </div>\\n\\n        <div className=\\\"col-4\\\">\\n          <div className=\\\"kpi-card\\\">\\n            <div className=\\\"card-icon selesai\\\">\\n              <i className=\\\"ph-fill ph-check-circle\\\"></i>\\n            </div>\\n            <div className=\\\"flex flex-col gap-2\\\">\\n              <p style={{ fontSize: '14px' }} className=\\\"text-muted fw-500\\\">\\n                Laporan Selesai\\n              </p>\\n              <p style={{ fontSize: '20px' }} className=\\\"fw-600\\\">\\n                {item.total_selesai ? formatThousand(item.total_selesai) : '0'}\\n              </p>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  );\\n}\\n\",\"html\":\"<div class=\\\"h-100 py-2\\\">\\n\\n  <!-- ROW -->\\n  <div class=\\\"flex flex-wrap \\\">\\n\\n    <!-- COL 1 -->\\n    <div class=\\\"w-1/5 px-2\\\">\\n      <div class=\\\"kpi-card bg-white p-6 rounded-lg  border border-gray-200 flex items-center space-x-4\\\">\\n        <div class=\\\"card-icon\\\">\\n          <i class=\\\"ph-fill ph-file-arrow-down\\\"></i>\\n        </div>\\n        <div class=\\\"flex flex-col gap-2\\\">\\n          <p class=\\\"fs-14 text-muted fw-500\\\">Masuk</p>\\n          <p class=\\\"fs-20 fw-700\\\">{{data.0.total_masuk}}</p>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <!-- COL 2 -->\\n    <div class=\\\"w-1/5 px-2\\\">\\n      <div class=\\\"kpi-card bg-white p-6 rounded-lg  border border-gray-200 flex items-center space-x-4\\\">\\n        <div class=\\\"card-icon verifikasi\\\">\\n          <i class=\\\"ph-fill ph-shield-check\\\"></i>\\n        </div>\\n        <div class=\\\"flex flex-col gap-2\\\">\\n          <p class=\\\"fs-14 text-muted fw-500\\\">Verifikasi</p>\\n          <p class=\\\"fs-20 fw-700\\\">{{data.0.total_verifikasi}}</p>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <!-- COL 3 -->\\n    <div class=\\\"w-1/5 px-2\\\">\\n      <div class=\\\"kpi-card bg-white p-6 rounded-lg  border border-gray-200 flex items-center space-x-4\\\">\\n        <div class=\\\"card-icon disposisi\\\">\\n          <i class=\\\"ph-fill ph-arrows-clockwise\\\"></i>\\n        </div>\\n        <div class=\\\"flex flex-col gap-2\\\">\\n          <p class=\\\"fs-14 text-muted fw-500\\\">Disposisi</p>\\n          <p class=\\\"fs-20 fw-700\\\">{{data.0.total_disposisi}}</p>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <!-- COL 4 -->\\n    <div class=\\\"w-1/5 px-2\\\">\\n      <div class=\\\"kpi-card bg-white p-6 rounded-lg  border border-gray-200 flex items-center space-x-4\\\">\\n        <div class=\\\"card-icon penanganan\\\">\\n          <i class=\\\"ph-fill ph-hand\\\"></i>\\n        </div>\\n        <div class=\\\"flex flex-col gap-2\\\">\\n          <p class=\\\"fs-14 text-muted fw-500\\\">Penanganan</p>\\n          <p class=\\\"fs-20 fw-700\\\">{{data.0.total_penanganan}}</p>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"w-1/5 px-2\\\">\\n      <div class=\\\"kpi-card bg-white p-6 rounded-lg  border border-gray-200 flex items-center space-x-4\\\">\\n        <div class=\\\"card-icon selesai\\\">\\n          <i class=\\\"ph-fill ph-check-circle\\\"></i>\\n        </div>\\n        <div class=\\\"flex flex-col gap-2\\\">\\n          <p class=\\\"fs-14 text-muted fw-500\\\">Selesai</p>\\n          <p class=\\\"fs-20 fw-700\\\">{{data.0.total_selesai}}</p>\\n        </div>\\n      </div>\\n    </div>\\n\\n  </div>\\n\\n</div>\"},\"sourceInfo\":\"\",\"sourceInfoUrl\":\"\",\"hideSource\":false,\"data\":{\"title\":\"\",\"sourceType\":\"\"},\"fullscreen\":false,\"hideWidget\":true,\"dateFields\":\"\",\"useAsFilterConfig\":{\"enable\":false},\"enableTimelapse\":false,\"enableLoadMore\":false,\"en