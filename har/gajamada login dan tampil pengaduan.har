            "mimeType": "application/json",
            "compression": 15534,
            "text": "{\"metaData\":{\"pagination\":{\"size\":10,\"totalElements\":552,\"totalPages\":56,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":76},\"data\":[{\"id\":\"2026071300081\",\"created_date\":1783908614000,\"created_date_utc\":1783883414000,\"p_id\":\"2026071300081-00001\",\"updated_at\":1783920541156,\"prepetrator_id\":\"2026071300081-00001\",\"prepetrator_name\":null,\"type\":\"SUMBER SURAT DUMAS\",\"method\":null,\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"YANDUAN\",\"disposisi_case_position\":\"OPERATOR YANDUAN POLDA JAWA BARAT\",\"category\":\"PENANGANAN PERKARA PIDANA\",\"total_report\":0,\"content\":\"Melaporkan dugaan ketidakprofesionalan penyidik Unit 3 Subdit 1 Ditreskrimum Polda Jawa Barat berupa ketidaknetralan dengan mengesampungkan asas praduga tak bersalah terhadap klien pendumas sebagai terlapor dalam laporan polisi nomor: LP/B/815/IV/2026/SPKT/POLDA JAWA BARAT\",\"5w1h_when\":null,\"5w1h_where\":null,\"phone_no\":\"+6282111397729\",\"summary\":\"Pengaduan memuat tuduhan ketidakprofesionalan penyidik yang bekerja di Unit 3 Subdit 1 Ditreskrimum Polda Jawa Barat. Penyidik diduga tidak netral dan menegaskan asas praduga tak bersalah terhadap klien Pendudamas yang menjadi terlapor. Keputusan tersebut didokumentasikan dalam laporan polisi nomor LP/B/815/IV/2026/SPKT/POLDA JAWA BARAT. Pengadu menilai bahwa tindakan penyidik menyalahi etika profesional dan SOP penyidik. Pengadu meminta Divpropam menindaklanjuti dugaan pelanggaran tersebut.\",\"pengirim\":\"Samsur Rijal, S.H., M.H. & Partners / Nursyaharani Nabila\",\"source\":null,\"source_alias\":\"SUMBER SURAT DUMAS\",\"reporter_nik\":null,\"email\":\"abc@abc.com\",\"status_label\":\"Laporan Dikirim ke Polda\"},{\"id\":\"2026071200196\",\"created_date\":1783853776000,\"created_date_utc\":1783828576000,\"p_id\":\"2026071200196-00001\",\"updated_at\":1783914867705,\"prepetrator_id\":\"2026071200196-00001\",\"prepetrator_name\":\"Pak Siswanto\",\"type\":\"Website\",\"method\":\"Web Form\",\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"YANDUAN\",\"disposisi_case_position\":\"KASUBBAG YANDUAN POLDA JAWA BARAT\",\"category\":\"PERILAKU & INTEGRITAS PERSONAL\",\"total_report\":2,\"content\":\"Saya menitipkan mobil mercedesbenz tahun 2012 tipe CE200 para tahun 2017 kepada oknum polisi yg saat ini menjabat sebagai wakapolsek cigasong atas nama pak siswanto, namun mbl tsbt sampai dengan saat ini belum dikembalikan kepada saya, mohon bantuan bapak kepala propam untuk menindaklanjuti laporan saya. Terima kasih\",\"5w1h_when\":1483203600000.0,\"5w1h_where\":\"Wakapolsek Cigasong\",\"phone_no\":\"6281219253674\",\"summary\":\"Pada tahun 2017, pemilik mobil Mercedes-Benz CE200 tahun 2012 menitipkan kendaraan tersebut kepada oknum polisi yang saat itu menjabat sebagai Wakil Kepala Polsek Cigasong, Pak Siswanto. Hingga kini, kendaraan belum dikembalikan kepada pemiliknya, sehingga pemilik mengajukan aduan kepada Divisi Propam untuk menindaklanjuti kasus ini.\",\"pengirim\":\"Hetty Hertaty\",\"source\":\"Surat dari Masyarakat\",\"source_alias\":\"SUMBER QR CODE\",\"reporter_nik\":\"3173015512800013\",\"email\":null,\"status_label\":\"Laporan Diterima Polda\"},{\"id\":\"2026071000145\",\"created_date\":1783666596000,\"created_date_utc\":1783641396000,\"p_id\":\"2026071000145-00001\",\"updated_at\":1783914896929,\"prepetrator_id\":\"2026071000145-00001\",\"prepetrator_name\":null,\"type\":\"SUMBER SURAT DUMAS\",\"method\":null,\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"YANDUAN\",\"disposisi_case_position\":\"KASUBBAG YANDUAN POLDA JAWA BARAT\",\"category\":\"PENANGANAN PERKARA PIDANA\",\"total_report\":0,\"content\":\"DUGAAN KETIDAKPROFESIONALAN BERUPA TIDAK MEMBERIKAN SP2HP TERHADAP PELAPOR BERDASARKAN STPP/605/VI/2026/SEK CILEUNGSI TENTANG ADUAN PENJUALAN ROKO TANPA CUKAI DI DESA PASIR ANGIN KEC CILEUNGSI KAB BOGOR\\n\",\"5w1h_when\":null,\"5w1h_where\":null,\"phone_no\":\"+628122938907\",\"summary\":\"Pengadu menyoroti dugaan ketidakprofesionalan penyidik Polri yang tidak memberikan SP2HP kepada pelapor atas kasus penjualan rokok tanpa cukai di Desa Pasir Angin. Pengadu merujuk pada surat tertanggal VI/2026/SEK Cileungsi (STPP/605/VI/2026/SEK Cileungsi) yang mengatur penanganan bukti untuk perkara tersebut. Tidak adanya SP2HP menghambat pelaporan dan proses lanjutan ke penegakan hukum. Akibatnya, pelapor menilai tindakan penyidik sebagai tidak profesional dan meminta penyelidikan Divpropam. Pelaporan difokuskan pada kegagalan penyidik untuk melaksanakan kewajiban resmi sesuai SOP.\",\"pengirim\":\"PIMPINAN CABANG SEMARANG KANNI \",\"source\":null,\"source_alias\":\"SUMBER SURAT DUMAS\",\"reporter_nik\":null,\"email\":\"abc@abc.com\",\"status_label\":\"Laporan Diterima Polda\"},{\"id\":\"2026071000138\",\"created_date\":1783665207000,\"created_date_utc\":1783640007000,\"p_id\":\"2026071000138-00001\",\"updated_at\":1783914936848,\"prepetrator_id\":\"2026071000138-00001\",\"prepetrator_name\":null,\"type\":\"SUMBER SURAT DUMAS\",\"method\":null,\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"YANDUAN\",\"disposisi_case_position\":\"KASUBBAG YANDUAN POLDA JAWA BARAT\",\"category\":\"PENANGANAN PERKARA PIDANA\",\"total_report\":0,\"content\":\"Melaporkan lambannya penanganan perkara Laporan Polisi nomor: LP/B/271/IV/2025/SPKT/POLRES CIANJUR/POLDA JAWA BARAT\",\"5w1h_when\":null,\"5w1h_where\":null,\"phone_no\":\"+628231107896\",\"summary\":\"Pengaduan menyatakan bahwa penanganan perkara nomor LP/B/271/IV/2025/SPKT/POLRES CIANJUR/POLDA JAWA BARAT diperlakukan lamban oleh petugas penegakan hukum. Komplainer meyakini bahwa petugas tidak menyampaikan progres atau hasil penyidikan secara tepat waktu. Permintaan pengaduan adalah agar dilakukan penelaahan internal terhadap perilaku petugas yang dianggap melanggar prosedur. Pengaduan ini menyoroti dugaan ketidakprofesionalan dalam pelaksanaan tugas polisi, yang dapat menimbulkan ketidakpuasan publik. Dampak terhadap pelayanan publik berpotensi menurunkan kepercayaan masyarakat.\",\"pengirim\":\"Pana & Partners / Carlo Jeffry E Panjaitan\",\"source\":null,\"source_alias\":\"SUMBER SURAT DUMAS\",\"reporter_nik\":null,\"email\":\"abc@abc.com\",\"status_label\":\"Laporan Diterima Polda\"},{\"id\":\"2026071000132\",\"created_date\":1783664095000,\"created_date_utc\":1783638895000,\"p_id\":\"2026071000132-00001\",\"updated_at\":1783915061774,\"prepetrator_id\":\"2026071000132-00001\",\"prepetrator_name\":\"Ipda Hendra Mulyana\",\"type\":\"SUMBER SURAT DUMAS\",\"method\":null,\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"YANDUAN\",\"disposisi_case_position\":\"KASUBBAG YANDUAN POLDA JAWA BARAT\",\"category\":\"PENANGANAN PERKARA PIDANA\",\"total_report\":0,\"content\":\"Melaporkan dugaan ketidakprofesionalan penyidik Satreskrim Polresta Bogor Kota Ipda Hendra Mulyana berupa tidak memberikan SP2HP terhadap pendumas dan berkas perkara LP/1026/X/2014 dinyatakan hilang\",\"5w1h_when\":null,\"5w1h_where\":null,\"phone_no\":\"+62822333963651\",\"summary\":\"Pada pelaporan ini diakui bahwa penyidik Satreskrim Polresta Bogor Kota, Ipda Hendra Mulyana, tidak menyerahkan SP2HP kepada penduda. Selain itu, dia menyatakan bahwa berkas perkara LP/1026/X/2014 dinyatakan hilang. Kasus ini menimbulkan kerugian administratif bagi penduda yang tidak dapat melanjutkan proses. Adanya kelalaian tersebut menimbulkan dugaan ketidakprofesionalan penyidik dan memerlukan penyelidikan internal.\",\"pengirim\":\"Deddy Barnas Djiun\",\"source\":null,\"source_alias\":\"SUMBER SURAT DUMAS\",\"reporter_nik\":null,\"email\":\"abc@abc.com\",\"status_label\":\"Laporan Diterima Polda\"},{\"id\":\"2026070900314\",\"created_date\":1783612704000,\"created_date_utc\":1783587504000,\"p_id\":\"2026070900314-00001\",\"updated_at\":1783754873900,\"prepetrator_id\":\"2026070900314-00001\",\"prepetrator_name\":\"Aiptu Ervan Faradis\",\"type\":\"Website\",\"method\":\"Web Form\",\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":\"POLRES SUKABUMI\",\"disposisi_polda_code\":6013,\"disposisi_polres_code\":60010206654940.0,\"disposisi_police_function\":\"PAMINAL\",\"disposisi_case_position\":\"KANIT PAMINAL POLRES SUKABUMI POLDA JAWA BARAT\",\"category\":\"PERILAKU & INTEGRITAS PERSONAL\",\"total_report\":4,\"content\":\"saya beli motor vario kzr dari fb dengan kondisi tidak ada surat surat tetapi dengan kunci original saya beli motor tersebut dengan harga 3.4 juta dan perbaikan motor sekitar 1.8 juta jadi total kerugian 5,2 juta rupiah , lalu karna saya bosan karna sudah 3 bulanan , saya jual motor tersebut di fb lagi dengan harga 4 juta rupiah ,saya posting motor tersebut pada tanggal 13 juni 2026 sore hari , lalu oknum chat saya untuk menanyakan perihal motor tersebut ada atau tidak , singkat cerita , oknum mengajak Tukar motor saya dengan motor oknum yaitu beat delux 2025 dengan kondisi tidak ada surat surat , singkat cerita deal di mesengger dan oknum mengajak untuk cod jam 6 pagi tanggal 14 juni, di pelabuhan ratu , singkat cerita saya berangkat dari rumah sekitar jam 5 kurang , dan sampainya di pelabuhan ratu sekitar jam 6 lebih , dia mengajak saya cod di sebuah warung beralasan punya dia ,kondisi tempat saat itu sepi , dan akhirnya oknum Aiptu Ervan Faradis dinas di polres Sukabumi 1 anggota lainnya yang saya kurang tau namanya karena memakai rompi ber 3 dengan 2 motor , 1 motor polisi dan 1 motor beat , datang langsung menanyakan bahwa itu motor saya atau bukan, langsung meminta kunci motor saya , dan menyuruh saya serching pasal menjual motor tanpa surat, tanpa memberi tahu indentitas mereka dan surat perintah, saya di introgasi mengenai dapat dari mana barang tersebut di dapat , saya menjelaskan bahwa saya dapat dari fb dengan posisi rumahnya di cibadak dan saya menjelaskan bahwa saya tau rumah pemilik motor sebelumnya, tetapi oknum bersikeras untuk saya menunjukan/ menemukan stnk padahal saya sudah menjelaskan saya dapat motor tersebut dalam keadaan tidak ada surat surat , akhirnya oknum memberikan 2 pilihan untuk datang ke polsek terdekat atau saya harus mendapatkan stnk dari pemilik sebelumnya , tetapi pada saat oknum menjelaskan pilihan di bawa ke polsek , oknum juga menjelaskan betapa ribetnya kalo saya harus mengurus di polsek dan harga yang di bayar lebih dari 10 juta kalo saya ingin bebas , sehingga saya bingung dan akhirnya memilih untuk mengambil pilihan ke dua yaitu mencari stnk nya sendiri dan jika sudah ketemu diharapkan untuk menghubungi oknum, lalu saya memberitahu jika saya tidak ada uang cash untuk pulang ke rumah dan oknum memberikan sejumlah uang 70 ribu untuk ongkos bus mgi , saya di antarkan oleh salah satu oknum ke terminal dan oknum langsung pergi sesampainya saya di terminal pelabuhan ratu ,  dan sesampainya saya dirumah saya mencoba chat oknum untuk menanyakan kejelasan prosesnya , tapi ternyata saya sudah di blok di mesengger dan di whatsapp , saya mencoba chat di akun whatsapp ke 2 saya dan tidak lama di blok kembali , lalu saya chat di akun ke 3 dengan kondisi saya menyampaikan kekesalan dan meminta pada oknum apakah ada surat dari pengadilan untuk pengambilan motor saya , karna saya merasa tertipu disitu, tetapi oknum malah mengancam untuk menangkap saya dan menyalahkan saya karna menjual motor tersebut.\",\"5w1h_when\":1781391600000.0,\"5w1h_where\":\"Pelabuhan Ratu, Sukabumi, Jawa Barat\",\"phone_no\":\"6285133494475\",\"summary\":\"Pada 13 Juni 2026, M Aldo Shafwan Azmi memposting motor Vario KZR yang ia beli tanpa surat di FB. Pada 14 Juni 2026, oknum Polres Sukabumi 1, Aiptu Ervan Faradis, mengajak tukar motor dengan Beat Delux 2025 di Pelabuhan Ratu. Oknum meminta kunci motor, menuntut STNK, mengancam penangkapan, dan memaksa pelapor mencari STNK sendiri. Setelah pelapor kembali ke rumah, ia diblokir di messenger dan WhatsApp, dan oknum mengancam penangkapan lagi.\",\"pengirim\":\"M Aldo Shafwan Azmi\",\"source\":\"Surat dari Masyarakat\",\"source_alias\":\"SUMBER QR CODE\",\"reporter_nik\":\"3202271707040002\",\"email\":null,\"status_label\":\"Laporan Diterima\"},{\"id\":\"2026070900183\",\"created_date\":1783575743000,\"created_date_utc\":1783550543000,\"p_id\":\"2026070900183-00001\",\"updated_at\":1783667413035,\"prepetrator_id\":\"2026070900183-00001\",\"prepetrator_name\":\"Ateng Nadiana\",\"type\":\"Website\",\"method\":\"Web Form\",\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"PROVOS\",\"disposisi_case_position\":\"KASIPROVOS SATBRIMOB POLDA JAWA BARAT\",\"category\":\"PELANGGARAN HUKUM / TINDAK PIDANA\",\"total_report\":4,\"content\":\"Terlapor selaku anggota aktif Korps Brimob Polri diduga kuat telah melakukan pelanggaran disiplin berat, kode etik profesi, serta murni melakukan Tindak Pidana Penggelapan (Pasal 372/374 KUHP) karena menyalahgunakan kepercayaan dengan menggadaikan aset milik warga sipil secara ilegal.\\n\\nIdentitas Terlapor\\nNama : Ateng Nadiana\\nPangkat : Anggota Brimob\\nTempat Berdinas : Jl. Ir. Soekarno No. 11, Desa Sayang, Kecamatan Jatinangor, Kabupaten Sumedang, Jawa Barat (Kantor Brimob Kompi 2 Sayang Sumedang)\\n\\n\",\"5w1h_when\":1783525343000.0,\"5w1h_where\":\"Jl. Ir. Soekarno No. 11, Desa Sayang, Kecamatan Jatinangor, Kabupaten Sumedang, Jawa Barat (Kantor Brimob Kompi 2 Sayang Sumedang)\",\"phone_no\":\"62895411969570\",\"summary\":\"Ateng Nadiana, anggota Brimob, diduga melakukan penggelapan dengan menggadaikan aset milik warga sipil secara ilegal, melanggar disiplin berat dan kode etik profesi.\",\"pengirim\":\"UJANG ENGKOS\",\"source\":\"Surat dari Masyarakat\",\"source_alias\":\"SUMBER QR CODE\",\"reporter_nik\":\"3204050511770003\",\"email\":null,\"status_label\":\"Laporan Diterima\"},{\"id\":\"2026070700228\",\"created_date\":1783432058000,\"created_date_utc\":1783406858000,\"p_id\":\"2026070700228-00001\",\"updated_at\":1783480788861,\"prepetrator_id\":\"2026070700228-00001\",\"prepetrator_name\":null,\"type\":\"Website\",\"method\":\"Web Form\",\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":null,\"disposisi_polda_code\":6013,\"disposisi_polres_code\":null,\"disposisi_police_function\":\"PAMINAL\",\"disposisi_case_position\":\"UNIT 2 SUBBID PAMINAL POLDA JAWA BARAT\",\"category\":\"TUGAS KEDINASAN KEPOLISIAN\",\"total_report\":2,\"content\":\"Perihal: Penyampaian Dugaan Kerugian yang Dialami PT Intan Surya Adiyaksa\\n\\nKepada Yth.\\nBapak Kabid Propam Polda Jawa Barat\\n\\nDengan hormat,\\n\\nBersama surat ini kami menyampaikan adanya kerugian yang dialami oleh perusahaan kami, PT Intan Surya Adiyaksa, sehubungan dengan pelaksanaan pekerjaan pengelolaan limbah di PT TJF.\\n\\nPada kurun waktu 1 Desember sampai dengan 17 Desember 2025, perusahaan kami memperoleh Surat Perintah Kerja (SPK) dari PT TJF untuk melaksanakan pengambilan limbah di PT TJF. Dalam pelaksanaannya, pihak manajemen perusahaan meminta kepada kami untuk menyediakan dana pengamanan dengan alasan adanya aksi unjuk rasa yang dilakukan oleh pihak yang tidak puas atas berakhirnya kerja sama pengelolaan limbah antara PT TJF dengan PT CMM. Menurut penjelasan pihak manajemen, dana tersebut diperuntukkan sebagai biaya pengamanan oleh aparat Kepolisian dari Polres Karawang.\\n\\nAtas permintaan tersebut, perusahaan kami telah mengeluarkan dana sekitar Rp650.000.000,00 yang diserahkan melalui pihak manajemen perusahaan yaitu Sdri. Ai Fitria Wijayanti dan di transfer melalui Sdr. Rusdi. Selanjutnya, kami memperoleh informasi dari pihak manajemen bahwa dana tersebut diperuntukkan bagi Kabag Ops Polres Karawang (AKBP Suparlan) dan Kasat Samapta Polres Karawang (AKP Wahyu Kurniawan) sebagai biaya pengamanan.\\n\\nNamun demikian, kami menilai bahwa pengamanan yang diberikan tidak sebanding dengan biaya yang telah kami keluarkan. Selama periode 1 Desember hingga 17 Desember 2025, ketika perusahaan kami hendak melaksanakan kegiatan pengambilan limbah dan menghadapi penghadangan dari sejumlah organisasi kemasyarakatan (ormas), kami tidak melihat adanya tindakan pengamanan yang efektif dari pihak Kepolisian. Kondisi tersebut mengakibatkan kegiatan operasional perusahaan kami tidak dapat berjalan sebagaimana mestinya, sehingga kami merasa tidak memperoleh perlindungan maupun pengamanan sesuai dengan tujuan pengeluaran dana tersebut.\\n\\nSelain itu, kami juga memperoleh informasi langsung dari pihak manajemen perusahaan bahwa dana pengamanan yang kami serahkan telah diterima oleh Kasat Samapta Polres Karawang melalui anggotanya yang bernama Bripda Dadang Satya. Namun, setelah kami melakukan penelusuran dan meminta klarifikasi kepada sejumlah anggota Kepolisian yang bertugas melakukan pengamanan di lokasi, kami memperoleh keterangan bahwa anggota-anggota yang melaksanakan pengamanan tidak pernah menerima dana pengamanan sebagaimana dimaksud.\\n\\nAkibat tidak adanya pengamanan yang efektif selama periode tersebut, perusahaan kami akhirnya diputus secara sepihak oleh PT TJF sehingga mengalami kerugian yang cukup besar.\\n\\nBerdasarkan uraian tersebut, kami memohon kepada Bapak Kabid Propam Polda Jawa Barat untuk melakukan pendalaman dan pemeriksaan secara objektif terhadap dugaan penyimpangan dalam penggunaan dana pengamanan yang telah kami keluarkan, sehingga diperoleh kepastian hukum serta kejelasan mengenai pihak yang bertanggung jawab atas permasalahan tersebut.\\n\\nDemikian penyampaian ini kami buat dengan sebenar-benarnya. Atas perhatian dan tindak lanjut Bapak, kami ucapkan terima kasih.\",\"5w1h_when\":1764522000000.0,\"5w1h_where\":\"PT TJF, Karawang, Jawa Barat\",\"phone_no\":\"6281311122217\",\"summary\":\"PT Intan Surya Adiyaksa mengajukan aduan kepada Divpropam Polda Jawa Barat atas dugaan penyalahgunaan dana pengamanan sebesar Rp650.000.000,00 yang diberikan kepada pihak kepolisian (Kabag Ops Polres Karawang, Kasat Samapta Polres Karawang, dan Bripda Dadang Satya). Perusahaan menilai dana tersebut tidak disalurkan atau tidak digunakan secara efektif, sehingga tidak ada perlindungan keamanan yang diberikan selama periode 1–17 Desember 2025. Akibatnya, kegiatan pengambilan limbah tidak berjalan, perusahaan mengalami kerugian, dan PT TJF memutuskan kontrak secara sepihak. Perusahaan meminta penyelidikan dan klarifikasi atas penggunaan dana tersebut.\",\"pengirim\":\"Yayan Suryawan Husein\",\"source\":\"Surat dari Instansi Lainnya\",\"source_alias\":\"SUMBER QR CODE\",\"reporter_nik\":\"3215031705920005\",\"email\":null,\"status_label\":\"Laporan Diterima\"},{\"id\":\"2026070600169\",\"created_date\":1783322584000,\"created_date_utc\":1783297384000,\"p_id\":\"2026070600169-00001\",\"updated_at\":1783368254258,\"prepetrator_id\":\"2026070600169-00001\",\"prepetrator_name\":null,\"type\":\"Website\",\"method\":\"Web Form\",\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":\"POLRESTA BANDUNG\",\"disposisi_polda_code\":6013,\"disposisi_polres_code\":60010251654954.0,\"disposisi_police_function\":\"YANDUAN\",\"disposisi_case_position\":\"KAUR YANDUAN POLRESTA BANDUNG POLDA JAWA BARAT\",\"category\":\"PENANGANAN PERKARA PIDANA\",\"total_report\":26,\"content\":\"dugaan kesewenang-wenangan atasan yang dilakukan oleh penyidik Polresta Bandung perihal dugaan adanya keberpihakan dalam menangani Tindak Pidana pencemaran nama baik melalui live tiktok dengan pelapor Saudari Sheryl Zalfaa dengan terlapor Saudari Herawati (sebagai korban) (bukti dukung berupa surat pernyataan)\",\"5w1h_when\":1783272184000.0,\"5w1h_where\":\"Polresta Bandung, Kota Bandung\",\"phone_no\":\"6285894375637\",\"summary\":\"Pelapor mengadu bahwa penyidik Polresta Bandung melakukan penyalahgunaan wewenang atasan dalam menangani kasus pencemaran nama baik melalui live TikTok antara pelapor Sheryl Zalfaa dan terlapor Herawati, didukung oleh surat pernyataan.\",\"pengirim\":\"pelimpahan WBS\",\"source\":\"Surat dari Masyarakat\",\"source_alias\":\"SUMBER QR CODE\",\"reporter_nik\":\"1374012602020001\",\"email\":null,\"status_label\":\"Laporan Dikirim ke Polres\"},{\"id\":\"2026070600145\",\"created_date\":1783318537000,\"created_date_utc\":1783293337000,\"p_id\":\"2026070600145-00001\",\"updated_at\":1783583141866,\"prepetrator_id\":\"2026070600145-00001\",\"prepetrator_name\":\"AIPTU DEDI SUHENDI\",\"type\":\"SUMBER SURAT DUMAS\",\"method\":null,\"polda\":null,\"polres\":null,\"polsek\":null,\"polda_code\":null,\"polres_code\":null,\"polsek_code\":null,\"disposisi_polda\":\"POLDA JAWA BARAT\",\"disposisi_polres\":\"POLRES BOGOR\",\"disposisi_polda_code\":6013,\"disposisi_polres_code\":60010205642960.0,\"disposisi_police_function\":\"PAMINAL\",\"disposisi_case_position\":\"KANIT PAMINAL POLRES BOGOR POLDA JAWA BARAT\",\"category\":\"PELAGGARAN ETIKA PUBLIK & RUANG DIGITAL\",\"total_report\":0,\"content\":\"DUGAAN KETIDAKPROFESIONALAN BERUPA PENCEMARAN NAMA BAIK YANG DILAKUKAN OLEH AIPTU DEDI SUHENDI ANGGOTA POLSEK BABAKAN MADANG POLRES KAB BOGOR\\n\",\"5w1h_when\":null,\"5w1h_where\":null,\"phone_no\":\"+6287773357669\",\"summary\":\"Terdakwa adalah AIPTU Dedi Suhendi, anggota Polsek Babakan Madang. Ia didakwa melakukan pelanggaran profesional dengan mencemarkan nama baik. Tidak disebutkan tanggal dan waktu kejadian. Pelaporan menunjukkan keluhan terhadap tindakan tidak profesional ini.\",\"pengirim\":\"JONATHAN. WS,S.H. DAN REKAN / HENDAR\",\"source\":null,\"source_alias\":\"SUMBER SURAT DUMAS\",\"reporter_nik\":null,\"email\":\"advokaj@gmail.com\",\"status_label\":\"Laporan Diterima\"}],\"additionalInfo\":{\"query\":\"SELECT *\\nFROM gold.report\\nWHERE (gold.report.status_label NOT IN %(status_label_0)s\\n       AND gold.report.disposisi_polda_code = %(disposisi_polda_code_1)s)\\nORDER BY created_date DESC\\nLIMIT 10 OFFSET 0;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
