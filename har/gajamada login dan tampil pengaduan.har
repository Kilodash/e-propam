            "mimeType": "application/json",
            "compression": 105273,
            "text": "{\"metaData\":{\"pagination\":{\"size\":10000,\"totalElements\":4,\"totalPages\":1,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":20},\"data\":[{\"chartConfig\":{},\"createdAt\":\"2026-05-06 14:01:38.846000\",\"createdBy\":\"074fd5f6f6ad928bec90e9ce68f19073\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-02 16:55:54\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":5,\"id\":\"347d07e8805b048936705eb80b8bdc05\",\"menuId\":\"ce64015a07578d9195a0e589de1108c8\",\"metaData\":{\"params\":{\"chart\":\"react-js\",\"connectionId\":\"\",\"queryId\":\"\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":7,\"y\":7,\"w\":5,\"h\":5}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"react-js\",\"updatedAt\":\"2026-07-13 10:48:10.740000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":5,\"widgetConfig\":{\"collectionGroup\":\"react-js\",\"styleType\":\"react-js\",\"visualizationType\":\"react-js\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useMemo } from 'react';\\nimport { useNotification } from 'notification.hooks';\\nimport BuatLaporan from 'widget:7764bcfb6e65ebdb9017627f98692265';\\nimport CetakLaporan from 'widget:71e7a40233654c5e9a3205c3bbb1359d';\\n\\nexport default function CetakBuatLaporan({ widget, data, G, user }) {\\n  // console.log(user, 'auth user');\\n  // const permissionParentName = user?.permissionDetail?.parentDetail?.name;\\n  const userGroupName = user?.groupDetail?.name;\\n\\n  const isTaudDivPropam = userGroupName === 'TAUD DIV PROPAM MABES POLRI';\\n  // const isAllowed =\\n  //   permissionParentName === 'Paminal' || permissionParentName === 'Polda';\\n\\n  // const isPaminal = permissionParentName === 'Paminal';\\n\\n  const { dispatchNotification } = useNotification();\\n  // const isAllowed = useMemo(() => {\\n  //   return (\\n  //     userGroupName === 'Paminal' ||\\n  //     userGroupName === 'Polda' ||\\n  //     allowedGroupNames.includes(userGroupName)\\n  //   );\\n  // }, [userGroupName]);\\n\\n  const isPaminal = useMemo(() => {\\n    return allowedGroupNames.includes(userGroupName);\\n  }, [userGroupName]);\\n\\n  const isYanduan = useMemo(() => {\\n    return suratDumasGroups.includes(userGroupName);\\n  }, [userGroupName]);\\n\\n  // const isAllowed = useMemo(() => {\\n  //   return (\\n  //     allowedGroupNames.includes(userGroupName) ||\\n  //     suratDumasGroups.includes(userGroupName)\\n  //   );\\n  // }, [userGroupName]);\\n\\n  // const canAccessSuratDumas = useMemo(() => {\\n  //   return suratDumasGroups.includes(userGroupName);\\n  // }, [userGroupName]);\\n\\n  const canAccessBuatLaporan = isPaminal || isYanduan || isTaudDivPropam;\\n\\n  if (!canAccessBuatLaporan) {\\n    return (\\n      <div className=\\\"d-flex justify-content-end\\\">\\n        <CetakLaporan className=\\\"w-100\\\" />\\n      </div>\\n    );\\n  }\\n\\n  return (\\n    <>\\n      <div className=\\\"d-flex align-items-center justify-content-end gap-5\\\">\\n        <CetakLaporan />\\n        <BuatLaporan\\n          user={user}\\n          dispatchNotification={dispatchNotification}\\n          showLaporanInformasi={isPaminal}\\n          showInfosus={isPaminal}\\n          showSuratDumas={isYanduan}\\n          showSuratKadiv={isTaudDivPropam}\\n        />\\n        {/* <div>\\n          <h3>Data Grup:</h3>\\n           <pre>{JSON.stringify(grupData, null, 2)}</pre> \\n        </div> */}\\n      </div>\\n    </>\\n  );\\n}\\n\\nconst allowedGroupNames = [\\n  'KANIT PAMINAL POLRES ACEH BARAT DAYA POLDA ACEH',\\n  'KANIT PAMINAL POLRES ACEH BARAT POLDA ACEH',\\n  'KANIT PAMINAL POLRES ACE