          "content": {
            "size": 19223,
            "mimeType": "application/json",
            "compression": 14144,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":4},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-06-18 15:33:44.772000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-20 14:17:51\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":66,\"id\":\"f7d4cbeb1d9335c070016daacb8b9c30\",\"menuId\":\"2734f2a65be5c978f8555bf1658b587f\",\"metaData\":{\"params\":{\"connectionId\":\"\",\"queryId\":\"\",\"chart\":\"devtools\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":1,\"y\":0,\"w\":7,\"h\":66}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"devtools\",\"updatedAt\":\"2026-07-13 10:48:10.740000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":7,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useMemo } from 'react';\\nimport { Form, Row, Col, Button, InputGroup } from 'react-bootstrap';\\nimport styled from 'styled-components';\\nimport Select from 'react-select';\\nimport { Controller } from 'react-hook-form';\\nimport axios from 'axios';\\n\\nexport default function LaporanDumas({\\n  registerEdit = () => {},\\n  watchEdit = () => {},\\n  setValueEdit = () => {},\\n  controlEdit = null,\\n  errorsEdit = {},\\n  triggerEdit = () => {},\\n  getValuesEdit = () => {},\\n}) {\\n  const [allKategoriData, setAllKategoriData] = useState([]);\\n  const [loadingKategori, setLoadingKategori] = useState(false);\\n  const [phoneInput, setPhoneInput] = useState('');\\n\\n  const fetchAllKategori = async () => {\\n    setLoadingKategori(true);\\n    try {\\n      const response = await axios.post(\\n        '/api/v1/apps/data/management/get-all',\\n        {\\n          orderBy: 'kategori',\\n          order: 'asc',\\n          page: 1,\\n          size: 1000,\\n          connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n          table: 'dimension.catalog_kategori_perbuatan',\\n          database: 'divpropam',\\n          filters: [],\\n        },\\n        {\\n          headers: {\\n            'Content-Type': 'application/json',\\n            Authorization: `Bearer ${localStorage.getItem('token') || ''}`,\\n          },\\n        },\\n      );\\n\\n      setAllKategoriData(response.data?.data || []);\\n    } catch (error) {\\n      console.error('Error fetch kategori:', error);\\n    } finally {\\n      setLoadingKategori(false);\\n    }\\n  };\\n\\n  useEffect(() => {\\n    fetchAllKategori();\\n  }, []);\\n\\n  // Cek apakah watchEdit ada\\n  const kategoriValue = watchEdit('kategori');\\n  const subkategoriValue = watchEdit('subkategori');\\n\\n  // Options dari data kategori\\n  const kategoriOptions = useMemo(() => {\\n    const uniqueKategori = [\\n      ...new Set(allKategoriData.map((item) => item.kategori)),\\n    ];\\n    return uniqueKategori.map((kategori) => ({\\n      value: kategori,\\n      label: kategori,\\n    }));\\n  }, [allKategoriData]);\\n\\n  const subKategoriOptions = useMemo(() => {\\n    if (!kategoriValue) return [];\\n    if (!allKategoriData || allKategoriData.length === 0) return [];\\n\\n    const filteredData = allKategoriData.filter(\\n      (item) => item.kategori === kategoriValue,\\n    );\\n\\n    const uniqueSubKategori = [\\n      ...new Set(filteredData.map((item) => item.sub_kategori)),\\n    ];\\n    return uniqueSubKategori.map((subKategori) => ({\\n      value: subKategori,\\n      label: subKategori,\\n    }));\\n  }, [allKategoriData, kategoriValue]);\\n\\n  const wujudPerbuatanOptions = useMemo(() => {\\n    if (!kategoriValue || !subkategoriValue) return [];\\n\\n    const filteredData = allKategoriData.filter(\\n      (item) =>\\n        item.kategori === kategoriValue &&\\n        item.sub_kategori === subkategoriValue,\\n    );\\n\\n    return filteredData.map((item) => ({\\n      value: item.wujud_perbuatan,\\n      label: item.wujud_perbuatan,\\n    }));\\n  }, [allKategoriData, kategoriValue, subkategoriValue]);\\n  const handlePhoneChange = (e) => {\\n    let value = e.target.value;\\n\\n    // Hanya angka yang diizinkan\\n    value = value.replace(/\\\\D/g, '');\\n\\n    // Jika dimulai dengan 0, hapus 0 di depan\\n    if (value.startsWith('0')) {\\n      value = value.substring(1);\\n    }\\n\\n    // Set state\\n    setPhoneInput(value);\\n\\n    // Set value ke form dengan format +62 + nomor\\n    const fullNumber = value ? `+62${value}` : '';\\n    setValueEdit('prepetrator_phone', fullNumber);\\n  };\\n\\n  const PROVOS_OPTIONS = [\\n    { value: 'opsi1', label: 'Opsi 1' },\\n    { value: 'opsi2', label: 'Opsi 2' },\\n    { value: 'opsi3', label: 'Opsi 3' },\\n  ];\\n\\n  if (!controlEdit) {\\n    return (\\n      <div className=\\\"text-center py-4\\\">\\n        <p>Loading form...</p>\\n      </div>\\n    );\\n  }\\n\\n  return (\\n    <>\\n      <Row>\\n        <TitleInput className=\\\"mb-3\\\">Data Laporan</TitleInput>\\n        {/* Kronologi */}\\n\\n        <Col md={12}>\\n          <Form.Group className=\\\"w-100\\\">\\n            <LabelInput className=\\\"mb-3\\\">Kronologi</LabelInput>\\n            <StyledTextarea\\n              as=\\\"textarea\\\"\\n              rows={3}\\n              placeholder=\\\"Kronologi\\\"\\n              {...registerEdit('kronologi')}\\n            />\\n          </Form.Group>\\n        </Col>\\n\\n        {/* Kategori - Dropdown */}\\n        <Col md={12}>\\n          <Form.Group>\\n            <LabelInput className=\\\"mb-3\\\">Kategori</LabelInput>\\n            <Controller\\n              name=\\\"kategori\\\"\\n              control={controlEdit}\\n              rules={{ required: 'Kategori wajib dipilih' }}\\n              render={({ field }) => (\\n                <Select\\n                  {...field}\\n                  options={kategoriOptions}\\n                  styles={ReactSelectStyle}\\n                  isClearable={true}\\n                  placeholder=\\\"Pilih Kategori\\\"\\n                  isLoading={loadingKategori}\\n                  value={\\n                    kategoriOptions.find((o) => o.value === field.value) || null\\n                  }\\n                  onChange={(val) => {\\n                    field.onChange(val ? val.value : null);\\n                    setValueEdit('subkategori', null);\\n                    setValueEdit('form_of_action', null);\\n                  }}\\n                />\\n              )}\\n            />\\n            {errorsEdit?.kategori && (\\n              <div className=\\\"text-danger\\\">{errorsEdit.kategori.message}</div>\\n            )}\\n          </Form.Group>\\n        </Col>\\n\\n        {/* Sub Kategori - Dropdown */}\\n        <Col md={12}>\\n          <Form.Group className=\\\"mt-3\\\">\\n            <LabelInput className=\\\"mb-3\\\">Sub Kategori</LabelInput>\\n            <Controller\\n              name=\\\"subkategori\\\"\\n              control={controlEdit}\\n              rules={{ required: 'Subkategori wajib dipilih' }}\\n              render={({ field }) => (\\n                <Select\\n                  {...field}\\n                  options={subKategoriOptions}\\n                  styles={ReactSelectStyle}\\n                  isClearable={true}\\n                  placeholder={\\n                    kategoriValue\\n                      ? 'Pilih Sub Kategori'\\n                      : 'Pilih kategori dahulu...'\\n                  }\\n                  isLoading={loadingKategori}\\n                  isDisabled={!kategoriValue}\\n                  value={\\n                    subKategoriOptions.find((o) => o.value === field.value) ||\\n                    null\\n                  }\\n                  onChange={(val) => {\\n                    field.onChange(val ? val.value : null);\\n                    setValueEdit('form_of_action', null);\\n                  }}\\n                />\\n              )}\\n            />\\n            {errorsEdit?.subkategori && (\\n              <div className=\\\"text-danger\\\">\\n                {errorsEdit.subkategori.message}\\n              </div>\\n            )}\\n          </Form.Group>\\n        </Col>\\n\\n        {/* Wujud Perbuatan - Dropdown */}\\n        <Col md={12}>\\n          <Form.Group className=\\\"mt-3\\\">\\n            <LabelInput>Wujud Perbuatan</LabelInput>\\n            <Controller\\n              name=\\\"form_of_action\\\"\\n              control={controlEdit}\\n              render={({ field }) => (\\n                <Select\\n                  {...field}\\n                  options={wujudPerbuatanOptions}\\n                  styles={ReactSelectStyle}\\n                  isClearable={true}\\n                  placeholder={\\n                    !kategoriValue\\n                      ? 'Pilih kategori dahulu...'\\n                      : !subkategoriValue\\n                        ? 'Pilih sub kategori dahulu...'\\n                        : 'Pilih wujud perbuatan'\\n                  }\\n                  isLoading={loadingKategori}\\n                  isDisabled={!kategoriValue || !subkategoriValue}\\n                  value={wujudPerbuatanOptions.find(\\n                    (o) => o.value === field.value,\\n                  )}\\n                  onChange={(val) => field.onChange(val?.value)}\\n                />\\n              )}\\n            />\\n          </Form.Group>\\n        </Col>\\n\\n        {/* Catatan */}\\n        <Col md={12}>\\n          <Divinder />\\n        </Col>\\n\\n        <TitleInput className=\\\"mb-3\\\">Data Pelapor</TitleInput>\\n\\n        <Col md={12}>\\n          <Form.Group className=\\\"mt-3\\\">\\n            <LabelInput>Nama</LabelInput>\\n            <StyledInput\\n              rows={4}\\n              placeholder=\\\"Nama\\\"\\n              {...registerEdit('nama', {\\n                required: 'Nama wajib diisi',\\n              })}\\n            />\\n            {errorsEdit?.nama && (\\n              <div className=\\\"text-danger\\\">{errorsEdit.nama.message}</div>\\n            )}\\n          </Form.Group>\\n        </Col>\\n\\n        <Col md={6}>\\n          <Form.Group className=\\\"mt-3\\\">\\n            <LabelInput className=\\\"mb-3\\\">Nomor Telepon</LabelInput>\\n            <StyledInputGroup>\\n              <InputGroupTextCustom>+62</InputGroupTextCustom>\\n              <FormControlCustom\\n                type=\\\"text\\\"\\n                placeholder=\\\"81234567890\\\"\\n                value={phoneInput}\\n                onChange={handlePhoneChange}\\n                maxLength={15}\\n              />\\n            </StyledInputGroup>\\n\\n            <input\\n              type=\\\"hidden\\\"\\n              {...registerEdit('prepetrator_phone')}\\n              value={phoneInput ? `+62${phoneInput}` : ''}\\n            />\\n            <small\\n              className=\\\"text-muted\\\"\\n              style={{\\n                fontSize: '0.75rem',\\n                marginTop: '0.25rem',\\n                display: 'block',\\n              }}\\n            >\\n              Masukkan nomor tanpa 0 di depan (contoh: 81234567890)\\n            </small>\\n          </Form.Group>\\n        </Col>\\n        <Col md={6}>\\n          {' '}\\n          <Form.Group className=\\\"mt-3\\\">\\n            <LabelInput className=\\\"mb-3\\\">Email</LabelInput>\\n\\n            <StyledInput\\n              rows={4}\\n              placeholder=\\\"Email\\\"\\n              {...registerEdit('email')}\\n            />\\n          </Form.Group>\\n        </Col>\\n\\n        <Col md={12}>\\n          <Form.Group className=\\\"mt-3\\\">\\n            <LabelInput className=\\\"mb-3\\\">Alamat</LabelInput>\\n            <StyledTextarea\\n              as=\\\"textarea\\\"\\n              rows={3}\\n              placeholder=\\\"Alamat\\\"\\n              {...registerEdit('alamat')}\\n            />\\n          </Form.Group>\\n        </Col>\\n      </Row>\\n    </>\\n  );\\n}\\n\\n// Styled Components (sama kaya sebelumnya)\\nconst Divinder = styled.div`\\n  width: 100%;\\n  border-top: 1px solid var(--black-100);\\n  margin-top: 1.42857rem;\\n  margin-bottom: 1.42857rem;\\n`;\\n\\nconst TitleInput = styled.div`\\n  color: var(--black);\\n  font-size: 1rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n`;\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;\\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  background: var(--white);\\n  border: 1px solid var(--black-100);\\n  font-family: Inter;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst FormStyle = styled(Form.Group)`\\n  margin-bottom: 1.14rem;\\n`;\\nconst StyledInputGroup = styled.div`\\n  display: flex;\\n  align-items: stretch; /* Memaksa +62 dan input memiliki tinggi yang sama */\\n  width: 100%;\\n  height:40px;\\n  border: 1px solid var(--black-100);\\n  border-radius: 0.5rem; /* Menyamakan kelengkungan sudut dengan StyledInput */\\n  overflow: hidden;\\n  background-color: var(--white);\\n\\n  &:focus-within {\\n    border-color: var(--primary-500);\\n    box-shadow: 0 0 0 1px var(--primary-500); /* Efek focus ring yang tipis & rapi */\\n  }\\n`;\\n\\nconst InputGroupTextCustom = styled.div`\\n  background-color: var(--black-50, #f8f9fa);\\n  border-right: 1px solid var(--black-100);\\n  color: #6c757d;\\n  font-size: 1rem; /* Ukuran teks disamakan dengan input lain */\\n  font-weight: 500;\\n  padding: 0 1rem; /* Padding horizontal agar text +62 tidak mepet */\\n  display: flex;\\n  align-items: center;\\n  justify-content: center;\\n  user-select: none;\\n`;\\n\\nconst FormControlCustom = styled(Form.Control)`\\n  border: none !important;\\n  font-size: 1rem !important;\\n  padding: 0.75rem 1rem !important; /* PADDING UTAMA: Disamakan persis dengan StyledInput */\\n  border-radius: 0 !important;\\n  box-shadow: none !important;\\n\\n  &:focus {\\n    background-color: var(--white) !important;\\n    box-shadow: none !important;\\n  }\\n\\n  &::placeholder {\\n    color: #adb5bd;\\n  }\\n\\n  /* Menghilangkan spinner up/down bawaan type=\\\"number\\\" */\\n  &::-webkit-outer-spin-button,\\n  &::-webkit-inner-spin-button {\\n    -webkit-appearance: none;\\n    margin: 0;\\n  }\\n  &[type=number] {\\n    -moz-appearance: textfield;\\n  }\\n`;\\nconst ReactSelectStyle = {\\n  control: (styles, { isDisabled }) => ({\\n    ...styles,\\n    backgroundColor: isDisabled ? 'var(--black-25)' : 'var(--white)',\\n    borderColor: 'var(--black-150)',\\n    padding: '0rem 0.8rem',\\n    borderRadius: '0.5rem',\\n    borderWidth: '1px',\\n    transition: 'none',\\n    ':hover': {\\n      borderColor: 'var(--primary-400)',\\n    },\\n    minHeight: '1.85rem',\\n    width: '100%',\\n  }),\\n  input: (styles) => ({\\n    ...styles,\\n    color: 'var(--black-800)',\\n    margin: '0',\\n  }),\\n  placeholder: (styles) => ({\\n    ...styles,\\n    color: 'var(--black-300)',\\n    fontSize: '0.875rem',\\n    fontStyle: 'normal',\\n    fontWeight: '400',\\n    lineHeight: '1.4rem',\\n  }),\\n  valueContainer: (styles) => ({\\n    ...styles,\\n    padding: '0',\\n    textOverflow: 'ellipsis',\\n    textWrap: 'nowrap',\\n  }),\\n  indicatorSeparator: (styles) => ({\\n    ...styles,\\n    backgroundColor: 'transparent',\\n    marginTop: '6px',\\n    marginBottom: '6px',\\n    padding: 0,\\n  }),\\n  indicatorsContainer: (styles) => ({\\n    ...styles,\\n    color: 'var(--black)',\\n    padding: '0',\\n  }),\\n  singleValue: (styles) => ({\\n    ...styles,\\n    color: 'var(--black)',\\n    fontWeight: '500',\\n  }),\\n  menu: (styles) => ({\\n    ...styles,\\n    backgroundColor: 'var(--white)',\\n    zIndex: 9999,\\n  }),\\n  option: (styles) => ({\\n    ...styles,\\n    backgroundColor: 'var(--white)',\\n    color: 'var(--black)',\\n    ':hover': {\\n      backgroundColor: 'var(--primary-50)',\\n    },\\n  }),\\n};\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"f7d4cbeb1d9335c070016daacb8b9c30\":false},\"customColors\":false,\"limitData\":0,\"backgroundColor\":\"\",\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigFields\":{\"tableCategoryCustom\":[]},\"container\":{\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"containLabel\":false},\"title\":{\"show\":false,\"text\":\"\",\"fontSize\":\"\",\"width\":\"\",\"fontFamily\":\"\",\"fontColor\":\"\"},\"dataLabel\":{\"fontWeight\":\"\",\"fontCase\":\"\",\"show\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"numberOnly\":false,\"percentOnly\":false,\"isDate\":false,\"labelWidth\":\"\",\"fontSize\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"color\":\"\",\"position\":\"\",\"dateFormatter\":\"\"},\"legend\":{\"show\":false,\"showValue\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"i