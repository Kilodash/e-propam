            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":3},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-05-05 17:54:56.882000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-20 14:17:51\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":46,\"id\":\"f67152af1fa3b83640a16d2f3ffe18de\",\"menuId\":\"4d86341cee2d5560a2bc61b25f43eb9f\",\"metaData\":{\"params\":{\"connectionId\":\"\",\"queryId\":\"\",\"chart\":\"devtools\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":1,\"y\":17,\"w\":6,\"h\":46}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"devtools\",\"updatedAt\":\"2026-07-13 10:48:10.740000\",\"updatedBy\":\"66deb222e28eff3895dc85ee17d1d2dd\",\"w\":6,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport { Form } from 'react-bootstrap';\\nimport styled from 'styled-components';\\n\\nexport default function LaporanInformasiStep1({\\n  registerEdit,\\n  watchEdit,\\n  setValueEdit,\\n}) {\\n  return (\\n    <>\\n      <div className=\\\"d-flex flex-column w-100\\\">\\n        <Form.Group className=\\\"w-100\\\">\\n          <TitleInput className=\\\"mb-3\\\">Tentang</TitleInput>\\n          <StyledTextarea\\n            type=\\\"text\\\"\\n            as={'textarea'}\\n            rows={3}\\n            placeholder=\\\"Tentang\\\"\\n            {...registerEdit?.('about')}\\n          />\\n        </Form.Group>\\n\\n        <Divinder />\\n        {/* <hr style={{ borderColor: 'var(--black-100)' }} /> */}\\n\\n        <TitleInput className=\\\"mb-3\\\">Pendahuluan</TitleInput>\\n\\n        {/* Nama */}\\n        <FormStyle className=\\\"w-100\\\" style={{ marginBottom: '1.14rem' }}>\\n          <TitleInput className=\\\"mb-3\\\">Nama</TitleInput>\\n          <StyledInput\\n            type=\\\"text\\\"\\n            placeholder=\\\"Nama\\\"\\n            {...registerEdit?.('name')}\\n          />\\n        </FormStyle>\\n\\n        {/* Pekerjaan */}\\n        <FormStyle className=\\\"w-100\\\">\\n          <TitleInput className=\\\"mb-3\\\">Pekerjaan</TitleInput>\\n          <StyledInput\\n            type=\\\"text\\\"\\n            placeholder=\\\"Pekerjaan\\\"\\n            {...registerEdit?.('occupation')}\\n          />\\n        </FormStyle>\\n\\n        {/* Hubungan dengan Sasaran */}\\n        <FormStyle className=\\\"w-100\\\">\\n          <TitleInput className=\\\"mb-3\\\">Hubungan Dengan Sasaran</TitleInput>\\n          <StyledInput\\n            type=\\\"text\\\"\\n            placeholder=\\\"Hubungan Dengan Sasaran\\\"\\n            {...registerEdit?.('relation_to_target')}\\n          />\\n        </FormStyle>\\n\\n        {/* Cara Mendapat Baket */}\\n        <FormStyle className=\\\"w-100\\\">\\n          <TitleInput className=\\\"mb-3\\\">Cara Mendapat Baket</TitleInput>\\n          <StyledInput\\n            type=\\\"text\\\"\\n            placeholder=\\\"Cara Mendapat Baket\\\"\\n            {...registerEdit?.('information_source')}\\n          />\\n        </FormStyle>\\n\\n        {/* Tempat & Waktu Mendapatkan Baket */}\\n        <FormStyle className=\\\"w-100\\\">\\n          <TitleInput className=\\\"mb-3\\\">\\n            Tempat & Waktu Mendapat Baket\\n          </TitleInput>\\n          <StyledInput\\n            type=\\\"text\\\"\\n            placeholder=\\\"Cara Mendapat Braket\\\"\\n            {...registerEdit?.('information_place_time')}\\n          />\\n        </FormStyle>\\n      </div>\\n    </>\\n  );\\n}\\n\\nconst StepIndicator = styled.span`\\n  margin-left: 1rem;\\n  font-size: 0.875rem;\\n  color: var(--black-400);\\n  font-weight: 500;\\n`;\\n\\nconst TitleHead = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-weight: 500;\\nline-height: 140%; \\n`;\\n\\nconst Divider = styled.div`\\n  width: 100%;\\n  height: 0;\\n  margin-top:1.25rem;\\n  margin-bottom:1.25rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst Divinder = styled.div`\\n  width: 100%;\\n  border-top: 1px solid var(--black-100);\\n  margin-top:1.42857rem;\\n  margin-bottom:1.42857rem;\\n\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\\nconst TitleInput = styled.div`\\ncolor: var(--black);\\nfont-size: 1rem;\\nfont-weight: 500;\\nline-height: 140%; \\n\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  background: var(--white);\\n  border: 1px solid var(--black-100);\\n  font-family:Inter;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\nconst CustomStyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  font-family: Inter;\\n\\n  border: none;\\n  outline: none;\\n  box-shadow: none;\\n  background: transparent;\\n\\n  resize: none;\\n\\n  &:focus {\\n    outline: none;\\n    box-shadow: none;\\n  }\\n`;\\n\\nconst FormStyle = styled(Form.Group)`\\n    margin-bottom: 1.14rem;\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"f67152af1fa3b83640a16d2f3ffe18de\":false},\"customColors\":false,\"limitData\":0,\"backgroundColor\":\"\",\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigFields\":{\"tableCategoryCustom\":[]},\"container\":{\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"containLabel\":false},\"title\":{\"show\":false,\"text\":\"\",\"fontSize\":\"\",\"width\":\"\",\"fontFamily\":\"\",\"fontColor\":\"\"},\"dataLabel\":{\"fontWeight\":\"\",\"fontCase\":\"\",\"show\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"numberOnly\":false,\"percentOnly\":false,\"isDate\":false,\"labelWidth\":\"\",\"fontSize\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"color\":\"\",\"position\":\"\",\"dateFormatter\":\"\"},\"legend\":{\"show\":false,\"showValue\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"isPercentage\":false,\"valuePrefix\":\"\",\"fontSize\":\"\",\"width\":\"\",\"customPosition\":{\"left\":\"\",\"right\":\"\",\"top\":\"\",\"bottom\":\"\"},\"icon\":\"\",\"type\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"fontColor\":\"\",\"fontCase\":\"\"},\"series\":{\"seriesName\":false,\"percentage\":false,\"inverse\":false,\"smooth\":false,\"labelLine\":false,\"borderWidth\":\"\",\"opacity\":1,\"suggestionColor\":false,\"caseSensitive\":false,\"customPosition\":{\"left\":\"\",\"right\":\"\",\"top\":\"\",\"bottom\":\"\"},\"startAngle\":\"\",\"endAngle\":\"\",\"symbol\":\"\"},\"xAxis\":{\"show\":false,\"inverse\":false,\"width\":\"\"