          "content": {
            "size": 11996,
            "mimeType": "application/json",
            "compression": 8556,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":3},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-05-05 18:12:47.475000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-20 14:17:51\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":25,\"id\":\"796110bfed729feda4fdad6e649a8a86\",\"menuId\":\"4d86341cee2d5560a2bc61b25f43eb9f\",\"metaData\":{\"params\":{\"connectionId\":\"\",\"queryId\":\"\",\"chart\":\"devtools\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":7,\"y\":17,\"w\":4,\"h\":25}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"devtools\",\"updatedAt\":\"2026-07-13 10:48:10.740000\",\"updatedBy\":\"b5e923912240161c067592321042f60a\",\"w\":4,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React from 'react';\\nimport { Form, Row } from 'react-bootstrap';\\n\\nimport styled from 'styled-components';\\n\\nexport default function LaporanInformasiStep3({\\n  registerEdit,\\n  watchEdit,\\n  setValueEdit,\\n}) {\\n  return (\\n    <>\\n      <Form.Group className=\\\"w-100\\\">\\n        <div\\n          className=\\\"d-flex justify-content-between align-items-center\\\"\\n          style={{ marginBottom: '1.43rem' }}\\n        >\\n          {/* <LabelInput>Pendapat Pelapor</LabelInput> */}\\n          <div\\n            style={{\\n              color: 'var(--black-400)',\\n              fontSize: '1.14286rem',\\n              fontWeight: '600',\\n              textAlign: 'center',\\n            }}\\n          >\\n            Pendapat Pelapor\\n          </div>\\n          <button\\n            type=\\\"button\\\"\\n            onClick={() => {\\n              const current = watchEdit?.('reporter_opinion') || [];\\n              setValueEdit?.('reporter_opinion', [\\n                ...current,\\n                { reporter_opinion: '' },\\n              ]);\\n            }}\\n            style={{\\n              background: 'none',\\n              border: 'none',\\n              color: 'var(--primary)',\\n              fontWeight: '600',\\n              cursor: 'pointer',\\n              padding: 0,\\n              fontSize: '0.875rem',\\n            }}\\n          >\\n            + Tambah Pendapat\\n          </button>\\n        </div>\\n        {(watchEdit?.('reporter_opinion') || []).length > 0 ? (\\n          <div\\n            style={{\\n              display: 'flex',\\n              flexDirection: 'column',\\n              gap: '0.75rem',\\n            }}\\n          >\\n            {(watchEdit?.('reporter_opinion') || []).map((item, index) => (\\n              <div\\n                key={index}\\n                style={{\\n                  width: '100%',\\n                  paddingLeft: 16,\\n                  paddingRight: 16,\\n                  paddingTop: 11,\\n                  paddingBottom: 11,\\n                  background: 'white',\\n                  overflow: 'hidden',\\n                  borderRadius: 10,\\n                  outline: '1px #E6E9F0 solid',\\n                  outlineOffset: '-1px',\\n                  justifyContent: 'space-between',\\n                  alignItems: 'center',\\n                  gap: 8,\\n                  display: 'flex',\\n                }}\\n              >\\n                <input\\n                  type=\\\"text\\\"\\n                  placeholder=\\\"Masukkan catatan\\\"\\n                  value={item.reporter_opinion || ''}\\n                  onChange={(e) => {\\n                    const currentFacts = watchEdit?.('reporter_opinion') || [];\\n\\n                    const updated = currentFacts.map((item, i) =>\\n                      i === index\\n                        ? { ...item, reporter_opinion: e.target.value }\\n                        : item,\\n                    );\\n\\n                    setValueEdit?.('reporter_opinion', updated, {\\n                      shouldValidate: true,\\n                      shouldDirty: true,\\n                    });\\n                  }}\\n                  style={{\\n                    flex: '1 1 0',\\n                    color: item.reporter_opinion ? '#050505' : '#A0A3AA',\\n                    fontSize: 14,\\n                    fontFamily: 'Inter',\\n                    fontWeight: '400',\\n                    lineHeight: '19.60px',\\n                    wordWrap: 'break-word',\\n                    border: 'none',\\n                    outline: 'none',\\n                    background: 'transparent',\\n                  }}\\n                />\\n                <button\\n                  type=\\\"button\\\"\\n                  onClick={() => {\\n                    const updated = (\\n                      watchEdit?.('reporter_opinion') || []\\n                    ).filter((_, i) => i !== index);\\n                    setValueEdit?.('reporter_opinion', updated);\\n                  }}\\n                  style={{\\n                    width: 16,\\n                    height: 16,\\n                    position: 'relative',\\n                    background: 'none',\\n                    border: 'none',\\n                    cursor: 'pointer',\\n                    padding: 0,\\n                    display: 'flex',\\n                    alignItems: 'center',\\n                    justifyContent: 'center',\\n                  }}\\n                >\\n                  <i className=\\\"ph ph-x\\\" style={{ fontSize: 16 }} />\\n                </button>\\n              </div>\\n            ))}\\n          </div>\\n        ) : (\\n          <div\\n            style={{\\n              padding: '1rem',\\n              textAlign: 'center',\\n              color: 'var(--black-400)',\\n              backgroundColor: 'var(--black-25)',\\n              borderRadius: '0.5rem',\\n              border: '1px dashed var(--black-100)',\\n              fontSize: '0.875rem',\\n            }}\\n          >\\n            Belum ada Pendapat Pelapor. Klik \\\"Tambah Pendapat\\\" untuk\\n            menambahkan.\\n          </div>\\n        )}\\n      </Form.Group>\\n      {/* Pemeriksa */}\\n      <div className=\\\"d-flex flex-column gap-3 w-100\\\">\\n        <TitleInput className=\\\"mb-4\\\">Pelapor</TitleInput>\\n        {/* Nama dan Pangkat */}\\n        <Row className=\\\"g-3 w-100\\\">\\n          <Form.Group>\\n            <TitleInput className=\\\"mb-3\\\">Sandi</TitleInput>\\n            <StyledInput\\n              type=\\\"text\\\"\\n              placeholder=\\\"Sandi\\\"\\n              {...registerEdit?.('reporter_code')}\\n            />\\n          </Form.Group>\\n        </Row>\\n      </div>\\n    </>\\n  );\\n}\\n\\nconst StepIndicator = styled.span`\\n  margin-left: 1rem;\\n  font-size: 0.875rem;\\n  color: var(--black-400);\\n  font-weight: 500;\\n`;\\n\\nconst TitleHead = styled.div`\\ncolor: var(--black);\\nfont-size: 0.875rem;\\nfont-weight: 500;\\nline-height: 140%; \\n`;\\n\\nconst Divider = styled.div`\\n  width: 100%;\\n  height: 0;\\n  margin-top:1.25rem;\\n  margin-bottom:1.25rem;\\n  border-top: 1px solid var(--black-100);\\n`;\\n\\nconst LabelInput = styled.label`\\n  color: var(--black);\\n  font-size: 0.875rem;\\n  font-weight: 500;\\n  line-height: 140%;\\n  margin-bottom: 0.25rem;\\n  display: block;\\n`;\\n\\nconst Divinder = styled.div`\\n  width: 100%;\\n  border-top: 1px solid var(--black-100);\\n  margin-top:1.42857rem;\\n  margin-bottom:1.42857rem;\\n\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\\nconst TitleInput = styled.div`\\ncolor: var(--black);\\nfont-size: 1rem;\\nfont-weight: 500;\\nline-height: 140%; \\n\\n`;\\n\\nconst StyledInput = styled(Form.Control)`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\n\\nconst StyledTextarea = styled.textarea`\\n  width: 100%;  \\n  font-size: 1rem;\\n  padding: 0.75rem 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  border: 1px solid var(--black-100);\\n  font-family:Inter;\\n  box-shadow: none;\\n\\n  &:focus {\\n    border-color: var(--primary-500);\\n  }\\n`;\\nconst CustomStyledTextarea = styled.textarea`\\n  width: 100%;\\n  font-size: 1rem;\\n  border-radius: 0.5rem;\\n  line-height: 1.5;\\n  font-family: Inter;\\n\\n  border: none;\\n  outline: none;\\n  box-shadow: none;\\n  background: transparent;\\n\\n  resize: none;\\n\\n  &:focus {\\n    outline: none;\\n    box-shadow: none;\\n  }\\n`;\\n\\nconst FormStyle = styled(Form.Group)`\\n    margin-bottom: 1.14rem;\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"796110bfed729feda4fdad6e649a8a86\":false},\"customColors\":false,\"limitData\":0,\"backgroundColor\":\"\",\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigFields\":{\"tableCategoryCustom\":[]},\"container\":{\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"containLabel\":false},\"title\":{\"show\":false,\"text\":\"\",\"fontSize\":\"\",\"width\":\"\",\"fontFamily\":\"\",\"fontColor\":\"\"},\"dataLabel\":{\