          "content": {
            "size": 40459,
            "mimeType": "application/json",
            "compression": 32179,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":4},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-05-06 13:32:18.003000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-20 14:17:51\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":11,\"id\":\"7764bcfb6e65ebdb9017627f98692265\",\"menuId\":\"4d86341cee2d5560a2bc61b25f43eb9f\",\"metaData\":{\"params\":{\"connectionId\":\"\",\"queryId\":\"\",\"chart\":\"devtools\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":1,\"y\":6,\"w\":11,\"h\":11}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"devtools\",\"updatedAt\":\"2026-07-13 10:48:10.740000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":11,\"widgetConfig\":{\"collectionGroup\":\"devtools\",\"styleType\":\"devtools\",\"visualizationType\":\"devtools\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState, useEffect, useMemo } from 'react';\\nimport { useForm, Controller } from 'react-hook-form';\\nimport { dashboard } from '@store/app';\\nimport { useNotification } from 'notification.hooks';\\nimport axios from 'axios';\\nimport {\\n  Dropdown,\\n  Button,\\n  Modal,\\n  Form,\\n  Row,\\n  ButtonGroup,\\n} from 'react-bootstrap';\\n\\nimport styled from 'styled-components';\\n\\nimport LaporanInformasiStep1 from 'widget:f67152af1fa3b83640a16d2f3ffe18de';\\nimport LaporanInformasiStep2 from 'widget:9c99b0b8207cc17ecab462d05b9de9ea';\\nimport LaporanInformasiStep3 from 'widget:796110bfed729feda4fdad6e649a8a86';\\n\\nimport InfosusStep1 from 'widget:d39f16930e8e41a55ce773b46d282eae';\\nimport InfosusStep2 from 'widget:3f93186554258072b16998b52191ce6b';\\nimport InfosusStep3 from 'widget:57aa9b76c958acd3817c669a52c57e3a';\\n\\nimport LaporanDumas from 'widget:f7d4cbeb1d9335c070016daacb8b9c30';\\nimport LaporanUpload from 'widget:07031b282ea9e361c12a75c1790ae60f';\\n\\nexport default function BuatLaporan({\\n  widget,\\n  data,\\n  G,\\n  user,\\n  dispatchNotification,\\n  showLaporanInformasi,\\n  showInfosus,\\n  showSuratDumas,\\n  showSuratKadiv,\\n  // uploadedFiles,\\n  // setUploadedFiles,\\n}) {\\n  const [uploadedFiles, setUploadedFiles] = useState([]);\\n  const [items, setItems] = useState(data || []);\\n  const [showModal, setShowModal] = useState(false);\\n  const [loading, setLoading] = useState(false);\\n  const [unit, setUnit] = useState([]);\\n  const [loadingKategori, setLoadingKategori] = useState(false);\\n  const [casePositionAfter, setCasePositionAfter] = useState('');\\n\\n  // STATE UNTUK SURAT DUMAS\\n  const [dumasUnit, setDumasUnit] = useState([]);\\n  const [dumasCasePosition, setDumasCasePosition] = useState('');\\n\\n  const [kadivUnit, setKadivUnit] = useState([]);\\n  const [kadivCasePosition, setKadivCasePosition] = useState('');\\n\\n  const permissionParentName = user?.permissionDetail?.parentDetail?.name;\\n  const isGroupName = user?.groupDetail?.name;\\n\\n  // const isTaudDivPropam = isGroupName === 'TAUD DIV PROPAM MABES POLRI';\\n\\n  const report = items?.[0];\\n  const [step, setStep] = useState(1);\\n\\n  const handleCloseEdit = () => {\\n    setShowModal(false);\\n    resetEdit();\\n    setStep(1);\\n  };\\n\\n  const handleCloseWithReset = () => {\\n    setStep(1);\\n    setSelectedTipeLaporan('Laporan Informasi');\\n    setUploadedFiles([]);\\n    handleCloseEdit();\\n  };\\n\\n  const getModalConfig = () => {\\n    const configs = {\\n      'Laporan Informasi': {\\n        title: 'Laporan Informasi',\\n        desc: 'Sesuaikan isi laporan',\\n        icon: 'ph-user',\\n        iconColor: 'var(--primary)',\\n      },\\n      Infosus: {\\n        title: 'Infosus',\\n        desc: 'Sesuaikan isi laporan',\\n        icon: 'ph-shield',\\n        iconColor: 'var(--primary)',\\n      },\\n      SuratDumas: {\\n        title: 'Input Surat Dumas',\\n        desc: 'Sesuaikan isi laporan',\\n        icon: 'ph-file-text',\\n        iconColor: 'var(--primary)',\\n      },\\n      SuratKadiv: {\\n        title: 'Input Surat Kadiv',\\n        desc: 'Sesuaikan isi laporan',\\n        icon: 'ph-file-text',\\n        iconColor: 'var(--primary)',\\n      },\\n    };\\n\\n    return configs[selectedTipeLaporan] || configs['Laporan Informasi'];\\n  };\\n\\n  const {\\n    register,\\n    watch,\\n    control,\\n    formState: { errors },\\n  } = useForm();\\n\\n  const {\\n    register: registerEdit,\\n    handleSubmit: handleSubmitEdit,\\n    watch: watchEdit,\\n    setValue: setValueEdit,\\n    reset: resetEdit,\\n    trigger: triggerEdit,\\n    control: controlEdit,\\n    formState: { errors: errorsEdit },\\n    getValues: getValuesEdit,\\n  } = useForm({\\n    defaultValues: {\\n      prepetrator_name: report?.prepetrator_name || '',\\n      report_date: report?.report_date || '',\\n      rank: report?.rank || '',\\n      identity_number: report?.identity_number || '',\\n      position: report?.position || '',\\n      prepetrator_phone: report?.prepetrator_phone || '',\\n      report_time: report?.report_time || '',\\n      functional_assignment: report?.functional_assignment || '',\\n      description: report?.description || '',\\n      kategori: report?.kategori || '',\\n      sub_kategori: report?.sub_kategori || '',\\n      chronology: report?.chronology || [],\\n      sender_name: report?.sender_name || '',\\n      sender_rank: report?.sender_rank || '',\\n      sender_identity_number: report?.sender_identity_number || '',\\n      sender_unit: report?.sender_unit || '',\\n      auditor_name: report?.auditor_name || '',\\n      auditor_rank: report?.auditor_rank || '',\\n      auditor_identity_number: report?.auditor_identity_number || '',\\n      auditor_unit: report?.auditor_unit || '',\\n      know_name: report?.know_name || '',\\n      know_rank: report?.know_rank || '',\\n      know_identity_number: report?.know_identity_number || '',\\n      know_unit: report?.know_unit || '',\\n      creator_name: report?.creator_name || '',\\n      creator_rank: report?.creator_rank || '',\\n      creator_identity_number: report?.creator_identity_number || '',\\n      creator_unit: report?.creator_unit || '',\\n      reviewer_name: report?.reviewer_name || '',\\n      reviewer_rank: report?.reviewer_rank || '',\\n      reviewer_identity_number: report?.reviewer_identity_number || '',\\n      reviewer_unit: report?.reviewer_unit || '',\\n      witnesses: report?.witnesses || [],\\n      evidence: report?.evidence || [],\\n      id: report?.id || '',\\n    },\\n    mode: 'onChange',\\n  });\\n\\n  const [selectedTipeLaporan, setSelectedTipeLaporan] =\\n    useState('Laporan Informasi');\\n  // const maxStep = selectedTipeLaporan === 'SuratDumas' ? 2 : 3;\\n  const maxStep = ['SuratDumas', 'SuratKadiv'].includes(selectedTipeLaporan)\\n    ? 2\\n    : 3;\\n\\n  // FETCH UNIT UNTUK LAPORAN INFORMASI & INFOSUS\\n  const fetchUnit = async () => {\\n    setLoadingKategori(true);\\n    try {\\n      const response = await axios.post(\\n        '/api/v1/apps/data/management/get-all',\\n        {\\n          orderBy: '',\\n          order: 'asc',\\n          page: 1,\\n          size: 1000,\\n          connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n          table: 'dimension.catalog_unit_v2',\\n          database: 'divpropam',\\n          filters: [\\n            {\\n              field: 'case_position',\\n              operator: 'is',\\n              table: 'dimension.catalog_unit_v2',\\n              fieldType: 'text',\\n              value: {\\n                is: isGroupName || '',\\n              },\\n            },\\n          ],\\n        },\\n        {\\n          headers: {\\n            'Content-Type': 'application/json',\\n            Authorization: `Bearer ${localStorage.getItem('token') || ''}`,\\n          },\\n        },\\n      );\\n\\n      const result = response.data?.data || [];\\n      setUnit(result);\\n      const firstData = result?.[0];\\n      setCasePositionAfter(firstData?.case_position_after || '');\\n      console.log('case_position_after:', firstData?.case_position_after);\\n    } catch (error) {\\n      console.error('Error fetch unit:', error);\\n    } finally {\\n      setLoadingKategori(false);\\n    }\\n  };\\n\\n  const fetchDumasUnit = async () => {\\n    setLoadingKategori(true);\\n    try {\\n      const response = await axios.post(\\n        '/api/v1/apps/data/management/get-all',\\n        {\\n          orderBy: '',\\n          order: 'asc',\\n          page: 1,\\n          size: 1000,\\n          connectionId: '245b8fd7c4a763019d5172fad5ec0086',\\n          table: 'dimension.catalog_surat_dumas',\\n          database: 'divpropam',\\n          filters: [\\n            {\\n              field: 'group_name',\\n              operator: 'is',\\n              table: 'dimension.catalog_surat_dumas',\\n              fieldType: 'text',\\n              value: {\\n                is: isGroupName || '',\\n              },\\n            },\\n          ],\\n        },\\n        {\\n          headers: {\\n            'Content-Type': 'application/json',\\n            Authorization: `Bearer ${localStorage.getItem('token') || ''}`,\\n          },\\n        },\\n      );\\n\\n      const result = response.data?.data || [];\\n      setDumasUnit(result);\\n      const firstData = result?.[0];\\n      setDumasCasePosition(firstData?.next_case_position || '');\\n      console.log('dumas next_case_position:', firstData?.next_case_position);\\n    } catch (error) {\\n      console.error('Error fetch dumas unit:', error);\\n    } finally {\\n      setLoadingKategori(false);\\n    }\\n  };\\n\\n  useEffect(() => {\\n    if (!isGroupName) return;\\n    fetchUnit();\\n    fetchDumasUnit();\\n  }, [isGroupName]);\\n\\n  // FUNGSI UNTUK MENENTUKAN STATUS & CASE POSITION SURAT DUMAS\\n  const getDumasStatusAndPosition = () => {\\n    const isPolres = isGroupName?.toLowerCase().includes('polres');\\n    const isPolda = permissionParentName?.toLowerCase() === 'polda';\\n    const isBagyanduan = isGroupName?.toLowerCase().includes('bagyanduan');\\n    const isKorbrimob = isGroupName === 'OPERATOR YANDUAN KORBRIMOB POLRI';\\n\\n    let statusText = '';\\n    let casePositionValue = '';\\n\\n    if (isKorbrimob) {\\n      statusText = 'Laporan diterima & Di Review Kassubag';\\n      casePositionValue = 'KASUBBAG YANDUAN KORBRIMOB POLRI';\\n    } else if (isBagyanduan) {\\n      statusText = 'Laporan diterima Bagyanduan & Di Review Kasubag Trimlap';\\n      casePositionValue = 'KASUBAG TRIMLAP BAGYANDUAN';\\n    } else if (isPolres) {\\n      statusText = 'Laporan Diterima';\\n      casePositionValue = dumasCasePosition || '';\\n    } else if (isPolda) {\\n      statusText = 'Laporan Diterima Polda';\\n      casePositionValue = dumasCasePosition || '';\\n    } else {\\n      statusText = 'Laporan Diterima';\\n      casePositionValue = dumasCasePosition || '';\\n    }\\n\\n    // if (isBagyanduan) {\\n    //   // statusText = 'Laporan Diterima';\\n    //   // casePositionValue = dumasCasePosition || '';\\n    //   statusText = 'Laporan diterima Bagyanduan & Di Review Kasubag Trimlap';\\n    //   casePositionValue = 'KASUBAG TRIMLAP BAGYANDUAN' || '';\\n    // } else if (isPolres) {\\n    //   statusText = 'Laporan Diterima';\\n    //   casePositionValue = dumasCasePosition || '';\\n    // } else if (isKorbrimob) {\\n    //   statusText = 'Laporan diterima & Di Review Kassubag';\\n    //   casePositionValue = 'KASUBBAG YANDUAN KORBRIMOB POLRI';\\n    // } else if (isPolda) {\\n    //   statusText = 'Laporan Diterima Polda';\\n    //   casePositionValue = dumasCasePosition || '';\\n    // } else {\\n    //   statusText = 'Laporan Diterima';\\n    //   casePositionValue = dumasCasePosition || '';\\n    // }\\n\\n    return { statusText, casePositionValue };\\n  };\\n\\n  const getKadivStatusAndPosition = () => {\\n    // HARDCODE untuk TAUD DIV PROPAM MABES POLRI\\n    return {\\n      statusText: 'Laporan Masuk',\\n      casePositionValue: 'KADIV PROPAM MABES POLRI',\\n    };\\n  };\\n\\n  const getEndpointByType = (tipe) => {\\n    if (tipe === 'SuratDumas') {\\n      return '/api/v2/report/complaintLetter/create';\\n    }\\n    if (tipe === 'SuratKadiv') {\\n      return '/api/v2/report/complaintLetter/create';\\n    }\\n    return '/api/v2/report/intelligenceReport/create';\\n  };\\n\\n  const onSubmitEdit = async (formData) => {\\n    console.log('=== SUBMIT EDIT ===');\\n    console.log('Step saat ini:', step);\\n    console.log('Form data:', formData);\\n\\n    setLoading(true);\\n\\n    try {\\n      // VALIDASI - Laporan Informasi\\n      if (selectedTipeLaporan === 'Laporan Informasi') {\\n        if (!formData.about) {\\n          alert('Tentang wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.name) {\\n          alert('Nama wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.occupation) {\\n          alert('Pekerjaan wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.relation_to_target) {\\n          alert('Hubungan Dengan Sasaran wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.information_source) {\\n          alert('Cara Mendapat Baket wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.information_place_time) {\\n          alert('Tempat & Waktu Mendapat Baket wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.facts) {\\n          alert('Minimal 1 Fakta wajib ditambahkan');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.reporter_opinion) {\\n          alert('Minimal 1 Pendapat wajib ditambahkan');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.reporter_code) {\\n          alert('Sandi wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n      }\\n\\n      // VALIDASI - Infosus\\n      if (selectedTipeLaporan === 'Infosus') {\\n        if (!formData.about) {\\n          alert('Perihal wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.facts) {\\n          alert('Minimal 1 Fakta wajib ditambahkan');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.notes) {\\n          alert('Minimal 1 Catatan wajib ditambahkan');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.signature) {\\n          alert('Minimal 1 Paraf wajib ditambahkan');\\n          setLoading(false);\\n          return;\\n        }\\n      }\\n\\n      // VALIDASI - SuratDumas\\n      if (\\n        selectedTipeLaporan === 'SuratDumas' ||\\n        selectedTipeLaporan === 'SuratKadiv'\\n      ) {\\n        if (!formData.kronologi) {\\n          alert('Kronologi wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.kategori) {\\n          alert('Kategori wajib dipilih');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.subkategori) {\\n          alert('Subkategori wajib dipilih');\\n          setLoading(false);\\n          return;\\n        }\\n        if (!formData.nama) {\\n          alert('Nama pelapor wajib diisi');\\n          setLoading(false);\\n          return;\\n        }\\n        // if (!formData.email) {\\n        //   alert('Email wajib diisi');\\n        //   setLoading(false);\\n        //   return;\\n        // }\\n      }\\n\\n      const isPolres = isGroupName?.toLowerCase().includes('polres');\\n\\n      // === BUILD DATA ===\\n      const buildEditData = () => {\\n        const baseData = {\\n          group_name: isGroupName,\\n        };\\n\\n        if (selectedTipeLaporan === 'Laporan Informasi') {\\n          baseData.report_type = 'Laporan Informasi';\\n\\n          // Status & Case Position untuk Laporan Informasi\\n          let statusText = 'Laporan Diterima PAMINAL';\\n          let casePositionValue = casePositionAfter;\\n\\n          if (permissionParentName?.toLowerCase() === 'polda') {\\n            statusText = 'Laporan Diterima SUBBID POLDA';\\n            casePositionValue = casePositionAfter;\\n          } else if (isPolres) {\\n            statusText = 'Laporan Diterima KASIPROPAM';\\n            casePositionValue = casePositionAfter;\\n          } else if (\\n            permissionParentName?.toLowerCase().includes('korbrimob')\\n          ) {\\n            statusText = 'Laporan Diterima';\\n            casePositionValue = casePositionAfter;\\n          }\\n\\n          baseData.status = statusText;\\n          baseData.case_position = casePositionValue;\\n\\n          // Step 1\\n          if (formData.about) baseData.about = formData.about;\\n          if (formData.name) baseData.name = formData.name;\\n          if (formData.occupation) baseData.occupation = formData.occupation;\\n          if (formData.relation_to_target)\\n            baseData.relation_to_target = formData.relation_to_target;\\n          if (formData.information_source)\\n            baseData.information_source = formData.information_source;\\n          if (formData.information_place_time)\\n            baseData.information_place_time = formData.information_place_time;\\n\\n          // Step 2\\n          if (formData.facts && formData.facts.length > 0) {\\n            baseData.facts = formData.facts.map((item) => item.facts);\\n          }\\n          if (\\n            formData.reporter_opinion &&\\n            formData.reporter_opinion.length > 0\\n          ) {\\n            baseData.reporter_opinion = formData.reporter_opinion.map(\\n              (item) => item.reporter_opinion,\\n            );\\n          }\\n\\n          // Step 3\\n          if (formData.reporter_code)\\n            baseData.reporter_code = formData.reporter_code;\\n        } else if (selectedTipeLaporan === 'Infosus') {\\n          baseData.report_type = 'Infosus';\\n\\n          // Status & Case Position untuk Infosus (sama dengan Laporan Informasi)\\n          let statusText = 'Laporan Diterima PAMINAL';\\n          let casePositionValue = casePositionAfter;\\n\\n          if (permissionParentName?.toLowerCase() === 'polda') {\\n            statusText = 'Laporan Diterima SUBBID POLDA';\\n            casePositionValue = casePositionAfter;\\n          } else if (isPolres) {\\n            statusText = 'Laporan Diterima KASIPROPAM';\\n            casePositionValue = casePositionAfter;\\n          } else if (\\n            permissionParentName?.toLowerCase().includes('korbrimob')\\n          ) {\\n            statusText = 'Laporan Diterima';\\n            casePositionValue = casePositionAfter;\\n          }\\n\\n          baseData.status = statusText;\\n          baseData.case_position = casePositionValue;\\n\\n          if (formData.about) baseData.about = formData.about;\\n          if (formData.facts && formData.facts.length > 0) {\\n            baseData.facts = formData.facts.map((item) => item.facts);\\n          }\\n          if (formData.notes && formData.notes.length > 0) {\\n            baseData.notes = formData.notes.map((item) => item.notes);\\n          }\\n          if (formData.signature && formData.signature.length > 0) {\\n            baseData.signature = formData.signature.map(\\n              (item) => item.signature,\\n            );\\n          }\\n        } else if (selectedTipeLaporan === 'SuratDumas') {\\n          // ===== SURAT DUMAS - PAKAI STATUS & CASE POSITION KHUSUS =====\\n          const { statusText: dumasStatus, casePositionValue: dumasCasePos } =\\n            getDumasStatusAndPosition();\\n\\n          baseData.report_type = 'SUMBER SURAT DUMAS';\\n          baseData.status = dumasStatus;\\n          baseData.case_position = dumasCasePos;\\n\\n          // Data dari LaporanDumas\\n          baseData.report = formData.kronologi || '';\\n          baseData.category_name = formData.kategori || '';\\n          baseData.sub_category = formData.subkategori || '';\\n          baseData.misconduct_type = formData.form_of_action || '';\\n\\n          // Data Pelapor\\n          baseData.full_name = formData.nama || '';\\n          baseData.phone_number = formData.prepetrator_phone || null;\\n          baseData.email = formData.email || null;\\n          baseData.address = formData.alamat || '';\\n\\n          // File attachments (array of paths)\\n          baseData.attachments = uploadedFiles.map((file) => file.path);\\n        } else if (selectedTipeLaporan === 'SuratKadiv') {\\n          const { statusText: kadivStatus, casePositionValue: kadivCasePos } =\\n            getKadivStatusAndPosition();\\n\\n          baseData.report_type = 'SUMBER SATKER LAIN';\\n          baseData.status = kadivStatus; // \\\"Laporan Masuk\\\"\\n          baseData.case_position = kadivCasePos; // \\\"KADIV PROPAM MABES POLRI\\\"\\n\\n          // Data dari LaporanDumas (sama seperti SuratDumas)\\n          baseData.report = formData.kronologi || '';\\n          baseData.category_name = formData.kategori || '';\\n          baseData.sub_category = formData.subkategori || '';\\n          baseData.misconduct_type = formData.form_of_action || '';\\n\\n          // Data Pelapor\\n          baseData.full_name = formData.nama || '';\\n          baseData.phone_number = formData.prepetrator_phone || null;\\n          baseData.email = formData.email || null;\\n          baseData.address = formData.alamat || '';\\n\\n          // File attachments (array of paths)\\n          baseData.attachments = uploadedFiles.map((file) => file.path);\\n        }\\n\\n        return baseData;\\n      };\\n\\n      const editData = buildEditData();\\n\\n      const endpoint = getEndpointByType(selectedTipeLaporan);\\n      const requestPayload = {\\n        client: 'Propam Polri',\\n        gatewayId: '6dc296b5128cfa192c1e14d178b62e02',\\n        params: editData,\\n        body: {},\\n        headers: {},\\n        additionalPath: endpoint,\\n        additionalParams: {},\\n        additionalFileParams: {},\\n        tags: ['Propam Polri'],\\n        createdBy: user?.id || '',\\n        startDate: '',\\n        endDate: '',\\n        dashboardId: dashboard?.id || '',\\n        sessionId: '',\\n        logging: false,\\n        appendedLog: false,\\n      };\\n\\n      console.log('Sending to gateway:', requestPayload);\\n\\n      const gatewayResponse = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: {\\n          'Content-Type': 'application/json',\\n        },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      if (!gatewayResponse.ok) {\\n        const errorText = await gatewayResponse.text();\\n        throw new Error(\\n          `Gateway error: ${gatewayResponse.status} - ${errorText}`,\\n        );\\n      }\\n\\n      const gatewayResult = await gatewayResponse.json();\\n      console.log('Edit success:', gatewayResult);\\n\\n      if (typeof dispatchNotification === 'function') {\\n        dispatchNotification('Laporan Berhasil Dibuat!');\\n      } else {\\n        alert('Laporan Berhasil Dibuat!');\\n      }\\n\\n      setUploadedFiles([]);\\n      setShowModal(false);\\n      resetEdit();\\n      setStep(1);\\n    } catch (err) {\\n      console.error('Error editing laporan:', err);\\n\\n      if (typeof dispatchNotification === 'function') {\\n        dispatchNotification(`Error: ${err.message}`, 'danger');\\n      }\\n\\n      alert(`Gagal mengupdate data: ${err.message}`);\\n    } finally {\\n      setLoading(false);\\n    }\\n  };\\n\\n  const handleNext = async () => {\\n    let isValid = true;\\n\\n    if (selectedTipeLaporan === 'Laporan Informasi') {\\n      if (step === 1) {\\n        if (!watchEdit('about')) {\\n          alert('Tentang wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('name')) {\\n          alert('Nama wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('occupation')) {\\n          alert('Pekerjaan wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('relation_to_target')) {\\n          alert('Hubungan Dengan Sasaran wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('information_source')) {\\n          alert('Cara Mendapat Baket wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('information_place_time')) {\\n          alert('Tempat & Waktu Mendapat Baket wajib diisi');\\n          isValid = false;\\n        }\\n      } else if (step === 2) {\\n        if (!watchEdit('facts') || watchEdit('facts').length === 0) {\\n          alert('Minimal 1 Fakta wajib ditambahkan');\\n          isValid = false;\\n        }\\n      } else if (step === 3) {\\n        if (\\n          !watchEdit('reporter_opinion') ||\\n          watchEdit('reporter_opinion').length === 0\\n        ) {\\n          alert('Minimal 1 Pendapat wajib ditambahkan');\\n          isValid = false;\\n        } else if (!watchEdit('reporter_code')) {\\n          alert('Sandi wajib diisi');\\n          isValid = false;\\n        }\\n      }\\n    } else if (selectedTipeLaporan === 'Infosus') {\\n      if (step === 1) {\\n        if (!watchEdit('about')) {\\n          alert('Perihal wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('facts') || watchEdit('facts').length === 0) {\\n          alert('Minimal 1 Fakta wajib ditambahkan');\\n          isValid = false;\\n        }\\n      } else if (step === 2) {\\n        if (!watchEdit('notes') || watchEdit('notes').length === 0) {\\n          alert('Minimal 1 Catatan wajib ditambahkan');\\n          isValid = false;\\n        }\\n      } else if (step === 3) {\\n        if (!watchEdit('signature' || watchEdit('signature').length === 0)) {\\n          alert('Minimal 1 Paraf wajib ditambahkan');\\n          isValid = false;\\n        }\\n      }\\n    } else if (\\n      selectedTipeLaporan === 'SuratDumas' ||\\n      selectedTipeLaporan === 'SuratKadiv'\\n    ) {\\n      if (step === 1) {\\n        if (!watchEdit('kronologi')) {\\n          alert('Kronologi wajib diisi');\\n          isValid = false;\\n        } else if (!watchEdit('kategori')) {\\n          alert('Kategori wajib dipilih');\\n          isValid = false;\\n        } else if (!watchEdit('subkategori')) {\\n          alert('Subkategori wajib dipilih');\\n          isValid = false;\\n        } else if (!watchEdit('nama')) {\\n          alert('Nama pelapor wajib diisi');\\n          isValid = false;\\n        }\\n      }\\n    }\\n\\n    if (isValid && step < maxStep) {\\n      setStep(step + 1);\\n    }\\n  };\\n\\n  const handlePrevious = () => {\\n    if (step > 1) {\\n      setStep(step - 1);\\n    }\\n  };\\n\\n  return (\\n    <>\\n      <div className=\\\"flex justify-end \\\">\\n        <Dropdown as={ButtonGroup}>\\n          <Dropdown.Toggle\\n            className=\\\"flex items-center gap-2 w-100\\\"\\n            style={{\\n              backgroundColor: 'var(--primary-500)',\\n              border: '1px solid var(--black-100)',\\n              fontSize: '1rem',\\n              borderRadius: '0.5rem',\\n              color: 'var(--white)',\\n              padding: '0.57143rem 1rem',\\n            }}\\n          >\\n            <i\\n              className=\\\"fs-14 ph ph-plus\\\"\\n              style={{ color: 'var(--white)' }}\\n            ></i>\\n            Buat Laporan\\n            <i\\n              className=\\\"fs-14 ph ph-caret-down\\\"\\n              style={{ color: 'var(--white)' }}\\n            ></i>\\n          </Dropdown.Toggle>\\n          <StyledDropdownMenu>\\n            {/* Laporan Informasi - hanya muncul jika showLaporanInformasi true */}\\n            {showLaporanInformasi && (\\n              <Dropdown.Item\\n                className=\\\"flex items-center gap-2\\\"\\n                onClick={() => {\\n                  setSelectedTipeLaporan('Laporan Informasi');\\n                  resetEdit();\\n                  setShowModal(true);\\n                }}\\n              >\\n                Laporan Informasi\\n              </Dropdown.Item>\\n            )}\\n\\n            {/* Infosus - hanya muncul jika showInfosus true */}\\n            {showInfosus && (\\n              <Dropdown.Item\\n                className=\\\"flex items-center gap-2\\\"\\n                onClick={() => {\\n                  setSelectedTipeLaporan('Infosus');\\n                  resetEdit();\\n                  setShowModal(true);\\n                }}\\n              >\\n                Infosus\\n              </Dropdown.Item>\\n            )}\\n\\n            {/* Surat Dumas - hanya muncul jika showSuratDumas true */}\\n            {showSuratDumas && (\\n              <Dropdown.Item\\n                className=\\\"flex items-center gap-2\\\"\\n                onClick={() => {\\n                  setSelectedTipeLaporan('SuratDumas');\\n                  resetEdit();\\n                  setShowModal(true);\\n                }}\\n              >\\n                Surat Dumas\\n              </Dropdown.Item>\\n            )}\\n\\n            {/* Surat Kadiv - hanya muncul jika showSuratKadiv true */}\\n            {showSuratKadiv && (\\n              <Dropdown.Item\\n                className=\\\"flex items-center gap-2\\\"\\n                onClick={() => {\\n                  setSelectedTipeLaporan('SuratKadiv');\\n                  resetEdit();\\n                  setShowModal(true);\\n                }}\\n              >\\n                Surat Kadiv\\n              </Dropdown.Item>\\n            )}\\n          </StyledDropdownMenu>\\n        </Dropdown>\\n      </div>\\n\\n      <StyledModal centered size=\\\"lg\\\" show={showModal} onHide={handleCloseEdit}>\\n        <Form onSubmit={handleSubmitEdit(onSubmitEdit)}>\\n          <ModalHeader closeButton>\\n            <WrappIcon>\\n              <i\\n                className={`ph-duotone ${getModalConfig().icon}`}\\n                style={{\\n                  fontSize: '1.6rem',\\n                  color: getModalConfig().iconColor,\\n                }}\\n              ></i>\\n            </WrappIcon>\\n            <div className=\\\"d-flex flex-column gap-1\\\">\\n              <TitleHeader>{getModalConfig().title}</TitleHeader>\\n              <DescHeader>{getModalConfig().desc}</DescHeader>\\n            </div>\\n          </ModalHeader>\\n          <ModalBody>\\n            {step === 1 && selectedTipeLaporan === 'Laporan Informasi' && (\\n              <LaporanInformasiStep1\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n              />\\n            )}\\n\\n            {step === 1 && selectedTipeLaporan === 'Infosus' && (\\n              <InfosusStep1\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n              />\\n            )}\\n\\n            {step === 1 && selectedTipeLaporan === 'SuratDumas' && (\\n              <LaporanDumas\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n                controlEdit={controlEdit}\\n                errorsEdit={errorsEdit}\\n                triggerEdit={triggerEdit}\\n                getValuesEdit={getValuesEdit}\\n              />\\n            )}\\n\\n            {step === 1 && selectedTipeLaporan === 'SuratKadiv' && (\\n              <LaporanDumas\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n                controlEdit={controlEdit}\\n                errorsEdit={errorsEdit}\\n                triggerEdit={triggerEdit}\\n                getValuesEdit={getValuesEdit}\\n              />\\n            )}\\n\\n            {step === 2 && selectedTipeLaporan === 'Laporan Informasi' && (\\n              <LaporanInformasiStep2\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n              />\\n            )}\\n\\n            {step === 2 && selectedTipeLaporan === 'SuratDumas' && (\\n              <LaporanUpload\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n                uploadedFiles={uploadedFiles}\\n                setUploadedFiles={setUploadedFiles}\\n                dispatchNotification={dispatchNotification}\\n                user={user}\\n                dashboard={dashboard}\\n              />\\n            )}\\n\\n            {step === 2 && selectedTipeLaporan === 'SuratKadiv' && (\\n              <LaporanUpload\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n                uploadedFiles={uploadedFiles}\\n                setUploadedFiles={setUploadedFiles}\\n                dispatchNotification={dispatchNotification}\\n                user={user}\\n                dashboard={dashboard}\\n              />\\n            )}\\n\\n            {step === 2 && selectedTipeLaporan === 'Infosus' && (\\n              <InfosusStep2\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n              />\\n            )}\\n\\n            {step === 3 && selectedTipeLaporan === 'Laporan Informasi' && (\\n              <LaporanInformasiStep3\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n              />\\n            )}\\n\\n            {step === 3 && selectedTipeLaporan === 'Infosus' && (\\n              <InfosusStep3\\n                registerEdit={registerEdit}\\n                watchEdit={watchEdit}\\n                setValueEdit={setValueEdit}\\n              />\\n            )}\\n          </ModalBody>\\n          <ModalFooter>\\n            <ProgressWrapper>\\n              <ProgressBase>\\n                <ProgressFill step={step} maxStep={maxStep} />\\n              </ProgressBase>\\n            </ProgressWrapper>\\n            <div className=\\\"d-flex gap-3\\\">\\n              {step === 1 && (\\n                <Button\\n                  variant=\\\"outline-primary\\\"\\n                  onClick={handleCloseWithReset}\\n                >\\n                  Batal\\n                </Button>\\n              )}\\n              {step > 1 && (\\n                <Button variant=\\\"outline-secondary\\\" onClick={handlePrevious}>\\n                  Kembali\\n                </Button>\\n              )}\\n              {step < maxStep ? (\\n                <Button variant=\\\"primary\\\" onClick={handleNext}>\\n                  Selanjutnya\\n                </Button>\\n              ) : (\\n                <Button\\n                  variant=\\\"primary\\\"\\n                  onClick={handleSubmitEdit(onSubmitEdit)}\\n                  disabled={loading}\\n                >\\n                  {loading ? 'Menyimpan...' : 'Simpan'}\\n                </Button>\\n              )}\\n            </div>\\n          </ModalFooter>\\n        </Form>\\n      </StyledModal>\\n    </>\\n  );\\n}\\n\\n// ============================================\\n// STYLED COMPONENTS\\n// ============================================\\n\\nconst StyledDropdownMenu = styled(Dropdown.Menu)`\\n  border-radius: 0.5rem;\\n  border: 1px solid #e1e2e5;\\n  box-shadow: 0px 4px 12px rgba(0,0,0,0.15);\\n  padding: 0.5rem 0;\\n\\n  .dropdown-item {\\n    padding: 0.5rem 1rem;\\n    font-size: 0.875rem;\\n    color: var(--black);\\n\\n    &:hover {\\n      background-color: var(--black-50);\\n    }\\n  }\\n`;\\n\\nconst ProgressWrapper = styled.div`\\n  flex: 1;\\n  display: flex;\\n  align-items: center;\\n`;\\n\\nconst ProgressBase = styled.div`\\n  width: 5.71429rem;\\n  height: 0.57143rem;\\n  background-color: var(--primary-50);\\n  border-radius: 1.71429rem;\\n  position: relative;\\n  overflow: hidden;\\n`;\\n\\nconst ProgressFill = styled.div`\\n  position: absolute;\\n  top: 0;\\n  left: 0;\\n  height: 100%;\\n  width: ${(props) => {\\n    switch (props.step) {\\n      case 1:\\n        return '33%';\\n      case 2:\\n        return '66%';\\n      case 3:\\n        return '100%';\\n      default:\\n        return '0%';\\n    }\\n  }};\\n  background-color: var(--primary-500);\\n  transition: width 0.4s ease;\\n  border-radius: 1.71429rem;\\n`;\\n\\nconst StyledModal = styled(Modal)`\\n  .modal-dialog {\\n    max-width: 670px;\\n  }\\n\\n  .modal-content {\\n    display: flex;\\n    flex-direction: column;\\n  }\\n`;\\n\\nconst ModalHeader = styled(Modal.Header)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem;\\n  align-items: center;\\n  gap: 1.06667rem;\\n  border-bottom: 1px solid var(--black-100);\\n  flex-shrink: 0;\\n`;\\n\\nconst ModalBody = styled(Modal.Body)`\\n  display: flex;\\n  padding: 1.06667rem 1.33333rem;\\n  flex-direction: column;\\n  align-items: flex-start;\\n  gap: 1.33333rem;\\n  max-height: 45rem;\\n  overflow-y: auto;\\n  flex: 1;\\n  min-height: 0;\\n`;\\n\\nconst ModalFooter = styled(Modal.Footer)`\\n  display: flex;\\n  padding: 0.8rem 1.33333rem 1.06667rem 1.33333rem;\\n  justify-content: flex-end;\\n  align-items: center;\\n  gap: 0.53333rem;\\n  border-top: 1px solid var(--black-100);\\n  flex-shrink: 0;\\n`;\\n\\nconst TitleHeader = styled.p`\\n  color: var(--black);\\n  font-size: 1.14286rem;\\n  font-weight: 600;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst DescHeader = styled.p`\\n  color: var(--black-400);\\n  font-size: 1rem;\\n  font-weight: 400;\\n  line-height: 150%;\\n  margin: 0;\\n`;\\n\\nconst WrappIcon = styled.div`\\n  display: flex;\\n  padding: 0.53333rem;\\n  justify-content: center;\\n  align-items: center;\\n  gap: 0.66667rem;\\n  border-radius: 0.53333rem;\\n  border: 1px solid var(--black-100);\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"description\":\"\",\"styleConfig\":{\"relationsQueryParams\":{\"7764bcfb6e65ebdb9017627f98692265\":false},\"customColors\":false,\"limitData\":0,\"backgroundColor\":\"\",\"headerStyle\":{\"background\":false,\"disableBorder\":false,\"disableDescription\":false},\"customConfigFields\":{\"tableCategoryCustom\":[]},\"container\":{\"left\":\"\",\"top\":\"\",\"right\":\"\",\"bottom\":\"\",\"containLabel\":false},\"title\":{\"show\":false,\"text\":\"\",\"fontSize\":\"\",\"width\":\"\",\"fontFamily\":\"\",\"fontColor\":\"\"},\"dataLabel\":{\"fontWeight\":\"\",\"fontCase\":\"\",\"show\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"numberOnly\":false,\"percentOnly\":false,\"isDate\":false,\"labelWidth\":\"\",\"fontSize\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"color\":\"\",\"position\":\"\",\"dateFormatter\":\"\"},\"legend\":{\"show\":false,\"showValue\":false,\"roundingNumber\":false,\"roundDigitDecimal\":\"\",\"numberFormatter\":false,\"isPercentage\":false,\"valuePrefix\":\"\",\"fontSize\":\"\",\"width\":\"\",\"customPosition\":{\"left\":\"\",\"right\":\"\",\"top\":\"\",\"bottom\":\"\"},\"icon\":\"\",\"type\":\"\",\"fontFamily\":\"\",\"fontStyle\":\"\",\"fontColor\":