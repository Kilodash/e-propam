            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":3},\"data\":{\"chartConfig\":{},\"createdAt\":\"2026-05-06 13:31:10.303000\",\"createdBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"dashboardId\":\"1769155096865\",\"description\":\"Devtools - 2026-04-02 16:55:54\",\"fieldMapping\":null,\"filtersConfig\":null,\"group\":null,\"h\":6,\"id\":\"71e7a40233654c5e9a3205c3bbb1359d\",\"menuId\":\"4d86341cee2d5560a2bc61b25f43eb9f\",\"metaData\":{\"params\":{\"chart\":\"react-js\",\"connectionId\":\"\",\"queryId\":\"\"}},\"name\":\"Devtools\",\"parentId\":null,\"referenceId\":null,\"referenceType\":null,\"responsive\":{\"1024\":{\"x\":5,\"y\":0,\"w\":6,\"h\":6}},\"styleType\":null,\"tags\":null,\"thumbnail\":null,\"type\":\"react-js\",\"updatedAt\":\"2026-07-13 10:48:10.740000\",\"updatedBy\":\"3c04f304c5e949d5cc0d54bfb06a6f8d\",\"w\":6,\"widgetConfig\":{\"collectionGroup\":\"react-js\",\"styleType\":\"react-js\",\"visualizationType\":\"react-js\",\"showTitle\":false,\"handler\":false,\"hideMobile\":true,\"mapInsight\":false,\"cacheEnabled\":false,\"enableCache\":false,\"developer\":{\"enabledReact\":true,\"enabled\":false,\"css\":\"\",\"js\":\"\",\"react\":\"import React, { useState } from 'react';\\nimport { Button } from 'react-bootstrap';\\nimport styled from 'styled-components';\\n\\nexport default function CetakLaporan({ widget, data, G, user }) {\\n  const searchParams = new URLSearchParams(window.location.search);\\n\\n  const createdDate = decodeURIComponent(\\n    searchParams.get('created_date') || '',\\n  );\\n\\n  const [gte, lte] = createdDate.split(',').map((item) => item?.trim());\\n\\n  // console.log('createdDate:', createdDate);\\n  // console.log('gte:', gte);\\n  // console.log('lte:', lte);\\n\\n  const [loading, setLoading] = useState(false);\\n\\n  const onGenerateReport = async (type) => {\\n    if (!gte || !lte) {\\n      alert('Tanggal tidak ditemukan!');\\n      return;\\n    }\\n\\n    setLoading(true);\\n\\n    const formatDateTime = (ts) => {\\n      const d = new Date(Number(ts));\\n\\n      const yyyy = d.getFullYear();\\n      const mm = String(d.getMonth() + 1).padStart(2, '0');\\n      const dd = String(d.getDate()).padStart(2, '0');\\n\\n      const hh = String(d.getHours()).padStart(2, '0');\\n      const mi = String(d.getMinutes()).padStart(2, '0');\\n      const ss = String(d.getSeconds()).padStart(2, '0');\\n\\n      return `${yyyy}-${mm}-${dd} ${hh}:${mi}:${ss}`;\\n    };\\n\\n    const start_date = formatDateTime(gte);\\n    const end_date = formatDateTime(lte);\\n\\n    console.log('start_date:', start_date);\\n    console.log('end_date:', end_date);\\n\\n    const output_format = type;\\n    const filename = 'Laporan_Lengkap';\\n    const fileNameWithExt = `${filename}.${output_format}`;\\n\\n    const requestPayload = {\\n      client: 'Propam Polri',\\n      gatewayId: 'ca968792cd435d32f6dc0879c9378334',\\n      params: {\\n        start_date,\\n        end_date,\\n        filename,\\n        // output_format,\\n      },\\n\\n      body: {},\\n      headers: {},\\n      additionalPath: '',\\n      additionalParams: {},\\n      additionalFileParams: {},\\n      tags: ['Propam Polri'],\\n      createdBy: user?.fullname,\\n      logging: false,\\n    };\\n\\n    try {\\n      const res = await fetch('/api/v1/apps/api/gateway/execute', {\\n        method: 'POST',\\n        headers: { 'Content-Type': 'application/json' },\\n        body: JSON.stringify(requestPayload),\\n      });\\n\\n      const json = await res.json();\\n\\n      const s3Path = json?.data?.response?.s3_path;\\n      if (!s3Path) throw new Error('s3Path tidak ditemukan');\\n\\n      const downloadUrl = s3Path;\\n\\n      const link = document.createElement('a');\\n      link.href = downloadUrl;\\n      link.download = fileNameWithExt;\\n      link.target = '_blank';\\n      document.body.appendChild(link);\\n      link.click();\\n      document.body.removeChild(link);\\n    } catch (err) {\\n      console.error(err);\\n      alert(err.message);\\n    } finally {\\n      setLoading(false);\\n    }\\n  };\\n\\n  return (\\n    <div className=\\\"\\\">\\n      <ButtonStyle\\n        disabled={loading}\\n        className=\\\"flex items-center gap-2 \\\"\\n        onClick={() => onGenerateReport('xlsx')}\\n        style={{\\n          opacity: loading ? 0.6 : 1,\\n          cursor: loading ? 'not-allowed' : 'pointer',\\n        }}\\n      >\\n        {loading ? (\\n          <>\\n            <span className=\\\"spinner-border spinner-border-sm\\\" />\\n            Mencetak...\\n          </>\\n        ) : (\\n          <>\\n            <i className=\\\"fs-14 ph ph-printer\\\" />\\n            Cetak Laporan\\n          </>\\n        )}\\n      </ButtonStyle>\\n    </div>\\n  );\\n}\\n\\nconst ButtonStyle = styled.div`\\n  width: 9.5rem ;\\n  \\n  border-radius: 0.5rem;\\n  border: 1px solid var(--black-100);\\n  background: var(--white);\\n  padding: 0.57143rem 1rem;\\n  font-size: 0.85714rem;\\n  font-style: normal;\\n  font-weight: 600;\\n  line-height: 1.14286rem;\\n`;\\n\",\"html\":\"<h3>Please add content as needed.</h3>\"},\"cache\":{\"status\":false,\"duration\":0},\"styleConfig\":{\"relationsQueryParams\":{\"71e7a40233654c5e9a3205c3bbb1359d\":false},\"limitData\":0,\"axis\":{\"radius\":\"\",\"center\":[]},\"series\":{\"opacity\":0},\"xAxis\":{\"interval\":0},\"yAxis\":{\"interval\":0}},\"enableTimelapse\":false,\"enableLoadMore\":false,\"enableDrilldown\":false,\"minusStartDate\":{\"enable\":false},\"enableOverflow\":true,\"actionCopy\":false,\"pageState\":false,\"orderColumn\":false,\"filterdByWorkspace\":false,\"dontUseDefaultValue\":false,\"splitTime\":false,\"shareAPI\":\"\"},\"x\":5,\"y\":0},\"additionalInfo\":null,\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
          },
