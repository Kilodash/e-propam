          "content": {
            "size": 2374,
            "mimeType": "application/json",
            "compression": 1315,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":235,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"prepetrator_id\",\"id\",\"summary\",\"detail\",\"updated_at\",\"comment\",\"comment_date\"],[\"260226000003-00001\",\"260226000003\",null,\"Dugaan arogansi yang dilakukan oleh Iptu Deny selaku Kapolsek Ibun Polresta Bandung Polda Jawa Barat beserta Aiptu Dani Suandani selaku Kanit Reskrim dengan wujud menghentikan kendaraan R2 yang dikemudikan oleh pendumas bersama temannya dan langsung menarik baju pendumas, menyuruh mendorong motor, merangkul secara paksa, berteriak marah-marah tanpa penjelasan, menuduh motor pendumas hasil kejahatan, menuduh melakukan balap liar dan tidak memakai helm, serta menahan kendaraan dengan tuduhan yang tidak mendasar.\",1783553088178,null,\"2026-07-09 06:24:48\"]],\"additionalInfo\":{\"query\":\"WITH latest_report AS (\\n    SELECT DISTINCT ON (r.id) r.*\\n    FROM aduan_masyarakat_v3.report r\\n    WHERE COALESCE(lower(r.status), '') <> 'spam'\\n    ORDER BY r.id, r.updated_at DESC\\n),\\nlatest_report_info AS (\\n    SELECT DISTINCT ON (ri.id) ri.*\\n    FROM aduan_masyarakat_v3.report_info ri\\n    ORDER BY ri.id, ri.updated_at DESC\\n),\\nlatest_prepetrator AS (\\n    SELECT DISTINCT ON (p.id) p.*\\n    FROM aduan_masyarakat_v3.prepetrator p\\n    ORDER BY p.id, p.updated_at DESC\\n),\\nbase AS (\\n    SELECT DISTINCT ON (rp.prepetrator_id)\\n        rp.prepetrator_id,\\n        rp.report_id,\\n        r.updated_at\\n    FROM aduan_masyarakat_v3.report_prepetrators rp\\n    JOIN latest_report r\\n        ON r.id = rp.report_id\\n    ORDER BY rp.prepetrator_id, r.updated_at DESC\\n)\\nSELECT\\n    p.id AS prepetrator_id,\\n    r.id,\\n    r.summary,\\n    r.detail,\\n    r.updated_at,\\n    COALESCE(rc.comment, ri.operator_recommendation) AS comment,\\n    (COALESCE(rc.created_at, r.updated_at) AT TIME ZONE 'UTC') AT TIME ZONE 'Asia/Jakarta' AS comment_date\\nFROM base b\\nJOIN latest_prepetrator p\\n    ON b.prepetrator_id = p.id\\nJOIN latest_report r\\n    ON b.report_id = r.id\\nLEFT JOIN latest_report_info ri\\n    ON r.id = ri.id\\nLEFT JOIN aduan_masyarakat_v3.report_comment rc\\n    ON rc.id = r.id\\n   AND rc.prepetrator_id = p.id\\nWHERE p.id = %(id_0)s\\nORDER BY\\n    p.id,\\n    comment_date DESC\\nLIMIT 15;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
          },
