          "content": {
            "size": 5707,
            "mimeType": "application/json",
            "compression": 3913,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":214,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"id\",\"prepetrator_id\",\"sender_name\",\"sender_address\",\"phone_no\",\"type\",\"report_type\",\"report_number\",\"type_of_violation\",\"datetime\",\"description\",\"short_description\",\"name\",\"birth_date\",\"birth_place\",\"rank\",\"identity_number\",\"division\",\"phone_number\",\"professional_education\",\"graduation_year\",\"gender\",\"functional_assignment\",\"position\",\"summary\",\"category\",\"sub_category\",\"form_of_action\",\"application_of_article\",\"witness\",\"evidence\",\"report_updated_at\",\"articles\",\"documents\",\"persons_responsible\"],[\"260226000003\",\"260226000003-00001\",\"DUPAN RAIDINUR\",\"kp bojong peuntas rt 03 rw 13 desa bojong kec majalaya\",\"+6281999155455\",null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,null,[],[{\"id\":\"ad81419f8fc2f6d2fef04d596fc8fcca1d8e01fc2286e5171e89312f71bc932c\",\"url\":\"s3://fusion/agent/0000005300000a5d000141960026f17a_1784274778086_bgheue.pdf\",\"size\":null,\"detail\":null,\"type\":\"pdf\",\"file_name\":\"SPSP22026062900237.pdf\"}],[]]],\"additionalInfo\":{\"query\":\"WITH persons AS (\\n    SELECT\\n        prp.police_report_id,\\n        json_agg(\\n            json_build_object(\\n                'name', prp.name,\\n                'type', prp.type,\\n                'nrp', prp.nrp,\\n                'rank', prp.rank,\\n                'unit', prp.unit\\n            )\\n        ) AS persons_responsible\\n    FROM aduan_masyarakat_v3.police_report_person_responsible prp\\n    GROUP BY prp.police_report_id\\n),\\nRankedData AS (\\n    SELECT \\n        r.id AS report_internal_id,\\n        p.id AS prepetrator_id,\\n        p.description,\\n        r.sender_name,\\n        r.sender_address,\\n        r.phone_no,\\n        p.type,\\n        p.name,\\n        p.birth_date,\\n        p.birth_place,\\n        p.rank,\\n        p.identity_number,\\n        p.division,\\n        p.phone_number,\\n        p.professional_education,\\n        p.graduation_year,\\n        p.gender,\\n        p.functional_assignment,\\n        p.position,\\n        p.updated_at AS prepetrator_updated_at,\\n        r.summary,\\n        p.category,\\n        p.sub_category,\\n        p.form_of_action,\\n        p.application_of_article,\\n        ROW_NUMBER() OVER (\\n            PARTITION BY p.id \\n            ORDER BY r.updated_at DESC, p.updated_at DESC\\n        ) as rn\\n    FROM aduan_masyarakat_v3.report r\\n    INNER JOIN aduan_masyarakat_v3.report_prepetrators rp \\n        ON r.id = rp.report_id\\n    INNER JOIN aduan_masyarakat_v3.prepetrator p \\n        ON rp.prepetrator_id = p.id\\n),\\nArticlesData AS (\\n    SELECT\\n        pa.prepetrator_id,\\n        json_agg(\\n            json_build_object(\\n                'article_id', pa.article_id,\\n                'type', pa.cp_type,\\n                'kode_pasal', pa.kode_pasal,\\n                'description', pa.description\\n            )\\n        ) AS articles_list\\n    FROM (\\n        SELECT \\n            inner_pa.prepetrator_id,\\n            inner_pa.article_id,\\n            inner_pa.\\\"type\\\",\\n            cp.type AS cp_type,\\n            cp.kode_pasal,\\n            cp.description,\\n            DENSE_RANK() OVER (\\n                PARTITION BY inner_pa.prepetrator_id \\n                ORDER BY inner_pa.updated_at DESC\\n            ) as session_rank\\n        FROM aduan_masyarakat_v3.prepetrator_article inner_pa\\n        LEFT JOIN dimension.catalog_pasal cp \\n            ON inner_pa.article_id = cp.id\\n        WHERE (inner_pa.\\\"type\\\" <> 'juncto' OR inner_pa.\\\"type\\\" IS NULL)\\n    ) pa\\n    WHERE session_rank = 1 \\n    GROUP BY prepetrator_id\\n),\\nDocumentsData AS (\\n    SELECT \\n        ra.report_id,\\n        json_agg(\\n            json_build_object(\\n                'id', rd.id,\\n                'url', rd.url,\\n                'size', rd.size,\\n                'detail', rd.detail,\\n                'type', rd.type,\\n                'file_name', rd.file_name\\n            )\\n        ) AS documents_list\\n    FROM aduan_masyarakat_v3.report_officer_attachments ra\\n    LEFT JOIN aduan_masyarakat_v3.report_officer_attachments_detail rd \\n        ON ra.attachment_status_id = rd.id \\n    GROUP BY ra.report_id\\n)\\nSELECT \\n    rd.report_internal_id AS id,\\n    rd.prepetrator_id,\\n    rd.sender_name,\\n    rd.sender_address,\\n    rd.phone_no,\\n    rd.type,\\n    pr.report_type,\\n    pr.report_number,\\n    pr.type_of_violation,\\n    pr.datetime,\\n    rd.description,\\n    pr.short_description,\\n    rd.name,\\n    rd.birth_date,\\n    rd.birth_place,\\n    rd.rank,\\n    rd.identity_number,\\n    rd.division,\\n    rd.phone_number,\\n    rd.professional_education,\\n    rd.graduation_year,\\n    rd.gender,\\n    rd.functional_assignment,\\n    rd.position,\\n    rd.summary,\\n    rd.category,\\n    rd.sub_category,\\n    rd.form_of_action,\\n    rd.application_of_article,\\n    pr.witness,\\n    pr.evidence,\\n    pr.updated_at AS report_updated_at,\\n    COALESCE(ad.articles_list, '[]'::json) AS articles,\\n    COALESCE(dd.documents_list, '[]'::json) AS documents,\\n    COALESCE(ps.persons_responsible, '[]'::json) AS persons_responsible\\nFROM RankedData rd\\nLEFT JOIN aduan_masyarakat_v3.police_report pr \\n    ON rd.report_internal_id = pr.report_id\\nLEFT JOIN ArticlesData ad \\n    ON rd.prepetrator_id = ad.prepetrator_id\\nLEFT JOIN DocumentsData dd \\n    ON rd.report_internal_id = dd.report_id\\nLEFT JOIN persons ps \\n    ON pr.id = ps.police_report_id\\nWHERE rd.rn = 1\\n  AND rd.prepetrator_id = %(prepetrator_id_0)s\\nORDER BY pr.updated_at desc\\nLIMIT 1;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
          },
