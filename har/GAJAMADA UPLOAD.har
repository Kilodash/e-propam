            "mimeType": "application/json",
            "compression": 1399,
            "text": "{\"metaData\":{\"pagination\":{\"size\":0,\"totalElements\":0,\"totalPages\":0,\"scrollId\":\"\"},\"status\":true,\"executionTime\":77,\"responseCode\":200,\"message\":\"Success\",\"model_info\":{}},\"data\":[[\"id\",\"created_at\",\"file_name\",\"file_type\",\"report_type\",\"url\",\"prepetrator_id\",\"source_table\"],[\"260226000003\",1784274778629,\"SPSP22026062900237.pdf\",\"pdf\",null,\"s3://fusion/agent/0000005300000a5d000141960026f17a_1784274778086_bgheue.pdf\",\"260226000003-00001\",\"report_officer_attachments\"],[\"260226000003\",1784274773202,\"SPSP22026062900237.pdf\",\"pdf\",\"SP2HP2\",\"s3://fusion/agent/0000005300000a5d000141960026f17a_1784274772642_5bbhge.pdf\",\"260226000003-00001\",\"generate_report\"]],\"additionalInfo\":{\"query\":\"SELECT * FROM (\\n    SELECT\\n        gr.id,\\n        ((gr.created_at AT TIME ZONE 'UTC') AT TIME ZONE 'Asia/Jakarta') AS created_at,\\n        gr.file_name,\\n        gr.file_type,\\n        gr.report_type,\\n        gr.url,\\n        gr.prepetrator_id,\\n        'generate_report' AS source_table\\n    FROM aduan_masyarakat_v3.generate_report gr\\n    UNION ALL\\n    SELECT\\n        ra.id,\\n        ((ra.created_at AT TIME ZONE 'UTC') AT TIME ZONE 'Asia/Jakarta') AS created_at,\\n        ra.file_name,\\n        ra.file_type,\\n        NULL AS report_type,\\n        ra.url,\\n        gr2.prepetrator_id,\\n        'report_attachments' AS source_table\\n    FROM aduan_masyarakat_v3.report_attachments ra\\n    LEFT JOIN aduan_masyarakat_v3.generate_report gr2\\n           ON gr2.id = ra.id\\n    UNION ALL\\n    SELECT\\n        roa.report_id,\\n        ((roa.updated_at AT TIME ZONE 'UTC') AT TIME ZONE 'Asia/Jakarta') AS created_at,\\n        road.file_name,\\n        road.\\\"type\\\" AS file_type,\\n        NULL AS report_type,\\n        road.url,\\n        roa.prepetrator_id,\\n        'report_officer_attachments' AS source_table\\n    FROM aduan_masyarakat_v3.report_officer_attachments roa\\n    JOIN aduan_masyarakat_v3.report_officer_attachments_detail road\\n         ON roa.attachment_status_id = road.id\\n    WHERE roa.prepetrator_id = %(prepetrator_id_0)s\\n) x\\nWHERE x.prepetrator_id = %(prepetrator_id_0)s\\nORDER BY x.created_at DESC\\nLIMIT 100;\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
