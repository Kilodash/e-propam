          "postData": {
            "mimeType": "application/json",
            "text": "{\"queryId\":\"fcc2ae98ceb45de19e73d0ecc04cce56\",\"name\":\"Data Terlapor\",\"chart\":\"table\",\"connectionId\":\"245b8fd7c4a763019d5172fad5ec0086\",\"sourceId\":[\"56c565c5896a5d1966aae657ed113a34\",\"450bbebba0f02fae55daab5ef1b15874\",\"2bf60c8295b82b4bbf351a1a728661db\",\"e3dd3c5e53fa4350bb2d65e687708e7c\"],\"database_type\":\"postgresql\",\"dateMapping\":{\"timeZone\":\"Asia/Jakarta\",\"fields\":[\"latest_updated_at\",\"created_date\",\"updated_at\"]},\"filters\":[{\"table\":\"aduan_masyarakat_v3.\\\"report_prepetrators\\\"\",\"field\":\"prepetrator_id\",\"fieldType\":\"character varying\",\"field_type_origin\":\"character varying\",\"operatorField\":\"AND\",\"operator\":\"is\",\"value\":{\"gte\":0,\"is\":\"251107000015-00000\",\"isOneOf\":[],\"lte\":0}}],\"enableCache\":false,\"expiredTime\":0,\"exludeGrok\":false,\"metaData\":{\"widgetId\":\"1b4585af9dd59ba73d7b220c4b1a0a5a\",\"widgetName\":\"Data Terlapor\",\"menuId\":\"01f63e60376afe827638ed614e1cea76\",\"dashboardId\":\"1769155096865\",\"dashboardName\":\"Propam Aduan\"},\"globalVariable\":{}}"
          }
