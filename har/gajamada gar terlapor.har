            "mimeType": "application/json",
            "compression": 4617,
            "text": "{\"metaData\":{\"pagination\":{\"size\":1000,\"totalElements\":8,\"totalPages\":1,\"scrollId\":\"\"},\"status\":true,\"executionTime\":0,\"responseCode\":200,\"message\":\"Success\",\"execution_time\":46},\"data\":[{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"12(1)A\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila dipidana penjara berdasarkan putusan pengadilan yang telah mempunyai kekuatan hukum tetap dan menurut pertimbangan pejabat yang berwenang tidak dapat dipertahankan untuk tetap berada dalam dinas Kepolisian Negara Republik Indonesia\",\"id\":\"d5d3739d6e1d62d313043b1ebe1797be\",\"raw_pasal\":\"12(1)A Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila dipidana penjara berdasarkan putusan pengadilan yang telah mempunyai kekuatan hukum tetap dan menurut pertimbangan pejabat yang berwenang tidak dapat dipertahankan untuk tetap berada dalam dinas Kepolisian Negara Republik Indonesia\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"12(1)B\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila diketahui kemudian memberikan keterangan palsu dan/atau tidak benar pada saat mendaftarkan diri sebagai calon anggota Kepolisian Negara Republik Indonesia\",\"id\":\"871ce6c09d27854da8336074f909b496\",\"raw_pasal\":\"12(1)B Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila diketahui kemudian memberikan keterangan palsu dan/atau tidak benar pada saat mendaftarkan diri sebagai calon anggota Kepolisian Negara Republik Indonesia\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"12(1)C\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila melakukan usaha atau kegiatan yang nyata-nyata bertujuan mengubah Pancasila, terlibat dalam gerakan, atau melakukan kegiatan yang menentang negara dan/atau Pemerintah Republik Indonesia secara tidak sah\",\"id\":\"3de9a0f87952d268a42c310ad677617d\",\"raw_pasal\":\"12(1)C Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila melakukan usaha atau kegiatan yang nyata-nyata bertujuan mengubah Pancasila, terlibat dalam gerakan, atau melakukan kegiatan yang menentang negara dan/atau Pemerintah Republik Indonesia secara tidak sah\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"13(1)\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia dapat diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia karena melanggar sumpah/janji Kepolisian Negara Republik Indonesia, sumpah/janji jabatan dan/atau Kode Etik Profesi Kepolisian Negara Republik Indonesia\",\"id\":\"063b7e77a06a20d5885f81f1496a7988\",\"raw_pasal\":\"13(1) Anggota Kepolisian Negara Republik Indonesia dapat diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia karena melanggar sumpah/janji Kepolisian Negara Republik Indonesia, sumpah/janji jabatan dan/atau Kode Etik Profesi Kepolisian Negara Republik Indonesia\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"14(1)A\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila meninggalkan tugasnya secara tidak sah dalam waktu lebih dari 30 (tiga puluh) hari kerja secara berturut-turut\",\"id\":\"8417ef263724dd6267f01e9a159748b2\",\"raw_pasal\":\"14(1)A Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila meninggalkan tugasnya secara tidak sah dalam waktu lebih dari 30 (tiga puluh) hari kerja secara berturut-turut\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"14(1)B\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila melakukan perbuatan dan berperilaku yang dapat merugikan dinas Kepolisian\",\"id\":\"78f78f42e540a9422b006715e4882760\",\"raw_pasal\":\"14(1)B Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila melakukan perbuatan dan berperilaku yang dapat merugikan dinas Kepolisian\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"14(1)C\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila melakukan bunuh diri dengan maksud menghindari penyidikan dan/atau tuntutan hukum atau meninggal dunia sebagai akibat tindak pidana yang dilakukannya\",\"id\":\"150b5f0127cb3116879309c8050506d6\",\"raw_pasal\":\"14(1)C Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila melakukan bunuh diri dengan maksud menghindari penyidikan dan/atau tuntutan hukum atau meninggal dunia sebagai akibat tindak pidana yang dilakukannya\"},{\"type\":\"PPRI NOMOR 1 TAHUN 2003\",\"kode_pasal\":\"14(1)D\",\"description\":\"Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila menjadi anggota dan/atau pengurus partai politik\",\"id\":\"d098f75aa923d14b8b2ca34248334fed\",\"raw_pasal\":\"14(1)D Anggota Kepolisian Negara Republik Indonesia diberhentikan tidak dengan hormat dari dinas Kepolisian Negara Republik Indonesia apabila menjadi anggota dan/atau pengurus partai politik\"}],\"additionalInfo\":{\"query\":\"SELECT * \\nFROM dimension.catalog_pasal \\nWHERE dimension.catalog_pasal.type = %(type_0)s \\nORDER BY kode_pasal ASC \\nLIMIT 1000 OFFSET 0\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
