A\"}],\"additionalInfo\":{\"query\":\"SELECT * FROM dimension.catalog_function  ORDER BY function ASC LIMIT 1000 OFFSET 0\"},\"copyright\":\"&copy; 2025 · eBdesk Teknologi · All rights reserved.\"}"
